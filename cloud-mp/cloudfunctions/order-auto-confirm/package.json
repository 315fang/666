{
  "name": "order-auto-confirm",
  "version": "1.0.0",
  "description": "定时任务：自动确认超期已发货订单",
  "main": "index.js",
  "dependencies": {
    "wx-server-sdk": "~2.6.3"
  },
  "cloudfunction-config": {
    "memorySize": 256,
    "timeout": 30
  },
  "triggers": [
    {
      "name": "orderAutoConfirmTimer",
      "type": "timer",
      "config": "0 30 */1 * * * *"
    }
  ]
}
