.poster-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E7EFF5 0%, #F7FBFF 34%, #F4F8FB 100%);
  padding-bottom: calc(38rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.poster-nav {
  padding: 0 28rpx;
  box-sizing: border-box;
}

.poster-nav-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.poster-back {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(111, 159, 196, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-back-icon {
  width: 30rpx;
  height: 30rpx;
}

.poster-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #132235;
}

.poster-body {
  padding: 20rpx 34rpx 0;
  box-sizing: border-box;
}

.poster-preview-shell {
  position: relative;
  width: 100%;
  height: 890rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(210, 224, 234, 0.76);
  box-shadow: 0 14rpx 38rpx rgba(16, 42, 67, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
}

.poster-canvas {
  position: absolute;
  left: -9999rpx;
  top: -9999rpx;
  width: 600px;
  height: 860px;
}

.poster-result {
  width: 100%;
  height: 100%;
  display: block;
}

.poster-loading,
.poster-empty {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(247, 251, 255, 0.82);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.poster-spin {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(61, 107, 179, 0.18);
  border-top-color: #3D6BB3;
  animation: posterSpin 0.8s linear infinite;
}

.poster-loading-text,
.poster-empty {
  font-size: 25rpx;
  color: #46596B;
}

.poster-actions {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
}

.poster-action {
  flex: 1;
  height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.poster-action::after {
  border: none;
}

.poster-action-share,
.poster-action-secondary {
  padding: 0;
  margin: 0;
  color: #3D6BB3;
  background: #FFFFFF;
  border: 1rpx solid rgba(210, 224, 234, 0.86);
}

.poster-action-primary {
  color: #FFFFFF;
  background: linear-gradient(135deg, #D93448 0%, #B22C3D 100%);
  box-shadow: 0 12rpx 24rpx rgba(217, 52, 72, 0.22);
}

.poster-action-disabled {
  opacity: 0.45;
  pointer-events: none;
}

.poster-action-icon {
  width: 28rpx;
  height: 28rpx;
}

.poster-action-icon-light {
  filter: brightness(0) invert(1);
}

.poster-tip {
  display: block;
  margin-top: 22rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8A8F98;
}

@keyframes posterSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
