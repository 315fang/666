  flex-direction: column;
  gap: 5rpx;
}

.share-coupon-title {
  font-size: 25rpx;
  color: #1f2933;
  font-weight: 700;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.share-coupon-desc {
  font-size: 22rpx;
  color: #8a3b40;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.share-coupon-btn {
  flex-shrink: 0;
  min-width: 106rpx;
