  border: 1rpx solid rgba(210, 224, 234, 0.82);
  border-radius: 22rpx;
  background: #F7FBFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  line-height: 1;
