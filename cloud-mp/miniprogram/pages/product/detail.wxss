.share-coupon-float {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  z-index: 360;
  min-height: 76rpx;
  padding: 12rpx 14rpx 12rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 244, 242, 0.96);
  border: 1rpx solid rgba(216, 52, 58, 0.2);
  box-shadow: 0 14rpx 36rpx rgba(145, 55, 46, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
}

.share-coupon-float-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.share-coupon-float-kicker {
  font-size: 20rpx;
  color: #d8343a;
  font-weight: 700;
  line-height: 1;
}

.share-coupon-float-title {
  font-size: 24rpx;
  color: #182331;
  font-weight: 700;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.share-coupon-float-btn {
  flex-shrink: 0;
  min-width: 104rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #d8343a;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
