}

.share-panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 380;
  background: rgba(19, 34, 53, 0.38);
}

.share-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 390;
  padding: 16rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -18rpx 46rpx rgba(16, 42, 67, 0.18);
  box-sizing: border-box;
}

.share-panel-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #D2E0EA;
  margin: 0 auto 24rpx;
}

.share-panel-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 26rpx;
}

.share-panel-title {
  font-size: 32rpx;
  color: #132235;
  font-weight: 700;
}

.share-panel-subtitle {
  font-size: 24rpx;
  color: #6B7F91;
}

.poster-coupon-picker {
  margin-bottom: 22rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f7f8fa;
  border: 1rpx solid rgba(210, 224, 234, 0.78);
  box-sizing: border-box;
}

.poster-coupon-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.poster-coupon-title {
  font-size: 24rpx;
  color: #1f2933;
  font-weight: 700;
}

.poster-coupon-clear {
  font-size: 22rpx;
  color: #6B7F91;
}

.poster-coupon-scroll {
  width: 100%;
  white-space: nowrap;
}

.poster-coupon-track {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 2rpx;
}

.poster-coupon-chip {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  width: 210rpx;
  min-height: 86rpx;
  padding: 12rpx 16rpx;
