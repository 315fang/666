}

.share-panel-option:active {
  opacity: 0.72;
}

.share-panel-icon-wrap {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 1rpx solid rgba(111, 159, 196, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-panel-icon-primary {
  background: #D93448;
  border-color: #D93448;
}

.share-panel-icon {
  width: 30rpx;
  height: 30rpx;
}

.share-panel-icon-light {
  filter: brightness(0) invert(1);
}

.share-panel-option-title {
  font-size: 24rpx;
  color: #132235;
  font-weight: 600;
  white-space: nowrap;
}

.share-panel-tip {
