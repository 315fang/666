/* 会员等级权益 */
.page {
  min-height: 100vh;
  background: #f6f2ea;
  color: #1f2933;
}

.scroll {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
  background: #f6f2ea;
}

.state-wrap {
  min-height: 100vh;
  padding: 120rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid rgba(154, 106, 47, 0.18);
  border-top-color: #9a6a2f;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #1f2933;
  color: #fff;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
}

.state-text {
  font-size: 28rpx;
  color: #667085;
}

.retry-btn {
  margin-top: 10rpx;
  padding: 18rpx 48rpx;
  border-radius: 16rpx;
  background: #1f2933;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.hero {
  margin: 0;
  padding: 34rpx 28rpx 32rpx;
  min-height: 258rpx;
  box-sizing: border-box;
  background: #1f2933;
  color: #fff;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  right: -96rpx;
  top: -88rpx;
  width: 250rpx;
  height: 250rpx;
  border: 2rpx solid rgba(217, 181, 111, 0.25);
  transform: rotate(28deg);
}

.hero-copy {
  min-width: 0;
  flex: 1;
  position: relative;
  z-index: 1;
}

.hero-kicker {
  display: block;
  color: #d9b56f;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 800;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 900;
}

.hero-sub {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
  line-height: 1.5;
}

.hero-meter {
  width: 174rpx;
  min-height: 142rpx;
  padding: 18rpx 16rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 1rpx solid rgba(217, 181, 111, 0.38);
  background: rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.hero-meter-num {
  display: block;
  color: #fff;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 900;
  word-break: break-all;
}

.hero-meter-label {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 21rpx;
  line-height: 1.3;
}

.level-tabs {
  width: 100%;
  white-space: nowrap;
  background: #fff9ed;
  border-bottom: 1rpx solid #e8dac4;
}

.level-tabs-inner {
  display: inline-flex;
  gap: 14rpx;
  padding: 18rpx 24rpx;
  box-sizing: border-box;
}

.level-tab {
  width: 156rpx;
  min-height: 82rpx;
  padding: 14rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  border: 1rpx solid #e8dac4;
  background: #fffdf8;
  color: #1f2933;
  vertical-align: top;
}

.level-tab-active {
  background: #1f2933;
  border-color: #1f2933;
  color: #fff;
}

.level-tab-current {
  border-color: #d9b56f;
}

.level-tab-name {
  display: block;
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 800;
  white-space: normal;
}

.level-tab-meta {
  display: block;
  margin-top: 8rpx;
  color: #9a6a2f;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 800;
}

.level-tab-active .level-tab-meta {
  color: #d9b56f;
}

.level-swiper {
  height: 620rpx;
}

.level-pane {
  width: 100%;
  height: 620rpx;
  box-sizing: border-box;
}

.level-panel {
  margin: 22rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #fff9ed;
  border: 1rpx solid #e8dac4;
  box-sizing: border-box;
}

.level-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.level-label {
  display: block;
  color: #9a6a2f;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
}

.level-title {
  display: block;
  margin-top: 8rpx;
  color: #1f2933;
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 900;
}

.status-pill {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 14rpx;
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 900;
}

.status-current {
  color: #fff;
  background: #1f2933;
}

.status-passed {
  color: #1f7a5a;
  background: #dcebe3;
}

.status-next {
  color: #9a6a2f;
  background: #efe3cf;
}

.status-locked {
  color: #667085;
  background: #ece8df;
}

.level-brief {
  display: block;
  margin-top: 18rpx;
  color: #7a6b5d;
  font-size: 24rpx;
  line-height: 1.48;
}

.section-block {
  margin-top: 26rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eadfce;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.78;
}

.section-title {
  color: #1f2933;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
}

.privilege-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.privilege-item {
  min-height: 74rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #fffdf8;
  border: 1rpx solid #efe5d8;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  box-sizing: border-box;
}

.privilege-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #d9b56f;
  flex-shrink: 0;
}

.privilege-text {
  min-width: 0;
  color: #1f2933;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 800;
}

.team-note {
  margin-top: 26rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #eef7f2;
  border: 1rpx solid #cfe6da;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.team-note-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.8;
  flex-shrink: 0;
}

.team-note-copy {
  min-width: 0;
  flex: 1;
}

.team-note-title {
  display: block;
  color: #1f2933;
  font-size: 25rpx;
  line-height: 1.25;
  font-weight: 900;
}

.team-note-desc {
  display: block;
  margin-top: 6rpx;
  color: #557263;
  font-size: 21rpx;
  line-height: 1.35;
}

.team-note-arrow {
  color: #1f7a5a;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 900;
}

.route-section,
.faq-section {
  margin: 20rpx 24rpx 0;
  padding: 26rpx;
  border-radius: 18rpx;
  background: #fff9ed;
  border: 1rpx solid #e8dac4;
}

.route-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.route-title {
  color: #1f2933;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
}

.route-sub {
  max-width: 270rpx;
  color: #7a6b5d;
  font-size: 21rpx;
  line-height: 1.35;
  text-align: right;
}

.route-scroll {
  margin-top: 20rpx;
  width: 100%;
  white-space: nowrap;
}

.route-line {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 2rpx;
}

.route-node {
  width: 132rpx;
  min-height: 92rpx;
  padding: 14rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #fffdf8;
  border: 1rpx solid #efe5d8;
}

.route-node-passed {
  border-color: #cfe6da;
  background: #eef7f2;
}

.route-node-current {
  border-color: #1f2933;
  background: #1f2933;
  color: #fff;
}

.route-node-level {
  display: block;
  color: #9a6a2f;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 900;
}

.route-node-current .route-node-level {
  color: #d9b56f;
}

.route-node-name {
  display: block;
  margin-top: 8rpx;
  color: inherit;
  font-size: 23rpx;
  line-height: 1.3;
  font-weight: 900;
  white-space: normal;
}

.faq-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.faq-item {
  padding-top: 16rpx;
  border-top: 1rpx solid #efe5d8;
}

.faq-item:first-child {
  padding-top: 0;
  border-top: 0;
}

.faq-title {
  display: block;
  color: #1f2933;
  font-size: 25rpx;
  line-height: 1.35;
  font-weight: 900;
}

.faq-body {
  display: block;
  margin-top: 8rpx;
  color: #7a6b5d;
  font-size: 22rpx;
  line-height: 1.45;
}

.bottom-space {
  height: 72rpx;
}
