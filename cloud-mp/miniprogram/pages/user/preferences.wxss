/* pages/user/preferences.wxss - 暖棕统一版 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F3ED 0%, #FAFAF8 35%, #F1EEEA 100%);
  padding-bottom: 140rpx;
}

.header {
  padding: 60rpx 32rpx 40rpx;
  text-align: center;
  background: linear-gradient(140deg, #2B2018 0%, #1A1511 100%);
  color: #FFF7EF;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -50%; right: -20%; width: 200%; height: 200%;
  background: radial-gradient(circle, rgba(185, 139, 88, 0.12) 0%, transparent 70%);
  animation: pulse 6s ease-in-out infinite;
}

.title { display: block; font-size: 44rpx; font-weight: 700; margin-bottom: 16rpx; position: relative; z-index: 1; }
.subtitle { display: block; font-size: 26rpx; opacity: 0.75; line-height: 1.6; position: relative; z-index: 1; }

.question-list { padding: 24rpx 24rpx; display: flex; flex-direction: column; gap: 24rpx; }

.question-card {
  background: rgba(255,255,255,0.94);
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 29, 21, 0.05);
}

.q-title {
  font-size: 30rpx; font-weight: 700; color: #1C1917;
  margin-bottom: 24rpx; position: relative; padding-left: 20rpx;
}

.q-title::before {
  content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
  width: 6rpx; height: 28rpx;
  background: linear-gradient(135deg, #B98B58 0%, #8D6A3F 100%);
  border-radius: 999rpx;
}

.option-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }

.option-item {
  padding: 24rpx 20rpx;
  background: #F8F5F1;
  border: 2rpx solid rgba(122, 108, 94, 0.10);
  border-radius: 16rpx;
  text-align: center; font-size: 26rpx; color: #78716C;
  transition: all 0.25s ease;
}

.option-item text { display: block; line-height: 1.5; }

.option-item.active {
  background: linear-gradient(135deg, #2B2018 0%, #1A1511 100%);
  border-color: transparent; color: #FFF7EF;
  transform: scale(1.03);
  box-shadow: 0 8rpx 24rpx rgba(28, 20, 14, 0.15);
}

.option-item:active { transform: scale(0.97); }

.footer {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(250, 248, 244, 0.96);
  backdrop-filter: blur(12px);
  border-top: 1rpx solid rgba(122, 108, 94, 0.08);
  display: flex; gap: 16rpx; z-index: 100;
}

.reset-btn {
  flex: 0 0 140rpx; height: 84rpx; line-height: 84rpx;
  background: #F8F5F1; color: #78716C;
  border: 2rpx solid rgba(122, 108, 94, 0.15);
  border-radius: 999rpx; font-size: 28rpx; font-weight: 600;
}

.save-btn {
  flex: 1; height: 84rpx; line-height: 84rpx;
  background: linear-gradient(135deg, #2B2018 0%, #1A1511 100%);
  color: #FFF7EF; border: none;
  border-radius: 999rpx; font-size: 30rpx; font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(28, 20, 14, 0.15);
}

.save-btn[loading] { opacity: 0.7; }

@keyframes pulse { 0%, 100% { opacity: 0.5; } 50% { opacity: 0.8; } }
