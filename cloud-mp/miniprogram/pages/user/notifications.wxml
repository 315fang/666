<view class="container">
  <view class="message-topbar">
    <view class="privacy-icon-btn ripple" bindtap="onPrivacyTap" aria-label="隐私协议">
      <image class="privacy-icon-img" src="/assets/icons/shield.svg" mode="aspectFit"></image>
      <view class="privacy-icon-dot"></view>
    </view>
  </view>

  <view class="notif-list" wx:if="{{notifications.length > 0}}">
    <view
      class="notif-item card-enter delay-{{index < 8 ? index : 7}} {{item.is_read ? '' : 'unread'}}"
      wx:for="{{notifications}}"
      wx:key="id"
      bindtap="onRead"
      data-id="{{item.id}}"
      data-index="{{index}}"
      hover-class="notif-item--hover"
    >
      <view class="notif-icon-box {{item.type}}-bg">
        <image class="notif-icon-img" wx:if="{{item.type === 'upgrade'}}" src="/assets/icons/rocket.svg" mode="aspectFit"/>
        <image class="notif-icon-img" wx:if="{{item.type === 'commission'}}" src="/assets/icons/dollar-sign.svg" mode="aspectFit"/>
        <image class="notif-icon-img" wx:if="{{item.type === 'stock'}}" src="/assets/icons/alert-triangle.svg" mode="aspectFit"/>
        <image class="notif-icon-img" wx:if="{{item.type === 'system'}}" src="/assets/icons/settings.svg" mode="aspectFit"/>
        <image class="notif-icon-img" wx:if="{{item.type === 'withdrawal'}}" src="/assets/icons/credit-card.svg" mode="aspectFit"/>
        <image class="notif-icon-img" wx:if="{{item.type === 'refund'}}" src="/assets/icons/refresh-cw.svg" mode="aspectFit"/>
      </view>
      <view class="notif-content">
        <view class="notif-header">
          <text class="notif-title">{{item.title}}</text>
          <text class="notif-time">{{item.created_at_format}}</text>
        </view>
        <text class="notif-desc">{{item.content}}</text>
      </view>
    </view>
  </view>

  <!-- Empty State -->
  <view class="empty card-enter" wx:else>
    <text class="empty-emoji">🔔</text>
    <text class="empty-text">消息躲起来了~</text>
    <text class="empty-sub">暂时没有新通知，去逛逛商城吧</text>
    <view class="empty-action ripple" bindtap="goHome">
      <text class="empty-action-text">去首页看看</text>
    </view>
  </view>
</view>
