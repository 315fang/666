/* 收藏/浏览 */
.page-combo { min-height: 100vh; background: #f8f7f4; display: flex; flex-direction: column; padding-bottom: env(safe-area-inset-bottom); }
.tab-bar-top {
  display: flex; flex-direction: row; margin: 24rpx 24rpx 16rpx; padding: 8rpx;
  background: #fff; border-radius: 999rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.04);
  flex-shrink: 0; position: relative; overflow: hidden;
}
.tab-item {
  flex: 1; text-align: center; font-size: 28rpx; color: #6b7280;
  padding: 20rpx 12rpx; border-radius: 999rpx;
  transition: color 0.3s, font-weight 0.3s; position: relative; z-index: 2;
}
.tab-active { color: #fff; font-weight: 600; }
.tab-slider {
  position: absolute; top: 8rpx; left: 8rpx; width: calc(50% - 8rpx); height: calc(100% - 16rpx);
  border-radius: 999rpx; background: #2563eb; z-index: 1;
  transition: transform 0.35s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 4rpx 12rpx rgba(37,99,235,0.2);
}
.panel { flex: 1; display: flex; flex-direction: column; min-height: 0; }
.panel .list-scroll { height: calc(100vh - 260rpx); padding: 0 24rpx 32rpx; box-sizing: border-box; }
.panel .head-row { flex-shrink: 0; }
.head-row { display: flex; justify-content: flex-end; align-items: center; padding: 12rpx 24rpx 12rpx; }
.clear-all { font-size: 24rpx; color: #dc2626; padding: 8rpx 16rpx; border-radius: 999rpx; background: #fef2f2; }
.empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 40rpx; }
.empty-emoji { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #1f2937; font-weight: 600; margin-bottom: 12rpx; }
.empty-sub { font-size: 24rpx; color: #9ca3af; line-height: 1.6; }
.row {
  display: flex; align-items: center; gap: 20rpx; padding: 24rpx;
  background: #fff; border-radius: 20rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.04);
}
.thumb { width: 132rpx; height: 132rpx; border-radius: 20rpx; flex-shrink: 0; }
.row-main { min-width: 0; flex: 1; display: flex; flex-direction: column; gap: 10rpx; }
.row-title { font-size: 28rpx; line-height: 1.45; color: #1f2937; font-weight: 600; }
.row-meta { font-size: 26rpx; color: #dc2626; font-weight: 700; }
.row-time { font-size: 22rpx; color: #6b7280; }
