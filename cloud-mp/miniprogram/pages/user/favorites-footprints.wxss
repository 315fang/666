.page-combo {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 20%, #F7F5FF 44%, #FAFAF8 100%);
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-top {
  display: flex;
  flex-direction: row;
  margin: 24rpx 24rpx 16rpx;
  padding: 8rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px) saturate(160%);
  -webkit-backdrop-filter: blur(16px) saturate(160%);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #78716c;
  padding: 20rpx 12rpx;
  border-radius: 999rpx;
  transition: color 0.3s, font-weight 0.3s;
  position: relative;
  z-index: 2;
}

.tab-active {
  color: #fff;
  font-weight: 600;
}

.tab-slider {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: calc(50% - 8rpx);
  height: calc(100% - 16rpx);
  border-radius: 999rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  z-index: 1;
  transition: transform 0.35s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.25);
}

.panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.panel .list-scroll {
  height: calc(100vh - 260rpx);
  padding: 0 24rpx 32rpx;
  box-sizing: border-box;
}

.panel .head-row {
  flex-shrink: 0;
}

.head-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 12rpx 24rpx 12rpx;
}

.clear-all {
  font-size: 24rpx;
  color: #667eea;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(102, 126, 234, 0.08);
}

.empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #1c1917;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #a8a29e;
  line-height: 1.6;
}

.row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.thumb {
  width: 132rpx;
  height: 132rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.row-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.row-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #1c1917;
  font-weight: 600;
}

.row-meta {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 700;
}

.row-time {
  font-size: 22rpx;
  color: #78716c;
}
