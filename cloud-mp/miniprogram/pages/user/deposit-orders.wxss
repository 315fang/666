page {
  background: #f4f8fa;
}

.deposit-page {
  min-height: 100vh;
}

.state-wrap,
.empty-wrap {
  padding: 120rpx 48rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.state-text,
.empty-title {
  font-size: 32rpx;
  color: #1f2937;
}

.empty-desc {
  font-size: 26rpx;
  color: #6b7280;
  text-align: center;
  line-height: 1.6;
}

.retry-btn {
  min-width: 200rpx;
  padding: 20rpx 32rpx;
  border-radius: 999rpx;
  background: #1e4a6d;
  color: #fff;
  text-align: center;
  font-size: 28rpx;
}

.deposit-scroll {
  height: 100vh;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

.deposit-list {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.deposit-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.deposit-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.deposit-no {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.deposit-status {
  font-size: 24rpx;
  color: #1e4a6d;
  background: #e0f2fe;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.deposit-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #64748b;
}

.deposit-actions {
  margin-top: 24rpx;
}

.deposit-btn {
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.deposit-btn-primary {
  background: linear-gradient(90deg, #1e4a6d 0%, #2c6a93 100%);
  color: #fff;
}

.deposit-btn-disabled {
  background: #e5e7eb;
  color: #94a3b8;
}
