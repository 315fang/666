<view class="container">

  <!-- ══ 头图 Hero + 资产大卡 ══ -->
  <view class="hero-zone">
    <view class="hero-bg"></view>
    <view class="hero-inner">
      <view style="height: {{statusBarHeight}}px;"></view>

      <!-- 个人信息（合并工具栏） -->
      <view class="hero-profile-wrap">
        <view class="hero-profile-left" bindtap="onEditProfile">
          <view class="hero-avatar-wrap">
            <image class="hero-avatar" src="{{userInfo.avatar || userInfo.avatar_url || '/assets/images/default-avatar.svg'}}" mode="aspectFill"></image>
          </view>
          <view class="hero-info">
            <view class="hero-name-row">
              <view class="hero-nickname-wrap">
                <text class="hero-nickname">{{displayNickname || userInfo.nick_name || userInfo.nickname || '微信用户'}}</text>
              </view>
            </view>
            <view class="hero-member-badges" catchtap="onMemberLevelTap" wx:if="{{isLoggedIn}}">
              <view class="hero-member-pill hero-member-pill-consume">
                <image src="/assets/icons/crown.svg" mode="aspectFit" class="member-pill-icon"></image>
                <text class="member-pill-text">{{growthDisplay && growthDisplay.currentTierName ? growthDisplay.currentTierName : '普通会员'}}</text>
              </view>
              <view class="hero-member-pill {{agentPillSkinClass}}" wx:if="{{displayAgentRoleLevel > 0 && displayAgentRoleLevel !== 6}}">
                <text class="member-pill-text">{{agentRoleBadgeName}}</text>
              </view>
              <view class="hero-member-pill hero-member-pill-agent" wx:if="{{displayAgentRoleLevel === 6 || isStoreManager}}">
                <text class="member-pill-text">店长</text>
              </view>
            </view>
            <view class="hero-meta-row" wx:if="{{isStoreManager && storeManagerStationName}}">
              <text class="member-code-label">门店</text>
              <text class="member-code-value">{{storeManagerStationName}}{{storeManagerStationCount > 1 ? (' 等 ' + storeManagerStationCount + ' 家') : ''}}</text>
            </view>
            <view class="hero-meta-row" wx:if="{{isLoggedIn && userInfo.invite_code}}">
              <view class="hero-member-code" catchtap="onCopyMemberCode">
                <text class="member-code-label member-code-label-id">ID</text>
                <text class="member-code-value" user-select="true">{{userInfo.invite_code}}</text>
                <text class="member-code-action">复制</text>
              </view>
            </view>
          </view>
        </view>
        <view class="hero-toolbar-right">
          <view class="hero-tool-grid">
            <view class="hero-top-btn" bindtap="goAddress" hover-class="hero-top-btn-hover">
              <image class="hero-top-icon" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
              <text class="hero-top-text">地址</text>
            </view>
            <view class="hero-top-btn" bindtap="goCustomerService" hover-class="hero-top-btn-hover">
              <image class="hero-top-icon" src="/assets/icons/headphones.svg" mode="aspectFit"></image>
              <text class="hero-top-text">客服</text>
            </view>
            <view class="hero-top-btn" bindtap="onNotificationsTap" hover-class="hero-top-btn-hover">
              <view class="hero-top-icon-wrap">
                <image class="hero-top-icon" src="/assets/icons/bell.svg" mode="aspectFit"></image>
                <view class="hero-top-badge" wx:if="{{isLoggedIn && notificationsCount > 0}}">{{notificationsCount > 99 ? '99+' : notificationsCount}}</view>
              </view>
              <text class="hero-top-text">消息</text>
            </view>
          </view>
        </view>
      </view>
      <!-- 未登录提示（如需） -->
      <view class="hero-login-hint" wx:if="{{!isLoggedIn}}" bindtap="onLoginBtnTap">立即登录</view>

      <!-- 核心资产卡 -->
      <view class="vip-card">
        <!-- 卡片头部: 省钱与宣传位 -->
        <view class="vip-card-header">
            <view class="vip-card-saved" bindtap="onGrowthPrivilegesTap">
            <view class="growth-header">
              <text class="saved-label">累计成长值</text><text class="saved-val">{{growthDisplay ? growthDisplay.value : 0}}</text><text class="saved-arrow">›</text>
            </view>
            <view class="growth-progress-bar" wx:if="{{isLoggedIn && growthDisplay}}">
              <view class="growth-progress-track">
                <view class="growth-progress-fill" style="width: {{growthDisplay.barPercent || 0}}%"></view>
              </view>
              <text class="growth-progress-text">{{growthDisplay.subLine || ''}}</text>
            </view>
          </view>
          <view class="vip-card-promo">
            <view class="promo-block" bindtap="onGrowthPrivilegesTap">
              <text class="promo-title">会员中心</text>
              <view class="promo-subtitle">查看说明 <text class="promo-arrow">›</text></view>
            </view>
            <view class="promo-divider"></view>
            <view class="promo-block" bindtap="goPoints">
              <text class="promo-title">积分中心</text>
              <view class="promo-subtitle">每日签到 <text class="promo-arrow">›</text></view>
            </view>
          </view>
        </view>

        <!-- 中央: 资产数据 -->
        <view class="vip-assets-panel">
          <view class="vip-assets-matrix">
            <view class="vip-asset-item" bindtap="onAssetPointsTap">
              <text class="vip-asset-title">我的积分</text>
              <view class="vip-asset-value">{{isLoggedIn ? pointsBalanceDisplay : '--'}}</view>
            </view>
            <view class="vip-asset-item" bindtap="onAssetBalanceTap">
              <text class="vip-asset-title">货款余额</text>
              <view class="vip-asset-value"><text class="vip-asset-sym">¥</text>{{isLoggedIn ? (balance || '0') : '--'}}</view>
            </view>
            <view class="vip-asset-item" bindtap="onCommissionWalletTap">
              <text class="vip-asset-title">佣金钱包</text>
              <view class="vip-asset-value"><text class="vip-asset-sym">¥</text>{{isLoggedIn ? (commissionBalance || '0') : '--'}}</view>
            </view>
            <view class="vip-asset-item" bindtap="onPiggyBankTap">
              <text class="vip-asset-title">我的存款</text>
              <view class="vip-asset-value"><text class="vip-asset-sym">¥</text>{{isLoggedIn ? (piggyBankBalance || '0') : '--'}}</view>
            </view>
          </view>
        </view>

      </view>
    </view>
  </view>

  <!-- ══ 我的订单 ══ -->
  <view class="section-card section-card--orders">
    <view class="section-row-header" bindtap="onOrderTap" data-type="all">
      <text class="section-row-title">我的订单</text>
      <view class="section-row-more"><text>查看全部</text><text class="arrow-icon">›</text></view>
    </view>
    <view class="order-tabs">
      <view class="order-tab" bindtap="onOrderTap" data-type="pending">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/credit-card.svg" mode="aspectFit"></image>
          <view class="order-tab-badge order-tab-dot" wx:if="{{orderStats.pending > 0}}">{{orderStats.pending > 99 ? '99+' : orderStats.pending}}</view>
        </view>
        <text class="order-tab-text">待付款</text>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-type="paid">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/package.svg" mode="aspectFit"></image>
          <view class="order-tab-badge order-tab-dot" wx:if="{{orderFreshFlags.paid}}">{{orderStats.paid > 99 ? '99+' : orderStats.paid}}</view>
        </view>
        <text class="order-tab-text">待发货</text>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-type="shipped">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/truck.svg" mode="aspectFit"></image>
          <view class="order-tab-badge order-tab-dot" wx:if="{{orderFreshFlags.shipped}}">{{orderStats.shipped > 99 ? '99+' : orderStats.shipped}}</view>
        </view>
        <text class="order-tab-text">待收货</text>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-type="pending_review">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/message.svg" mode="aspectFit"></image>
          <view class="order-tab-badge order-tab-alert-dot" wx:if="{{orderStats.pendingReview > 0}}"></view>
        </view>
        <text class="order-tab-text">待评价</text>
      </view>
      <view class="order-tab" bindtap="onRefundTap">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/refresh-cw.svg" mode="aspectFit"></image>
          <view class="order-tab-badge order-tab-dot" wx:if="{{orderFreshFlags.refund}}">{{orderStats.refund > 99 ? '99+' : orderStats.refund}}</view>
        </view>
        <text class="order-tab-text">退款/售后</text>
      </view>
    </view>
  </view>

  <!-- ══ 购物袋摘要 ══ -->
  <view class="section-card account-cart-card" bindtap="onAccountCartTap" hover-class="account-cart-card-hover">
    <view class="account-cart-head">
      <view class="account-cart-title-wrap">
        <view class="account-cart-icon-wrap">
          <image class="account-cart-icon" src="/assets/icons/shopping-cart.svg" mode="aspectFit"></image>
          <view class="account-cart-badge" wx:if="{{cartPreview.count > 0}}">{{cartPreview.count > 99 ? '99+' : cartPreview.count}}</view>
        </view>
        <view class="account-cart-copy">
          <text class="account-cart-title">购物袋</text>
          <text class="account-cart-sub">{{cartPreview.sub}}</text>
        </view>
      </view>
      <view class="account-cart-action" catchtap="onAccountCartCheckout">{{cartPreview.actionText}}</view>
    </view>
    <view class="account-cart-body" wx:if="{{cartPreview.hasItems}}">
      <view class="account-cart-thumbs">
        <image class="account-cart-thumb" wx:for="{{cartPreview.items}}" wx:key="id" src="{{item.image}}" mode="aspectFill"></image>
        <view class="account-cart-more" wx:if="{{cartPreview.remainingCount > 0}}">+{{cartPreview.remainingCount}}</view>
      </view>
      <view class="account-cart-summary">
        <text class="account-cart-name">{{cartPreview.primaryName}}</text>
        <text class="account-cart-meta">{{cartPreview.meta}}</text>
      </view>
      <text class="account-cart-price">¥{{cartPreview.total}}</text>
    </view>
    <view class="account-cart-empty" wx:else>
      <text class="account-cart-empty-text">{{cartPreview.meta}}</text>
      <image class="account-cart-empty-icon" src="/assets/icons/shopping-bag.svg" mode="aspectFit"></image>
    </view>
  </view>

  <view class="section-card favorite-strip" bindtap="onQuadFavoriteTap" hover-class="favorite-strip-hover">
    <view class="favorite-strip-copy">
      <text class="favorite-strip-title">近期浏览与收藏</text>
      <text class="favorite-strip-sub">{{quadFavorite.sub}}</text>
    </view>
    <image class="favorite-strip-thumb" wx:if="{{quadFavorite.hasImage}}" src="{{quadFavorite.image}}" mode="aspectFill"></image>
    <view class="favorite-strip-icon-wrap" wx:else>
      <image class="favorite-strip-icon" src="/assets/icons/heart.svg" mode="aspectFit"></image>
    </view>
    <text class="favorite-strip-arrow">›</text>
  </view>

  <!-- ══ 我的功能 ══ -->
  <view class="section-card func-card">
    <view class="func-row" bindtap="goTeamCenter" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/users.svg" mode="aspectFit"></image>
      <text class="func-label">团队中心</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider"></view>
    <view class="func-row" wx:if="{{featureFlags.show_station_entry}}" bindtap="goStationsMap" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
      <text class="func-label">自提站点</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider" wx:if="{{featureFlags.show_station_entry && isStoreManager}}"></view>
    <view class="func-row" wx:if="{{isStoreManager}}" bindtap="goStoreManagerExclusive" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/package.svg" mode="aspectFit"></image>
      <text class="func-label">店长专属</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider" wx:if="{{featureFlags.show_station_entry || isStoreManager}}"></view>
    <view class="func-row" bindtap="goInvitePoster" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/share.svg" mode="aspectFit"></image>
      <text class="func-label">品牌推荐</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider" wx:if="{{showPickupVerify}}"></view>
    <view class="func-row" wx:if="{{showPickupVerify}}" bindtap="goPickupVerify" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/package.svg" mode="aspectFit"></image>
      <text class="func-label">自提核销</text>
      <text class="func-arrow">›</text>
    </view>
  </view>

  <view class="section-card func-card">
    <view class="func-row" bindtap="onSettingsTap" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/settings.svg" mode="aspectFit"></image>
      <text class="func-label">设置</text>
      <text class="func-arrow">›</text>
    </view>
  </view>

  <view class="safe-area-bottom"></view>

  <view class="avatar-pick-mask" wx:if="{{showAvatarPickSheet}}" catchtap="onCancelAvatarPick">
    <view class="avatar-pick-panel" catchtap="stopP">
      <text class="avatar-pick-title">更换头像</text>
      <text class="avatar-pick-tip">点击下方按钮，从相册或微信头像中选择</text>
      <button class="avatar-pick-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">选择头像</button>
      <view class="avatar-pick-cancel" bindtap="onCancelAvatarPick">取消</view>
    </view>
  </view>

  <view class="nick-modal-mask" wx:if="{{showNicknameModal}}" catchtap="onCancelNickname">
    <view class="nick-modal" catchtap="stopP">
      <text class="nick-modal-title">修改昵称</text>
      <input
        class="nick-modal-input"
        type="nickname"
        placeholder="输入昵称或使用微信昵称"
        maxlength="32"
        value="{{newNickname}}"
        bindinput="onNicknameInput"
      />
      <view class="nick-modal-actions">
        <view class="nick-modal-btn nick-modal-btn-cancel" bindtap="onCancelNickname">取消</view>
        <view class="nick-modal-btn nick-modal-btn-ok" bindtap="onConfirmNickname">保存</view>
      </view>
    </view>
  </view>

  <light-tip-modal
    show="{{lightTipShow}}"
    title="{{lightTipTitle}}"
    content="{{lightTipContent}}"
    bind:close="onLightTipClose"
  />
</view>
