/* pages/user/member-levels.wxss - 会员等级晋升路线 */

.page {
  min-height: 100vh;
  background: #f5f2ee;
}

.scroll {
  height: 100vh;
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.state-text {
  font-size: 28rpx;
  color: #78716c;
}

.retry-btn {
  margin-top: 32rpx;
  padding: 18rpx 56rpx;
  background: #2563EB;
  color: #fff;
  font-size: 28rpx;
  border-radius: 999rpx;
}

/* 顶部进度卡 */
.hero-card {
  margin: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(140deg, #2b2018 0%, #1a1511 100%);
  color: rgba(255, 240, 220, 0.92);
}

.hero-top {
  margin-bottom: 28rpx;
}

.hero-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.hero-tier-name {
  font-size: 36rpx;
  font-weight: 700;
  flex: 1;
}

.hero-growth-label {
  font-size: 22rpx;
  opacity: 0.65;
}

.hero-growth-val {
  font-size: 48rpx;
  font-weight: 700;
  color: #BFDBFE;
}

.progress-wrap {
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 10rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #60A5FA, #2563EB);
  border-radius: 999rpx;
  transition: width 0.4s;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.progress-min,
.progress-next-val {
  font-size: 20rpx;
  opacity: 0.55;
}

.hero-sub {
  font-size: 24rpx;
  opacity: 0.75;
  line-height: 1.5;
  display: block;
}

.hero-sub-max {
  color: #BFDBFE;
  opacity: 0.9;
}

/* 等级阶梯 */
.section-title-wrap {
  padding: 24rpx 24rpx 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #44403c;
}

.tier-list {
  margin: 0 24rpx 24rpx;
}

.tier-row {
  display: flex;
  gap: 0;
  padding-bottom: 0;
}

.tier-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 56rpx;
  flex-shrink: 0;
}

.tier-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #e7e5e4;
  border: 3rpx solid #d6d3d1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.dot-passed {
  background: #2563EB;
  border-color: #2563EB;
}

.dot-active {
  background: #93C5FD;
  border-color: #2563EB;
  box-shadow: 0 0 0 6rpx rgba(59, 130, 246, 0.2);
}

.dot-check {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.tier-line {
  flex: 1;
  width: 3rpx;
  background: #e7e5e4;
  min-height: 32rpx;
}

.tier-body {
  flex: 1;
  padding: 4rpx 0 40rpx 20rpx;
}

.tier-head-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.tier-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
}

.tier-row-active .tier-name {
  color: #92400e;
}

.tier-tag-current {
  font-size: 20rpx;
  color: #92400e;
  background: rgba(59, 130, 246, 0.18);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.tier-tag-done {
  font-size: 20rpx;
  color: #78716c;
  background: rgba(120, 113, 108, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.tier-threshold {
  font-size: 24rpx;
  color: #78716c;
  display: block;
  margin-bottom: 6rpx;
}

.tier-discount {
  font-size: 26rpx;
  color: #44403c;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.tier-row-active .tier-discount {
  color: #92400e;
}

.tier-desc {
  font-size: 22rpx;
  color: #a8a29e;
  display: block;
  line-height: 1.45;
}

/* 底部说明 */
.footer-tip {
  margin: 0 24rpx 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(59, 130, 246, 0.08);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #78716c;
  line-height: 1.6;
}

.bottom-space {
  height: 60rpx;
}
