/* pages/user/membership-center.wxss - 会员权益中心（整合版）*/

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0f23 0%, #1a1a2e 30%, #16213e 100%);
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.state-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.retry-btn {
  margin-top: 32rpx;
  padding: 18rpx 56rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.scroll {
  height: 100vh;
  background: linear-gradient(180deg, #0f0f23 0%, #1a1a2e 30%, #16213e 100%);
}

.cards-wrap {
  padding-top: 24rpx;
  background: transparent;
  overflow: hidden;
}

.card-switch-tabs {
  margin: 0 24rpx 16rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(22, 33, 62, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(0, 210, 255, 0.1);
  display: flex;
  gap: 8rpx;
}

.card-switch-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.card-switch-tab-active {
  background: linear-gradient(90deg, #667eea, #764ba2);
  color: #fff;
  font-weight: 700;
}

.cards-skeleton {
  margin: 24rpx;
  height: 320rpx;
  border-radius: 28rpx;
  background: rgba(22, 33, 62, 0.4);
  border: 1rpx solid rgba(0, 210, 255, 0.05);
}

.member-card-swiper {
  height: 332rpx;
  background: transparent;
  overflow: hidden;
}

.member-card-swiper swiper-item {
  background: transparent;
}

.member-card {
  margin: 0 12rpx;
  height: 300rpx;
  border-radius: 28rpx;
  padding: 30rpx 30rpx 28rpx;
  box-sizing: border-box;
  color: #fff4e7;
  box-shadow: 0 18rpx 48rpx rgba(28, 25, 23, 0.12);
  overflow: hidden;
}

.member-card-consume {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #a78bfa 100%);
}

.member-card-consume .member-card-title {
  margin-top: 36rpx;
}

.member-card-consume .member-card-foot {
  margin-top: 28rpx;
}

.member-card-agent {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 55%, #4f87c0 100%);
}

.member-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.member-card-label {
  font-size: 24rpx;
  opacity: 0.82;
}

.member-card-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.member-card-title {
  display: block;
  margin-top: 28rpx;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.member-card-growth-row {
  margin-top: 24rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.member-card-growth-label {
  font-size: 24rpx;
  opacity: 0.78;
}

.member-card-growth-value {
  font-size: 58rpx;
  font-weight: 700;
  color: #ffe3a8;
}

.member-card-progress {
  margin-top: 22rpx;
}

.member-card-progress-track {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  overflow: hidden;
}

.member-card-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f4d58f, #fff1ca);
  border-radius: 999rpx;
}

.member-card-progress-text {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  opacity: 0.86;
}

.member-card-foot {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #fff3d1;
}

.member-card-agent-meta {
  margin-top: 24rpx;
}

.member-card-agent-points {
  display: inline-block;
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.member-card-agent-status {
  display: block;
  margin-top: 22rpx;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.86;
}

.current-card-meta {
  margin: 18rpx 24rpx 0;
  padding: 24rpx 28rpx;
  border-radius: 22rpx;
  background: rgba(22, 33, 62, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(0, 210, 255, 0.08);
}

.card-indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.indicator-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transition: all 0.25s ease;
}

.indicator-dot-active {
  width: 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.current-card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
}

.current-card-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
}

.benefits-panel {
  margin: 24rpx;
  background: rgba(22, 33, 62, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  border: 1rpx solid rgba(0, 210, 255, 0.08);
}

.benefits-panel-head {
  margin-bottom: 20rpx;
}

.benefits-panel-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
}

.benefits-panel-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.5);
}

.growth-rule {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(59, 130, 246, 0.08);
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  margin-bottom: 20rpx;
}

.growth-rule-icon {
  font-size: 28rpx;
}

.growth-rule-text {
  font-size: 24rpx;
  color: #92400e;
  font-weight: 500;
}

.tier-card {
  background: rgba(22, 33, 62, 0.4);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(0, 210, 255, 0.08);
}

.tier-active {
  border-color: rgba(102, 126, 234, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
}

.tier-passed {
  background: rgba(22, 33, 62, 0.3);
}

.tier-next {
  border-style: dashed;
  border-color: rgba(102, 126, 234, 0.3);
}

.tier-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.tier-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  flex: 1;
}

.tier-tag,
.tier-tag-done,
.tier-tag-next,
.level-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.tier-tag {
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.15);
}

.tier-tag-done,
.level-badge {
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.08);
}

.tier-tag-next {
  color: #667eea;
  background: rgba(102, 126, 234, 0.15);
}

.tier-meta {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 6rpx;
}

.tier-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.4);
}

.perks {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.perk {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.06);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.agent-summary-card,
.agent-empty-card {
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  padding: 24rpx;
  background: linear-gradient(140deg, #1a2340 0%, #111827 100%);
  color: rgba(255, 240, 220, 0.92);
}

.agent-summary-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.72;
}

.agent-summary-title,
.agent-empty-title {
  display: block;
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.25;
}

.agent-summary-desc,
.agent-empty-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  opacity: 0.76;
}

.agent-entry-wrap {
  margin-top: 20rpx;
  text-align: center;
}

.agent-entry-btn {
  background: linear-gradient(90deg, #667eea, #764ba2);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 28rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.bottom-space {
  height: 60rpx;
}
