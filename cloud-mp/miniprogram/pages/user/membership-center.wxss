/* 权益中心 */
.page { min-height: 100vh; background: #f8f7f4; }
.state-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 40rpx; }
.state-text { font-size: 28rpx; color: #6b7280; }
.retry-btn { margin-top: 32rpx; padding: 18rpx 56rpx; background: #2563eb; color: #fff; font-size: 28rpx; border-radius: 999rpx; }
.scroll { height: 100vh; background: #f8f7f4; width: 100%; box-sizing: border-box; overflow-x: hidden; }

/* 资产摘要 */
.asset-summary {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  color: #fff;
}
.asset-summary-title {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  opacity: 0.9;
}
.asset-summary-grid {
  display: flex;
  justify-content: space-around;
}
.asset-summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.asset-summary-value {
  font-size: 40rpx;
  font-weight: 700;
}
.asset-summary-label {
  font-size: 22rpx;
  opacity: 0.8;
}
.cards-wrap { padding-top: 24rpx; background: transparent; overflow: hidden; }

/* Tab 切换 */
.card-switch-tabs {
  margin: 0 24rpx 16rpx; padding: 8rpx; border-radius: 999rpx;
  background: #fff; border: 1rpx solid rgba(0,0,0,0.06);
  display: flex; gap: 8rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.card-switch-tab { flex: 1; text-align: center; padding: 14rpx 0; border-radius: 999rpx; font-size: 24rpx; color: #6b7280; font-weight: 500; transition: all 0.3s; }
.card-switch-tab-active { background: #2563eb; color: #fff; font-weight: 700; box-shadow: 0 4rpx 12rpx rgba(37,99,235,0.2); }
.cards-skeleton { margin: 24rpx; height: 320rpx; border-radius: 28rpx; background: #f0f4f8; }

/* 会员卡 Swiper */
.member-card-swiper { height: 332rpx; background: transparent; overflow: hidden; }
.member-card-swiper swiper-item { background: transparent; }
.member-card { margin: 0 12rpx; height: 300rpx; border-radius: 28rpx; padding: 30rpx 30rpx 28rpx; box-sizing: border-box; color: #fff; box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.12); overflow: hidden; position: relative; }
.member-card::before { content: ''; position: absolute; top: -50%; right: -30%; width: 300rpx; height: 300rpx; border-radius: 50%; background: rgba(255,255,255,0.06); }
.member-card-consume { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 50%, #3b82f6 100%); }
.member-card-consume .member-card-title { margin-top: 36rpx; }
.member-card-consume .member-card-foot { margin-top: 28rpx; }
.member-card-agent { background: linear-gradient(135deg, #1e3a5f 0%, #1a4d80 55%, #2563eb 100%); }
.member-card-head { display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 1; }
.member-card-label { font-size: 24rpx; opacity: 0.82; }
.member-card-badge { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 999rpx; background: rgba(255,255,255,0.18); backdrop-filter: blur(8px); }
.member-card-title { display: block; margin-top: 28rpx; font-size: 44rpx; font-weight: 700; line-height: 1.2; position: relative; z-index: 1; }
.member-card-foot { display: block; margin-top: 20rpx; font-size: 24rpx; color: rgba(255,255,255,0.85); position: relative; z-index: 1; }
.member-card-agent-meta { margin-top: 24rpx; position: relative; z-index: 1; }
.member-card-agent-points { display: inline-block; font-size: 24rpx; padding: 8rpx 18rpx; border-radius: 999rpx; background: rgba(255,255,255,0.15); backdrop-filter: blur(8px); }
.member-card-agent-status { display: block; margin-top: 22rpx; font-size: 24rpx; line-height: 1.6; opacity: 0.86; }

/* 卡片指示器 */
.current-card-meta {
  margin: 18rpx 24rpx 0; padding: 24rpx 28rpx; border-radius: 20rpx;
  background: #fff; border: 1rpx solid rgba(0,0,0,0.04); box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.card-indicator { display: flex; justify-content: center; gap: 12rpx; margin-bottom: 18rpx; }
.indicator-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #d1d5db; transition: all 0.25s ease; }
.indicator-dot-active { width: 36rpx; border-radius: 999rpx; background: #2563eb; }
.current-card-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; text-align: center; }
.current-card-desc { display: block; margin-top: 10rpx; font-size: 24rpx; line-height: 1.5; color: #6b7280; text-align: center; }

/* 权益面板 */
.benefits-panel { margin: 24rpx; background: #fff; border-radius: 24rpx; padding: 28rpx 24rpx 24rpx; border: 1rpx solid rgba(0,0,0,0.04); box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.benefits-panel-head { margin-bottom: 20rpx; }
.benefits-panel-title { display: block; font-size: 32rpx; font-weight: 700; color: #1f2937; }
.benefits-panel-desc { display: block; margin-top: 10rpx; font-size: 24rpx; line-height: 1.5; color: #6b7280; }
.growth-rule { display: flex; align-items: center; gap: 10rpx; background: #dbeafe; padding: 16rpx 20rpx; border-radius: 14rpx; margin-bottom: 20rpx; }
.growth-rule-icon { font-size: 28rpx; }
.growth-rule-text { font-size: 24rpx; color: #1e40af; font-weight: 500; }

/* 档位卡片 */
.tier-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; border: 1rpx solid rgba(0,0,0,0.06); transition: all 0.3s; }
.tier-active { border-color: #2563eb; box-shadow: 0 4rpx 16rpx rgba(37,99,235,0.15); background: #f0f7ff; }
.tier-passed { background: #f9fafb; opacity: 0.8; }
.tier-next { border-style: dashed; border-color: #2563eb; border-width: 2rpx; }
.tier-head { display: flex; align-items: center; gap: 12rpx; margin-bottom: 10rpx; }
.tier-name { font-size: 28rpx; font-weight: 600; color: #1f2937; flex: 1; }
.tier-tag, .tier-tag-done, .tier-tag-next, .level-badge { font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 999rpx; flex-shrink: 0; font-weight: 600; }
.tier-tag { color: #fff; background: #2563eb; }
.tier-tag-done { color: #059669; background: #d1fae5; }
.tier-tag-next { color: #2563eb; background: #dbeafe; }
.level-badge { color: #6b7280; background: #f3f4f6; }
.tier-meta { display: block; font-size: 24rpx; color: #4b5563; margin-bottom: 6rpx; }
.tier-desc { display: block; margin-top: 8rpx; font-size: 22rpx; line-height: 1.5; color: #6b7280; }
.perks { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 14rpx; }
.perk { font-size: 22rpx; color: #4b5563; background: #f3f4f6; padding: 6rpx 16rpx; border-radius: 999rpx; }

/* 代理卡片 */
.agent-summary-card { margin-bottom: 20rpx; border-radius: 20rpx; padding: 28rpx; background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; position: relative; overflow: hidden; }
.agent-summary-card::before { content: ''; position: absolute; top: -30%; right: -20%; width: 200rpx; height: 200rpx; border-radius: 50%; background: rgba(255,255,255,0.08); }
.agent-summary-label { display: block; font-size: 24rpx; opacity: 0.8; position: relative; z-index: 1; }
.agent-summary-title { display: block; margin-top: 12rpx; font-size: 42rpx; font-weight: 700; line-height: 1.2; position: relative; z-index: 1; }
.agent-summary-desc { display: block; margin-top: 14rpx; font-size: 24rpx; line-height: 1.6; opacity: 0.85; position: relative; z-index: 1; }
.agent-empty-card { margin-bottom: 20rpx; border-radius: 20rpx; padding: 28rpx; background: #f9fafb; border: 1rpx dashed #d1d5db; text-align: center; }
.agent-empty-title { display: block; font-size: 28rpx; font-weight: 600; color: #6b7280; }
.agent-empty-desc { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.6; color: #9ca3af; }

/* ═══ 升级进度卡片 ═══ */
.upgrade-progress-card {
  margin-bottom: 24rpx; border-radius: 20rpx; padding: 28rpx;
  background: linear-gradient(135deg, #f0f7ff 0%, #e0f2fe 100%);
  border: 2rpx solid #bae6fd;
}

.upgrade-progress-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.upgrade-progress-copy { min-width: 0; flex: 1; }
.upgrade-progress-label {
  display: inline-block; font-size: 20rpx; color: #2563eb; font-weight: 600;
  background: #dbeafe; padding: 4rpx 12rpx; border-radius: 999rpx; margin-bottom: 8rpx;
}
.upgrade-progress-title { display: block; font-size: 34rpx; line-height: 1.3; font-weight: 700; color: #1e3a5f; }
.upgrade-status { flex-shrink: 0; padding: 8rpx 18rpx; border-radius: 999rpx; font-size: 22rpx; font-weight: 700; }
.upgrade-status-pending { color: #2563eb; background: #dbeafe; }
.upgrade-status-ready { color: #059669; background: #d1fae5; }
.upgrade-status-max { color: #6b7280; background: #f3f4f6; }
.upgrade-progress-summary { display: block; margin-top: 16rpx; font-size: 26rpx; line-height: 1.6; color: #334155; }
.upgrade-progress-note { display: block; margin-top: 10rpx; font-size: 22rpx; line-height: 1.5; color: #64748b; background: rgba(255,255,255,0.6); padding: 10rpx 14rpx; border-radius: 10rpx; }

/* 推荐路径 */
.upgrade-best-path {
  margin-top: 24rpx; padding: 24rpx; border-radius: 18rpx;
  background: #fff; border: 2rpx solid #2563eb;
  box-shadow: 0 4rpx 16rpx rgba(37,99,235,0.1);
}
.upgrade-path-top, .upgrade-path-mini-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.upgrade-path-title, .upgrade-path-mini-title {
  min-width: 0; flex: 1; font-size: 28rpx; font-weight: 700; color: #1e3a5f; line-height: 1.35;
}
.upgrade-path-percent, .upgrade-path-mini-percent {
  flex-shrink: 0; font-size: 28rpx; font-weight: 800; color: #2563eb;
  background: #dbeafe; padding: 4rpx 14rpx; border-radius: 999rpx;
}

/* 进度条 */
.upgrade-progress-track { margin-top: 20rpx; height: 16rpx; border-radius: 999rpx; background: #e5e7eb; overflow: hidden; position: relative; }
.upgrade-progress-fill {
  height: 100%; border-radius: 999rpx;
  background: linear-gradient(90deg, #2563eb 0%, #3b82f6 50%, #10b981 100%);
  transition: width 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  position: relative;
}
.upgrade-progress-fill::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: progressShine 2s ease-in-out infinite;
}
@keyframes progressShine { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

.upgrade-path-desc { display: block; margin-top: 14rpx; font-size: 24rpx; line-height: 1.5; color: #475569; }

/* 升级要求 */
.upgrade-requirements { margin-top: 20rpx; display: flex; flex-direction: column; gap: 12rpx; }
.upgrade-requirement {
  display: flex; align-items: center; justify-content: space-between; gap: 16rpx;
  padding: 18rpx 20rpx; border-radius: 14rpx;
  background: #f8fafc; border: 1rpx solid #e5e7eb;
  transition: all 0.3s;
}
.upgrade-requirement-done {
  background: #ecfdf5; border-color: #a7f3d0;
}
.upgrade-req-main { min-width: 0; flex: 1; }
.upgrade-req-label { display: block; font-size: 22rpx; color: #64748b; line-height: 1.3; }
.upgrade-req-value { display: block; margin-top: 6rpx; font-size: 28rpx; font-weight: 700; color: #1e3a5f; line-height: 1.3; }
.upgrade-req-gap {
  flex-shrink: 0; max-width: 240rpx; text-align: right;
  font-size: 22rpx; line-height: 1.4; color: #2563eb; font-weight: 600;
  background: #dbeafe; padding: 6rpx 12rpx; border-radius: 8rpx;
}
.upgrade-requirement-done .upgrade-req-gap { color: #059669; background: #d1fae5; }

/* 其他路径 */
.upgrade-other-paths { margin-top: 24rpx; }
.upgrade-other-title { display: block; margin-bottom: 14rpx; font-size: 26rpx; font-weight: 700; color: #334155; }
.upgrade-path-mini {
  padding: 20rpx; border-radius: 16rpx;
  background: #fff; border: 1rpx solid #e5e7eb;
  margin-top: 12rpx; transition: all 0.3s;
}
.upgrade-path-mini:active { background: #f9fafb; }
.upgrade-path-mini-summary { display: block; margin-top: 10rpx; font-size: 22rpx; line-height: 1.5; color: #64748b; }

/* 入口按钮 */
.agent-entry-wrap { margin-top: 24rpx; text-align: center; }
.agent-entry-btn {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff; font-size: 30rpx; font-weight: 700; padding: 28rpx 0; border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.25);
  transition: transform 0.2s;
}
.agent-entry-btn:active { transform: scale(0.98); }
.bottom-space { height: 60rpx; }
