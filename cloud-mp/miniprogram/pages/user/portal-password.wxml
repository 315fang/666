<view class="wrap">
  <view class="card" wx:if="{{roleLevel < 1}}">
    <text class="section-title">当前账号暂不支持业务密码</text>
    <text class="tip">业务密码仅开放给团队业务用户，用于提现、货款支付和内部划拨等高风险操作。</text>
  </view>

  <block wx:else>
    <view class="card">
      <text class="section-title">业务密码状态</text>
      <view class="status-row">
        <text class="status-label">已设置</text>
        <text class="status-value">{{portalPasswordEnabled ? '是' : '否'}}</text>
      </view>
      <view class="status-row" wx:if="{{portalPasswordEnabled}}">
        <text class="status-label">状态</text>
        <text class="status-value">{{changeRequired ? '需先修改初始密码' : '可正常使用'}}</text>
      </view>
      <view class="status-row" wx:if="{{lockedUntil}}">
        <text class="status-label">锁定至</text>
        <text class="status-value">{{lockedUntil}}</text>
      </view>
      <button class="btn" loading="{{loading}}" bindtap="onApply" wx:if="{{!portalPasswordEnabled}}">申领初始密码</button>
    </view>

    <view class="result" wx:if="{{result && changeRequired}}">
      <view class="row"><text class="k">初始密码</text><text class="v mono">{{result.initial_password}}</text></view>
      <button class="btn secondary" bindtap="onCopyPassword">复制初始密码</button>
      <text class="hint">初始密码为 6 位数字，只会在本次申领后展示。完成修改后会自动消失，请立即保存。</text>
    </view>

    <view class="card" wx:if="{{portalPasswordEnabled}}">
      <text class="section-title">{{changeRequired ? '修改初始密码' : '修改业务密码'}}</text>
      <text class="tip" wx:if="{{changeRequired}}">首次修改时，当前密码就是你刚申领并复制的 6 位数字初始密码。</text>
      <view class="password-field">
        <input
          class="input password-input"
          password="{{!showCurrentPassword}}"
          placeholder="{{changeRequired ? '当前密码（首次请输入初始密码）' : '当前密码'}}"
          value="{{currentPassword}}"
          data-field="currentPassword"
          bindinput="onInput"
        />
        <view class="password-toggle" data-field="showCurrentPassword" bindtap="onTogglePasswordVisible">
          <image class="password-toggle-icon" src="{{showCurrentPassword ? '/assets/icons/eye-off.svg' : '/assets/icons/eye.svg'}}" mode="aspectFit" />
        </view>
      </view>
      <view class="password-field">
        <input
          class="input password-input"
          password="{{!showNewPassword}}"
          maxlength="6"
          placeholder="新密码（6位数字）"
          value="{{newPassword}}"
          data-field="newPassword"
          bindinput="onInput"
        />
        <view class="password-toggle" data-field="showNewPassword" bindtap="onTogglePasswordVisible">
          <image class="password-toggle-icon" src="{{showNewPassword ? '/assets/icons/eye-off.svg' : '/assets/icons/eye.svg'}}" mode="aspectFit" />
        </view>
      </view>
      <view class="password-field">
        <input
          class="input password-input"
          password="{{!showConfirmPassword}}"
          maxlength="6"
          placeholder="确认新密码（6位数字）"
          value="{{confirmPassword}}"
          data-field="confirmPassword"
          bindinput="onInput"
        />
        <view class="password-toggle" data-field="showConfirmPassword" bindtap="onTogglePasswordVisible">
          <image class="password-toggle-icon" src="{{showConfirmPassword ? '/assets/icons/eye-off.svg' : '/assets/icons/eye.svg'}}" mode="aspectFit" />
        </view>
      </view>
      <button class="btn" loading="{{saving}}" bindtap="onChangePassword">{{changeRequired ? '完成修改' : '更新密码'}}</button>
    </view>
  </block>
</view>
