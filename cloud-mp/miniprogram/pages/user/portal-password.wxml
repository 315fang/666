<view class="wrap">
  <view class="card">
    <text class="tip">用于登录电脑端「代理商门户」。密码随机生成，仅显示一次，请立即复制保存。24 小时内仅可申领一次。</text>
    <button class="btn" loading="{{loading}}" bindtap="onApply">申领初始密码</button>
  </view>

  <view class="result" wx:if="{{result}}">
    <view class="row"><text class="k">会员编号</text><text class="v mono">{{result.member_no}}</text></view>
    <view class="row"><text class="k">初始密码</text><text class="v mono">{{result.initial_password}}</text></view>
    <button class="btn secondary" bindtap="onCopyAll">复制编号+密码</button>
    <text class="hint">登录网页后请立即修改密码。</text>
  </view>
</view>
