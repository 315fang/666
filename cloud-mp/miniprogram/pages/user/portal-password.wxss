.wrap {
  padding: 24rpx;
  min-height: 100vh;
  background: #fafaf9;
  box-sizing: border-box;
}

.card,
.result {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1917;
  margin-bottom: 20rpx;
}

.tip,
.hint {
  font-size: 26rpx;
  color: #57534e;
  line-height: 1.6;
  display: block;
}

.hint {
  margin-top: 20rpx;
  color: #a8a29e;
}

.status-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.status-label {
  font-size: 24rpx;
  color: #78716c;
}

.status-value {
  font-size: 24rpx;
  color: #1c1917;
  font-weight: 600;
  text-align: right;
}

.input {
  height: 88rpx;
  border-radius: 12rpx;
  background: #f5f5f4;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1c1917;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.password-field {
  position: relative;
  margin-bottom: 16rpx;
}

.password-input {
  margin-bottom: 0;
  padding-right: 92rpx;
}

.password-toggle {
  position: absolute;
  top: 50%;
  right: 0;
  width: 88rpx;
  height: 88rpx;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.password-toggle-icon {
  width: 36rpx;
  height: 36rpx;
}

.btn {
  background: #1c1917;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-top: 12rpx;
}

.btn.secondary {
  background: #e7e5e4;
  color: #1c1917;
  margin-top: 20rpx;
}

.row {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.k {
  font-size: 24rpx;
  color: #78716c;
  margin-bottom: 8rpx;
}

.v {
  font-size: 30rpx;
  color: #1c1917;
  word-break: break-all;
}

.mono {
  font-family: ui-monospace, monospace;
}

.warning-card {
  border: 1px solid #e7d6c5;
  background: #fdf7ef;
}
