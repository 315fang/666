.page {
  min-height: 100vh;
  background: #f3f4f6;
}

.loading {
  padding: 120rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
}

.empty {
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-text {
  font-size: 30rpx;
  color: #6b7280;
}

.empty-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #9ca3af;
}

.card {
  margin: 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.type {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #fef3c7;
  color: #b45309;
}

.status.processing {
  background: #dbeafe;
  color: #1d4ed8;
}

.status.resolved,
.status.closed {
  background: #d1fae5;
  color: #047857;
}

.content {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.time {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.pad {
  height: 48rpx;
}
