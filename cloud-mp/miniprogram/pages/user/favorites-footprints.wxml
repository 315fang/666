<view class="page-combo">
  <view class="tab-bar-top">
    <view
      class="tab-item {{activeTab === 'favorites' ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="favorites"
    >我的收藏</view>
    <view
      class="tab-item {{activeTab === 'footprints' ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="footprints"
    >我的足迹</view>
  </view>

  <!-- 我的收藏 -->
  <view class="panel" wx:if="{{activeTab === 'favorites'}}">
    <view class="head-row" wx:if="{{favoriteItems.length > 0}}">
      <text class="clear-all" bindtap="onClearFavoritesTap">清空</text>
    </view>
    <view class="empty" wx:if="{{favoriteItems.length === 0}}">
      <text class="empty-text">暂无收藏</text>
    </view>
    <scroll-view wx:else scroll-y class="list-scroll" enhanced show-scrollbar="{{false}}">
      <view
        class="row"
        wx:for="{{favoriteItems}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onOpenFavoriteDetail"
      >
        <image class="thumb" src="{{item.image || '/assets/images/default-avatar.svg'}}" mode="aspectFill" />
        <view class="row-main">
          <text class="row-title">{{item.name || '商品'}}</text>
          <text class="row-meta" wx:if="{{item.price}}">¥{{item.price}}</text>
          <text class="row-time" wx:if="{{item.timeText}}">{{item.timeText}}</text>
        </view>
        <view class="row-del" catchtap="onRemoveFavorite" data-id="{{item.id}}">
          <image class="del-icon" src="/assets/icons/trash.svg" mode="aspectFit" />
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 我的足迹 -->
  <view class="panel" wx:if="{{activeTab === 'footprints'}}">
    <view class="head-row" wx:if="{{footprintItems.length > 0}}">
      <text class="clear-all" bindtap="onClearFootprintsTap">清空</text>
    </view>
    <view class="empty" wx:if="{{footprintItems.length === 0}}">
      <text class="empty-text">暂无浏览记录</text>
    </view>
    <scroll-view wx:else scroll-y class="list-scroll" enhanced show-scrollbar="{{false}}">
      <view
        class="row"
        wx:for="{{footprintItems}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onOpenFootprintDetail"
      >
        <image class="thumb" src="{{item.image || '/assets/images/default-avatar.svg'}}" mode="aspectFill" />
        <view class="row-main">
          <text class="row-title">{{item.name || '商品'}}</text>
          <text class="row-meta" wx:if="{{item.price}}">¥{{item.price}}</text>
          <text class="row-time">{{item.timeText}}</text>
        </view>
        <view class="row-del" catchtap="onRemoveFootprint" data-id="{{item.id}}">
          <image class="del-icon" src="/assets/icons/trash.svg" mode="aspectFit" />
        </view>
      </view>
    </scroll-view>
  </view>
</view>
