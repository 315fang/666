<view class="page-combo">
  <!-- 长按菜单 -->
  <context-menu id="contextMenu" actions="{{contextActions}}" bind:select="onContextMenuSelect" />

  <view class="tab-bar-top">
    <view
      class="tab-item {{activeTab === 'favorites' ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="favorites"
    >我的收藏</view>
    <view
      class="tab-item {{activeTab === 'footprints' ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="footprints"
    >近期浏览</view>
    <!-- 滑动指示器 -->
    <view class="tab-slider" style="transform:translateX({{activeTab === 'favorites' ? '0%' : '100%'}});"></view>
  </view>

  <!-- 我的收藏 -->
  <view class="panel" wx:if="{{activeTab === 'favorites'}}">
    <view class="head-row" wx:if="{{favoriteItems.length > 0}}">
      <text class="clear-all ripple-dark" bindtap="onClearFavoritesTap">清空</text>
    </view>
    <view class="empty card-enter" wx:if="{{favoriteItems.length === 0}}">
      <text class="empty-emoji">💜</text>
      <text class="empty-text">还没有收藏哦</text>
      <text class="empty-sub">去逛逛，把喜欢的商品收入囊中吧~</text>
    </view>
    <scroll-view wx:else scroll-y class="list-scroll" enhanced show-scrollbar="{{false}}">
      <swipe-cell
        wx:for="{{favoriteItems}}"
        wx:key="id"
        bind:action="onSwipeFavoriteAction"
        data-id="{{item.id}}"
      >
        <view
          class="row card-enter ripple-dark"
          data-id="{{item.id}}"
          bindtap="onOpenFavoriteDetail"
          bindlongpress="onItemLongPress"
        >
          <fade-image class="thumb" src="{{item.image || '/assets/images/default-avatar.svg'}}" mode="aspectFill" width="132rpx" height="132rpx" radius="20rpx"></fade-image>
          <view class="row-main">
            <text class="row-title">{{item.name || '商品'}}</text>
            <text class="row-meta" wx:if="{{item.price}}">¥{{item.price}}</text>
            <text class="row-time" wx:if="{{item.timeText}}">{{item.timeText}}</text>
          </view>
        </view>
      </swipe-cell>
    </scroll-view>
  </view>

  <!-- 近期浏览 -->
  <view class="panel" wx:if="{{activeTab === 'footprints'}}">
    <view class="head-row" wx:if="{{footprintItems.length > 0}}">
      <text class="clear-all ripple-dark" bindtap="onClearFootprintsTap">清空</text>
    </view>
    <view class="empty card-enter" wx:if="{{footprintItems.length === 0}}">
      <text class="empty-emoji">👀</text>
      <text class="empty-text">还没有浏览记录</text>
      <text class="empty-sub">去看看你感兴趣的商品吧~</text>
    </view>
    <scroll-view wx:else scroll-y class="list-scroll" enhanced show-scrollbar="{{false}}">
      <swipe-cell
        wx:for="{{footprintItems}}"
        wx:key="id"
        bind:action="onSwipeFootprintAction"
        data-id="{{item.id}}"
      >
        <view
          class="row card-enter ripple-dark"
          data-id="{{item.id}}"
          bindtap="onOpenFootprintDetail"
          bindlongpress="onItemLongPress"
        >
          <fade-image class="thumb" src="{{item.image || '/assets/images/default-avatar.svg'}}" mode="aspectFill" width="132rpx" height="132rpx" radius="20rpx"></fade-image>
          <view class="row-main">
            <text class="row-title">{{item.name || '商品'}}</text>
            <text class="row-meta" wx:if="{{item.price}}">¥{{item.price}}</text>
            <text class="row-time">{{item.timeText}}</text>
          </view>
        </view>
      </swipe-cell>
    </scroll-view>
  </view>
</view>
