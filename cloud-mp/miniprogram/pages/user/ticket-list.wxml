<view class="page">
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中…</text>
  </view>
  <view class="empty" wx:elif="{{!list.length}}">
    <text class="empty-text">暂无工单记录</text>
    <text class="empty-hint">可在客服中心提交工单</text>
  </view>
  <scroll-view scroll-y class="scroll" wx:else>
    <view class="card" wx:for="{{list}}" wx:key="id">
      <view class="card-head">
        <text class="type">{{item.type}}</text>
        <text class="status {{item.status}}">{{item.statusText}}</text>
      </view>
      <text class="content">{{item.content}}</text>
      <text class="meta">联系方式：{{item.contact}}</text>
      <text class="time">{{item.timeText}}</text>
    </view>
    <view class="pad"></view>
  </scroll-view>
</view>
