.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #e9f2ff 0%, #f7fbff 100%);
}

.loading,
.empty {
  padding: 120rpx 40rpx;
  text-align: center;
  color: #7c8ea8;
}

.hero,
.summary-card,
.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(20, 56, 110, 0.06);
  margin-bottom: 20rpx;
}

.hero-title,
.section-title,
.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #14386e;
}

.hero-sub,
.empty-desc,
.station-line,
.simple-line {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6f87aa;
}

.summary-card {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.summary-item,
.staff-stat {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f4f8ff;
  text-align: center;
}

.summary-value,
.staff-stat-value {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0d61ce;
}

.summary-label,
.staff-stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8da3c1;
}

.station-card,
.simple-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e7eef9;
}

.station-card:last-child,
.simple-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.station-top,
.simple-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.station-name,
.simple-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #14386e;
}

.station-tag,
.simple-tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #0d61ce;
}

.tag-ok {
  background: #e7f7ef;
  color: #14935f;
}

.tag-warn {
  background: #fff4e8;
  color: #c26a1d;
}

.staff-summary {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f6f9ff;
}

.staff-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.actions-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  margin-top: 8rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.secondary-btn {
  background: #eff6ff;
  color: #1d4ed8;
  border: 1rpx solid #bfdbfe;
}

.field {
  margin-top: 18rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #456b9d;
}

.field-box,
.field-input,
.field-textarea {
  width: 100%;
  min-height: 84rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f6f9ff;
  color: #14386e;
  font-size: 26rpx;
}

.field-textarea {
  min-height: 140rpx;
}

.simple-list {
  margin-top: 8rpx;
}

.text-money {
  color: #b05a46;
  font-weight: 600;
}
