.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fafaf9;
}
.map-banner {
  padding: 16rpx 24rpx;
  background: linear-gradient(180deg, #e8f1f7 0%, #f4f8fa 100%);
  border-bottom: 1rpx solid rgba(30, 74, 109, 0.12);
}
.map-banner-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #334155;
  display: block;
}
.map-wrap {
  position: relative;
  width: 100%;
}
.map {
  width: 100%;
  height: 380rpx;
}
.map-choose-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 16rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(30, 74, 109, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(28, 25, 23, 0.18);
}
.map-unavailable-tip {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 88rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.72);
  color: #fff;
  font-size: 22rpx;
  line-height: 1.45;
}
.map-unavailable {
  margin: 16rpx 24rpx 0;
  padding: 36rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(28, 25, 23, 0.04);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.map-unavailable-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1917;
}
.map-unavailable-desc {
  font-size: 24rpx;
  line-height: 1.55;
  color: #78716c;
}
.list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx;
}
.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(28, 25, 23, 0.04);
  border: 2rpx solid transparent;
  box-sizing: border-box;
}
.item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.item-active {
  border-color: rgba(202, 138, 4, 0.85);
  box-shadow: 0 4rpx 24rpx rgba(202, 138, 4, 0.18);
  background: #fffdf8;
}
.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
  display: block;
}
.item-tag {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #0f766e;
  background: #ecfdf5;
}
.sub {
  font-size: 24rpx;
  color: #78716c;
  margin-top: 8rpx;
  display: block;
  line-height: 1.45;
}
.meta,
.desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
}
.meta {
  color: #64748b;
}
.desc {
  color: #475569;
}
.empty {
  text-align: center;
  color: #a8a29e;
  padding: 40rpx;
}
.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}
.sheet {
  width: 100%;
  max-height: 72vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 32rpx 48rpx;
  box-sizing: border-box;
}
.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e7e5e4;
  margin: 8rpx auto 24rpx;
}
.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1c1917;
  display: block;
  margin-bottom: 16rpx;
}
.sheet-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: block;
  margin: 0 auto 20rpx;
  background: #f8fafc;
}
.sheet-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.sheet-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 22rpx;
}
.sheet-tag.pickup {
  background: #ecfdf5;
  color: #0f766e;
}
.sheet-info {
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  margin-bottom: 20rpx;
}
.sheet-info-row + .sheet-info-row {
  margin-top: 16rpx;
}
.sheet-info-label,
.sheet-info-value {
  display: block;
}
.sheet-info-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 6rpx;
}
.sheet-info-value {
  font-size: 26rpx;
  line-height: 1.55;
  color: #0f172a;
}
.sheet-intro {
  margin-bottom: 28rpx;
}
.sheet-intro-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
}
.sheet-intro-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.65;
  color: #475569;
}
.sheet-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}
.sheet-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: #1c1917;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}
.sheet-btn.ghost {
  background: #f8fafc;
  color: #0f172a;
  border: 1rpx solid #dbe3ee;
}
