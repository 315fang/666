.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #E3EDF4 0%, #F4F8FA 24%, #EBF5F2 100%);
  overflow: hidden;
}


.header-shell {
  padding: 8rpx 24rpx 10rpx;
  background: rgba(244, 248, 250, 0.96);
}

.header-title-row {
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.header-title {
  font-size: 32rpx;
  color: #0F172A;
  font-weight: 700;
}

.cat-section-header {
  padding: 16rpx 16rpx 8rpx;
  position: sticky;
  top: 0;
  background: transparent;
  z-index: 10;
}

.cat-section-title {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 500;
}

.cat-empty {
  padding: 40rpx 0;
  text-align: center;
}

.cat-loading {
  padding: 40rpx 16rpx;
  text-align: center;
}

.cat-loading-text {
  font-size: 24rpx;
  color: #B0A396;
}

.cat-empty-text {
  font-size: 24rpx;
  color: #B0A396;
}

.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* ── 左侧：外卖平台扁平列表 ── */
.left-sidebar {
  width: 160rpx;
  background: #F4F0EB;
  padding: 0 0 200rpx;
  flex-shrink: 0;
}

.sidebar-item {
  width: 100%;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  background: transparent;
  border-radius: 0;
  margin: 0;
  position: relative;
}

.sidebar-item.active {
  background: #FFFFFF;
  box-shadow: none;
}

.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 44rpx;
  border-radius: 0 4rpx 4rpx 0;
  background: #B98B58;
}

/* 未选中：浅灰色 */
.sidebar-text {
  font-size: 26rpx;
  color: #B0A396;
  text-align: center;
  line-height: 1.4;
}

/* 选中：深色加粗 */
.sidebar-item.active .sidebar-text {
  color: #0F172A;
  font-weight: 700;
}

/* ── 右侧内容区 ── */
.right-content {
  flex: 1;
  background: #FFFFFF;
  border-radius: 0;
  padding: 0 0 0 0;
}

/* 分类页顶部轮播（与后台 position=category 的 Banner 对应） */
.category-banner-wrap {
  padding: 16rpx 16rpx 8rpx;
  flex-shrink: 0;
}

.category-banner-swiper {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.category-banner-img {
  width: 100%;
  height: 200rpx;
  display: block;
  border-radius: 16rpx;
}

/* ── 外卖风横向商品列表 ── */
.product-list {
  display: flex;
  flex-direction: column;
  padding: 0 16rpx;
}

.product-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F2EEE8;
  gap: 18rpx;
  position: relative;
}

.product-item:last-child {
  border-bottom: none;
}

/* 固定正方形缩略图 */
.product-img-wrap {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F2EEE9;
  flex-shrink: 0;
  position: relative;
  padding-top: 0;
}

.product-img {
  width: 100%;
  height: 100%;
  position: static;
  border-radius: 0;
  background: transparent;
}

/* 中间信息区 */
.product-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 0;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F1A16;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 热度行（月售 + 热度标签） */
.product-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
}

.product-sales {
  font-size: 20rpx;
  color: #64748B;
}

.product-heat {
  font-size: 20rpx;
  color: #E8723A;
  font-weight: 500;
}

/* 折扣标签 */
.product-discount-tag {
  margin-top: 6rpx;
}

.discount-tag-text {
  font-size: 20rpx;
  color: #B98B58;
  background: rgba(185, 139, 88, 0.10);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

/* 划线原价 */
.price-origin {
  font-size: 20rpx;
  color: #B0A396;
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 积分提示 */
.product-points-tip {
  display: block;
  font-size: 18rpx;
  color: #B98B58;
  margin-top: 2rpx;
}

/* 价格行 */
.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

.price-stack {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.price-symbol {
  font-size: 20rpx;
  color: #B95E46;
  font-weight: 600;
}

.product-price {
  font-size: 34rpx;
  color: #B95E46;
  font-weight: 700;
}

/* "+" 加购按钮（右下角） */
.add-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #B98B58, #D4B896);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(185, 139, 88, 0.35);
  flex-shrink: 0;
  align-self: flex-end;
  margin-bottom: 2rpx;
}

.add-btn-text {
  font-size: 38rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}


.loading-footer {
  padding: 20rpx;
  text-align: center;
}

.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #B98B58;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}


.floating-cart-shell {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 16rpx;
  height: 100rpx;
  border-radius: 999rpx;
  background: rgba(28, 25, 23, 0.92);
  box-shadow: 0 12rpx 30rpx rgba(28, 25, 23, 0.22);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12rpx 0 22rpx;
  z-index: 100;
}

.floating-cart-main {
  flex: 1;
  display: flex;
  align-items: center;
}

.floating-cart-bag {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.cart-bag-icon {
  width: 38rpx;
  height: 38rpx;
}

.cart-count-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: #F29D77;
  color: #FFF;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.floating-cart-copy {
  display: flex;
  flex-direction: column;
}

.floating-cart-total {
  font-size: 34rpx;
  color: #FFF7EF;
  font-weight: 700;
}

.floating-cart-cta {
  min-width: 176rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.floating-cart-cta.active {
  background: linear-gradient(135deg, #D4B896 0%, #B98B58 100%);
  color: #2A2018;
}

.cart-popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 900;
  display: flex;
  align-items: flex-end;
}

.cart-popup-panel {
  width: 100%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: popupSlideUp 0.2s ease-out;
}

.cart-popup-header {
  height: 88rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #F1ECE7;
}

.cart-popup-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cart-popup-header-text {
  font-size: 26rpx;
  color: #1F1A16;
  font-weight: 500;
}

.cart-popup-header-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.cart-popup-clear-text {
  font-size: 24rpx;
  color: #64748B;
}

.cart-popup-list {
  max-height: 46vh;
  padding: 12rpx 24rpx 0;
}

.cart-popup-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F7F3EF;
  gap: 12rpx;
}

.cart-popup-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 17rpx;
  border: 2rpx solid #D7CFC6;
  margin-right: 14rpx;
  position: relative;
  flex-shrink: 0;
}

.cart-popup-check.checked {
  background: #B98B58;
  border-color: #B98B58;
}

.cart-popup-check.checked::after {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 6rpx;
  width: 8rpx;
  height: 14rpx;
  border: 2rpx solid #FFFFFF;
  border-top: 0;
  border-left: 0;
  transform: rotate(45deg);
}

.cart-popup-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: #F4F1EC;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.cart-popup-info {
  flex: 1;
  min-width: 0;
}

.cart-popup-name {
  display: block;
  font-size: 26rpx;
  color: #1F1A16;
}

.cart-popup-spec {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #8C8073;
}

.cart-popup-price {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #B95E46;
}

/* 步进器 */
.cart-popup-stepper {
  display: flex;
  align-items: center;
  border: 1rpx solid #E7E5E4;
  border-radius: 999rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.cart-popup-step-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #57534E;
}

.cart-popup-step-val {
  width: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #1C1917;
  font-weight: 600;
}

.cart-popup-footer {
  min-height: 96rpx;
  padding: 0 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #F1ECE7;
}

.cart-popup-total-wrap {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.cart-popup-total-label {
  font-size: 24rpx;
  color: #6E6257;
}

.cart-popup-total-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #B95E46;
}

.cart-popup-checkout {
  min-width: 180rpx;
  height: 74rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #D4B896 0%, #B98B58 100%);
  color: #2A2018;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

@keyframes popupSlideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 服务标签 */
.service-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.service-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: #8D6A3F;
  background: rgba(185, 139, 88, 0.08);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.tag-dot {
  color: #B98B58;
  font-size: 18rpx;
}

.view-detail-link {
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #B98B58;
  text-align: center;
  border-top: 1rpx solid rgba(185,139,88,0.12);
  margin-top: 16rpx;
}

.product-tag-row { display: flex; gap: 6rpx; margin-bottom: 4rpx; }
.ptag { display: inline-block; padding: 2rpx 10rpx; border-radius: 4rpx; font-size: 20rpx; font-weight: 600; color: #fff; }
.ptag-hot { background: linear-gradient(135deg, #FF4D4F, #FF7A45); }
.ptag-discount { background: linear-gradient(135deg, #FA8C16, #FAAD14); }
.ptag-new { background: linear-gradient(135deg, #52C41A, #73D13D); }
.ptag-group { background: linear-gradient(135deg, #F08A4B, #D35C2D); }
.ptag-slash { background: linear-gradient(135deg, #16B3A5, #0F8A88); }
