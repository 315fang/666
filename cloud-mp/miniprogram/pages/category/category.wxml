<view class="container">
  <page-loading show="{{loading && categories.length === 0}}" text="分类加载中..."></page-loading>
  <view class="header-shell" style="padding-top: {{headerTopPadding}}px;">
    <view class="header-title-row">
      <text class="header-title">商品分类</text>
    </view>
  </view>

  <view class="main-content">
    <scroll-view
      class="left-sidebar"
      scroll-y
      show-scrollbar="{{false}}"
      scroll-into-view="{{leftToView}}"
      scroll-with-animation
    >
      <view
        class="sidebar-item ripple-dark {{currentCategory === item.id ? 'active' : ''}}"
        wx:for="{{sidebarCategories}}"
        wx:key="id"
        id="left-{{item.id}}"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
        hover-class="press"
      >
        <text class="sidebar-text">{{item.name}}</text>
      </view>
    </scroll-view>

    <view class="loading-footer" wx:if="{{loading}}">
      <view class="spinner"></view>
    </view>

    <scroll-view
      class="right-content"
      scroll-y
      scroll-into-view="{{toView}}"
      scroll-with-animation
      bindscroll="onRightScroll"
      wx:if="{{!loading}}"
    >
      <!-- 分类页顶部广告：后台 Banner 位置「分类页」(position=category)，接口 GET /api/banners?position=category -->
      <view class="category-banner-wrap" wx:if="{{categoryBanners.length > 0}}">
        <swiper
          class="category-banner-swiper"
          indicator-dots="{{categoryBanners.length > 1}}"
          autoplay="{{categoryBanners.length > 1}}"
          interval="4500"
          circular="{{categoryBanners.length > 1}}"
          indicator-color="rgba(0,0,0,0.2)"
          indicator-active-color="#2563eb"
        >
          <swiper-item wx:for="{{categoryBanners}}" wx:key="id">
            <view
              class="category-banner-slide"
              bindtap="onCategoryBannerTap"
              data-item="{{item}}"
            >
              <image
                wx:if="{{item.image}}"
                class="category-banner-img"
                src="{{item.image}}"
                mode="aspectFill"
              />
              <view wx:else class="category-banner-fallback">
                <view class="category-banner-fallback-orb orb-a"></view>
                <view class="category-banner-fallback-orb orb-b"></view>
                <view class="category-banner-fallback-copy">
                  <text class="category-banner-fallback-title">{{item.title || '分类海报'}}</text>
                  <text class="category-banner-fallback-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
                </view>
              </view>
            </view>
          </swiper-item>
        </swiper>
      </view>

      <view class="cat-section cat-section-anchor card-enter" wx:if="{{productBundles.length > 0}}" id="cat-bundle-zone">
        <view class="cat-section-header">
          <text class="cat-section-title">组合专区</text>
        </view>
        <view class="bundle-zone-list">
          <view
            class="bundle-zone-card"
            wx:for="{{productBundles}}"
            wx:key="id"
            bindtap="onOpenBundleDetail"
            data-id="{{item.id}}"
            hover-class="press"
          >
            <image class="bundle-zone-image" src="{{item.cover_preview_url || item.cover_image}}" mode="aspectFill" wx:if="{{item.cover_preview_url || item.cover_image}}"></image>
            <view class="bundle-zone-image bundle-zone-image-placeholder" wx:else>
              <text class="bundle-zone-image-placeholder-text">组合</text>
            </view>
            <view class="bundle-zone-info">
              <text class="bundle-zone-title">{{item.hero_title || item.title}}</text>
              <text class="bundle-zone-subtitle" wx:if="{{item.hero_subtitle || item.subtitle}}">{{item.hero_subtitle || item.subtitle}}</text>
              <view class="bundle-zone-tags" wx:if="{{item.channel_tags && item.channel_tags.length > 0}}">
                <text class="bundle-zone-tag" wx:for="{{item.channel_tags}}" wx:key="index">{{item}}</text>
              </view>
              <view class="bundle-zone-meta">
                <text class="bundle-zone-price">¥{{item.bundle_price}}</text>
                <text class="bundle-zone-count">{{item.group_count}} 组 / {{item.option_count}} 选项</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="cat-section cat-section-anchor card-enter delay-{{index < 8 ? index : 7}}" wx:for="{{renderedCategories}}" wx:key="id" id="cat-{{item.id}}">
        <view class="cat-section-header">
          <text class="cat-section-title">{{item.name}}</text>
        </view>
        <view class="cat-loading" wx:if="{{!loadedCategories[item.id]}}">
          <text class="cat-loading-text">加载中...</text>
        </view>
        <view class="product-list" wx:elif="{{visibleProducts[item.id] && visibleProducts[item.id].length > 0}}">
          <view
            class="product-item ripple-dark"
            wx:for="{{visibleProducts[item.id]}}"
            wx:for-item="prod"
            wx:for-index="prodIndex"
            wx:key="id"
            bindtap="onOpenProductDetail"
            data-id="{{prod.id}}"
            hover-class="press"
          >
            <!-- 正方形缩略图 -->
            <view class="product-img-wrap">
              <image
                class="product-img"
                src="{{prod.image || prod.display_image || prod.image_url || prod.image_ref || '/assets/images/placeholder.svg'}}"
                mode="aspectFill"
                lazy-load="{{prodIndex > 5}}"
                binderror="onProductImageError"
                data-category-id="{{item.id}}"
                data-id="{{prod.id}}"
              ></image>
            </view>
            <!-- 中间信息 -->
            <view class="product-info">
              <view class="product-tag-row" wx:if="{{prod.product_tag && prod.product_tag !== 'normal'}}">
                <text class="ptag ptag-hot" wx:if="{{prod.product_tag === 'hot'}}">爆品</text>
                <text class="ptag ptag-discount" wx:if="{{prod.product_tag === 'discount'}}">折扣</text>
                <text class="ptag ptag-new" wx:if="{{prod.product_tag === 'new'}}">新品</text>
              </view>
              <text class="product-name">{{prod.name}}</text>
              <!-- 热度行：月售 + 热度标签 -->
              <view class="product-meta-row">
                <text class="product-sales" wx:if="{{prod.sales_label}}">{{prod.sales_label}}</text>
                <text class="product-heat" wx:if="{{prod.heat_label}}">{{prod.heat_label}}</text>
              </view>
              <!-- 规格摘要 -->
              <text class="product-spec-summary" wx:if="{{prod.specSummary}}">{{prod.specSummary}}</text>
              <!-- 折扣标签 -->
              <view class="product-discount-tag" wx:if="{{prod.discount_label}}">
                <text class="discount-tag-text">{{prod.discount_label}}</text>
              </view>
              <!-- 价格行 -->
              <view class="product-bottom">
                <view class="price-stack">
                  <text class="price-symbol">¥</text>
                  <text class="product-price">{{prod.price}}</text>
                  <text class="price-origin" wx:if="{{prod.market_price}}">¥{{prod.market_price}}</text>
                </view>
              </view>
              <!-- 到手价提示 -->
              <text class="product-points-tip" wx:if="{{prod.lowestTip}}">到手约¥{{prod.lowestTip}}</text>
            </view>
            <!-- 右侧加购按钮 -->
            <view class="add-btn btn-spring" catchtap="onOpenProductDetail" data-id="{{prod.id}}">
              <text class="add-btn-text">+</text>
            </view>
          </view>
        </view>
        <view class="cat-empty" wx:else>
          <text class="cat-empty-text">暂无商品</text>
        </view>
      </view>
      <view style="height: 160rpx;"></view>
    </scroll-view>
  </view>

  <!-- 悬浮购物袋（外卖平台模式） -->
  <view class="floating-cart-shell glass-dark" bindtap="onToggleCartPopup">
    <view class="floating-cart-main cart-fly-target">
      <view class="floating-cart-bag">
        <image class="cart-bag-icon" src="/assets/icons/shopping-bag.svg" mode="aspectFit"></image>
        <view class="cart-count-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
      </view>
      <view class="floating-cart-copy" wx:if="{{cartCount > 0}}">
        <text class="floating-cart-total">¥{{cartTotal}}</text>
      </view>
    </view>
    <view class="floating-cart-cta {{cartCount > 0 ? 'active' : ''}}" catchtap="onCheckout">去结算</view>
  </view>

  <!-- 底部购物袋弹层 -->
  <view class="cart-popup-mask modal-enter" wx:if="{{showCartPopup}}" bindtap="closeCartPopup">
    <view class="cart-popup-panel modal-panel-enter" catchtap="stopProp">
      <!-- 头部：全选 + 清空 -->
      <view class="cart-popup-header">
        <view class="cart-popup-header-left" bindtap="onPopupToggleAll">
          <view class="cart-popup-check {{cartPopupAllSelected ? 'checked' : ''}}"></view>
          <text class="cart-popup-header-text">全选</text>
        </view>
        <view class="cart-popup-header-right" bindtap="onPopupClearAll">
          <text class="cart-popup-clear-text">清空</text>
        </view>
      </view>
      <!-- 商品列表 -->
      <scroll-view class="cart-popup-list" scroll-y>
        <view class="cart-popup-item" wx:for="{{cartPopupItems}}" wx:key="id">
          <view class="cart-popup-check {{item.selected ? 'checked' : ''}}" bindtap="onToggleCartPopupItem" data-index="{{index}}"></view>
          <image class="cart-popup-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="cart-popup-info">
            <text class="cart-popup-name">{{item.name}}</text>
            <text class="cart-popup-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
            <text class="cart-popup-price">¥{{item.price}}</text>
          </view>
          <!-- 步进器 -->
          <view class="cart-popup-stepper">
            <view class="cart-popup-step-btn" catchtap="onPopupMinus" data-index="{{index}}">-</view>
            <text class="cart-popup-step-val">{{item.quantity}}</text>
            <view class="cart-popup-step-btn" catchtap="onPopupPlus" data-index="{{index}}">+</view>
          </view>
        </view>
      </scroll-view>
      <!-- 底部 -->
      <view class="cart-popup-footer">
        <view class="cart-popup-total-wrap">
          <text class="cart-popup-total-label">合计</text>
          <text class="cart-popup-total-price">¥{{cartPopupTotal}}</text>
        </view>
        <view class="cart-popup-checkout" bindtap="onPopupCheckout">去结算</view>
      </view>
    </view>
  </view>
</view>
