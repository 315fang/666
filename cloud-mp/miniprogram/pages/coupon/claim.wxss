/* 优惠券领取 — 2026 青春版 */
page {
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 42%, #F7F5FF 100%);
  min-height: 100vh;
}

.claim-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 40rpx;
  min-height: 100vh;
}

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 160rpx;
  gap: 24rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(102, 126, 234, 0.15);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  font-size: 28rpx;
  color: #78716c;
}

/* 错误 */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  gap: 24rpx;
}

.status-emoji {
  font-size: 96rpx;
}

.status-title {
  font-size: 32rpx;
  color: #1c1917;
  font-weight: 600;
}

/* 券卡片 */
.coupon-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 20rpx;
  display: flex;
  align-items: stretch;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.1);
  overflow: hidden;
  margin-bottom: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.coupon-left {
  width: 220rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  flex-shrink: 0;
}

.value-text {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.1;
}

.min-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.coupon-divider {
  width: 32rpx;
  position: relative;
  background: rgba(255, 255, 255, 0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
}

.coupon-hole {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #E8E0F0, #F0EBF8);
  flex-shrink: 0;
}

.coupon-hole.top { margin-top: -16rpx; }
.coupon-hole.bottom { margin-bottom: -16rpx; }

.dashed-line {
  flex: 1;
  width: 2rpx;
  background: repeating-linear-gradient(to bottom, rgba(102,126,234,0.2) 0, rgba(102,126,234,0.2) 8rpx, transparent 8rpx, transparent 16rpx);
}

.coupon-right {
  flex: 1;
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1917;
  line-height: 1.3;
}

.coupon-desc {
  font-size: 24rpx;
  color: #78716c;
  line-height: 1.4;
}

.coupon-days {
  font-size: 24rpx;
  color: #a8a29e;
}

/* 操作区 */
.action-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.status-badge {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.status-badge.inactive,
.status-badge.out-of-stock {
  background: rgba(102, 126, 234, 0.06);
  color: #78716c;
}

.status-badge.success {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.status-badge.owned {
  background: rgba(245, 158, 11, 0.1);
  color: #d97706;
}

.status-badge.error-badge {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.btn-primary {
  width: 560rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: opacity 0.2s;
}

.btn-primary.btn-loading {
  opacity: 0.6;
}

.btn-back {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #667eea;
  padding: 12rpx 32rpx;
}

/* 分享提示 */
.share-tip {
  margin-top: 48rpx;
  font-size: 26rpx;
  color: #a8a29e;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
