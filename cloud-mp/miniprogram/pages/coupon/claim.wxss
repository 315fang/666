/* 优惠券领取 */
page { background: #f8f7f4; min-height: 100vh; }

.claim-page {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 32rpx 40rpx; min-height: 100vh;
}

.loading-wrap { display: flex; flex-direction: column; align-items: center; margin-top: 160rpx; gap: 24rpx; }
.loading-spinner {
  width: 64rpx; height: 64rpx; border: 6rpx solid #fecaca; border-top: 6rpx solid #dc2626;
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #6b7280; }

.error-wrap { display: flex; flex-direction: column; align-items: center; margin-top: 100rpx; gap: 24rpx; }
.status-emoji { font-size: 96rpx; }
.status-title { font-size: 32rpx; color: #1f2937; font-weight: 600; }

.coupon-card {
  width: 100%; background: #fff; border-radius: 20rpx; display: flex; align-items: stretch;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); overflow: hidden; margin-bottom: 48rpx;
  border: 1rpx solid rgba(220,38,38,0.08);
}
.coupon-left {
  width: 220rpx; background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 40rpx 0; flex-shrink: 0;
}
.value-text { font-size: 52rpx; font-weight: 700; color: #fff; line-height: 1.1; }
.min-text { font-size: 22rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; }

.coupon-divider {
  width: 32rpx; position: relative; background: #fff;
  display: flex; flex-direction: column; align-items: center; justify-content: space-between;
}
.coupon-hole { width: 32rpx; height: 32rpx; border-radius: 50%; background: #f8f7f4; flex-shrink: 0; }
.coupon-hole.top { margin-top: -16rpx; }
.coupon-hole.bottom { margin-bottom: -16rpx; }
.dashed-line {
  flex: 1; width: 2rpx;
  background: repeating-linear-gradient(to bottom, #fecaca 0, #fecaca 8rpx, transparent 8rpx, transparent 16rpx);
}
.coupon-right {
  flex: 1; padding: 32rpx 28rpx; display: flex; flex-direction: column;
  justify-content: center; gap: 10rpx;
}
.coupon-name { font-size: 32rpx; font-weight: 600; color: #1f2937; line-height: 1.3; }
.coupon-desc { font-size: 24rpx; color: #6b7280; line-height: 1.4; }
.coupon-days { font-size: 24rpx; color: #9ca3af; }

.action-area { width: 100%; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.status-badge { padding: 16rpx 40rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 500; text-align: center; }
.status-badge.inactive, .status-badge.out-of-stock { background: #f3f4f6; color: #9ca3af; }
.status-badge.success { background: #d1fae5; color: #10b981; }
.status-badge.owned { background: #fef3c7; color: #d97706; }
.status-badge.error-badge { background: #fee2e2; color: #dc2626; }

.btn-primary {
  width: 560rpx; height: 96rpx; line-height: 96rpx; text-align: center;
  background: #dc2626; color: #fff; font-size: 32rpx; font-weight: 600;
  border-radius: 48rpx; box-shadow: 0 4rpx 16rpx rgba(220,38,38,0.2); transition: opacity 0.2s;
}
.btn-primary.btn-loading { opacity: 0.6; }
.btn-back { margin-top: 24rpx; font-size: 28rpx; color: #dc2626; padding: 12rpx 32rpx; }

.share-tip { margin-top: 48rpx; font-size: 26rpx; color: #9ca3af; display: flex; align-items: center; gap: 8rpx; }
