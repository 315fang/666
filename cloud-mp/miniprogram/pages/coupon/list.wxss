/** pages/coupon/list.wxss **/

.container { min-height: 100vh; background: #F8F9FA; }

/* Nav */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; background: #FFFFFF; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.nav-placeholder { width: 56rpx; }

/* Tabs */
.tab-row { display: flex; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; padding: 0 20rpx; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #666; position: relative; display: flex; align-items: center; justify-content: center; gap: 6rpx; cursor: pointer; }
.tab-item.active { color: #E53935; font-weight: 700; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 35%; right: 35%; height: 6rpx; background: #E53935; border-radius: 4rpx; }
.tab-count { background: #E53935; color: #FFF; font-size: 18rpx; font-weight: 700; min-width: 28rpx; height: 28rpx; border-radius: 14rpx; display: flex; align-items: center; justify-content: center; padding: 0 6rpx; margin-left: 4rpx; }

/* Scroll area */
.coupon-scroll { height: calc(100vh - 200rpx); }

/* Empty */
.empty-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 100rpx 40rpx; gap: 14rpx; }
.empty-icon { width: 80rpx; height: 80rpx; opacity: 0.3; }
.empty-text { font-size: 28rpx; color: #888; text-align: center; }
.empty-sub { font-size: 24rpx; color: #BBB; text-align: center; }
.empty-btn { margin-top: 16rpx; background: #E53935; color: #FFFFFF; font-size: 26rpx; font-weight: 600; padding: 16rpx 48rpx; border-radius: 50rpx; }

/* 骨架屏 */
.skeleton-list { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.skeleton-coupon { display: flex; background: #fff; border-radius: 16rpx; overflow: hidden; height: 140rpx; }
.sk-left { width: 160rpx; background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%); background-size: 200% 100%; animation: shimmer 1.4s infinite; }
.sk-right { flex: 1; padding: 24rpx 20rpx; display: flex; flex-direction: column; justify-content: center; gap: 12rpx; }
.sk-line { height: 20rpx; border-radius: 10rpx; background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%); background-size: 200% 100%; animation: shimmer 1.4s infinite; }
.sk-long { width: 80%; }
.sk-short { width: 55%; }
.sk-tiny { width: 45%; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

/* Coupon cards */
.coupon-list { padding: 24rpx; display: flex; flex-direction: column; gap: 24rpx; }

.coupon-card { display: flex; background: #FFF4F5; border-radius: 16rpx; overflow: hidden; position: relative; border: 1rpx solid #FCE4E6; }
.coupon-card.used, .coupon-card.expired, .coupon-card.coupon-expired { opacity: 0.6; filter: grayscale(1); }

.coupon-card.unused.coupon-expired { border-color: #E5E7EB; background: #F3F4F6; }

/* Left: value */
.coupon-left { padding: 28rpx 12rpx 28rpx 20rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 190rpx; min-width: 190rpx; box-sizing: border-box; }
.coupon-value-wrap { min-height: 74rpx; display: flex; align-items: flex-start; justify-content: center; color: #E53935; gap: 4rpx; width: 100%; }
.coupon-exchange-badge { font-size: 26rpx; font-weight: 700; color: #E53935; }
.coupon-currency { font-size: 28rpx; font-weight: 700; line-height: 1; padding-top: 8rpx; }
.coupon-value { font-size: 60rpx; font-weight: 800; line-height: 1; text-align: center; font-variant-numeric: tabular-nums; }
.coupon-min { font-size: 22rpx; color: #A45A5A; margin-top: 10rpx; text-align: center; line-height: 1.35; }

/* Divider */
.coupon-divider { display: flex; flex-direction: column; align-items: center; justify-content: space-between; width: 2rpx; position: relative; }
.dashed-line { flex: 1; border-left: 2rpx dashed #F8C3CB; margin: 16rpx 0; }
.dent { display: none; } /* 隐藏原有打孔 */

/* Right: info */
.coupon-right { flex: 1; padding: 30rpx 160rpx 30rpx 20rpx; display: flex; flex-direction: column; justify-content: center; position: relative; }
.coupon-name { font-size: 30rpx; font-weight: 700; color: #333; margin-bottom: 12rpx; }
.coupon-expire { font-size: 22rpx; color: #C67878; margin-bottom: 6rpx; }
.coupon-scope { font-size: 22rpx; color: #C67878; }
.coupon-scope.scope-limit { color: #A45A5A; }

.coupon-action { position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%); background: #E53935; color: #FFFFFF; font-size: 24rpx; font-weight: 600; padding: 12rpx 28rpx; border-radius: 8rpx; box-shadow: 0 4rpx 12rpx rgba(229,57,53,0.3); }
.coupon-used-tag, .coupon-expire-tag { position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%); font-size: 24rpx; color: #999; border: 1rpx solid #CCC; padding: 10rpx 24rpx; border-radius: 8rpx; }
