/* 我的优惠券 */
.container { min-height: 100vh; background: #f8f7f4; }

.nav-bar {
  display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx;
  background: #1e3a5f;
}
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
.nav-icon { width: 32rpx; height: 32rpx; filter: invert(1); }
.nav-title { font-size: 32rpx; font-weight: 700; color: #fff; }
.nav-placeholder { width: 56rpx; }

.tab-row { display: flex; background: #fff; border-bottom: 1rpx solid #f3f4f6; padding: 0 20rpx; position: relative; }
.tab-item {
  flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #6b7280;
  position: relative; display: flex; align-items: center; justify-content: center; gap: 6rpx;
  transition: color 0.3s;
}
.tab-item.active { color: #dc2626; font-weight: 700; }
.tab-count {
  background: #dc2626; color: #fff; font-size: 18rpx; font-weight: 700;
  min-width: 28rpx; height: 28rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center; padding: 0 6rpx; margin-left: 4rpx;
}
.tab-indicator {
  position: absolute; bottom: 0; left: 0; width: 33.33%; height: 6rpx;
  background: #dc2626; border-radius: 3rpx;
  transition: transform 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.coupon-scroll { height: calc(100vh - 200rpx); }

.empty-wrap {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 100rpx 40rpx; gap: 14rpx;
}
.empty-emoji { font-size: 80rpx; margin-bottom: 8rpx; }
.empty-text { font-size: 28rpx; color: #1f2937; text-align: center; font-weight: 600; }
.empty-sub { font-size: 24rpx; color: #6b7280; text-align: center; }
.empty-btn {
  margin-top: 16rpx; background: #dc2626; color: #fff;
  font-size: 26rpx; font-weight: 600; padding: 16rpx 48rpx; border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(220,38,38,0.2);
}

.skeleton-list { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.skeleton-coupon { display: flex; background: #fff; border-radius: 16rpx; overflow: hidden; height: 140rpx; }
.sk-left {
  width: 160rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%; animation: shimmer 1.4s infinite;
}
.sk-right { flex: 1; padding: 24rpx 20rpx; display: flex; flex-direction: column; justify-content: center; gap: 12rpx; }
.sk-line {
  height: 20rpx; border-radius: 10rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%; animation: shimmer 1.4s infinite;
}
.sk-long { width: 80%; }
.sk-short { width: 55%; }
.sk-tiny { width: 45%; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

.coupon-list { padding: 24rpx; display: flex; flex-direction: column; gap: 24rpx; }
.coupon-card {
  display: flex; background: #fff; border-radius: 16rpx; overflow: hidden;
  position: relative; border: 1rpx solid rgba(220,38,38,0.1);
}
.coupon-card.used, .coupon-card.expired, .coupon-card.coupon-expired { opacity: 0.6; filter: grayscale(0.5); }
.coupon-card.unused.coupon-expired { border-color: #e5e7eb; background: #f9fafb; }

.coupon-left {
  padding: 28rpx 12rpx 28rpx 20rpx; display: flex; flex-direction: column;
  align-items: center; justify-content: center; width: 190rpx; min-width: 190rpx;
  box-sizing: border-box; background: #fef2f2;
}
.coupon-value-wrap {
  min-height: 74rpx; display: flex; align-items: flex-start; justify-content: center;
  color: #dc2626; gap: 4rpx; width: 100%;
}
.coupon-exchange-badge { font-size: 26rpx; font-weight: 700; color: #dc2626; }
.coupon-currency { font-size: 28rpx; font-weight: 700; line-height: 1; padding-top: 8rpx; }
.coupon-value { font-size: 60rpx; font-weight: 800; line-height: 1; text-align: center; font-variant-numeric: tabular-nums; }
.coupon-min { font-size: 22rpx; color: #991b1b; margin-top: 10rpx; text-align: center; line-height: 1.35; }

.coupon-divider { display: flex; flex-direction: column; align-items: center; justify-content: space-between; width: 2rpx; position: relative; }
.dashed-line { flex: 1; border-left: 2rpx dashed #fecaca; margin: 16rpx 0; }
.dent { display: none; }

.coupon-right {
  flex: 1; padding: 30rpx 160rpx 30rpx 20rpx;
  display: flex; flex-direction: column; justify-content: center; position: relative;
}
.coupon-name { font-size: 30rpx; font-weight: 700; color: #1f2937; margin-bottom: 12rpx; }
.coupon-expire { font-size: 22rpx; color: #dc2626; margin-bottom: 6rpx; }
.coupon-scope { font-size: 22rpx; color: #6b7280; }
.coupon-scope.scope-limit { color: #991b1b; }

.coupon-action {
  position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%);
  background: #dc2626; color: #fff; font-size: 24rpx; font-weight: 600;
  padding: 12rpx 28rpx; border-radius: 8rpx; box-shadow: 0 4rpx 12rpx rgba(220,38,38,0.2);
}
.coupon-used-tag, .coupon-expire-tag {
  position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%);
  font-size: 24rpx; color: #9ca3af; border: 1rpx solid #e5e7eb; padding: 10rpx 24rpx; border-radius: 8rpx;
}
