/* 我的优惠券 — 2026 青春版 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 42%, #F7F5FF 100%);
}

/* 导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  background: rgba(15, 15, 35, 0.85);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
  filter: invert(1);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.nav-placeholder {
  width: 56rpx;
}

/* Tab 切换 */
.tab-row {
  display: flex;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.08);
  padding: 0 20rpx;
  position: relative;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #78716c;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  cursor: pointer;
  transition: color 0.3s;
}

.tab-item.active {
  color: #667eea;
  font-weight: 700;
}

.tab-count {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  margin-left: 4rpx;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 33.33%;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 3rpx;
  transition: transform 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

/* 滚动区域 */
.coupon-scroll {
  height: calc(100vh - 200rpx);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  gap: 14rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #1c1917;
  text-align: center;
  font-weight: 600;
}

.empty-sub {
  font-size: 24rpx;
  color: #78716c;
  text-align: center;
}

.empty-btn {
  margin-top: 16rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 48rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.25);
}

/* 骨架屏 */
.skeleton-list {
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-coupon {
  display: flex;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  overflow: hidden;
  height: 140rpx;
}

.sk-left {
  width: 160rpx;
  background: linear-gradient(90deg, rgba(102,126,234,0.06) 25%, rgba(102,126,234,0.12) 50%, rgba(102,126,234,0.06) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}

.sk-right {
  flex: 1;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.sk-line {
  height: 20rpx;
  border-radius: 10rpx;
  background: linear-gradient(90deg, rgba(102,126,234,0.06) 25%, rgba(102,126,234,0.12) 50%, rgba(102,126,234,0.06) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}

.sk-long { width: 80%; }
.sk-short { width: 55%; }
.sk-tiny { width: 45%; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 优惠券卡片 */
.coupon-list {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.coupon-card {
  display: flex;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.coupon-card.used,
.coupon-card.expired,
.coupon-card.coupon-expired {
  opacity: 0.6;
  filter: grayscale(0.5);
}

.coupon-card.unused.coupon-expired {
  border-color: rgba(102, 126, 234, 0.05);
  background: rgba(255, 255, 255, 0.5);
}

/* 左侧：面值 */
.coupon-left {
  padding: 28rpx 12rpx 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 190rpx;
  min-width: 190rpx;
  box-sizing: border-box;
}

.coupon-value-wrap {
  min-height: 74rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  color: #667eea;
  gap: 4rpx;
  width: 100%;
}

.coupon-exchange-badge {
  font-size: 26rpx;
  font-weight: 700;
  color: #667eea;
}

.coupon-currency {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  padding-top: 8rpx;
}

.coupon-value {
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.coupon-min {
  font-size: 22rpx;
  color: #78716c;
  margin-top: 10rpx;
  text-align: center;
  line-height: 1.35;
}

/* 分割线 */
.coupon-divider {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  width: 2rpx;
  position: relative;
}

.dashed-line {
  flex: 1;
  border-left: 2rpx dashed rgba(102, 126, 234, 0.2);
  margin: 16rpx 0;
}

.dent { display: none; }

/* 右侧：信息 */
.coupon-right {
  flex: 1;
  padding: 30rpx 160rpx 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1917;
  margin-bottom: 12rpx;
}

.coupon-expire {
  font-size: 22rpx;
  color: #667eea;
  margin-bottom: 6rpx;
}

.coupon-scope {
  font-size: 22rpx;
  color: #78716c;
}

.coupon-scope.scope-limit {
  color: #667eea;
}

.coupon-action {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}

.coupon-used-tag,
.coupon-expire-tag {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #94a3b8;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
}
