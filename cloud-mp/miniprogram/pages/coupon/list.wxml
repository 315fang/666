<!--pages/coupon/list.wxml - 我的券包-->
<view class="container">
  <!-- 导航 -->
  <view class="nav-bar" style="padding-top: {{navTopPadding}}px;">
    <view class="nav-inner" style="height: {{navBarHeight}}px;">
      <view class="nav-back ripple" bindtap="onBack">
        <image class="nav-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"/>
      </view>
      <view class="nav-title">
        <text class="nav-title-text">我的券包</text>
      </view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-row">
    <view class="tab-item {{activeTab === 'unused' ? 'active' : ''}}" bindtap="switchTab" data-tab="unused">
      可用券包
      <text class="tab-count" wx:if="{{unusedCount > 0}}">{{unusedCount}}</text>
    </view>
    <view class="tab-item {{activeTab === 'used' ? 'active' : ''}}" bindtap="switchTab" data-tab="used">已用券包</view>
    <view class="tab-item {{activeTab === 'expired' ? 'active' : ''}}" bindtap="switchTab" data-tab="expired">过期券包</view>
    <!-- 滑动指示器 -->
    <view class="tab-indicator-track">
      <view class="tab-indicator" style="transform:translateX({{activeTab === 'unused' ? '0%' : activeTab === 'used' ? '100%' : '200%'}});"></view>
    </view>
  </view>

  <!-- 券列表 -->
  <scroll-view scroll-y class="coupon-scroll">

    <!-- 未登录提示 -->
    <view class="empty-wrap card-enter" wx:if="{{notLoggedIn}}">
      <image class="empty-icon" src="/assets/icons/shield.svg" mode="aspectFit"></image>
      <text class="empty-text">请先登录</text>
      <text class="empty-sub">登录后查看已领取券包</text>
      <view class="empty-btn ripple" bindtap="onGoLogin">立即登录</view>
    </view>

    <!-- 骨架屏 loading -->
    <view class="skeleton-list" wx:elif="{{loading}}">
      <view class="skeleton-coupon" wx:for="{{[1,2,3]}}" wx:key="index">
        <view class="sk-left"></view>
        <view class="sk-right">
          <view class="sk-line sk-long"></view>
          <view class="sk-line sk-short"></view>
          <view class="sk-line sk-tiny"></view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap card-enter" wx:elif="{{!coupons.length}}">
      <image class="empty-icon" src="{{activeTab === 'unused' ? '/assets/icons/tag.svg' : activeTab === 'used' ? '/assets/icons/check-circle.svg' : '/assets/icons/clock.svg'}}" mode="aspectFit"></image>
      <text class="empty-text" wx:if="{{activeTab === 'unused'}}">暂无券包</text>
      <text class="empty-sub" wx:if="{{activeTab === 'unused'}}">快去参与活动领券吧</text>
      <view class="empty-btn ripple" wx:if="{{activeTab === 'unused'}}" bindtap="onOpenCouponCenter">领券中心</view>
      <text class="empty-text" wx:elif="{{activeTab === 'used'}}">暂无记录</text>
      <text class="empty-text" wx:else>暂无记录</text>
    </view>

    <!-- 真实券列表 -->
    <view class="coupon-list" wx:else>
      <view class="coupon-swipe-row" wx:for="{{coupons}}" wx:key="user_coupon_id">
        <view class="coupon-delete-action" catchtap="onDeleteCoupon" data-id="{{item.user_coupon_id}}" data-index="{{index}}">删除</view>
        <view
          class="coupon-card {{activeTab}} {{item.is_expired ? 'coupon-expired' : ''}}"
          style="transform: translateX({{item.slideX || 0}}rpx);"
          bindtouchstart="onCouponTouchStart"
          bindtouchmove="onCouponTouchMove"
          bindtouchend="onCouponTouchEnd"
          bindtouchcancel="onCouponTouchEnd"
          data-index="{{index}}"
        >
          <!-- 左侧：面值 -->
          <view class="coupon-left">
            <view class="coupon-value-wrap">
              <text class="coupon-exchange-badge" wx:if="{{item.is_exchange}}">兑</text>
              <text class="coupon-currency" wx:if="{{!item.is_exchange && (item.coupon_type === 'fixed' || item.coupon_type === 'no_threshold')}}">¥</text>
              <text class="coupon-value">
                {{item.is_exchange ? item.exchange_value_text : (item.coupon_type === 'percent' ? item.discount_text : item.coupon_value)}}
              </text>
            </view>
            <text class="coupon-min" wx:if="{{item.is_exchange}}">{{item.exchange_scope_text}}</text>
            <text class="coupon-min" wx:elif="{{item.min_purchase > 0}}">满{{item.min_purchase}}元可用</text>
            <text class="coupon-min" wx:else>无门槛</text>
          </view>
          <!-- 锯齿分割线 -->
          <view class="coupon-divider">
            <view class="dent top"/>
            <view class="dashed-line"/>
            <view class="dent bottom"/>
          </view>
          <!-- 右侧：信息 -->
          <view class="coupon-right">
            <text class="coupon-name">{{item.coupon_name}}</text>
            <text class="coupon-expire">{{item.expire_at_formatted}} 到期</text>
            <text class="coupon-scope scope-limit" wx:if="{{item.is_exchange}}">{{item.exchange_desc}}</text>
            <text class="coupon-scope scope-limit" wx:elif="{{item.scope !== 'all'}}">限该店铺内指定商品使用</text>
            <text class="coupon-scope scope-all" wx:else>全场通用</text>
            <!-- 操作 -->
            <view class="coupon-action ripple" wx:if="{{activeTab === 'unused'}}" bindtap="onUse" data-coupon="{{item}}">
              {{item.action_text || '使用'}}
            </view>
            <view class="coupon-used-tag" wx:elif="{{activeTab === 'used'}}">已使用</view>
            <view class="coupon-expire-tag" wx:else>已过期</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
