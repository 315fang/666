/* 优惠券中心 */
.page { min-height: 100vh; background: #f8f7f4; }
.scroll { min-height: 100vh; }

.hero { padding: 34rpx 28rpx 0; position: relative; overflow: hidden; }
.hero-glow {
  position: absolute; top: -80rpx; right: -60rpx; width: 280rpx; height: 280rpx;
  border-radius: 50%; background: rgba(220, 38, 38, 0.06);
}
.hero-kicker { display: block; font-size: 20rpx; letter-spacing: 4rpx; color: #dc2626; font-weight: 600; position: relative; z-index: 1; }
.hero-title { display: block; margin-top: 12rpx; font-size: 54rpx; line-height: 1.1; font-weight: 700; color: #1f2937; position: relative; z-index: 1; }
.hero-subtitle { display: block; margin-top: 16rpx; max-width: 620rpx; font-size: 25rpx; line-height: 1.8; color: #6b7280; position: relative; z-index: 1; }
.hero-metrics { display: flex; gap: 16rpx; margin-top: 28rpx; align-items: stretch; position: relative; z-index: 1; }

.metric-card {
  flex: 1; height: 144rpx; padding: 22rpx 24rpx; border-radius: 24rpx;
  background: #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.04);
  display: flex; flex-direction: column; justify-content: flex-end;
}
.metric-card-main { background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%); border-color: transparent; box-shadow: 0 4rpx 12rpx rgba(220,38,38,0.2); }
.metric-card-main .metric-value, .metric-card-main .metric-label { color: #fff; }
.metric-value { display: block; font-size: 54rpx; line-height: 1; font-weight: 700; color: #1f2937; }
.metric-label { display: block; margin-top: 10rpx; font-size: 22rpx; letter-spacing: 2rpx; color: #6b7280; }

.section {
  margin: 28rpx 24rpx 0; padding: 28rpx; border-radius: 24rpx;
  background: #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.04);
}
.my-section { margin-top: 20rpx; }
.section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }
.section-copy { flex: 1; min-width: 0; }
.section-title { display: block; font-size: 34rpx; line-height: 1.3; font-weight: 700; color: #1f2937; }
.section-subtitle { display: block; margin-top: 8rpx; font-size: 22rpx; line-height: 1.7; color: #6b7280; }
.section-link { flex-shrink: 0; padding-top: 8rpx; font-size: 24rpx; font-weight: 600; color: #dc2626; }

.coupon-list { display: flex; flex-direction: column; gap: 18rpx; margin-top: 24rpx; }
.coupon-card {
  display: flex; align-items: stretch; border-radius: 20rpx; overflow: hidden;
  background: #fff; border: 1rpx solid rgba(220, 38, 38, 0.1);
}
.coupon-card-muted { opacity: 0.62; }
.coupon-card-rail { width: 16rpx; background: linear-gradient(180deg, #dc2626 0%, #b91c1c 100%); }
.coupon-value-area {
  width: 196rpx; padding: 24rpx 12rpx 24rpx 22rpx;
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  background: #fef2f2;
}
.coupon-value { display: block; font-size: 48rpx; line-height: 1.1; font-weight: 700; color: #dc2626; }
.coupon-threshold { display: block; margin-top: 10rpx; font-size: 20rpx; line-height: 1.6; text-align: center; color: #991b1b; }
.coupon-copy-area { flex: 1; min-width: 0; padding: 24rpx 24rpx 24rpx 10rpx; }
.coupon-copy-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }
.coupon-name { flex: 1; min-width: 0; font-size: 30rpx; line-height: 1.4; font-weight: 600; color: #1f2937; }
.coupon-window { flex-shrink: 0; font-size: 20rpx; line-height: 1.5; color: #dc2626; }
.coupon-desc { display: block; margin-top: 10rpx; font-size: 22rpx; line-height: 1.7; color: #6b7280; }
.coupon-meta-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.coupon-meta { padding: 8rpx 14rpx; border-radius: 999rpx; background: #fef2f2; font-size: 20rpx; color: #dc2626; }
.coupon-bottom-row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-top: 20rpx; }
.coupon-hint { flex: 1; min-width: 0; font-size: 22rpx; line-height: 1.6; color: #6b7280; }
.coupon-action {
  flex-shrink: 0; min-width: 156rpx; padding: 18rpx 18rpx; border-radius: 999rpx;
  text-align: center; background: #dc2626; color: #fff;
  font-size: 24rpx; font-weight: 600; box-shadow: 0 4rpx 12rpx rgba(220,38,38,0.2);
}
.coupon-action-disabled { background: #e5e7eb; color: #9ca3af; box-shadow: none; }

.mine-preview-list { display: flex; flex-direction: column; gap: 14rpx; margin-top: 22rpx; }
.mine-preview-card {
  display: flex; align-items: center; gap: 16rpx; padding: 20rpx; border-radius: 16rpx;
  background: #fef2f2; border: 1rpx solid rgba(220,38,38,0.08);
}
.mine-preview-left { width: 168rpx; flex-shrink: 0; }
.mine-preview-value { display: block; font-size: 34rpx; line-height: 1.2; font-weight: 700; color: #dc2626; }
.mine-preview-threshold { display: block; margin-top: 8rpx; font-size: 20rpx; line-height: 1.6; color: #991b1b; }
.mine-preview-right { flex: 1; min-width: 0; }
.mine-preview-name { display: block; font-size: 28rpx; line-height: 1.4; font-weight: 600; color: #1f2937; }
.mine-preview-expire { display: block; margin-top: 8rpx; font-size: 21rpx; line-height: 1.6; color: #6b7280; }

.state-card {
  margin-top: 24rpx; padding: 30rpx 24rpx; border-radius: 20rpx;
  background: #f9fafb; text-align: center; display: flex; flex-direction: column; align-items: center;
}
.state-card-light { background: #f9fafb; }
.state-emoji { font-size: 48rpx; margin-bottom: 12rpx; }
.loading-spinner {
  width: 40rpx; height: 40rpx; border: 4rpx solid #fecaca; border-top: 4rpx solid #dc2626;
  border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 12rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.state-title { display: block; font-size: 28rpx; line-height: 1.5; font-weight: 600; color: #1f2937; }
.state-desc { display: block; margin-top: 10rpx; font-size: 22rpx; line-height: 1.7; color: #6b7280; }
.safe-bottom { height: calc(32rpx + env(safe-area-inset-bottom)); }
