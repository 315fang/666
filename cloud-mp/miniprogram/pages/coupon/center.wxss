.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(198, 161, 110, 0.18), transparent 28%),
    linear-gradient(180deg, #F8FBFC 0%, #F4F8FA 42%, #EEF3F6 100%);
}

.scroll {
  min-height: 100vh;
}

.hero {
  padding: 34rpx 28rpx 0;
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #1E4A6D;
  opacity: 0.68;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #0F172A;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  max-width: 620rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #475569;
}

.hero-metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  align-items: stretch;
}

.metric-card {
  flex: 1;
  height: 144rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 28rpx rgba(30, 74, 109, 0.08);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.metric-card-main {
  background: linear-gradient(135deg, #1E4A6D 0%, #355F83 100%);
}

.metric-card-main .metric-value,
.metric-card-main .metric-label {
  color: #FFF8F0;
}

.metric-value {
  display: block;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 700;
  color: #0F172A;
}

.metric-label {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #64748B;
}

.section {
  margin: 28rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 32rpx rgba(30, 74, 109, 0.08);
}

.my-section {
  margin-top: 20rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-copy {
  flex: 1;
  min-width: 0;
}

.section-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #0F172A;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #64748B;
}

.section-link {
  flex-shrink: 0;
  padding-top: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1E4A6D;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.coupon-card {
  display: flex;
  align-items: stretch;
  border-radius: 26rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255, 246, 246, 0.96) 0%, rgba(255, 252, 246, 0.98) 100%);
  border: 1rpx solid rgba(229, 91, 91, 0.12);
}

.coupon-card-muted {
  opacity: 0.62;
}

.coupon-card-rail {
  width: 16rpx;
  background: linear-gradient(180deg, #E55B5B 0%, #F2A65A 100%);
}

.coupon-value-area {
  width: 196rpx;
  padding: 24rpx 12rpx 24rpx 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.coupon-value {
  display: block;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #D84B4B;
}

.coupon-threshold {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
  text-align: center;
  color: #9F4B4B;
}

.coupon-copy-area {
  flex: 1;
  min-width: 0;
  padding: 24rpx 24rpx 24rpx 10rpx;
}

.coupon-copy-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.coupon-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #0F172A;
}

.coupon-window {
  flex-shrink: 0;
  font-size: 20rpx;
  line-height: 1.5;
  color: #1E4A6D;
}

.coupon-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #64748B;
}

.coupon-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.coupon-meta {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(30, 74, 109, 0.08);
  font-size: 20rpx;
  color: #355F83;
}

.coupon-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.coupon-hint {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8A5B3B;
}

.coupon-action {
  flex-shrink: 0;
  min-width: 156rpx;
  padding: 18rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: linear-gradient(135deg, #E55B5B 0%, #D84B4B 100%);
  color: #FFF8F0;
  font-size: 24rpx;
  font-weight: 600;
}

.coupon-action-disabled {
  background: #E2E8F0;
  color: #64748B;
}

.mine-preview-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.mine-preview-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #F8FBFC;
}

.mine-preview-left {
  width: 168rpx;
  flex-shrink: 0;
}

.mine-preview-value {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #D84B4B;
}

.mine-preview-threshold {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #9F4B4B;
}

.mine-preview-right {
  flex: 1;
  min-width: 0;
}

.mine-preview-name {
  display: block;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #0F172A;
}

.mine-preview-expire {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: #64748B;
}

.state-card {
  margin-top: 24rpx;
  padding: 30rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(30, 74, 109, 0.06) 0%, rgba(198, 161, 110, 0.12) 100%);
}

.state-card-light {
  background: #F8FBFC;
}

.state-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #0F172A;
}

.state-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #64748B;
}

.safe-bottom {
  height: calc(32rpx + env(safe-area-inset-bottom));
}
