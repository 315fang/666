/* 优惠券中心 — 2026 青春版 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 42%, #F7F5FF 100%);
}

.scroll {
  min-height: 100vh;
}

/* Hero */
.hero {
  padding: 34rpx 28rpx 0;
  position: relative;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(102, 126, 234, 0.08);
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #667eea;
  font-weight: 600;
  position: relative;
  z-index: 1;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #1c1917;
  position: relative;
  z-index: 1;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  max-width: 620rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #78716c;
  position: relative;
  z-index: 1;
}

.hero-metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  align-items: stretch;
  position: relative;
  z-index: 1;
}

.metric-card {
  flex: 1;
  height: 144rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.06);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.metric-card-main {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  box-shadow: 0 12rpx 28rpx rgba(102, 126, 234, 0.25);
}

.metric-card-main .metric-value,
.metric-card-main .metric-label {
  color: #fff;
}

.metric-value {
  display: block;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 700;
  color: #1c1917;
}

.metric-label {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #78716c;
}

/* 区块 */
.section {
  margin: 28rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.06);
}

.my-section {
  margin-top: 20rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-copy {
  flex: 1;
  min-width: 0;
}

.section-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1c1917;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #78716c;
}

.section-link {
  flex-shrink: 0;
  padding-top: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
}

/* 优惠券列表 */
.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.coupon-card {
  display: flex;
  align-items: stretch;
  border-radius: 26rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.coupon-card-muted {
  opacity: 0.62;
}

.coupon-card-rail {
  width: 16rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
}

.coupon-value-area {
  width: 196rpx;
  padding: 24rpx 12rpx 24rpx 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.coupon-value {
  display: block;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #667eea;
}

.coupon-threshold {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
  text-align: center;
  color: #78716c;
}

.coupon-copy-area {
  flex: 1;
  min-width: 0;
  padding: 24rpx 24rpx 24rpx 10rpx;
}

.coupon-copy-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.coupon-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #1c1917;
}

.coupon-window {
  flex-shrink: 0;
  font-size: 20rpx;
  line-height: 1.5;
  color: #667eea;
}

.coupon-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #78716c;
}

.coupon-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.coupon-meta {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(102, 126, 234, 0.06);
  font-size: 20rpx;
  color: #667eea;
}

.coupon-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.coupon-hint {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.6;
  color: #78716c;
}

.coupon-action {
  flex-shrink: 0;
  min-width: 156rpx;
  padding: 18rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.25);
}

.coupon-action-disabled {
  background: #e2e8f0;
  color: #94a3b8;
  box-shadow: none;
}

/* 我的券包预览 */
.mine-preview-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.mine-preview-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(102, 126, 234, 0.04);
  border: 1rpx solid rgba(102, 126, 234, 0.08);
}

.mine-preview-left {
  width: 168rpx;
  flex-shrink: 0;
}

.mine-preview-value {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #667eea;
}

.mine-preview-threshold {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #78716c;
}

.mine-preview-right {
  flex: 1;
  min-width: 0;
}

.mine-preview-name {
  display: block;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #1c1917;
}

.mine-preview-expire {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: #78716c;
}

/* 状态卡片 */
.state-card {
  margin-top: 24rpx;
  padding: 30rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(102, 126, 234, 0.04);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.state-card-light {
  background: rgba(102, 126, 234, 0.03);
}

.state-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.15);
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #1c1917;
}

.state-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #78716c;
}

.safe-bottom {
  height: calc(32rpx + env(safe-area-inset-bottom));
}
