/* 优惠券兑换 */
.container { min-height: 100vh; background: #f8f7f4; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 24rpx; background: #1e3a5f; }
.nav-back, .nav-placeholder { width: 72rpx; color: #fff; font-size: 40rpx; text-align: center; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #fff; }
.hero-card { margin: 24rpx; padding: 28rpx; background: linear-gradient(135deg, #dc2626, #b91c1c); border-radius: 20rpx; box-shadow: 0 8rpx 20rpx rgba(220,38,38,0.15); }
.hero-title { display: block; font-size: 30rpx; font-weight: 700; color: #fff; }
.hero-sub { display: block; margin-top: 12rpx; font-size: 24rpx; color: rgba(255,255,255,0.85); line-height: 1.6; }
.empty-wrap { padding: 120rpx 40rpx; text-align: center; display: flex; flex-direction: column; align-items: center; }
.loading-spinner { width: 48rpx; height: 48rpx; border: 4rpx solid #fecaca; border-top: 4rpx solid #dc2626; border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 16rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-emoji { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #6b7280; }
.product-list { padding: 0 24rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.product-card {
  display: flex; background: #fff; border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.04);
}
.product-image-wrap { flex-shrink: 0; }
.product-image { width: 200rpx; height: 200rpx; background: #f0f4f8; }
.product-copy { flex: 1; padding: 24rpx; display: flex; flex-direction: column; justify-content: center; }
.product-name { font-size: 28rpx; font-weight: 700; color: #1f2937; }
.product-desc { margin-top: 10rpx; font-size: 22rpx; color: #6b7280; line-height: 1.6; }
.product-action { margin-top: 18rpx; font-size: 24rpx; color: #dc2626; font-weight: 600; }
