.container { min-height: 100vh; background: #F8F9FA; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 24rpx; background: #FFFFFF; }
.nav-back, .nav-placeholder { width: 72rpx; color: #333; font-size: 40rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.hero-card { margin: 24rpx; padding: 28rpx; background: #FFF4F5; border-radius: 20rpx; }
.hero-title { display: block; font-size: 30rpx; font-weight: 700; color: #1A1A1A; }
.hero-sub { display: block; margin-top: 12rpx; font-size: 24rpx; color: #8C6B6B; line-height: 1.6; }
.empty-wrap { padding: 120rpx 40rpx; text-align: center; }
.empty-text { font-size: 28rpx; color: #8A8A8A; }
.product-list { padding: 0 24rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.product-card { display: flex; background: #FFFFFF; border-radius: 20rpx; overflow: hidden; }
.product-image { width: 200rpx; height: 200rpx; background: #F1F5F9; }
.product-copy { flex: 1; padding: 24rpx; display: flex; flex-direction: column; justify-content: center; }
.product-name { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.product-desc { margin-top: 10rpx; font-size: 22rpx; color: #7A7A7A; line-height: 1.6; }
.product-action { margin-top: 18rpx; font-size: 24rpx; color: #C15555; font-weight: 600; }
