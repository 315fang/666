/* 优惠券兑换 — 2026 青春版 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 42%, #F7F5FF 100%);
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: rgba(15, 15, 35, 0.85);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.nav-back,
.nav-placeholder {
  width: 72rpx;
  color: #fff;
  font-size: 40rpx;
  text-align: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.hero-card {
  margin: 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(102, 126, 234, 0.2);
}

.hero-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

.empty-wrap {
  padding: 120rpx 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.15);
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.empty-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #78716c;
}

.product-list {
  padding: 0 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  display: flex;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.product-image-wrap {
  flex-shrink: 0;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  background: rgba(102, 126, 234, 0.04);
}

.product-copy {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.product-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1c1917;
}

.product-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #78716c;
  line-height: 1.6;
}

.product-action {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
}
