.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E3EDF4 0%, #F4F8FA 32%, #EDF5F2 100%);
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.search-section {
  position: sticky;
  top: 0;
  z-index: 10;
  padding-bottom: 18rpx;
  background: linear-gradient(180deg, #E3EDF4 0%, rgba(227, 237, 244, 0.92) 100%);
}

.search-box {
  height: 84rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 8rpx 20rpx rgba(35, 27, 20, 0.04);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 84rpx;
  font-size: 26rpx;
  color: #1F2937;
}

.search-clear {
  flex-shrink: 0;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #64748B;
  background: #F1F5F9;
}

.station-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6rpx 4rpx 18rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #211A15;
}

.summary-count {
  font-size: 24rpx;
  color: #64748B;
}

.station-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.station-card {
  padding: 24rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid transparent;
  box-shadow: 0 8rpx 20rpx rgba(35, 27, 20, 0.04);
}

.station-card:active {
  opacity: 0.86;
}

.station-card.selected {
  border-color: #3B82F6;
  background: #FFF9F0;
}

.station-card.disabled {
  opacity: 0.64;
}

.station-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.station-title-col {
  flex: 1;
  min-width: 0;
}

.station-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #211A15;
  line-height: 1.4;
}

.station-area {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748B;
  line-height: 1.4;
}

.station-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.stock-badge,
.selected-mark {
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.stock-ok {
  color: #166534;
  background: #DCFCE7;
}

.stock-empty {
  color: #8A8A8A;
  background: #F1F1F1;
}

.selected-mark {
  color: #1D4ED8;
  background: #DBEAFE;
}

.station-address-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(117, 105, 95, 0.08);
}

.info-label {
  flex-shrink: 0;
  min-width: 48rpx;
  font-size: 20rpx;
  color: #B0A090;
}

.station-address {
  flex: 1;
  font-size: 23rpx;
  color: #4B5563;
  line-height: 1.55;
}

.station-info-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.station-info-pill {
  flex: 1;
  min-width: 0;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #F8FAFC;
  border: 1rpx solid rgba(141, 117, 90, 0.12);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-value {
  font-size: 22rpx;
  color: #44382F;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.station-days {
  display: block;
  margin-bottom: 10rpx;
  font-size: 20rpx;
  color: #9A8B7C;
}

.station-rule {
  display: block;
  font-size: 21rpx;
  color: #2563EB;
}

.empty-state {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #334155;
}

.empty-desc {
  font-size: 24rpx;
  color: #94A3B8;
}
