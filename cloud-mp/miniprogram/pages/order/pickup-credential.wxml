<view class="wrap" wx:if="{{info}}">
  <view class="card">
    <text class="status" wx:if="{{info.status === 'shipped'}}">已发货，可到店核销</text>
    <text class="status warn" wx:elif="{{info.verified_at}}">已核销</text>
    <text class="status warn" wx:else>请等待商家发货后再到店核销</text>
    <text class="no">订单号 {{info.order_no}}</text>
  </view>

  <view class="card notice-card" wx:if="{{info.pickupStation}}">
    <text class="title">核销限制</text>
    <text class="notice-strong">仅限「{{info.pickupStation.name}}」门店核销</text>
    <text class="txt sub">请前往下单时选择的自提门店出示二维码或核销码，其他门店无法代核销。</text>
  </view>

  <view class="card" wx:if="{{info.pickupStation}}">
    <text class="title">自提门店</text>
    <text class="txt">{{info.pickupStation.name}}</text>
    <text class="txt sub">{{info.pickupStation.city}} {{info.pickupStation.address || ''}}</text>
    <text class="txt sub" wx:if="{{info.pickupStation.contact_phone}}">电话 {{info.pickupStation.contact_phone}}</text>
    <text class="txt sub" wx:if="{{info.pickupStation.business_time_start && info.pickupStation.business_time_end}}">营业时间 {{info.pickupStation.business_time_start}} - {{info.pickupStation.business_time_end}}</text>
  </view>

  <view class="card" wx:if="{{info.pickup_code}}">
    <text class="title">核销码（16位）</text>
    <text class="code">{{info.pickup_code}}</text>
    <button class="btn ghost" bindtap="onCopyCode">复制核销码</button>
  </view>

  <view class="card" wx:if="{{info.pickup_qr_data_url}}">
    <text class="title">核销二维码（请向店员出示）</text>
    <image class="qr" src="{{info.pickup_qr_data_url}}" mode="widthFix" />
  </view>
</view>

<view class="empty" wx:elif="{{!loading}}">加载失败或无权查看</view>
