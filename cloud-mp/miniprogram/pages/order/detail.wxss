/* pages/order/detail.wxss */
.container {
  padding: 20rpx 24rpx;
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #E3EDF4 0%, #F4F8FA 30%, #EDF5F2 100%);
  min-height: 100vh;
}

.order-bubble {
  position: sticky;
  top: 12rpx;
  z-index: 20;
  margin-bottom: 18rpx;
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.order-bubble-show {
  opacity: 1;
  transform: translateY(0);
}

.order-bubble-hide {
  opacity: 0;
  transform: translateY(-10rpx);
}

.order-bubble-inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(30, 74, 109, 0.92);
  border-radius: 999rpx;
  padding: 14rpx 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(30, 74, 109, 0.2);
}

.order-bubble-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2563EB;
}

.order-bubble-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.88);
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #1E4A6D 0%, #2E6B94 100%);
  border-radius: 28rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.status-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
}

.status-pending { background: linear-gradient(135deg, #60A5FA 0%, #2563EB 100%); }
.status-paid { background: linear-gradient(135deg, #2E6B94 0%, #1E4A6D 100%); }
.status-shipped { background: linear-gradient(135deg, #0F766E 0%, #14B8A6 100%); }
.status-completed { background: linear-gradient(135deg, #047857 0%, #10B981 100%); }
.status-agent_confirmed { background: linear-gradient(135deg, #334155 0%, #475569 100%); }
.status-shipping_requested { background: linear-gradient(135deg, #CA8A04 0%, #D4A84B 100%); }
.status-cancelled { background: linear-gradient(135deg, #64748B 0%, #475569 100%); }
.status-refunding { background: linear-gradient(135deg, #B45309 0%, #D97706 100%); }
.status-refund_completed { background: linear-gradient(135deg, #0D9488 0%, #0F766E 100%); }
.status-refund_rejected { background: linear-gradient(135deg, #B91C1C 0%, #DC2626 100%); }

/* 卡片 */
.card {
  background: rgba(255,255,255,0.94);
  border-radius: 28rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(30, 74, 109, 0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #241D18;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(117, 105, 95, 0.08);
}

/* 商品行 */
.product-row {
  display: flex;
  gap: 20rpx;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.product-img-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 22rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.product-name {
  font-size: 28rpx;
  color: #241D18;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.55;
  margin-bottom: 12rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #B95E46;
  margin-bottom: 6rpx;
}

.product-qty {
  font-size: 24rpx;
  color: #9A8D80;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #9A8D80;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #2C241D;
  text-align: right;
  max-width: 420rpx;
  line-height: 1.7;
}

.info-value.info-muted {
  color: #A09080;
  font-size: 24rpx;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.copy-btn {
  font-size: 22rpx;
  color: #2563EB;
  background: #EFF6FF;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #BFDBFE;
}

.price-value-strong {
  color: #B95E46;
  font-weight: 700;
  font-size: 34rpx;
}

.product-card,
.info-card {
  overflow: hidden;
}

.activity-card {
  border: 1rpx solid rgba(37, 99, 235, 0.12);
}

.activity-card-group {
  background: linear-gradient(135deg, #EFF6FF 0%, rgba(255,255,255,0.96) 70%);
}

.activity-card-slash {
  background: linear-gradient(135deg, #FFF7ED 0%, rgba(255,255,255,0.96) 70%);
}

.activity-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.activity-label {
  display: inline-flex;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(15, 23, 42, 0.08);
  color: #334155;
  font-size: 20rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.activity-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
}

.activity-status {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #0F172A;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
}

.activity-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748B;
  margin-bottom: 20rpx;
}

.activity-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  background: #2563EB;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.activity-action-disabled {
  background: #E2E8F0;
  color: #64748B;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.96);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: flex-end;
  box-shadow: 0 -8rpx 24rpx rgba(31, 25, 20, 0.06);
}

.bar-action-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.bar-action-row {
  width: 100%;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.bar-action-row.single {
  justify-content: flex-end;
}

.bar-action-link-row {
  width: 100%;
  display: flex;
  justify-content: flex-end;
}

.btn-primary {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #fff;
  padding: 0 34rpx;
  min-height: 76rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-soft {
  background: #EFF6FF;
  color: #2563EB;
  padding: 0 34rpx;
  min-height: 76rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 2rpx solid #BFDBFE;
  white-space: nowrap;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-outline {
  background: #fff;
  color: #475569;
  padding: 0 34rpx;
  min-height: 76rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 2rpx solid #BFDBFE;
  white-space: nowrap;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-text-link {
  font-size: 24rpx;
  color: #64748B;
  padding: 8rpx 4rpx;
  line-height: 1.2;
}

/* 商品图片占位 icon */
.placeholder-icon { width: 56rpx; height: 56rpx; opacity: 0.3; }

/* 加载/失败容器 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F0EBE3;
  border-top-color: #2563EB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text { font-size: 26rpx; color: #9A8D80; }

@keyframes spin { to { transform: rotate(360deg); } }

.error-container { gap: 20rpx; }
.error-icon { width: 80rpx; height: 80rpx; opacity: 0.4; }
.error-text { font-size: 28rpx; color: #9A8D80; }
.retry-btn { background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%); color: #fff; font-size: 26rpx; padding: 16rpx 48rpx; border-radius: 40rpx; margin-top: 8rpx; }

/* 订单进度条 */
.progress-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.94);
  border-radius: 28rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(30, 74, 109, 0.08);
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  z-index: 2;
}

.step-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #E7E5E4;
  border: 4rpx solid #E7E5E4;
  transition: all 0.3s ease;
}

.progress-step.active .step-dot {
  background: #2563EB;
  border-color: #2563EB;
  box-shadow: 0 0 0 6rpx rgba(37, 99, 235, 0.18);
  transform: scale(1.1);
}

.progress-step.done .step-dot {
  background: #60A5FA;
  border-color: #60A5FA;
}

.step-label {
  font-size: 22rpx;
  color: #94A3B8;
  white-space: nowrap;
}

.progress-step.active .step-label {
  color: #2563EB;
  font-weight: 600;
}

.progress-step.done .step-label {
  color: #3B82F6;
  font-weight: 500;
}

.progress-line {
  flex: 1;
  min-width: 20rpx;
  height: 4rpx;
  background: #E7E5E4;
  margin: 0 8rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.progress-line.done {
  background: #60A5FA;
}

/* 佣金结算卡片 */
.settlement-card {
  background: #EFF6FF !important;
  border: 1rpx solid rgba(59, 130, 246, 0.24);
}

.settlement-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.settlement-icon {
  font-size: 36rpx;
}

.settlement-text {
  font-size: 26rpx;
  color: #2563EB;
}

/* 退款信息样式 */
.card-title-danger { color: #DC2626; }
.info-value-danger { color: #DC2626; }
.refund-link { color: #2563EB; font-size: 28rpx; }

.pickup-hint {
  font-size: 26rpx;
  color: #78716c;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}
.pickup-btn {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
}

/* 支付方式标签 */
.payment-method-tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  align-items: center;
}
.payment-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 600;
}
.payment-tag-wallet { background: #FEF3C7; color: #B45309; }
.payment-tag-wechat { background: #DCFCE7; color: #15803D; }
.payment-tag-free   { background: #F3F4F6; color: #6B7280; }
.payment-tag-points { background: #EDE9FE; color: #6D28D9; }
.payment-tag-coupon { background: #FEE2E2; color: #B91C1C; }

/* 货款余额支付（代理商待付款） */
.wallet-pay-hint {
  font-size: 22rpx;
  color: #B98B58;
  text-align: center;
  margin-bottom: 12rpx;
  font-weight: 600;
}
.btn-wallet {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #C8973A, #D4A55A);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 44rpx;
}
.btn-primary-ghost {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #1A73E8;
  color: #1A73E8;
  font-size: 26rpx;
  border-radius: 40rpx;
  background: transparent;
}
