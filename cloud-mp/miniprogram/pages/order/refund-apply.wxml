<!--pages/order/refund-apply.wxml - 申请退款-->
<view class="container">
  <!-- 订单信息 -->
  <view class="order-card" wx:if="{{order}}">
    <view class="section-title section-title-inline">订单商品</view>
    <view class="order-summary">
      <text class="product-price">订单合计 ¥{{order.display_pay_amount}} / 共 {{order.quantity}} 件</text>
      <text class="product-price">已退 ¥{{order.display_refunded_cash_total || '0.00'}} / 剩余可退 ¥{{order.display_remaining_refundable_cash || order.display_pay_amount}}</text>
    </view>
    <view class="bundle-refund-tip" wx:if="{{bundleOrder}}">
      <text>组合订单仅支持整套退款，已自动锁定整套商品。</text>
    </view>
    <view class="refund-item-list">
      <view class="refund-item-card" wx:for="{{refundItems}}" wx:key="refund_item_key">
        <view class="refund-item-head">
          <image class="product-img" src="{{item.product && item.product.images && item.product.images[0] || item.product && item.product.image || ''}}" mode="aspectFill" wx:if="{{item.product && ((item.product.images && item.product.images.length > 0) || item.product.image)}}"></image>
          <view class="product-info">
            <text class="product-name">{{item.product && item.product.name || item.name || '商品'}}</text>
            <text class="product-spec" wx:if="{{item.sku && item.sku.spec_value}}">{{item.sku.spec_value}}</text>
            <text class="product-price">商品实付 ¥{{item.display_cash_paid_allocated_amount}} / 已退 ¥{{item.display_refunded_cash_amount}}</text>
            <text class="product-price">本次最多可退 ¥{{item.display_refundable_cash_amount}} / 剩余 {{item.refundable_quantity}} 件</text>
          </view>
        </view>
        <view class="qty-row refund-item-qty" wx:if="{{!bundleOrder}}">
          <view class="qty-control">
            <view class="qty-btn {{item.selectedQuantity <= 0 ? 'qty-btn-disabled' : ''}}" bindtap="onRefundQtyMinus" data-index="{{index}}">−</view>
            <input class="qty-input" type="number" value="{{item.selectedQuantity}}" bindinput="onRefundQtyInput" data-index="{{index}}" />
            <view class="qty-btn {{item.selectedQuantity >= item.refundable_quantity ? 'qty-btn-disabled' : ''}}" bindtap="onRefundQtyPlus" data-index="{{index}}">+</view>
          </view>
          <text class="qty-hint">本次退款 ¥{{item.refundAmount || '0.00'}}</text>
        </view>
        <view class="bundle-refund-item-lock" wx:else>
          <text class="qty-hint">整套退款 ¥{{item.refundAmount || '0.00'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退款金额 -->
  <view class="section-title">退款金额</view>
  <view class="amount-row">
    <text class="amount-symbol">¥</text>
    <text class="amount-value">{{amount || '0.00'}}</text>
    <text class="amount-max">按现金实付退回</text>
  </view>

  <view class="section-title">退款类型</view>
  <radio-group bindchange="onTypeChange" class="type-group">
    <label class="type-item {{type === 'refund_only' ? 'active' : ''}}">
      <radio value="refund_only" checked="{{type === 'refund_only'}}" color="#0F172A" />
      <view class="type-info">
        <text class="type-name">仅退款</text>
        <text class="type-desc">无需退货，审核通过后退款</text>
      </view>
    </label>
    <label class="type-item {{type === 'return_refund' ? 'active' : ''}}">
      <radio value="return_refund" checked="{{type === 'return_refund'}}" color="#0F172A" />
      <view class="type-info">
        <text class="type-name">退货退款</text>
        <text class="type-desc">需要寄回商品后退款</text>
      </view>
    </label>
  </radio-group>

  <!-- 退款原因 -->
  <view class="section-title">退款原因</view>
  <picker mode="selector" range="{{reasons}}" range-key="label" value="{{reasonIndex}}" bindchange="onReasonChange">
    <view class="picker-row">
      <text wx:if="{{reasonIndex >= 0}}">{{reasons[reasonIndex].label}}</text>
      <text class="placeholder" wx:else>请选择退款原因</text>
      <text class="arrow">›</text>
    </view>
  </picker>

  <!-- 退款说明 -->
  <view class="section-title">补充说明</view>
  <textarea class="desc-input" placeholder="请简要说明问题" bindinput="onDescInput" value="{{description}}" maxlength="200"></textarea>

  <!-- 退货数量提示（仅退货退款显示） -->
  <view wx:if="{{type === 'return_refund'}}">
    <view class="refund-qty-tip">退货退款将按所选件数恢复库存；仅退款不恢复库存。</view>
  </view>
  <view class="refund-only-tip" wx:if="{{type === 'refund_only'}}">
    <image class="tip-icon-img" src="/assets/icons/info.svg" mode="aspectFit"/>
    <text>仅退款不退货，不恢复库存，审核通过后退款</text>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-bar">
    <button class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交申请'}}
    </button>
  </view>
</view>
