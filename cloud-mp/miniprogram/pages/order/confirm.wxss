.container {
    min-height: 100vh;
    background: linear-gradient(180deg, #E3EDF4 0%, #F4F8FA 28%, #EDF5F2 100%);
    padding: 28rpx 0 160rpx;
}

.checkout-hero {
    padding: 8rpx 28rpx 12rpx;
}

.checkout-title {
    display: block;
    font-size: 46rpx;
    color: #0F172A;
    font-weight: 700;
    margin-bottom: 10rpx;
}

.checkout-subtitle {
    display: block;
    font-size: 24rpx;
    line-height: 1.7;
    color: #64748B;
}

.checkout-assurance-card {
    margin: 0 24rpx 20rpx;
    padding: 24rpx 26rpx;
    border-radius: 28rpx;
    background: rgba(255,255,255,0.86);
    box-shadow: 0 10rpx 24rpx rgba(37, 29, 21, 0.05);
    display: flex;
    justify-content: space-between;
    gap: 12rpx;
}

.assurance-item {
    display: flex;
    align-items: center;
    gap: 10rpx;
}

.assurance-icon {
    width: 28rpx;
    height: 28rpx;
}

.assurance-text {
    font-size: 22rpx;
    color: #63584E;
}

.section {
    background: rgba(255,255,255,0.92);
    margin: 20rpx 24rpx;
    border-radius: 28rpx;
    padding: 28rpx 24rpx;
    box-shadow: 0 8rpx 20rpx rgba(35, 27, 20, 0.04);
}

.order-state-section,
.inline-state-section {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.order-state-title,
.inline-state-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #1F1915;
}

.order-state-desc,
.inline-state-desc {
    font-size: 24rpx;
    line-height: 1.7;
    color: #73675C;
}

.order-state-btn,
.inline-state-btn {
    align-self: flex-start;
    min-width: 176rpx;
    padding: 18rpx 28rpx;
    border-radius: 999rpx;
    border: 1rpx solid rgba(185, 139, 88, 0.35);
    color: #8d6a3f;
    font-size: 24rpx;
    font-weight: 600;
    background: rgba(185, 139, 88, 0.08);
}

.section-head-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18rpx;
}

.bundle-summary-card {
    margin-bottom: 20rpx;
    padding: 20rpx 24rpx;
    border-radius: 20rpx;
    background: linear-gradient(135deg, rgba(185, 139, 88, 0.12), rgba(185, 139, 88, 0.04));
    display: flex;
    flex-direction: column;
    gap: 8rpx;
}

.bundle-summary-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #312821;
}

.bundle-summary-subtitle {
    font-size: 24rpx;
    color: #8F7D6A;
}

.bundle-summary-discount {
    font-size: 24rpx;
    color: #B05A46;
    font-weight: 500;
}

.section-title-text {
    font-size: 28rpx;
    font-weight: 600;
    color: #211A15;
}

.section-link-text,
.section-meta-text {
    font-size: 22rpx;
    color: #9A8B7C;
}

.section-link-row {
    display: flex;
    align-items: center;
    gap: 4rpx;
}

.address-info {
    flex: 1;
}

.address-top {
    display: flex;
    align-items: center;
    gap: 16rpx;
    margin-bottom: 10rpx;
}

.address-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #0F172A;
}

.address-phone,
.address-detail {
    font-size: 26rpx;
    color: #64594F;
}

.address-tag {
    font-size: 20rpx;
    color: #8D755A;
    border: 1rpx solid rgba(141,117,90,0.4);
    border-radius: 999rpx;
    padding: 2rpx 12rpx;
}

.address-empty {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.empty-icon-img {
    width: 36rpx;
    height: 36rpx;
}

.empty-text {
    flex: 1;
    font-size: 28rpx;
    color: #73675C;
}

.arrow {
    font-size: 36rpx;
    color: #B1A598;
    margin-left: 12rpx;
}

.goods-item {
    display: flex;
    gap: 20rpx;
    padding: 20rpx 0;
    border-bottom: 1rpx solid rgba(117, 105, 95, 0.08);
}

.goods-item:last-child {
    border-bottom: none;
}

.goods-image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 20rpx;
    background: #F1ECE6;
    flex-shrink: 0;
}

.goods-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.goods-name {
    font-size: 28rpx;
    color: #1F1915;
    font-weight: 600;
    line-height: 1.5;
}

.goods-spec {
    font-size: 22rpx;
    color: #9A8B7C;
    margin-top: 8rpx;
}

.goods-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10rpx;
}

.goods-price {
    font-size: 30rpx;
    color: #221B16;
    font-weight: 700;
}

.goods-quantity {
    font-size: 24rpx;
    color: #938677;
}

.remark-section,
.coupon-section,
.points-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20rpx;
}

.coupon-section {
    flex-direction: column;
    align-items: stretch;
    gap: 12rpx;
}

.coupon-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16rpx;
    width: 100%;
}

.coupon-label-row {
    display: flex;
    align-items: center;
    gap: 12rpx;
    flex-shrink: 0;
}

.coupon-help-chip {
    font-size: 22rpx;
    font-weight: 600;
    color: #8d6a3f;
    padding: 4rpx 14rpx;
    border-radius: 999rpx;
    border: 1rpx solid rgba(185, 139, 88, 0.4);
}

.remark-label,
.coupon-label,
.points-label {
    font-size: 28rpx;
    color: #312821;
    flex-shrink: 0;
}

.points-right {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.points-balance {
    font-size: 24rpx;
    color: #9A8D80;
}

.points-disabled {
    opacity: 0.5;
}

.points-balance-disabled {
    font-size: 24rpx;
    color: #C0C4CC;
}

.points-detail {
    padding-top: 0 !important;
    padding-bottom: 16rpx !important;
}

.points-deduct-text {
    font-size: 24rpx;
    color: #B98B58;
    font-weight: 500;
}

.points-deduct-tip {
    font-size: 20rpx;
    color: #B0A396;
    margin-left: 8rpx;
}

.benefit-preview-section {
    display: flex;
    flex-direction: column;
    gap: 14rpx;
}

.benefit-preview-head {
    margin-bottom: 0;
}

.benefit-preview-note {
    font-size: 22rpx;
    color: #9A8D80;
}

.benefit-preview-grid {
    display: flex;
    border-top: 1rpx solid rgba(117, 105, 95, 0.1);
    border-bottom: 1rpx solid rgba(117, 105, 95, 0.1);
}

.benefit-preview-item {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
    padding: 16rpx 18rpx 16rpx 0;
}

.benefit-preview-item-split {
    border-left: 1rpx solid rgba(117, 105, 95, 0.1);
    padding-left: 18rpx;
}

.benefit-preview-label {
    font-size: 23rpx;
    line-height: 1.4;
    color: #8A7B6D;
}

.benefit-preview-value {
    font-size: 30rpx;
    line-height: 1.35;
    font-weight: 700;
    color: #B76447;
    word-break: break-all;
}

.benefit-preview-tip {
    font-size: 21rpx;
    line-height: 1.5;
    color: #A89B8E;
}

.growth-preview-section {
    display: flex;
    flex-direction: column;
    gap: 18rpx;
    border: 1rpx solid rgba(15, 118, 110, 0.12);
    background: rgba(255,255,255,0.94);
}

.growth-preview-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20rpx;
}

.growth-preview-title-col {
    flex: 1;
    min-width: 0;
}

.growth-preview-title {
    display: block;
    font-size: 28rpx;
    font-weight: 700;
    color: #173F3A;
}

.growth-preview-summary {
    display: block;
    margin-top: 8rpx;
    font-size: 23rpx;
    line-height: 1.55;
    color: #64748B;
}

.growth-preview-gain {
    flex-shrink: 0;
    min-width: 104rpx;
    padding: 10rpx 18rpx;
    border-radius: 999rpx;
    background: #E8F7F3;
    color: #0F766E;
    font-size: 30rpx;
    line-height: 1.2;
    font-weight: 800;
    text-align: center;
}

.growth-progress-track {
    height: 12rpx;
    border-radius: 999rpx;
    background: #E2E8F0;
    overflow: hidden;
}

.growth-progress-fill {
    height: 100%;
    border-radius: 999rpx;
    background: linear-gradient(90deg, #0F766E 0%, #2E6B94 100%);
}

.growth-preview-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12rpx;
}

.growth-preview-metric {
    min-width: 0;
    padding: 14rpx 16rpx;
    border-radius: 18rpx;
    background: #F8FAFC;
}

.growth-preview-label,
.growth-preview-value {
    display: block;
}

.growth-preview-label {
    font-size: 20rpx;
    line-height: 1.35;
    color: #64748B;
}

.growth-preview-value {
    margin-top: 6rpx;
    font-size: 25rpx;
    line-height: 1.35;
    color: #0F172A;
    font-weight: 700;
    word-break: break-all;
}

.growth-preview-tip {
    font-size: 21rpx;
    line-height: 1.45;
    color: #94A3B8;
}

.remark-input {
    flex: 1;
    font-size: 26rpx;
    text-align: right;
    color: #62584E;
}

.coupon-right {
    display: flex;
    align-items: center;
    gap: 8rpx;
}

.coupon-selected {
    font-size: 24rpx;
    color: #B05A46;
}

.coupon-none {
    font-size: 24rpx;
    color: #9A8D80;
}

.coupon-tip {
    font-size: 22rpx;
    line-height: 1.5;
    color: #B78B58;
}

.coupon-tip-active {
    color: #C45E3D;
}

.coupon-picker {
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    z-index: 10100;
}

.coupon-picker.show {
    display: block;
}

.coupon-picker-mask {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
}

.coupon-picker-panel {
    position: absolute;
    left: 0;
    right: 0;
    /* 抬离系统导航/手势区，避免 Android 上整片被挡在屏幕外 */
    bottom: 0;
    /* 额外留出一段距离：部分 Android 三键导航 safe-area 为 0，仍会被系统条遮挡 */
    padding-bottom: calc(56rpx + constant(safe-area-inset-bottom));
    padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
    background: #fff;
    border-radius: 32rpx 32rpx 0 0;
    padding-top: 32rpx;
    padding-left: 24rpx;
    padding-right: 24rpx;
    max-height: calc(85vh - constant(safe-area-inset-bottom));
    max-height: calc(85vh - env(safe-area-inset-bottom));
    min-height: 360rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
}

.coupon-picker-scroll {
    flex: 1;
    min-height: 240rpx;
    max-height: 58vh;
    width: 100%;
    box-sizing: border-box;
    overflow-x: hidden;
}

.coupon-picker-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #201A15;
    text-align: center;
    margin-bottom: 28rpx;
}

.coupon-list {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.coupon-picker-empty {
    text-align: center;
    color: #9A8D80;
    font-size: 24rpx;
    padding: 56rpx 0;
}

.coupon-card {
    display: flex;
    align-items: center;
    border: 2rpx solid #EEE7DF;
    border-radius: 20rpx;
    overflow: hidden;
    position: relative;
}

.coupon-card.active {
    border-color: #B99265;
    background: #FBF6EE;
}

.coupon-card-left {
    width: 180rpx;
    background: #FBF2E8;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24rpx 16rpx;
    flex-shrink: 0;
}

.coupon-value {
    font-size: 36rpx;
    font-weight: 700;
    color: #B76447;
}

.coupon-min {
    font-size: 20rpx;
    color: #A09080;
    margin-top: 6rpx;
}

.coupon-card-right {
    flex: 1;
    padding: 20rpx;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
}

.coupon-name-text {
    font-size: 28rpx;
    font-weight: 500;
    color: #201A15;
}

.coupon-expire {
    font-size: 22rpx;
    color: #9E9286;
}

.coupon-check {
    position: absolute;
    right: 20rpx;
    top: 50%;
    transform: translateY(-50%);
    width: 44rpx;
    height: 44rpx;
    background: #8D755A;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.coupon-no-use {
    text-align: center;
    font-size: 26rpx;
    color: #9A8D80;
    padding: 20rpx 0;
}

.bottom-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255,255,255,0.96);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18rpx 24rpx;
    padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
    box-shadow: 0 -8rpx 24rpx rgba(31, 25, 20, 0.06);
    z-index: 100;
}

.total-lines {
    display: flex;
    flex-direction: column;
    gap: 4rpx;
}

.total-row {
    display: flex;
    align-items: baseline;
}

.discount-label,
.total-label {
    font-size: 24rpx;
    color: #9A8D80;
}

.discount-amount {
    font-size: 26rpx;
    color: #B76447;
    font-weight: 500;
}

.shipping-amount {
    font-size: 26rpx;
    color: #55725F;
    font-weight: 500;
}

.shipping-row { opacity: 0.8; }

.total-price {
    font-size: 40rpx;
    font-weight: 700;
    color: #201A15;
    margin-left: 8rpx;
}

.submit-btn {
    min-width: 220rpx;
    height: 84rpx;
    padding: 0 32rpx;
    border-radius: 999rpx;
    background: linear-gradient(135deg, #1F1B17 0%, #3A3027 100%);
    color: #fff;
    font-size: 28rpx;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
}

.submit-btn.disabled {
    opacity: 0.5;
}

.success-popup {
  position: fixed;
  inset: 0;
  z-index: 999;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.success-popup.show {
  visibility: visible;
  opacity: 1;
}

.success-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
}

.success-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-popup.show .success-content {
  transform: translate(-50%, -50%) scale(1);
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: #F2E9DE;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.success-icon-img {
  width: 58rpx;
  height: 58rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #201A15;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #72675D;
  margin-bottom: 60rpx;
  text-align: center;
}

.success-btns {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary,
.btn-outline {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: #1F1B17;
  color: #fff;
}

.btn-outline {
  background: #fff;
  border: 2rpx solid #E5DED6;
  color: #6A5F55;
}

/* 自提 / 配送方式 */
.delivery-seg {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.delivery-seg-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #6A5F55;
  background: #F3EDE6;
  border: 2rpx solid transparent;
}

.delivery-seg-item.active {
  color: #1F1B17;
  font-weight: 600;
  background: #FFF9F0;
  border-color: #3B82F6;
}

.delivery-seg-item-disabled {
  opacity: 0.45;
}

.delivery-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9A8B7C;
  line-height: 1.5;
}

.delivery-hint-muted {
  color: #B0A090;
}

.address-optional .empty-text {
  color: #9A8B7C;
}

.pickup-selected-card {
  padding: 24rpx 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #FFFCF8 0%, #F8F3EC 100%);
  border: 2rpx solid #3B82F6;
  box-shadow: 0 8rpx 18rpx rgba(42, 32, 23, 0.05);
}

.pickup-selected-card:active {
  opacity: 0.86;
}

.pickup-row-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
  gap: 16rpx;
}

.pickup-title-col {
  flex: 1;
  min-width: 0;
}

.pickup-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #211A15;
  line-height: 1.4;
}

.pickup-row-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.pickup-stock-badge {
  min-width: 72rpx;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.stock-ok {
  color: #166534;
  background: #DCFCE7;
}

.stock-empty {
  color: #8A8A8A;
  background: #F1F1F1;
}

.pickup-addr {
  flex: 1;
  font-size: 22rpx;
  color: #74695F;
  line-height: 1.55;
}

.pickup-address-block {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(117, 105, 95, 0.08);
}

.pickup-info-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.pickup-info-pill {
  flex: 1;
  min-width: 0;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(141, 117, 90, 0.12);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pickup-info-label {
  flex-shrink: 0;
  min-width: 48rpx;
  font-size: 20rpx;
  color: #B0A090;
}

.pickup-info-value {
  font-size: 22rpx;
  color: #44382F;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.pickup-business-days {
  display: block;
  margin-bottom: 10rpx;
  font-size: 20rpx;
  color: #9A8B7C;
}

.pickup-rule {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #2563EB;
}

.pickup-empty-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 22rpx;
  border-radius: 18rpx;
  background: #F8FAFC;
  border: 2rpx dashed #CBD5E1;
}

.pickup-empty-card:active {
  background: #EFF6FF;
}

.pickup-empty-main {
  flex: 1;
  min-width: 0;
}

.pickup-empty-title {
  display: block;
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 600;
}

.pickup-empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #64748B;
}

