/* pages/order/review.wxss */
.review-page {
  padding: 0 0 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.product-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  padding: 28rpx 30rpx;
  margin-bottom: 16rpx;
}

.product-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.reward-tip {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FFFBEB 100%);
  border: 1rpx solid rgba(249, 115, 22, 0.18);
}

.reward-tip-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.reward-tip-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reward-tip-title {
  font-size: 28rpx;
  line-height: 1.4;
  color: #7C2D12;
  font-weight: 700;
}

.reward-tip-sub {
  font-size: 22rpx;
  line-height: 1.5;
  color: #9A3412;
}

.section {
  background: #fff;
  padding: 28rpx 30rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.star-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.star {
  font-size: 52rpx;
  color: #ddd;
  transition: color 0.2s;
}

.star.active {
  color: #f5a623;
}

.rating-label {
  font-size: 26rpx;
  color: #f5a623;
  margin-left: 12rpx;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.content-count {
  text-align: right;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #bbb;
}

.submit-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #60A5FA, #2563EB);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  opacity: 0.6;
}
