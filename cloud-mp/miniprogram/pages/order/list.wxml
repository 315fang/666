<!--pages/order/list.wxml - 订单列表-->
<view class="container">
  <page-loading show="{{loading && orders.length === 0}}" text="订单加载中..."></page-loading>
  <!-- 订单状态Tab -->
  <view class="tabs-wrapper">
    <scroll-view class="tabs-scroll" scroll-x>
      <view class="tab-item {{currentStatus === '' ? 'active' : ''}}"
            bindtap="onTabChange" data-status="">全部</view>
      <view class="tab-item {{currentStatus === 'pending' ? 'active' : ''}}"
            bindtap="onTabChange" data-status="pending">待付款</view>
      <view class="tab-item {{currentStatus === 'paid' ? 'active' : ''}}"
            bindtap="onTabChange" data-status="paid">待发货</view>
      <view class="tab-item {{currentStatus === 'shipped' ? 'active' : ''}}"
            bindtap="onTabChange" data-status="shipped">待收货</view>
      <view class="tab-item {{currentStatus === 'pending_review' ? 'active' : ''}}"
            bindtap="onTabChange" data-status="pending_review">待评价</view>
      <view class="tab-item {{currentStatus === 'completed' ? 'active' : ''}}"
            bindtap="onTabChange" data-status="completed">已完成</view>
      <view class="tab-item {{currentStatus === 'refund' ? 'active' : ''}}"
            bindtap="onTabChange" data-status="refund">退款/售后</view>
    </scroll-view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="order-list" scroll-y bindscrolltolower="onLoadMore">
    <!-- 列表容器 -->
    <view class="order-list-container">
      
      <!-- 骨架屏 - 加载时显示 -->
      <view class="skeleton-wrapper" wx:if="{{loading && orders.length === 0}}">
        <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="index">
          <view class="skeleton-header">
            <view class="skeleton-line short"></view>
            <view class="skeleton-line tiny"></view>
          </view>
          <view class="skeleton-body">
            <view class="skeleton-img"></view>
            <view class="skeleton-info">
              <view class="skeleton-line"></view>
              <view class="skeleton-line short"></view>
            </view>
          </view>
          <view class="skeleton-footer">
            <view class="skeleton-line short"></view>
            <view class="skeleton-btn"></view>
          </view>
        </view>
      </view>
      
      <!-- 真实订单列表 -->
      <view class="order-card {{item.animateIn ? 'card-fade-in' : ''}}" wx:for="{{orders}}" wx:key="id" style="animation-delay: {{index * 100}}ms">
      <!-- 订单头部 -->
      <view class="order-header">
        <text class="order-no">{{item.order_no}}</text>
        <text class="order-status {{item.displayStatus || item.status}} {{item.hasActiveRefund ? 'refunding' : ''}}">{{item.statusText}}</text>
      </view>
      <!-- 待付款倒计时 -->
      <view class="order-countdown" wx:if="{{item.status === 'pending' && item.countdownText}}">
        <text class="countdown-text">剩余 {{item.countdownText}}</text>
      </view>
      <view class="activity-strip activity-strip-{{item.activityInfo.type}}" wx:if="{{item.activityInfo}}">
        <text class="activity-strip-label">{{item.activityInfo.label}}订单</text>
        <text class="activity-strip-text" wx:if="{{item.activityInfo.type === 'group' && !item.activityInfo.targetNo}}">支付成功后生成拼团进度</text>
        <text class="activity-strip-text" wx:else>可继续查看活动状态</text>
      </view>

      <!-- 商品信息 -->
      <view class="order-products" bindtap="onOrderTap" data-order="{{item}}">
        <view class="order-product" wx:if="{{item.product}}">
          <image class="product-image" src="{{item.product.images[0] || ''}}" mode="aspectFill" wx:if="{{item.product.images && item.product.images.length > 0}}"></image>
          <view class="product-image product-image-placeholder" wx:else>
            <image class="placeholder-icon" src="/assets/icons/package.svg" mode="aspectFit"/>
          </view>
          <view class="product-info">
            <text class="product-name">{{item.product.name || '商品名称'}}</text>
            <text class="product-spec" wx:if="{{item.sku && item.sku.spec_value}}">{{item.sku.spec_value}}</text>
            <view class="product-price-qty">
              <text class="product-price">¥{{item.price || item.total_amount}}</text>
              <text class="product-qty">x{{item.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <view class="order-total">
          <text class="total-label">共{{item.quantity}}件 实付:</text>
          <text class="total-amount">¥{{item.total_amount}}</text>
          <text class="fulfillment-tag" wx:if="{{item.fulfillment_type === 'Agent'}}">团队发货</text>
        </view>
        <view class="order-actions">
          <!-- ★ 有活跃退款时：只显示"查看退款" -->
          <block wx:if="{{item.hasActiveRefund}}">
            <view class="action-row single">
              <view class="btn btn-sm btn-primary"
                    catchtap="onViewRefund" data-order="{{item}}">查看退款</view>
            </view>
          </block>

          <!-- ★ 无活跃退款时：正常按钮逻辑 -->
          <block wx:else>
            <view class="action-row single" wx:if="{{item.activityInfo}}">
              <view class="btn btn-sm btn-soft {{item.activityInfo.disabled ? 'btn-disabled' : ''}}"
                    catchtap="onViewActivity" data-order="{{item}}">{{item.activityInfo.actionText}}</view>
            </view>
            <!-- 待付款 -->
            <block wx:if="{{item.status === 'pending'}}">
              <view class="action-row">
                <view class="btn btn-sm btn-ghost"
                      catchtap="onCancelOrder" data-order="{{item}}">取消订单</view>
                <view class="btn btn-sm btn-primary"
                      catchtap="onPayOrder" data-order="{{item}}">去付款</view>
              </view>
            </block>
            
            <!-- 待发货：仅已支付未进入代理履约流程时可申请退款 -->
            <block wx:if="{{item.status === 'paid'}}">
              <view class="action-row single">
                <view class="btn btn-sm btn-ghost"
                      catchtap="onApplyRefund" data-order="{{item}}">申请退款</view>
              </view>
            </block>

            <!-- 待收货：主次分层 -->
            <block wx:if="{{item.status === 'shipped'}}">
              <view class="action-link-row" wx:if="{{!item.reviewed}}">
                <view class="action-link"
                      catchtap="onGoReview" data-order="{{item}}">评价</view>
              </view>
              <view class="action-row single" wx:if="{{item.tracking_no}}">
                <view class="btn btn-sm btn-soft"
                      catchtap="onViewLogistics" data-order="{{item}}">查看物流</view>
              </view>
              <view class="action-row">
                <view class="btn btn-sm btn-ghost"
                      catchtap="onApplyRefund" data-order="{{item}}">申请退款</view>
                <view class="btn btn-sm btn-primary"
                      catchtap="onConfirmReceive" data-order="{{item}}">确认收货</view>
              </view>
            </block>

            <!-- 已完成 -->
            <block wx:if="{{item.status === 'completed'}}">
              <view class="action-link-row" wx:if="{{!item.reviewed}}">
                <view class="action-link"
                      catchtap="onGoReview" data-order="{{item}}">评价晒单</view>
              </view>
              <view class="action-row" wx:if="{{item.tracking_no}}">
                <view class="btn btn-sm btn-soft"
                      catchtap="onViewLogistics" data-order="{{item}}">查看物流</view>
                <view class="btn btn-sm btn-primary"
                      catchtap="onBuyAgain" data-order="{{item}}">再次购买</view>
              </view>
              <view class="action-row single" wx:else>
                <view class="btn btn-sm btn-primary"
                      catchtap="onBuyAgain" data-order="{{item}}">再次购买</view>
              </view>
            </block>
            
            <!-- 退款Tab中已完成的退款 -->
            <block wx:if="{{item.displayStatus === 'refund_completed' || item.displayStatus === 'refund_rejected' || item.displayStatus === 'refund_cancelled'}}">
              <view class="action-row single">
                <view class="btn btn-sm btn-primary"
                      catchtap="onViewRefund" data-order="{{item}}">查看详情</view>
              </view>
            </block>
          </block>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{orders.length > 0}}">
      <text wx:if="{{hasMore}}">上拉加载更多</text>
      <text wx:else>没有更多订单了</text>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{!loading && orders.length === 0}}">
      <image src="/assets/icons/clipboard.svg" style="width:80rpx;height:80rpx;margin-bottom:16rpx;" mode="aspectFit"></image>
      <text class="empty-text">暂无订单</text>
      <navigator url="/pages/index/index" open-type="switchTab" class="btn btn-primary btn-sm">
        去逛逛
      </navigator>
    </view>

    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>
    </view>
  </scroll-view>
</view>
