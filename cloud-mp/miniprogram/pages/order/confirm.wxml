<view class="container">
  <view class="checkout-hero">
    <text class="checkout-title">确认本次选购</text>
    <text class="checkout-subtitle">核对收货地址与商品信息</text>
  </view>

  <view class="checkout-assurance-card">
    <view class="assurance-item">
      <image class="assurance-icon" src="/assets/icons/shield.svg" mode="aspectFit"></image>
      <text class="assurance-text">官方正品</text>
    </view>
    <view class="assurance-item">
      <image class="assurance-icon" src="/assets/icons/package.svg" mode="aspectFit"></image>
      <text class="assurance-text">精致包装</text>
    </view>
    <view class="assurance-item">
      <image class="assurance-icon" src="/assets/icons/headphones.svg" mode="aspectFit"></image>
      <text class="assurance-text">安心售后</text>
    </view>
  </view>

  <!-- 配送方式：始终展示；商品均未开启自提时「到店自提」为禁用态 -->
  <view class="section delivery-section">
    <view class="section-head-row">
      <text class="section-title-text">配送方式</text>
    </view>
    <view class="delivery-seg">
      <view
        class="delivery-seg-item {{deliveryType === 'express' ? 'active' : ''}}"
        data-type="express"
        bindtap="onDeliveryTypeChange"
      >快递配送</view>
      <view
        class="delivery-seg-item {{deliveryType === 'pickup' ? 'active' : ''}} {{pickupAllowed ? '' : 'delivery-seg-item-disabled'}}"
        data-type="pickup"
        bindtap="onDeliveryTypeChange"
      >到店自提</view>
    </view>
    <text class="delivery-hint" wx:if="{{deliveryType === 'express'}}">{{pickupAllowed ? '商品将邮寄至下方收货地址；需要到店取货可切换为「到店自提」。' : '商品将邮寄至下方收货地址。'}}</text>
    <text class="delivery-hint delivery-hint-muted" wx:if="{{!pickupAllowed}}">当前订单中的商品不支持到店自提。若需自提，请选购支持到店自提的商品，或咨询客服。</text>
    <text class="delivery-hint" wx:if="{{pickupAllowed && deliveryType === 'pickup'}}">自提免运费；可选填联系地址便于售后。可用当前位置推荐附近门店，也可用「地图选点」修正。</text>
    <view class="pickup-map-link" wx:if="{{pickupAllowed && deliveryType === 'pickup'}}" bindtap="onOpenStationsMap">
      <text class="pickup-map-link-text">查看全部门店地图</text>
    </view>
  </view>

  <!-- 快递：必须收货地址 -->
  <block wx:if="{{deliveryType === 'express'}}">
    <view class="section address-section" bindtap="onSelectAddress" wx:if="{{address}}">
      <view class="section-head-row">
        <text class="section-title-text">收货信息</text>
        <view class="section-link-row">
          <text class="section-link-text">切换</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="address-info">
        <view class="address-top">
          <text class="address-name">{{address.receiver_name}}</text>
          <text class="address-phone">{{address.phone}}</text>
          <text class="address-tag" wx:if="{{address.is_default}}">默认</text>
        </view>
        <view class="address-detail">{{address.province}} {{address.city}} {{address.district}} {{address.detail}}</view>
      </view>
    </view>
    <view class="section address-empty" bindtap="onAddAddress" wx:else>
      <image class="empty-icon-img" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
      <text class="empty-text">请添加收货地址</text>
      <text class="arrow">›</text>
    </view>
  </block>

  <!-- 自提：联系地址选填 -->
  <block wx:else>
    <view class="section address-section" bindtap="onSelectAddress" wx:if="{{address}}">
      <view class="section-head-row">
        <text class="section-title-text">联系地址（选填）</text>
        <view class="section-link-row">
          <text class="section-link-text">切换</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="address-info">
        <view class="address-top">
          <text class="address-name">{{address.receiver_name}}</text>
          <text class="address-phone">{{address.phone}}</text>
        </view>
        <view class="address-detail">{{address.province}} {{address.city}} {{address.district}} {{address.detail}}</view>
      </view>
    </view>
    <view class="section address-empty address-optional" bindtap="onAddAddress" wx:else>
      <image class="empty-icon-img" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
      <text class="empty-text">添加联系地址（选填）</text>
      <text class="arrow">›</text>
    </view>
  </block>

  <!-- 自提门店 -->
  <view class="section pickup-section" wx:if="{{deliveryType === 'pickup'}}">
    <view class="section-head-row">
      <text class="section-title-text">自提门店</text>
    </view>
    <view class="pickup-loc-btns">
      <button class="pickup-loc-btn" size="mini" bindtap="onLocateForPickupSort">使用当前位置</button>
      <button class="pickup-loc-btn ghost" size="mini" bindtap="onChooseRefLocation">地图选点</button>
      <button class="pickup-loc-btn ghost" size="mini" wx:if="{{refLocationName}}" bindtap="clearRefLocation">清除参考点</button>
    </view>
    <text class="pickup-hint-muted" wx:if="{{pickupDistanceHint}}">未显示距离时列表按城市与名称排序；点「定位排序」或「地图选点」后可显示约 xx km 并优先最近门店。</text>
    <text class="ref-loc-name" wx:if="{{refLocationName}}">参考：{{refLocationName}}</text>
    <view
      class="pickup-row {{pickupStation && pickupStation.id === item.id ? 'pickup-row-active' : ''}}"
      wx:for="{{pickupStations}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onSelectPickupStation"
    >
      <view class="pickup-row-main">
        <text class="pickup-name">{{item.name}}</text>
        <text class="pickup-dist" wx:if="{{item.distance_km != null}}">约 {{item.distance_km}} km</text>
      </view>
      <text class="pickup-addr">{{item.city}} {{item.district || ''}} {{item.address || ''}}</text>
      <text class="pickup-rule">仅该门店人员可核销本订单</text>
    </view>
    <text class="pickup-empty" wx:if="{{pickupStations.length === 0}}">暂无可用自提点，请稍后再试或联系客服</text>
    <view class="pickup-notice-card" wx:if="{{pickupStation}}">
      <text class="pickup-notice-title">已选自提门店</text>
      <text class="pickup-notice-name">{{pickupStation.name}}</text>
      <text class="pickup-notice-desc">提交订单后，仅限该门店工作人员完成核销，请勿前往其他门店自提。</text>
    </view>
  </view>

  <view class="section goods-section">
    <view class="section-head-row">
      <text class="section-title-text">商品摘要</text>
      <text class="section-meta-text">共 {{totalCount}} 件</text>
    </view>
    <view class="goods-item" wx:for="{{orderItems}}" wx:key="product_id">
      <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
        <view class="goods-bottom">
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-quantity">×{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section remark-section">
    <text class="remark-label">订单备注</text>
    <input class="remark-input" placeholder="选填，可留言给卖家" value="{{remark}}" bindinput="onRemarkInput" maxlength="100" />
  </view>

  <view class="section coupon-section">
    <view class="coupon-top" bindtap="onCouponTap">
      <view class="coupon-label-row">
        <text class="coupon-label">礼遇与优惠</text>
        <text class="coupon-help-chip" catchtap="onCouponHelpTap">说明</text>
      </view>
      <view class="coupon-right">
        <text class="coupon-selected" wx:if="{{selectedCoupon}}">-¥{{couponDiscount}}（{{selectedCoupon.coupon_name}}）</text>
        <text class="coupon-none" wx:elif="{{availableCoupons.length > 0}}">{{availableCoupons.length}}张可用</text>
        <text class="coupon-none" wx:else>暂无可用优惠券</text>
        <text class="arrow" wx:if="{{availableCoupons.length > 0}}">›</text>
      </view>
    </view>
    <text class="coupon-tip coupon-tip-active" wx:if="{{!selectedCoupon && availableCoupons.length > 0}}">您有{{availableCoupons.length}}张优惠券可用，点击立即选择</text>
    <text class="coupon-tip" wx:elif="{{!selectedCoupon && unusedCouponCount > 0}}">您有{{unusedCouponCount}}张优惠券不适用于本单（金额/范围不符）</text>
  </view>

  <!-- 积分抵扣 -->
  <view class="section points-section" wx:if="{{pointBalance > 0 && allowPoints}}">
    <text class="points-label">积分抵扣</text>
    <view class="points-right">
      <text class="points-balance">{{pointBalance}}积分可用</text>
      <switch checked="{{usePoints}}" bindchange="onTogglePoints" color="#B98B58" style="transform:scale(0.8)" />
    </view>
  </view>
  <view class="section points-detail" wx:if="{{usePoints && pointBalance > 0 && allowPoints}}">
    <text class="points-deduct-text">使用 {{pointsToUse}} 积分抵扣 ¥{{pointsDeduction}}</text>
    <text class="points-deduct-tip">（{{pointsRuleHint}}）</text>
  </view>
  <view class="section points-section points-disabled" wx:if="{{pointBalance > 0 && !allowPoints}}">
    <text class="points-label">积分抵扣</text>
    <text class="points-balance-disabled">当前商品不支持积分抵扣</text>
  </view>

  <!-- 货款余额支付（代理商专属） -->
  <view class="section points-section wallet-section" wx:if="{{isAgent}}">
    <view class="wallet-label-col">
      <text class="points-label">货款余额支付</text>
      <text class="wallet-balance-sub" wx:if="{{walletBalance > 0}}">可用余额 ¥{{walletBalance}}</text>
      <text class="wallet-balance-sub wallet-balance-empty" wx:else>余额不足，请先充值</text>
    </view>
    <view class="points-right">
      <switch
        checked="{{useWallet}}"
        bindchange="onToggleWallet"
        color="#B98B58"
        disabled="{{walletBalance <= 0}}"
        style="transform:scale(0.8)"
      />
    </view>
  </view>
  <view class="section points-detail" wx:if="{{isAgent && useWallet && walletBalance > 0}}">
    <text class="points-deduct-text">从货款余额扣款，无需微信支付</text>
    <text class="points-deduct-tip">（代理商专属付款方式，余额充值后方可使用）</text>
  </view>

  <view class="coupon-picker {{showCouponPicker ? 'show' : ''}}" wx:if="{{showCouponPicker}}">
    <view class="coupon-picker-mask" bindtap="onCloseCouponPicker"></view>
    <view class="coupon-picker-panel">
      <view class="coupon-picker-title">选择优惠券</view>
      <scroll-view scroll-y class="coupon-picker-scroll" show-scrollbar="{{true}}">
        <view class="coupon-picker-empty" wx:if="{{availableCoupons.length === 0}}">暂无可用优惠券</view>
        <view class="coupon-list" wx:else>
          <view
            class="coupon-card {{selectedCoupon && selectedCoupon.id === item.id ? 'active' : ''}}"
            wx:for="{{availableCoupons}}"
            wx:key="id"
            data-coupon="{{item}}"
            bindtap="onSelectCoupon"
          >
            <view class="coupon-card-left">
              <text class="coupon-value">
                <text wx:if="{{item.coupon_type === 'fixed' || item.coupon_type === 'no_threshold'}}">¥{{item.coupon_value}}</text>
                <text wx:else>{{item.coupon_value * 10}}折</text>
              </text>
              <text class="coupon-min">{{item.min_purchase > 0 ? ('满' + item.min_purchase + '元可用') : '无门槛可用'}}</text>
            </view>
            <view class="coupon-card-right">
              <text class="coupon-name-text">{{item.coupon_name}}</text>
              <text class="coupon-expire">{{item.expire_at_formatted}}到期</text>
            </view>
            <view class="coupon-check" wx:if="{{selectedCoupon && selectedCoupon.id === item.id}}">✓</view>
          </view>
          <view class="coupon-no-use" wx:if="{{selectedCoupon}}" bindtap="onClearCoupon">不使用优惠券</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="total-info">
      <view class="total-lines">
        <view class="total-row shipping-row">
          <text class="discount-label">运费：</text>
          <text class="shipping-amount">{{deliveryType === 'pickup' ? '到店自提' : (shippingFee > 0 ? '¥' + shippingFee : '免运费')}}</text>
        </view>
        <view class="total-row" wx:if="{{selectedCoupon}}">
          <text class="discount-label">优惠券：</text>
          <text class="discount-amount">-¥{{couponDiscount}}</text>
        </view>
        <view class="total-row" wx:if="{{usePoints && pointsDeduction > 0}}">
          <text class="discount-label">积分：</text>
          <text class="discount-amount">-¥{{pointsDeduction}}</text>
        </view>
        <view class="total-row">
          <text class="total-label">合计：</text>
          <text class="total-price">¥{{finalAmount}}</text>
        </view>
        <view class="total-row wallet-pay-tip" wx:if="{{isAgent && useWallet && walletBalance > 0}}">
          <text class="wallet-pay-tag">货款余额支付</text>
        </view>
      </view>
    </view>
    <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
      <text>{{submitting ? '提交中...' : '提交订单'}}</text>
    </view>
  </view>

  <brand-animation id="brandAnimation"></brand-animation>

  <light-tip-modal
    show="{{lightTipShow}}"
    title="{{lightTipTitle}}"
    content="{{lightTipContent}}"
    bind:close="onLightTipClose"
  />

  <view class="success-popup {{showSuccess ? 'show' : ''}}">
    <view class="success-mask"></view>
    <view class="success-content">
      <view class="success-icon">
        <image class="success-icon-img" src="/assets/icons/check-circle.svg" mode="aspectFit"></image>
      </view>
      <text class="success-title">下单成功</text>
      <text class="success-desc">感谢您的信任，我们会尽快为您安排发货</text>
      <view class="success-btns">
        <view class="btn-outline" bindtap="onViewOrder">查看订单</view>
        <view class="btn-primary" bindtap="onBackHome">返回首页</view>
      </view>
    </view>
  </view>
</view>
