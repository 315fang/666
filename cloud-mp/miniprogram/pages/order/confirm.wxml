<view class="container">
  <view class="checkout-hero">
    <text class="checkout-title">确认本次选购</text>
    <text class="checkout-subtitle">核对收货地址与商品信息</text>
  </view>

  <view class="checkout-assurance-card">
    <view class="assurance-item">
      <image class="assurance-icon" src="/assets/icons/shield.svg" mode="aspectFit"></image>
      <text class="assurance-text">官方正品</text>
    </view>
    <view class="assurance-item">
      <image class="assurance-icon" src="/assets/icons/package.svg" mode="aspectFit"></image>
      <text class="assurance-text">精致包装</text>
    </view>
    <view class="assurance-item">
      <image class="assurance-icon" src="/assets/icons/headphones.svg" mode="aspectFit"></image>
      <text class="assurance-text">安心售后</text>
    </view>
  </view>

  <view class="section order-state-section" wx:if="{{cartLoadStatus === 'loading'}}">
    <text class="order-state-title">订单加载中</text>
    <text class="order-state-desc">正在获取订单信息，请稍候。</text>
  </view>
  <view class="section order-state-section" wx:elif="{{cartLoadStatus === 'error'}}">
    <text class="order-state-title">订单加载失败</text>
    <text class="order-state-desc">{{cartLoadError || '订单暂时无法加载，请稍后重试。'}}</text>
    <view class="order-state-btn" bindtap="onRetryCartLoad">重新加载订单</view>
  </view>
  <block wx:else>

  <view class="section benefit-preview-section" wx:if="{{expectedCommissionAmount > 0 || expectedPoints > 0}}">
    <view class="section-head-row benefit-preview-head">
      <text class="section-title-text">本单权益预估</text>
      <text class="benefit-preview-note">支付后结算</text>
    </view>
    <view class="benefit-preview-grid">
      <view class="benefit-preview-item" wx:if="{{expectedCommissionAmount > 0}}">
        <text class="benefit-preview-label">自购预计佣金</text>
        <text class="benefit-preview-value">¥{{expectedCommission}}</text>
      </view>
      <view class="benefit-preview-item {{expectedCommissionAmount > 0 ? 'benefit-preview-item-split' : ''}}" wx:if="{{expectedPoints > 0}}">
        <text class="benefit-preview-label">积分奖励</text>
        <text class="benefit-preview-value">预计可得{{expectedPoints}}积分</text>
      </view>
    </view>
    <text class="benefit-preview-tip">以订单实际支付成功后的结果为准</text>
  </view>

  <!-- 配送方式：始终展示；商品均未开启自提时「到店自提」为禁用态 -->
  <view class="section delivery-section">
    <view class="section-head-row">
      <text class="section-title-text">配送方式</text>
    </view>
    <view class="delivery-seg">
      <view
        class="delivery-seg-item {{deliveryType === 'express' ? 'active' : ''}}"
        data-type="express"
        bindtap="onDeliveryTypeChange"
      >快递配送</view>
      <view
        class="delivery-seg-item {{deliveryType === 'pickup' ? 'active' : ''}} {{pickupAllowed ? '' : 'delivery-seg-item-disabled'}}"
        data-type="pickup"
        bindtap="onDeliveryTypeChange"
      >到店自提</view>
    </view>
    <text class="delivery-hint" wx:if="{{deliveryType === 'express'}}">{{pickupAllowed ? '商品将寄送至下方地址，如需自提可切换到店自提。' : '商品将寄送至下方地址。'}}</text>
    <text class="delivery-hint delivery-hint-muted" wx:if="{{!pickupAllowed}}">该订单商品不支持到店自提。</text>
    <text class="delivery-hint" wx:if="{{pickupAllowed && deliveryType === 'pickup'}}">到店自提免运费，可填写联系地址便于售后。</text>
  </view>

  <!-- 快递：必须收货地址 -->
  <block wx:if="{{deliveryType === 'express'}}">
    <view class="section inline-state-section" wx:if="{{addressLoadStatus === 'loading'}}">
      <text class="inline-state-title">收货信息加载中</text>
      <text class="inline-state-desc">正在获取默认收货地址，请稍候。</text>
    </view>
    <view class="section inline-state-section" wx:elif="{{addressLoadStatus === 'error'}}">
      <text class="inline-state-title">收货信息加载失败</text>
      <text class="inline-state-desc">{{addressLoadError || '地址暂时无法加载，请重试。'}}</text>
      <view class="inline-state-btn" bindtap="onRetryAddressLoad">重试地址</view>
    </view>
    <view class="section address-section" bindtap="onSelectAddress" wx:elif="{{address}}">
      <view class="section-head-row">
        <text class="section-title-text">收货信息</text>
        <view class="section-link-row">
          <text class="section-link-text">切换</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="address-info">
        <view class="address-top">
          <text class="address-name">{{address.receiver_name}}</text>
          <text class="address-phone">{{address.phone}}</text>
          <text class="address-tag" wx:if="{{address.is_default}}">默认</text>
        </view>
        <view class="address-detail">{{address.province}} {{address.city}} {{address.district}} {{address.detail}}</view>
      </view>
    </view>
    <view class="section address-empty" bindtap="onAddAddress" wx:else>
      <image class="empty-icon-img" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
      <text class="empty-text">请添加收货地址</text>
      <text class="arrow">›</text>
    </view>
  </block>

  <!-- 自提：联系地址选填 -->
  <block wx:else>
    <view class="section inline-state-section" wx:if="{{addressLoadStatus === 'loading'}}">
      <text class="inline-state-title">联系地址加载中</text>
      <text class="inline-state-desc">正在获取默认联系地址，请稍候。</text>
    </view>
    <view class="section inline-state-section" wx:elif="{{addressLoadStatus === 'error'}}">
      <text class="inline-state-title">联系地址加载失败</text>
      <text class="inline-state-desc">{{addressLoadError || '地址暂时无法加载，请重试。'}}</text>
      <view class="inline-state-btn" bindtap="onRetryAddressLoad">重试地址</view>
    </view>
    <view class="section address-section" bindtap="onSelectAddress" wx:elif="{{address}}">
      <view class="section-head-row">
        <text class="section-title-text">联系地址（选填）</text>
        <view class="section-link-row">
          <text class="section-link-text">切换</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="address-info">
        <view class="address-top">
          <text class="address-name">{{address.receiver_name}}</text>
          <text class="address-phone">{{address.phone}}</text>
        </view>
        <view class="address-detail">{{address.province}} {{address.city}} {{address.district}} {{address.detail}}</view>
      </view>
    </view>
    <view class="section address-empty address-optional" bindtap="onAddAddress" wx:else>
      <image class="empty-icon-img" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
      <text class="empty-text">添加联系地址（选填）</text>
      <text class="arrow">›</text>
    </view>
  </block>

  <!-- 自提门店 -->
  <view class="section pickup-section" wx:if="{{deliveryType === 'pickup'}}">
    <view class="section-head-row">
      <text class="section-title-text">自提门店</text>
      <view class="section-link-row" bindtap="onChoosePickupStation">
        <text class="section-link-text">{{pickupStation ? '更换' : '选择'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="pickup-selected-card" wx:if="{{pickupStation}}" bindtap="onChoosePickupStation">
      <view class="pickup-row-main">
        <view class="pickup-title-col">
          <text class="pickup-name">{{pickupStation.name}}</text>
        </view>
        <view class="pickup-row-tags">
          <text class="pickup-stock-badge {{pickupStation.pickup_stock_class}}">{{pickupStation.pickup_stock_text}}</text>
        </view>
      </view>
      <view class="pickup-address-block">
        <text class="pickup-info-label">地址</text>
        <text class="pickup-addr">{{pickupStation.full_address || (pickupStation.city + ' ' + (pickupStation.district || '') + ' ' + (pickupStation.address || ''))}}</text>
      </view>
      <view class="pickup-info-grid">
        <view class="pickup-info-pill">
          <text class="pickup-info-label">电话</text>
          <text class="pickup-info-value">{{pickupStation.contact_phone_text}}</text>
        </view>
        <view class="pickup-info-pill">
          <text class="pickup-info-label">营业</text>
          <text class="pickup-info-value">{{pickupStation.business_hours_text}}</text>
        </view>
      </view>
      <text class="pickup-business-days" wx:if="{{pickupStation.business_days_text}}">{{pickupStation.business_days_text}}</text>
      <text class="pickup-rule">提交后仅限该门店核销，请勿前往其他门店。</text>
    </view>
    <view class="pickup-empty-card" wx:else bindtap="onChoosePickupStation">
      <view class="pickup-empty-main">
        <text class="pickup-empty-title">请选择自提门店</text>
        <text class="pickup-empty-desc">进入门店列表后按名称、城市或地址查找，再选择本次自提门店。</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="section goods-section">
    <view class="section-head-row" wx:if="{{bundleOrder && bundleMeta}}">
      <text class="section-title-text">组合信息</text>
      <text class="section-meta-text">固定组合价 ¥{{bundlePrice}}</text>
    </view>
    <view class="bundle-summary-card" wx:if="{{bundleOrder && bundleMeta}}">
      <text class="bundle-summary-title">{{bundleMeta.title}}</text>
      <text class="bundle-summary-subtitle" wx:if="{{bundleMeta.subtitle}}">{{bundleMeta.subtitle}}</text>
      <text class="bundle-summary-discount" wx:if="{{bundleDiscount > 0}}">组合优惠 -¥{{bundleDiscount}}</text>
    </view>
    <view class="section-head-row">
      <text class="section-title-text">商品摘要</text>
      <text class="section-meta-text">共 {{totalCount}} 件</text>
    </view>
    <view class="goods-item" wx:for="{{orderItems}}" wx:key="product_id">
      <image class="goods-image" src="{{item.image}}" mode="aspectFill" data-index="{{index}}" binderror="onGoodsImageError"></image>
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
        <view class="goods-bottom">
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-quantity">×{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section coupon-section" wx:if="{{exchangeMode}}">
    <view class="coupon-top">
      <text class="coupon-label">兑换券订单</text>
      <view class="coupon-right">
        <text class="coupon-selected">0 元兑换</text>
      </view>
    </view>
    <text class="coupon-tip coupon-tip-active">{{exchangeCouponTitle || '该订单使用兑换券结算，不参与普通优惠券、积分或货款支付。'}}</text>
  </view>

  <view class="section coupon-section" wx:if="{{limitedSpotOrder}}">
    <view class="coupon-top">
      <text class="coupon-label">限时专享订单</text>
      <view class="coupon-right">
        <text class="coupon-selected" wx:if="{{limitedSpotMode === 'points'}}">{{limitedSpotPointsPrice}} 积分兑换</text>
        <text class="coupon-selected" wx:else>活动价 ¥{{limitedSpotMoneyPrice}}</text>
      </view>
    </view>
    <text class="coupon-tip coupon-tip-active">{{limitedSpotTitle || '该订单按活动价结算，不参与优惠券、积分抵扣和货款支付。'}}</text>
  </view>

  <view class="section remark-section">
    <text class="remark-label">订单备注</text>
    <input class="remark-input" placeholder="选填，可留言给卖家" value="{{remark}}" bindinput="onRemarkInput" maxlength="100" />
  </view>

  <view class="section inline-state-section" wx:if="{{!exchangeMode && !limitedSpotOrder && allowCoupon !== false && couponLoadStatus === 'loading'}}">
    <text class="inline-state-title">优惠券加载中</text>
    <text class="inline-state-desc">正在获取可用优惠券，请稍候。</text>
  </view>
  <view class="section inline-state-section" wx:elif="{{!exchangeMode && !limitedSpotOrder && allowCoupon !== false && couponLoadStatus === 'error'}}">
    <text class="inline-state-title">优惠券暂不可用</text>
    <text class="inline-state-desc">{{couponLoadError || '请稍后重试。'}}</text>
    <view class="inline-state-btn" bindtap="onRetryCouponLoad">重试优惠券</view>
  </view>
  <view class="section coupon-section" wx:if="{{!exchangeMode && !limitedSpotOrder && allowCoupon !== false && couponLoadStatus !== 'loading' && couponLoadStatus !== 'error'}}">
    <view class="coupon-top" bindtap="onCouponTap">
      <view class="coupon-label-row">
        <text class="coupon-label">礼遇与优惠</text>
        <text class="coupon-help-chip" catchtap="onCouponHelpTap">说明</text>
      </view>
      <view class="coupon-right">
        <text class="coupon-selected" wx:if="{{selectedCoupon}}">-¥{{couponDiscount}}（{{selectedCoupon.coupon_name}}）</text>
        <text class="coupon-none" wx:elif="{{availableCoupons.length > 0}}">{{availableCoupons.length}}张可用</text>
        <text class="coupon-none" wx:else>暂无可用优惠券</text>
        <text class="arrow" wx:if="{{availableCoupons.length > 0}}">›</text>
      </view>
    </view>
    <text class="coupon-tip coupon-tip-active" wx:if="{{!selectedCoupon && availableCoupons.length > 0}}">本单可用优惠券 {{availableCoupons.length}} 张，点击选择</text>
    <text class="coupon-tip" wx:elif="{{!selectedCoupon && unusedCouponCount > 0}}">{{unusedCouponCount}} 张优惠券不适用于本单</text>
  </view>
  <view class="section coupon-section coupon-disabled" wx:if="{{!exchangeMode && !limitedSpotOrder && allowCoupon === false}}">
    <text class="coupon-label">礼遇与优惠</text>
    <text class="coupon-none">{{bundleOrder ? '该订单不参与优惠券' : '该商品不参与优惠券'}}</text>
  </view>

  <view class="section inline-state-section" wx:if="{{!exchangeMode && !limitedSpotOrder && pointsLoadStatus === 'error'}}">
    <text class="inline-state-title">积分暂不可用</text>
    <text class="inline-state-desc">{{pointsLoadError || '请稍后重试。'}}</text>
    <view class="inline-state-btn" bindtap="onRetryPointsLoad">重试积分</view>
  </view>
  <!-- 积分抵扣 -->
  <view class="section points-section" wx:if="{{!exchangeMode && !limitedSpotOrder && pointsLoadStatus !== 'error' && pointBalance > 0 && allowPoints}}">
    <text class="points-label">积分抵扣</text>
    <view class="points-right">
      <text class="points-balance">可用积分 {{pointBalance}}</text>
      <switch checked="{{usePoints}}" bindchange="onTogglePoints" color="#B98B58" style="transform:scale(0.8)" />
    </view>
  </view>
  <view class="section points-detail" wx:if="{{!exchangeMode && !limitedSpotOrder && pointsLoadStatus !== 'error' && usePoints && pointBalance > 0 && allowPoints}}">
    <text class="points-deduct-text">使用 {{pointsToUse}} 积分，抵扣 ¥{{pointsDeduction}}</text>
    <text class="points-deduct-tip">（{{pointsRuleHint}}）</text>
  </view>
  <view class="section points-section points-disabled" wx:if="{{!exchangeMode && !limitedSpotOrder && pointsLoadStatus !== 'error' && pointBalance > 0 && !allowPoints}}">
    <text class="points-label">积分抵扣</text>
    <text class="points-balance-disabled">{{bundleOrder ? '该订单不支持积分抵扣' : '该商品不支持积分抵扣'}}</text>
  </view>

  <view class="section inline-state-section" wx:if="{{!exchangeMode && !limitedSpotOrder && isAgent && walletLoadStatus === 'loading'}}">
    <text class="inline-state-title">货款余额加载中</text>
    <text class="inline-state-desc">正在获取货款余额，请稍候。</text>
  </view>
  <view class="section inline-state-section" wx:if="{{!exchangeMode && !limitedSpotOrder && isAgent && walletLoadStatus === 'error'}}">
    <text class="inline-state-title">货款余额暂不可用</text>
    <text class="inline-state-desc">{{walletLoadError || '请稍后重试。'}}</text>
    <view class="inline-state-btn" bindtap="onRetryWalletLoad">重试余额</view>
  </view>
  <!-- 货款余额支付 -->
  <view class="section points-section wallet-section" wx:if="{{!exchangeMode && !limitedSpotOrder && isAgent && walletLoadStatus === 'success'}}">
    <view class="wallet-label-col">
      <text class="points-label">货款支付</text>
      <text class="wallet-balance-sub" wx:if="{{walletBalance > 0}}">可用余额 ¥{{walletBalanceDisplay}}</text>
      <text class="wallet-balance-sub wallet-balance-empty" wx:else>余额不足</text>
    </view>
    <view class="points-right">
      <switch
        checked="{{useWallet}}"
        bindchange="onToggleWallet"
        color="#B98B58"
        disabled="{{walletBalance <= 0}}"
        style="transform:scale(0.8)"
      />
    </view>
  </view>
  <view class="section points-detail" wx:if="{{!exchangeMode && !limitedSpotOrder && isAgent && walletLoadStatus === 'success' && useWallet && walletBalance > 0}}">
    <text class="points-deduct-text">本单将从货款余额扣款，无需微信支付</text>
  </view>

  <view class="coupon-picker {{showCouponPicker ? 'show' : ''}}" wx:if="{{showCouponPicker}}">
    <view class="coupon-picker-mask" bindtap="onCloseCouponPicker"></view>
    <view class="coupon-picker-panel">
      <view class="coupon-picker-title">选择优惠券</view>
      <scroll-view scroll-y class="coupon-picker-scroll" show-scrollbar="{{true}}">
        <view class="coupon-picker-empty" wx:if="{{availableCoupons.length === 0}}">暂无可用优惠券</view>
        <view class="coupon-list" wx:else>
          <view
            class="coupon-card {{selectedCoupon && selectedCoupon.id === item.id ? 'active' : ''}}"
            wx:for="{{availableCoupons}}"
            wx:key="id"
            data-coupon="{{item}}"
            bindtap="onSelectCoupon"
          >
            <view class="coupon-card-left">
              <text class="coupon-value">
                <text wx:if="{{item.coupon_type === 'fixed' || item.coupon_type === 'no_threshold'}}">¥{{item.coupon_value}}</text>
                <text wx:else>{{item.coupon_value * 10}}折</text>
              </text>
              <text class="coupon-min">{{item.min_purchase > 0 ? ('满' + item.min_purchase + '元可用') : '无门槛可用'}}</text>
            </view>
            <view class="coupon-card-right">
              <text class="coupon-name-text">{{item.coupon_name}}</text>
              <text class="coupon-expire">{{item.expire_at_formatted}}到期</text>
            </view>
            <view class="coupon-check" wx:if="{{selectedCoupon && selectedCoupon.id === item.id}}">✓</view>
          </view>
          <view class="coupon-no-use" wx:if="{{selectedCoupon}}" bindtap="onClearCoupon">不使用优惠券</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="total-info">
      <view class="total-lines">
        <view class="total-row shipping-row">
          <text class="discount-label">运费：</text>
          <text class="shipping-amount">{{deliveryType === 'pickup' ? '到店自提' : (shippingFee > 0 ? '¥' + shippingFee : '免运费')}}</text>
        </view>
        <view class="total-row" wx:if="{{selectedCoupon}}">
          <text class="discount-label">优惠券：</text>
          <text class="discount-amount">-¥{{couponDiscount}}</text>
        </view>
        <view class="total-row" wx:if="{{usePoints && pointsDeduction > 0}}">
          <text class="discount-label">积分：</text>
          <text class="discount-amount">-¥{{pointsDeduction}}</text>
        </view>
        <view class="total-row" wx:if="{{bundleOrder && bundleDiscount > 0}}">
          <text class="discount-label">组合优惠：</text>
          <text class="discount-amount">-¥{{bundleDiscount}}</text>
        </view>
        <view class="total-row" wx:if="{{limitedSpotOrder && limitedSpotMode === 'points'}}">
          <text class="discount-label">专享积分：</text>
          <text class="discount-amount">{{limitedSpotPointsPrice}} 积分</text>
        </view>
        <view class="total-row">
          <text class="total-label">合计：</text>
          <text class="total-price">¥{{finalAmount}}</text>
        </view>
        <view class="total-row wallet-pay-tip" wx:if="{{isAgent && useWallet && walletBalance > 0}}">
          <text class="wallet-pay-tag">货款余额支付</text>
        </view>
      </view>
    </view>
    <view class="submit-btn {{submitting || loading ? 'disabled' : ''}}" bindtap="onSubmit">
      <text>{{submitting ? '提交中...' : (limitedSpotOrder ? (limitedSpotMode === 'points' ? '提交兑换订单' : '提交秒杀订单') : '提交订单')}}</text>
    </view>
  </view>
  </block>

  <brand-animation id="brandAnimation"></brand-animation>

  <light-tip-modal
    show="{{lightTipShow}}"
    title="{{lightTipTitle}}"
    content="{{lightTipContent}}"
    bind:close="onLightTipClose"
  />

  <view class="success-popup {{showSuccess ? 'show' : ''}}">
    <view class="success-mask"></view>
    <view class="success-content">
      <view class="success-icon">
        <image class="success-icon-img" src="/assets/icons/check-circle.svg" mode="aspectFit"></image>
      </view>
      <text class="success-title">下单成功</text>
      <text class="success-desc">感谢您的信任，我们会尽快为您安排发货</text>
      <view class="success-btns">
        <view class="btn-outline" bindtap="onViewOrder">查看订单</view>
        <view class="btn-primary" bindtap="onBackHome">返回首页</view>
      </view>
    </view>
  </view>
</view>
