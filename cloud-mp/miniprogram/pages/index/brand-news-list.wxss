.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E7EFF5 0%, #F7FAFC 36%, #EFF6F3 100%);
}

.scroll {
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

.page-head {
  padding: 32rpx 28rpx 20rpx;
}

.page-kicker {
  display: block;
  font-size: 20rpx;
  color: #8AA0B6;
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
}

.page-title {
  display: block;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #0F172A;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748B;
}

.article-list {
  padding: 0 24rpx 24rpx;
}

.article-card {
  margin-bottom: 20rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 28rpx rgba(30, 74, 109, 0.08);
}

.article-cover {
  width: 100%;
  height: 320rpx;
  display: block;
}

.article-cover-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #DCEAF5 0%, #E8F1F7 46%, #DDEBE6 100%);
}

.article-cover-fallback-text {
  font-size: 30rpx;
  color: #496179;
  font-weight: 600;
}

.article-copy {
  padding: 24rpx 24rpx 28rpx;
}

.article-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #0F172A;
}

.article-summary {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748B;
}

.article-link {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #1D4ED8;
  font-weight: 600;
}

.state-loading,
.state-error,
.state-empty {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 48rpx;
  box-sizing: border-box;
}

.state-title {
  font-size: 30rpx;
  color: #0F172A;
  font-weight: 600;
}

.state-desc {
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.6;
}

.state-action {
  margin-top: 12rpx;
  min-width: 220rpx;
  text-align: center;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #60A5FA 0%, #2563EB 100%);
  color: #fff;
  font-size: 26rpx;
}

.press {
  opacity: 0.9;
  transform: scale(0.99);
}

.safe-bottom {
  height: calc(32rpx + env(safe-area-inset-bottom));
}
