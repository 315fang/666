<view class="container">
  <page-loading show="{{showHomeLoading}}" text="首页加载中..."></page-loading>
  <view class="{{navRootClass}}" style="padding-top: {{navTopPadding}}px">
    <view class="nav-inner" style="height: {{navBarHeight}}px;">
      <!-- 气泡足迹：替换品牌 Logo 区，暂不展示 Logo/品牌甄选 -->
      <view class="{{navBubbleClass}}" wx:if="{{bubbles.length > 0}}">
        <image class="nav-bubble-icon" src="/assets/icons/hot.svg" mode="aspectFit"></image>
        <view class="nav-bubble-scroll">
          <view class="nav-bubble-item" animation="{{bubbleAnim}}">
            <text class="nav-bubble-text">{{currentBubble}}</text>
          </view>
        </view>
        <view class="nav-search-icon" bindtap="onSearchTap">
          <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
        </view>
      </view>
      <!-- 若无气泡数据时保留搜索入口，避免右上角操作栏孤立 -->
      <view class="nav-search-icon-solo nav-visible" wx:if="{{showSoloSearch}}" bindtap="onSearchTap">
        <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
      </view>

      <view class="{{navSearchBoxClass}}">
        <view class="nav-search-bar" bindtap="onSearchTap">
          <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
          <text class="search-placeholder">搜索商品</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 全屏 Hero 轮播（第一屏，对标麦吉丽全屏大图） -->
  <view class="hero-editorial" style="height: {{heroViewportHeight}}px; min-height: {{heroViewportHeight}}px; opacity: {{heroOpacity}};">
    <view class="hero-parallax-inner" style="transform: {{heroTransform}};">
    <swiper class="hero-swiper" indicator-dots="{{true}}" autoplay="{{true}}" circular="{{true}}" interval="5000" duration="600" indicator-color="rgba(255,255,255,0.25)" indicator-active-color="#FFFFFF">
      <swiper-item wx:for="{{heroBanners}}" wx:key="id">
        <view class="hero-slide" bindtap="onBannerTap" data-item="{{item}}" hover-class="press">
          <image class="hero-image" src="{{item.image}}" mode="aspectFill" wx:if="{{item.image}}" binderror="onAssetImageError" data-scene="hero-banner" data-index="{{index}}"></image>
          <view class="hero-fallback" wx:else>
            <view class="hero-orb orb-a"></view>
            <view class="hero-orb orb-b"></view>
            <view class="hero-orb orb-c"></view>
          </view>
        </view>
      </swiper-item>
    </swiper>
    </view>
  </view>

  <!-- 中部海报区（后端 banners position=home_mid，对标麦吉丽的多海报铺排） -->
  <view id="reveal_mid_posters" class="{{revealMidPostersClass}}" wx:if="{{midPosters.length > 0}}">
    <view class="poster-card" wx:for="{{midPosters}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}" hover-class="press">
      <image class="poster-image" src="{{item.image}}" mode="widthFix" binderror="onAssetImageError" data-scene="mid-poster" data-index="{{index}}"></image>
    </view>
  </view>

  <view id="reveal_coupons" class="{{revealCouponsClass}}">
    <view class="section-head coupon-section-head">
      <view class="section-copy">
        <text class="section-intro-title">{{couponZoneTitle}}</text>
        <text class="section-intro-sub">{{couponZoneSubtitle}}</text>
      </view>
      <view class="section-link" bindtap="onCouponTap">
        更多 ›
      </view>
    </view>

    <scroll-view
      wx:if="{{homeCoupons.length > 0}}"
      scroll-x
      class="coupon-scroll-x"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view class="coupon-strip">
        <view class="coupon-mini-card" wx:for="{{homeCoupons}}" wx:key="id" bindtap="onCouponItemTap" data-coupon="{{item}}" hover-class="press">
          <view class="cmc-left">
            <text class="cmc-value">{{item.value_text}}</text>
            <text class="cmc-min">{{item.min_label}}</text>
          </view>
          <view class="cmc-right">
            <text class="cmc-name">{{item.name}}</text>
            <text class="cmc-expire">{{item.sub_label}}</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <view wx:else class="coupon-empty-tip" bindtap="onCouponTap" hover-class="press">
      <view class="coupon-empty-copy">
        <text class="coupon-empty-title">优惠券中心</text>
        <text class="coupon-empty-desc">查看可领取优惠券。</text>
      </view>
      <text class="coupon-empty-cta">去查看 ›</text>
    </view>
  </view>

  <!-- 分类商品编排 -->
  <view id="reveal_products" class="{{revealProductsClass}}" wx:if="{{featuredSections.length > 0}}">
    <view class="products-section-block" wx:for="{{featuredSections}}" wx:key="key">
      <view class="section-head">
        <view class="section-copy">
          <text class="section-intro-title">{{item.title}}</text>
          <text class="section-intro-sub" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
        </view>
        <view class="section-link" bindtap="onGoCategory">更多 ›</view>
      </view>

      <view class="products-grid">
        <view class="product-card" wx:for="{{item.products}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}" hover-class="press">
          <view class="product-card-img-wrap">
            <image
              wx:if="{{item.hasCardImage}}"
              class="product-card-img"
              src="{{item.cardImage}}"
              mode="aspectFill"
              lazy-load="{{true}}"
            ></image>
            <view wx:else class="product-card-img-fallback">
              <text class="product-card-img-fallback-label">暂无商品图片</text>
            </view>
            <view class="product-card-soldout" wx:if="{{item.soldOut}}">已售罄</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 精选单品回退 -->
  <view id="reveal_featured" class="{{revealFeaturedClass}}" wx:else>
    <view class="section-head">
      <text class="section-intro-title">精选单品</text>
      <view class="section-link" bindtap="onGoCategory">更多 ›</view>
    </view>

    <view class="products-grid" wx:if="{{showFeaturedSkeleton}}">
      <view class="product-card-skeleton" wx:for="{{[1,2,3,4]}}" wx:key="index">
        <view class="psk-img"></view>
        <view class="psk-info">
          <view class="psk-line psk-long"></view>
          <view class="psk-line psk-short"></view>
        </view>
      </view>
    </view>

    <view class="products-grid" wx:if="{{featuredProducts.length > 0}}">
<view class="product-card" wx:for="{{featuredProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}" hover-class="press">
          <view class="product-card-img-wrap">
            <image
              wx:if="{{item.hasCardImage}}"
              class="product-card-img"
              src="{{item.cardImage}}"
              mode="aspectFill"
              lazy-load="{{true}}"
              binderror="onFeaturedImageError"
              data-index="{{index}}"
            ></image>
            <view wx:else class="product-card-img-fallback">
              <text class="product-card-img-fallback-label">暂无商品图片</text>
            </view>
            <view class="product-card-soldout" wx:if="{{item.soldOut}}">已售罄</view>
          </view>
        </view>
      </view>

    <view class="products-empty" wx:if="{{showProductsEmpty}}">
      <text>暂无商品，请稍后查看</text>
    </view>
  </view>

  <view id="reveal_brand" class="{{revealBrandClass}}" wx:if="{{brandZone.enabled}}">
    <view class="brand-zone-header">
      <view class="brand-zone-header-line"></view>
      <text class="brand-zone-header-title">{{brandZone.title}}</text>
      <view class="brand-zone-header-line"></view>
    </view>

    <view class="brand-zone-hero">
      <image
        wx:if="{{brandZone.coverImage}}"
        class="brand-zone-cover"
        src="{{brandZone.coverImage}}"
        mode="aspectFill"
        binderror="onBrandZoneImageError"
        data-scene="cover"
      ></image>
      <view wx:else class="brand-zone-cover brand-zone-cover-fallback">
        <text class="brand-zone-cover-kicker">{{brandZoneCoverKicker}}</text>
        <text class="brand-zone-cover-title">{{brandZoneCoverTitle}}</text>
      </view>

      <view class="brand-zone-welcome-card" wx:if="{{brandZone.showWelcome}}">
        <text class="brand-zone-welcome-title">{{brandZone.welcomeTitle}}</text>
        <text class="brand-zone-welcome-subtitle" wx:if="{{brandZone.welcomeSubtitle}}">{{brandZone.welcomeSubtitle}}</text>
      </view>
    </view>

    <view class="brand-zone-card-grid" wx:if="{{brandZone.cards.length > 0}}">
      <view class="brand-zone-card" wx:for="{{brandZone.cards}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}" hover-class="press">
        <view class="brand-zone-card-media">
          <image
            wx:if="{{item.image}}"
            class="brand-zone-card-image"
            src="{{item.image}}"
            mode="aspectFill"
            binderror="onBrandZoneImageError"
            data-scene="card"
            data-index="{{index}}"
          ></image>
          <view wx:else class="brand-zone-card-image brand-zone-card-fallback">
            <text class="brand-zone-card-fallback-text">{{item.title}}</text>
          </view>
        </view>
        <text class="brand-zone-card-title">{{item.title}}</text>
        <text class="brand-zone-card-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
      </view>
    </view>

    <view class="brand-zone-cert-list" wx:if="{{brandZone.certifications.length > 0}}">
      <view class="brand-zone-cert-item" wx:for="{{brandZone.certifications}}" wx:key="id">
        <image
          wx:if="{{item.image}}"
          class="brand-zone-cert-image"
          src="{{item.image}}"
          mode="aspectFill"
          binderror="onBrandZoneImageError"
          data-scene="certification"
          data-index="{{index}}"
        ></image>
        <view wx:else class="brand-zone-cert-image brand-zone-cert-fallback"></view>
        <view class="brand-zone-cert-copy">
          <text class="brand-zone-cert-title">{{item.title}}</text>
          <text class="brand-zone-cert-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
        </view>
      </view>
    </view>

    <view class="brand-zone-story" wx:if="{{brandZone.story.body}}">
      <text class="brand-zone-story-title">{{brandZone.story.title}}</text>
      <text class="brand-zone-story-body">{{brandZone.story.body}}</text>
    </view>

  </view>

  <!-- 底部海报区（后端 banners position=home_bottom） -->
  <view id="reveal_bottom_posters" class="{{revealBottomPostersClass}}" wx:if="{{bottomPosters.length > 0}}">
    <view class="poster-card" wx:for="{{bottomPosters}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}" hover-class="press">
      <image class="poster-image" src="{{item.image}}" mode="widthFix" binderror="onAssetImageError" data-scene="bottom-poster" data-index="{{index}}"></image>
    </view>
  </view>

  <brand-animation id="brandAnimation"></brand-animation>

  <!-- 弹窗广告 -->
  <view class="popup-ad-overlay" wx:if="{{showPopupAd}}" bindtap="onClosePopupAd">
    <view class="popup-ad-card" catchtap="onPopupAdTap">
      <image class="popup-ad-image" src="{{popupAd.displayImage}}" mode="widthFix" wx:if="{{popupAd.hasImage}}" binderror="onAssetImageError" data-scene="popup-ad"/>
      <view class="popup-ad-btn" wx:if="{{popupAd.button_text}}">
        {{popupAd.button_text}}
      </view>
    </view>
    <view class="popup-ad-close" catchtap="onClosePopupAd">×</view>
  </view>

  <light-tip-modal
    show="{{regLightTipShow}}"
    title="{{regLightTipTitle}}"
    content="{{regLightTipContent}}"
    bind:close="onRegLightTipClose"
  />
</view>
