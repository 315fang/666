<view class="container">
  <page-loading show="{{loading && featuredProducts.length === 0}}" text="首页加载中..."></page-loading>
  <view class="custom-nav {{navScrolled ? 'nav-scrolled' : 'nav-transparent'}}" style="padding-top: {{navTopPadding}}px">
    <view class="nav-inner" style="height: {{navBarHeight}}px;">
      <!-- 气泡足迹：替换品牌 Logo 区，暂不展示 Logo/品牌甄选 -->
      <view class="nav-bubble-bar {{navScrolled ? 'nav-hidden' : 'nav-visible'}}" wx:if="{{bubbles.length > 0}}">
        <view class="nav-bubble-icon">🔥</view>
        <view class="nav-bubble-scroll">
          <view class="nav-bubble-item" animation="{{bubbleAnim}}">
            <text class="nav-bubble-text">{{currentBubble}}</text>
          </view>
        </view>
        <view class="nav-search-icon" bindtap="onSearchTap">
          <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
        </view>
      </view>
      <!-- 若无气泡数据时保留搜索入口，避免右上角操作栏孤立 -->
      <view class="nav-search-icon-solo nav-visible" wx:if="{{!bubbles.length && !navScrolled}}" bindtap="onSearchTap">
        <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
      </view>

      <view class="nav-search-box {{navScrolled ? 'nav-visible' : 'nav-hidden'}}">
        <view class="nav-search-bar" bindtap="onSearchTap">
          <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
          <text class="search-placeholder">搜索商品</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 全屏 Hero 轮播（第一屏，对标麦吉丽全屏大图） -->
  <view class="hero-editorial">
    <swiper class="hero-swiper" indicator-dots="{{true}}" autoplay="{{true}}" circular="{{true}}" interval="5000" duration="600" indicator-color="rgba(255,255,255,0.25)" indicator-active-color="#FFFFFF">
      <swiper-item wx:for="{{heroBanners}}" wx:key="id">
        <view class="hero-slide" bindtap="onBannerTap" data-item="{{item}}" hover-class="press">
          <image class="hero-image" src="{{item.image}}" mode="aspectFill" wx:if="{{item.image}}"></image>
          <view class="hero-fallback" wx:else>
            <view class="hero-orb orb-a"></view>
            <view class="hero-orb orb-b"></view>
            <view class="hero-orb orb-c"></view>
          </view>
          <view class="hero-mask"></view>
          <view class="hero-copy">
            <text class="hero-title">{{item.title}}</text>
            <text class="hero-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 优惠券入口（暂时隐藏） -->
  <!--
  <view class="coupon-section" wx:if="{{isLoggedIn && homeCoupons.length > 0}}">
    <view class="section-head">
      <text class="section-intro-title">我的优惠券</text>
      <view class="section-link" bindtap="onCouponTap">全部 {{unusedCouponCount}} 张 ›</view>
    </view>

    <scroll-view scroll-x class="coupon-scroll-x" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="coupon-strip">
        <view class="coupon-mini-card" wx:for="{{homeCoupons}}" wx:key="id" bindtap="onCouponItemTap" data-coupon="{{item}}" hover-class="press">
          <view class="cmc-left">
            <text class="cmc-value">{{item.value_text}}</text>
            <text class="cmc-min">{{item.min_label}}</text>
          </view>
          <view class="cmc-right">
            <text class="cmc-name">{{item.coupon_name}}</text>
            <text class="cmc-expire">{{item.expire_at_formatted}} 到期</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
  -->

  <!-- 中部海报区（后端 banners position=home_mid，对标麦吉丽的多海报铺排） -->
  <view class="poster-section" wx:if="{{midPosters.length > 0}}">
    <view class="poster-card" wx:for="{{midPosters}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}" hover-class="press">
      <image class="poster-image" src="{{item.image}}" mode="widthFix"></image>
      <view class="poster-overlay" wx:if="{{item.title}}">
        <text class="poster-title">{{item.title}}</text>
        <text class="poster-sub" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
      </view>
    </view>
  </view>

  <!-- 精选单品 -->
  <view class="products-section">
    <view class="section-head">
      <text class="section-intro-title">精选单品</text>
      <view class="section-link" bindtap="onGoCategory">更多 ›</view>
    </view>

    <view class="products-grid" wx:if="{{loading && featuredProducts.length === 0}}">
      <view class="product-card-skeleton" wx:for="{{[1,2,3,4]}}" wx:key="index">
        <view class="psk-img"></view>
        <view class="psk-info">
          <view class="psk-line psk-long"></view>
          <view class="psk-line psk-short"></view>
        </view>
      </view>
    </view>

    <view class="products-grid" wx:if="{{featuredProducts.length > 0}}">
      <view class="product-card" wx:for="{{featuredProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}" hover-class="press">
        <view class="product-card-img-wrap">
          <image class="product-card-img" src="{{item.cover_image || (item.images && item.images[0]) || '/assets/images/placeholder.svg'}}" mode="aspectFill" lazy-load="{{true}}"></image>
          <view class="product-card-badge" wx:if="{{item.market_price && item.market_price > item.retail_price && item.discount_label}}">
            {{item.discount_label}}
          </view>
          <view class="product-card-soldout" wx:if="{{item.stock === 0}}">已售罄</view>
        </view>
        <!-- 信息层悬浮在图片底部 -->
        <view class="product-card-info">
          <view>
            <text class="product-card-name">{{item.name}}</text>
            <text class="product-card-spec" wx:if="{{item.specSummary}}">{{item.specSummary}}</text>
            <view class="heat-tag" wx:if="{{item.heat_label}}">
              <text class="heat-icon">🔥</text>
              <text class="heat-text">{{item.heat_label}}</text>
            </view>
          </view>
          <view class="product-card-price-row">
            <view class="product-card-price">
              <text class="price-sym">¥</text>
              <text class="price-num">{{item.retail_price || item.price}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="products-empty" wx:if="{{!loading && featuredProducts.length === 0}}">
      <text>暂无商品，请稍后查看</text>
    </view>
  </view>

  <!-- 底部海报区（后端 banners position=home_bottom） -->
  <view class="poster-section" wx:if="{{bottomPosters.length > 0}}">
    <view class="poster-card" wx:for="{{bottomPosters}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}" hover-class="press">
      <image class="poster-image" src="{{item.image}}" mode="widthFix"></image>
      <view class="poster-overlay" wx:if="{{item.title}}">
        <text class="poster-title">{{item.title}}</text>
        <text class="poster-sub" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
      </view>
    </view>
  </view>

  <brand-animation id="brandAnimation"></brand-animation>

  <!-- 弹窗广告 -->
  <view class="popup-ad-overlay" wx:if="{{showPopupAd}}" bindtap="onClosePopupAd">
    <view class="popup-ad-card" catchtap="onPopupAdTap">
      <image class="popup-ad-image" src="{{popupAd.file_id || popupAd.image_url}}" mode="widthFix" wx:if="{{popupAd.file_id || popupAd.image_url}}"/>
      <view class="popup-ad-btn" wx:if="{{popupAd.button_text}}">
        {{popupAd.button_text}}
      </view>
    </view>
    <view class="popup-ad-close" catchtap="onClosePopupAd">×</view>
  </view>

  <light-tip-modal
    show="{{regLightTipShow}}"
    title="{{regLightTipTitle}}"
    content="{{regLightTipContent}}"
    bind:close="onRegLightTipClose"
  />
</view>
