.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #DDEAF3 0%, #F7FBFF 30%, #EDF4F8 100%);
  /* Reserve enough space for the custom tab bar plus iPhone safe area. */
  padding-bottom: 120rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ── 滚动渐显动画 ── */
.scroll-reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
              transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.scroll-reveal.revealed {
  opacity: 1;
  transform: translateY(0);
}

/* ── Hero 视差内层 ── */
.hero-parallax-inner {
  width: 100%;
  height: 100%;
  will-change: transform;
}

/* ── 导航栏 ── */
.custom-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; transition: all 0.3s ease; }
.nav-transparent { background: transparent; }
.nav-scrolled { background: rgba(247, 251, 255, 0.94); box-shadow: 0 10rpx 34rpx rgba(16, 42, 67, 0.08); border-bottom: 1rpx solid rgba(157, 177, 194, 0.18); }
.nav-inner { min-height: 88rpx; position: relative; padding: 0 28rpx; display: flex; align-items: center; }

.nav-brand, .nav-search-box {
  position: absolute; left: 28rpx; right: 190rpx;
  display: flex; align-items: center; transition: all 0.35s ease;
}
.nav-visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
.nav-hidden { opacity: 0; transform: translateY(16rpx); pointer-events: none; }
.nav-brand { gap: 16rpx; }

.nav-logo { width: 52rpx; height: 52rpx; border-radius: 12rpx; flex-shrink: 0; }
.nav-bubble-logo { width: 52rpx; height: 52rpx; position: relative; flex-shrink: 0; }
.nb-orb { display: none; }
@keyframes nb-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-5rpx); } }

.nav-brand-copy { display: flex; flex-direction: column; flex: 1; }
.nav-brand-title { font-size: 28rpx; color: #132235; font-weight: 600; }
.nav-brand-sub { font-size: 20rpx; color: #6B7F91; letter-spacing: 0; }

.nav-search-icon { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

.nav-search-bar {
  flex: 1; height: 68rpx; border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9); border: 1rpx solid rgba(111, 159, 196, 0.24);
  display: flex; align-items: center; padding: 0 24rpx; gap: 12rpx;
  box-shadow: 0 10rpx 30rpx rgba(16, 42, 67, 0.08);
}
.search-icon { width: 28rpx; height: 28rpx; opacity: 0.45; }
.search-placeholder { font-size: 24rpx; color: #94A3B8; }

/* ── Hero 轮播 ── */
.hero-editorial {
  position: relative;
  overflow: hidden;
  background: linear-gradient(160deg, #2B579A 0%, #3D6BB3 54%, #5B9BD5 100%);
  background-size: 200% 200%;
  animation: gradient-flow 5s ease infinite;
  will-change: opacity;
  transition: opacity 0.1s linear;
}
.hero-swiper, .hero-slide { width: 100%; height: 100%; }
.hero-image, .hero-fallback { width: 100%; height: 100%; display: block; }

.hero-slide::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 34%;
  background: linear-gradient(180deg, rgba(16, 42, 67, 0) 0%, rgba(16, 42, 67, 0.36) 100%);
  pointer-events: none;
}

.hero-fallback {
  position: relative;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(160deg, #2B579A 0%, #3D6BB3 58%, #5B9BD5 100%);
  background-size: 100% 100%, 200% 200%;
  animation: gradient-flow 5s ease infinite;
}
.hero-orb { display: none; }
.orb-a { width: 360rpx; height: 360rpx; top: 80rpx; right: -40rpx; background: rgba(255, 243, 224, 0.28); }
.orb-b { width: 240rpx; height: 240rpx; left: -40rpx; bottom: 120rpx; background: rgba(255, 228, 213, 0.2); }
.orb-c { width: 520rpx; height: 520rpx; right: 120rpx; bottom: -180rpx; background: rgba(255, 255, 255, 0.08); }

/* ── 海报区块（多海报铺排，对标麦吉丽） ── */
.poster-section {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.poster-card {
  position: relative;
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 34rpx rgba(16, 42, 67, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.poster-image {
  width: 100%;
  display: block;
}

/* ── 区块标题 ── */
.section-head {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx;
}
.section-intro-title { display: block; font-size: 34rpx; color: #132235; font-weight: 700; }
.section-copy { display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.section-intro-sub { font-size: 22rpx; color: #6B7F91; line-height: 1.5; }
.section-link { font-size: 24rpx; color: #9A7348; padding: 8rpx 0; min-height: 88rpx; display: flex; align-items: center; font-weight: 600; }

/* ── 商品精选区（全宽大图横幅，对标麦当劳） ── */
.products-section {
  padding: 0 24rpx 120rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.products-section-grouped {
  padding-bottom: 48rpx;
}

.products-section-block {
  margin-bottom: 32rpx;
}

.products-grid { display: flex; flex-direction: column; gap: 20rpx; }

.product-card {
  position: relative;
  border-radius: 24rpx; overflow: hidden;
  box-shadow: 0 14rpx 36rpx rgba(16, 42, 67, 0.13);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}
.product-card:active { transform: scale(0.98); }

/* 图片区：1:1 大图 */
.product-card-img-wrap {
  position: relative;
  width: 100%;
  padding-top: 100%;
  overflow: hidden;
  background: #EAF2F8;
  border-radius: 24rpx;
}
.product-card-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.product-card-img-fallback {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.72) 0%, rgba(255,255,255,0) 42%),
    linear-gradient(145deg, #DDEAF3 0%, #F7FBFF 100%);
}
.product-card-img-fallback-label {
  color: rgba(23, 50, 77, 0.68);
  font-size: 24rpx;
  letter-spacing: 0;
}

.product-card-soldout {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: rgba(0,0,0,0.45); color: rgba(255,255,255,0.9);
  font-size: 28rpx; font-weight: 600; letter-spacing: 2rpx; z-index: 2;
}
.product-card-skeleton { border-radius: 24rpx; overflow: hidden; background: #fff; }
.psk-img { width: 100%; padding-top: 56%; background: linear-gradient(90deg, #EAF2F8 25%, #DDEAF3 50%, #EAF2F8 75%); background-size: 200% 100%; animation: psk-shimmer 1.4s infinite; }
.psk-info { padding: 16rpx 18rpx 20rpx; display: flex; flex-direction: column; gap: 10rpx; }
.psk-line { height: 20rpx; border-radius: 6rpx; background: linear-gradient(90deg, #EAF2F8 25%, #DDEAF3 50%, #EAF2F8 75%); background-size: 200% 100%; animation: psk-shimmer 1.4s infinite; }
.psk-long { width: 80%; }
.psk-short { width: 50%; }
@keyframes psk-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

.products-empty { text-align: center; padding: 60rpx 0; font-size: 26rpx; color: #B0A396; }

.brand-zone-section {
  padding: 0 24rpx 28rpx;
}

.brand-zone-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.brand-zone-header-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(107, 127, 145, 0.05) 0%, rgba(198, 161, 110, 0.52) 100%);
}

.brand-zone-header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #132235;
  letter-spacing: 0;
}

.brand-zone-hero {
  position: relative;
  padding-bottom: 86rpx;
}

.brand-zone-cover {
  width: 100%;
  height: 420rpx;
  display: block;
  border-radius: 32rpx;
  background: #DDEAF3;
  box-shadow: 0 16rpx 40rpx rgba(16, 42, 67, 0.14);
}

.brand-zone-cover-fallback {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 44rpx 40rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.62) 0%, rgba(255,255,255,0) 42%),
    linear-gradient(150deg, #2B579A 0%, #5B9BD5 62%, #DDEAF3 100%);
}

.brand-zone-cover-kicker {
  font-size: 22rpx;
  color: #132235;
  opacity: 0.55;
  letter-spacing: 0;
  margin-bottom: 12rpx;
}

.brand-zone-cover-title {
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 600;
  color: #132235;
}

.brand-zone-welcome-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  padding: 22rpx 28rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(198, 161, 110, 0.18);
  box-shadow: 0 16rpx 36rpx rgba(16, 42, 67, 0.12);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.brand-zone-welcome-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #132235;
  flex-shrink: 0;
}

.brand-zone-welcome-subtitle {
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748B;
}

.brand-zone-card-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.brand-zone-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 30rpx rgba(16, 42, 67, 0.09);
  padding-bottom: 18rpx;
  border: 1rpx solid rgba(210, 224, 234, 0.74);
}

.brand-zone-card-media {
  width: 100%;
  height: 180rpx;
  background: #EAF2F8;
}

.brand-zone-card-image {
  width: 100%;
  height: 100%;
  display: block;
}

.brand-zone-card-fallback {
  display: flex;
  align-items: flex-end;
  padding: 18rpx;
  background: linear-gradient(160deg, #EEF6FA 0%, #F7FBFF 100%);
}

.brand-zone-card-fallback-text {
  font-size: 22rpx;
  line-height: 1.4;
  color: #475569;
}

.brand-zone-card-title {
  display: block;
  padding: 16rpx 16rpx 0;
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #132235;
  min-height: 66rpx;
}

.brand-zone-card-subtitle {
  display: block;
  padding: 6rpx 16rpx 0;
  font-size: 18rpx;
  line-height: 1.5;
  color: #6B7F91;
}

.brand-zone-cert-list {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 30rpx rgba(16, 42, 67, 0.08);
  border: 1rpx solid rgba(210, 224, 234, 0.74);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.brand-zone-cert-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-zone-cert-image {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: #EAF2F8;
  flex-shrink: 0;
}

.brand-zone-cert-fallback {
  background: linear-gradient(135deg, #EEF6FA 0%, #F7FBFF 100%);
}

.brand-zone-cert-copy {
  flex: 1;
  min-width: 0;
}

.brand-zone-cert-title {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #132235;
}

.brand-zone-cert-subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.55;
  color: #64748B;
}

.brand-zone-story {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(30, 74, 109, 0.08);
}

.brand-zone-story-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #132235;
  margin-bottom: 14rpx;
}

.brand-zone-story-body {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: #46596B;
}

/* 气泡足迹导航栏版：占据原品牌甄选位置 */
.nav-bubble-bar {
  position: absolute; left: 28rpx; right: 190rpx;
  display: flex; align-items: center; gap: 12rpx;
  transition: all 0.35s ease;
}
.nav-bubble-icon { width: 26rpx; height: 26rpx; flex-shrink: 0; filter: brightness(0) invert(86%) sepia(17%) saturate(809%) hue-rotate(354deg) brightness(91%) contrast(89%); }
.nav-bubble-scroll { flex: 1; overflow: hidden; height: 36rpx; }
.nav-bubble-item { height: 36rpx; display: flex; align-items: center; }
.nav-bubble-text { font-size: 24rpx; color: rgba(247, 251, 255, 0.94); white-space: nowrap; text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.32); }
.nav-search-icon-solo { position: absolute; right: 140rpx; display: flex; align-items: center; }

.press { opacity: 0.7; }

/* 弹窗广告 */
.popup-ad-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0,0,0,0.55);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.popup-ad-card {
  width: 580rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.25);
}

.popup-ad-image {
  width: 100%;
  display: block;
}

.popup-ad-btn {
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(135deg, #3D6BB3, #5B9BD5);
}

.popup-ad-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: rgba(255,255,255,0.8);
}

/* ── 优惠券入口区 ── */
.coupon-section { padding: 0 28rpx; margin-top: 16rpx; }
.coupon-section .section-head { margin-bottom: 16rpx; }
.coupon-section-head {
  align-items: flex-end;
}
.coupon-scroll-x { width: 100%; white-space: nowrap; }
.coupon-strip { display: inline-flex; gap: 16rpx; padding: 4rpx 0 12rpx; }
.bundle-mini-card {
  display: inline-flex;
  align-items: stretch;
  min-width: 480rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #F7FBFF 0%, #EAF2F8 100%);
  border: 1rpx solid rgba(198, 161, 110, 0.20);
}
.bundle-mini-image {
  width: 156rpx;
  height: 156rpx;
  background: #EAF2F8;
  flex-shrink: 0;
}
.bundle-mini-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}
.bundle-mini-image-placeholder-text {
  font-size: 24rpx;
  color: #6B7F91;
}
.coupon-mini-card {
  display: inline-flex; flex-direction: row; align-items: stretch;
  background: linear-gradient(135deg, #FFF7F4 0%, #FFFDFB 100%);
  border-radius: 16rpx; border: 1rpx solid rgba(217, 68, 53, 0.20);
  min-width: 400rpx; overflow: hidden; position: relative;
  transition: transform 0.15s ease;
  box-shadow: 0 10rpx 24rpx rgba(217, 68, 53, 0.10);
}
.coupon-mini-card.press { transform: scale(0.97); }
.cmc-left {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 20rpx 16rpx 20rpx 24rpx; min-width: 140rpx;
  background: linear-gradient(135deg, #D83A2E 0%, #FF7258 100%);
}
.cmc-value { font-size: 40rpx; font-weight: 800; color: #FFFFFF; line-height: 1.1; }
.cmc-min { font-size: 20rpx; color: rgba(255,255,255,0.78); margin-top: 4rpx; opacity: 1; }
.cmc-right {
  display: flex; flex-direction: column; justify-content: center;
  padding: 20rpx 24rpx; flex: 1;
}
.cmc-name { font-size: 26rpx; font-weight: 600; color: #2A1714; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.cmc-expire { font-size: 20rpx; color: #C45E3D; margin-top: 6rpx; opacity: 0.9; }

/* ── 优惠券无券引导 ── */
.coupon-empty-tip {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #FFF7F4 0%, #FFFDFB 100%);
  border-radius: 20rpx;
  border: 1rpx dashed rgba(198, 161, 110, 0.58);
}
.coupon-empty-copy {
  flex: 1;
  min-width: 0;
}
.coupon-empty-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #D83A2E;
}
.coupon-empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6B7F91;
  opacity: 0.82;
}
.coupon-empty-cta {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: #9A7348;
}
