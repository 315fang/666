<view class="container">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack">
        <image class="back-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"></image>
      </view>
      <text class="nav-title">成员详情</text>
      <view class="nav-right"></view>
    </view>
  </view>

  <scroll-view scroll-y class="main-scroll">
    <view class="skeleton-wrap" wx:if="{{loading}}">
      <view class="sk-hero"></view>
      <view class="sk-grid">
        <view class="sk-card" wx:for="{{[1,2,3,4]}}" wx:key="index"></view>
      </view>
    </view>

    <view class="empty-state" wx:elif="{{loadError}}">
      <image src="/assets/icons/users.svg" mode="aspectFit" class="empty-icon"></image>
      <text class="empty-title">成员信息加载失败</text>
      <text class="empty-desc">{{loadError}}</text>
      <view class="empty-retry-btn" bindtap="onRetry">重新加载</view>
    </view>

    <block wx:elif="{{member}}">
      <view class="hero-card">
        <view class="hero-row">
          <image class="hero-avatar" src="{{member.avatar || member.avatar_url || '/assets/icons/user.svg'}}" mode="aspectFill"></image>
          <view class="hero-meta">
            <text class="hero-name">{{member.nick_name || member.nickname || '团队成员'}}</text>
            <view class="hero-tags">
              <text class="hero-pill">{{member.level_label}}</text>
              <text class="hero-pill light">{{member.role_name}}</text>
              <text class="hero-pill light">{{member.relation_source_text || (member.relation_source === 'directed_b1' ? '定向邀约' : '普通邀请')}}</text>
            </view>
            <text class="hero-relation">{{member.current_relation_text || member.relation_text}}</text>
            <text class="hero-relation inviter">{{member.inviter_text}}</text>
          </view>
        </view>

        <view class="hero-stats">
          <view class="hero-stat">
            <text class="hero-stat-label">订单数</text>
            <text class="hero-stat-value">{{member.order_count}}</text>
          </view>
          <view class="hero-stat">
            <text class="hero-stat-label">累计业绩</text>
            <text class="hero-stat-value">¥{{member.total_sales}}</text>
          </view>
          <view class="hero-stat">
            <text class="hero-stat-label">加入时间</text>
            <text class="hero-stat-value small">{{member.joined_at_format}}</text>
          </view>
        </view>
      </view>

      <view class="detail-section">
        <view class="section-head">
          <text class="section-title">详细信息</text>
          <text class="section-sub">这里只展示你当前可查看的团队成员信息</text>
        </view>
        <view class="detail-grid">
          <view class="detail-card" wx:for="{{detailItems}}" wx:key="label">
            <text class="detail-label">{{item.label}}</text>
            <text class="detail-value">{{item.value}}</text>
          </view>
        </view>
      </view>

      <view class="action-card" bindtap="goInvitePoster">
        <view>
          <text class="action-title">继续拓展团队</text>
          <text class="action-sub">去生成海报，继续邀请一级成员进入你的团队</text>
        </view>
        <text class="action-arrow">›</text>
      </view>
      <view class="action-card" wx:if="{{member.can_apply_goods_fund_transfer}}" bindtap="onCreateGoodsFundTransfer">
        <view>
          <text class="action-title">申请货款划拨</text>
          <text class="action-sub">仅支持直属下级；每一笔都需后台审核后才会真正到账</text>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </block>

    <view class="bottom-space"></view>
  </scroll-view>
  <portal-password-dialog id="portalPasswordDialog" />
</view>
