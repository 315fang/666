.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(107, 182, 255, 0.28), transparent 28%),
    linear-gradient(180deg, #0f4ea7 0%, #0d6bd8 24%, #eef5ff 24%, #f5f9ff 100%);
  display: flex;
  flex-direction: column;
}

.nav-bar {
  background: transparent;
  flex-shrink: 0;
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  position: relative;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.96;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.main-scroll {
  flex: 1;
  height: 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.hero-card {
  margin: 16rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0.12));
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 24rpx 50rpx rgba(9, 56, 120, 0.28);
  backdrop-filter: blur(12rpx);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-user {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.hero-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.2);
}

.hero-user-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.hero-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  max-width: 320rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.hero-role {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
}

.hero-share-btn {
  min-width: 162rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: none;
  color: #0d5fd1;
  font-size: 26rpx;
  font-weight: 600;
  background: #ffffff;
}

.hero-share-btn::after,
.share-btn::after {
  border: none;
}

.hero-balance-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 26rpx;
}

.hero-balance-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-height: 184rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(4, 24, 53, 0.2);
}

.hero-balance-card.full {
  grid-column: 1 / -1;
}

.balance-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.balance-amount {
  font-size: 46rpx;
  line-height: 1.08;
  font-weight: 700;
  color: #ffffff;
}

.balance-sub {
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.65);
}

.invite-band {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.invite-band-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.invite-band-code {
  font-size: 36rpx;
  letter-spacing: 4rpx;
  color: #ffffff;
  font-weight: 700;
}

.invite-band-actions {
  display: flex;
  gap: 14rpx;
  flex-shrink: 0;
}

.ghost-btn {
  min-width: 110rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.share-btn {
  margin: 0;
  line-height: 58rpx;
}

.stats-panel {
  margin: 22rpx 24rpx 0;
  padding: 26rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(21, 80, 156, 0.08);
}

.stats-main,
.stats-sub {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.stats-main {
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #e3eefc;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-value {
  font-size: 42rpx;
  line-height: 1;
  font-weight: 700;
  color: #0e4fa9;
}

.stats-label {
  font-size: 22rpx;
  color: #7b91b4;
}

.stats-sub {
  padding-top: 20rpx;
}

.stats-sub-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: center;
}

.stats-sub-label {
  font-size: 20rpx;
  color: #94a6c4;
}

.stats-sub-value {
  font-size: 25rpx;
  font-weight: 600;
  color: #17396d;
}

.section-card {
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(21, 80, 156, 0.07);
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #12366a;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8ea1be;
  line-height: 1.55;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.quick-card {
  min-height: 176rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f5f9ff 0%, #eef4ff 100%);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.quick-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #153d77;
}

.quick-desc,
.quick-meta {
  font-size: 22rpx;
  line-height: 1.55;
  color: #6f87aa;
}

.team-level-card,
.wide-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f6f9ff 0%, #edf4ff 100%);
}

.team-level-card + .team-level-card,
.wide-action {
  margin-top: 16rpx;
}

.team-level-card.light {
  background: #f8fbff;
}

.team-level-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.team-level-name,
.wide-action-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #12366a;
}

.team-level-desc,
.wide-action-desc {
  font-size: 22rpx;
  line-height: 1.55;
  color: #8093b2;
}

.team-level-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #0d63d0;
}

.wide-action-arrow {
  font-size: 34rpx;
  color: #9cb1cf;
}

.tips-card {
  margin-bottom: 8rpx;
}

.tip-line {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.tip-line + .tip-line {
  margin-top: 14rpx;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #0d66d3;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f85a8;
}

.scroll-pad {
  height: 48rpx;
}
