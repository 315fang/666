.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F3ED 0%, #FAFAF8 30%, #F1EEEA 100%);
  padding: 24rpx;
}

.transfer-item {
  background: rgba(255,255,255,0.94);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(37, 29, 21, 0.05);
}

.item-header,
.item-main,
.item-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-main {
  margin-top: 16rpx;
}

.item-info {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9A8D80;
  flex-wrap: wrap;
  gap: 8rpx;
}

.direction {
  display: block;
  font-size: 20rpx;
  color: #A06C46;
}

.counterparty {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1917;
}

.amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #1C1917;
}

.relation {
  font-size: 22rpx;
  color: #9A8D80;
}

.status {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.status-pending { background: rgba(160, 108, 70, 0.10); color: #A06C46; }
.status-success { background: rgba(90, 128, 96, 0.10); color: #5A8060; }
.status-fail { background: rgba(183, 100, 71, 0.10); color: #B76447; }

.reject-reason {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  background: rgba(183, 100, 71, 0.08);
  color: #B76447;
  font-size: 22rpx;
  border-radius: 12rpx;
  line-height: 1.5;
}

.empty-state {
  padding-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-img { width: 80rpx; height: 80rpx; margin-bottom: 20rpx; opacity: 0.25; }
.empty-state text { font-size: 26rpx; color: #B0A396; }
.loading-more, .no-more { text-align: center; padding: 32rpx; font-size: 22rpx; color: #B0A396; }
