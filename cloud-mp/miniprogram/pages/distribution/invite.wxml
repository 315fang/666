<view class="invite-page">
    <view wx:if="{{loading}}" class="loading-wrap">
        <view class="loading-card">
            <view class="spinner"></view>
            <text class="loading-title">正在准备邀请卡</text>
            <text class="loading-desc">稍等一下，我们正在同步您的团队资格与数据。</text>
        </view>
    </view>

    <view wx:elif="{{!canShare}}" class="state-wrap">
        <view class="hero-card muted">
            <text class="hero-eyebrow">团队邀请</text>
            <text class="hero-title">暂时还不能发起邀请</text>
            <text class="hero-desc">您还没有加入团队，先和推荐人完成绑定，之后就可以继续分享邀请问卷了。</text>
            <button class="primary-btn" bindtap="onNoEligibilityTap">查看说明</button>
        </view>
    </view>

    <view wx:else class="content-wrap">
        <view class="hero-card">
            <text class="hero-eyebrow">团队邀请</text>
            <text class="hero-title">{{userInfo.nickname || '伙伴'}}，把问卷发给下一位合伙人</text>
            <text class="hero-desc">好友填写完成后即可进入您的团队，后续下单与成长数据也会同步计入团队表现。</text>
            <button class="primary-btn" open-type="share">分享邀请问卷</button>
        </view>

        <view class="stats-card">
            <view class="card-head">
                <text class="card-title">当前团队规模</text>
                <text class="card-tip">实时同步</text>
            </view>
            <view class="stats-grid">
                <view class="stat-item">
                    <text class="stat-value">{{team.totalCount || 0}}</text>
                    <text class="stat-label">团队总人数</text>
                </view>
                <view class="stat-item">
                    <text class="stat-value">{{team.directCount || 0}}</text>
                    <text class="stat-label">直推成员</text>
                </view>
                <view class="stat-item">
                    <text class="stat-value">{{team.indirectCount || 0}}</text>
                    <text class="stat-label">间接成员</text>
                </view>
            </view>
        </view>

        <view class="info-card">
            <view class="card-head">
                <text class="card-title">邀请奖励</text>
            </view>
            <view class="bullet-list">
                <view class="bullet-item">
                    <view class="bullet-dot"></view>
                    <text class="bullet-text">好友首单返佣按订单金额 10% 结算。</text>
                </view>
                <view class="bullet-item">
                    <view class="bullet-dot"></view>
                    <text class="bullet-text">团队成员持续成交，间接推荐可获得 5% 收益。</text>
                </view>
                <view class="bullet-item">
                    <view class="bullet-dot"></view>
                    <text class="bullet-text">团队越稳定，后续等级与权益空间越大。</text>
                </view>
            </view>
        </view>

        <view class="info-card">
            <view class="card-head">
                <text class="card-title">邀请流程</text>
            </view>
            <view class="steps">
                <view class="step-row">
                    <text class="step-no">01</text>
                    <view class="step-body">
                        <text class="step-title">发送问卷</text>
                        <text class="step-desc">把邀请问卷发给想加入团队的伙伴。</text>
                    </view>
                </view>
                <view class="step-row">
                    <text class="step-no">02</text>
                    <view class="step-body">
                        <text class="step-title">填写资料</text>
                        <text class="step-desc">对方完成基础信息与隐私授权后即可提交。</text>
                    </view>
                </view>
                <view class="step-row">
                    <text class="step-no">03</text>
                    <view class="step-body">
                        <text class="step-title">自动入队</text>
                        <text class="step-desc">问卷通过后会自动归入您的团队关系。</text>
                    </view>
                </view>
            </view>
        </view>

        <view class="action-area">
            <button class="secondary-btn" bindtap="goTeam">查看我的团队</button>
            <button class="ghost-btn" bindtap="goCenter">返回分佣中心</button>
        </view>
    </view>
</view>
