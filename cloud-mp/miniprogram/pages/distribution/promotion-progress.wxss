.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #F7F4EF 0%, #FAFAF8 34%, #F0EEE9 100%);
  overflow: hidden;
}

.overview-card {
  padding: 24rpx 24rpx 0;
  flex-shrink: 0;
}

.overview-inner {
  background: linear-gradient(140deg, #1F2933 0%, #121820 100%);
  border-radius: 24rpx;
  padding: 34rpx;
  display: flex;
  align-items: stretch;
  gap: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(18, 24, 32, 0.16);
}

.overview-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.overview-label,
.side-label {
  font-size: 22rpx;
  color: rgba(244, 247, 250, 0.58);
}

.overview-amount-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
  color: #FFF7EF;
}

.overview-currency {
  font-size: 30rpx;
  font-weight: 700;
  margin-right: 4rpx;
}

.overview-amount {
  font-size: 62rpx;
  font-weight: 800;
  line-height: 1;
}

.overview-sub {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: rgba(244, 247, 250, 0.62);
}

.overview-side {
  width: 184rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.side-block {
  min-height: 82rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.side-amount {
  font-size: 26rpx;
  font-weight: 700;
  color: #D6E7D2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  flex-shrink: 0;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #84786D;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  border: 1rpx solid rgba(122, 108, 94, 0.10);
  flex-shrink: 0;
}

.filter-item.active {
  color: #FFF7EF;
  background: #1C1917;
  border-color: transparent;
  font-weight: 600;
}

.filter-count {
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(132, 120, 109, 0.12);
  color: inherit;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.log-scroll {
  flex: 1;
  overflow: hidden;
}

.log-list {
  padding: 0 24rpx;
}

.log-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 29, 21, 0.04);
}

.log-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: rgba(90, 128, 96, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.log-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.72;
}

.log-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.log-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1917;
}

.log-time {
  font-size: 22rpx;
  color: #B0A396;
}

.log-source,
.log-order {
  font-size: 22rpx;
  color: #8C7E72;
  line-height: 1.5;
}

.log-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 8rpx;
}

.log-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #5A8060;
}

.log-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.status-pending { background: rgba(160, 108, 70, 0.10); color: #A06C46; }
.status-success { background: rgba(90, 128, 96, 0.10); color: #5A8060; }
.status-fail { background: rgba(183, 100, 71, 0.08); color: #B76447; }
.status-gray { background: rgba(154, 141, 128, 0.10); color: #9A8D80; }

.load-footer {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-more {
  font-size: 22rpx;
  color: #B0A396;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.empty-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.25;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #78716C;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #B0A396;
}

.deposit-guide-card {
  margin: 22rpx 0 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(252, 249, 244, 0.96)),
    #FFFDF8;
  border: 1rpx solid #E8DED1;
  box-shadow: 0 8rpx 24rpx rgba(57, 45, 32, 0.06);
}

.deposit-guide-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.deposit-guide-title-wrap {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.deposit-guide-kicker {
  flex-shrink: 0;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  color: #6F4B1C;
  background: rgba(209, 164, 79, 0.16);
  border: 1rpx solid rgba(209, 164, 79, 0.28);
}

.deposit-guide-title {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.deposit-guide-toggle {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 23rpx;
  color: #8C7E72;
}

.deposit-guide-arrow {
  display: inline-block;
  font-size: 24rpx;
  line-height: 1;
  transform: rotate(0deg);
  transition: transform 0.18s ease;
}

.deposit-guide-arrow.expanded {
  transform: rotate(180deg);
}

.deposit-guide-body {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(232, 222, 209, 0.82);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.deposit-guide-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.deposit-guide-index {
  flex: 0 0 42rpx;
  width: 42rpx;
  height: 32rpx;
  border-radius: 10rpx;
  background: #111827;
  color: #FFF7EF;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
}

.deposit-guide-copy {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.55;
  color: #6B7280;
}

.skeleton-wrap {
  padding-top: 4rpx;
}

.sk-log {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.sk-icon,
.sk-line,
.sk-amount-box {
  background: linear-gradient(90deg, #F3EEE9 25%, #EBE2D8 50%, #F3EEE9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.sk-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.sk-info {
  flex: 1;
}

.sk-line {
  height: 24rpx;
  margin-bottom: 12rpx;
}

.sk-long { width: 55%; }
.sk-short { width: 35%; height: 20rpx; }

.sk-amount-box {
  width: 80rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.bottom-space {
  height: 60rpx;
}
