.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F4EF 0%, #FAFAF8 42%, #F0EEE9 100%);
}

.page-scroll {
  height: 100vh;
}

.vault-card {
  margin: 24rpx 24rpx 0;
  padding: 30rpx;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 82% 14%, rgba(200, 164, 100, 0.18), rgba(200, 164, 100, 0) 36%),
    linear-gradient(145deg, #1F2933 0%, #101820 100%);
  color: #FFF7EF;
  box-shadow: 0 18rpx 40rpx rgba(17, 24, 39, 0.18);
  overflow: hidden;
}

.vault-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.vault-kicker {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 247, 239, 0.58);
  margin-bottom: 8rpx;
}

.vault-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.vault-state {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #2A1D09;
  background: #C8A464;
}

.vault-hero {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.vault-copy {
  flex: 1;
  min-width: 0;
}

.vault-amount-row {
  display: flex;
  align-items: baseline;
}

.vault-currency {
  font-size: 32rpx;
  font-weight: 800;
  margin-right: 6rpx;
}

.vault-amount {
  font-size: 74rpx;
  line-height: 0.96;
  font-weight: 900;
  color: #FFFFFF;
}

.vault-hint {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: rgba(255, 247, 239, 0.66);
}

.piggy-visual {
  position: relative;
  width: 194rpx;
  height: 156rpx;
  flex-shrink: 0;
  transform: translateY(4rpx);
}

.piggy-body {
  position: absolute;
  left: 20rpx;
  right: 12rpx;
  bottom: 24rpx;
  height: 98rpx;
  border-radius: 58rpx 64rpx 48rpx 52rpx;
  background: linear-gradient(145deg, #F2D58D 0%, #C8A464 58%, #A97831 100%);
  box-shadow:
    inset 0 8rpx 12rpx rgba(255, 255, 255, 0.28),
    0 12rpx 24rpx rgba(0, 0, 0, 0.16);
}

.piggy-ear {
  position: absolute;
  left: 58rpx;
  top: 35rpx;
  width: 34rpx;
  height: 40rpx;
  border-radius: 28rpx 28rpx 10rpx 10rpx;
  background: #DAB76C;
  transform: rotate(-22deg);
}

.piggy-slot {
  position: absolute;
  left: 52rpx;
  top: 19rpx;
  width: 58rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(42, 29, 9, 0.36);
}

.piggy-eye {
  position: absolute;
  right: 44rpx;
  top: 30rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #2A1D09;
}

.piggy-snout {
  position: absolute;
  right: -10rpx;
  top: 40rpx;
  width: 44rpx;
  height: 32rpx;
  border-radius: 999rpx;
  background: #F0CF82;
  box-shadow: inset 0 2rpx 5rpx rgba(255, 255, 255, 0.24);
}

.piggy-nostril {
  position: absolute;
  top: 12rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(42, 29, 9, 0.48);
}

.piggy-nostril-left {
  left: 12rpx;
}

.piggy-nostril-right {
  right: 12rpx;
}

.piggy-leg {
  position: absolute;
  bottom: 12rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 10rpx 10rpx 14rpx 14rpx;
  background: #A97831;
}

.piggy-leg-left {
  left: 58rpx;
}

.piggy-leg-right {
  right: 48rpx;
}

.piggy-tail {
  position: absolute;
  left: 8rpx;
  bottom: 70rpx;
  width: 30rpx;
  height: 28rpx;
  border: 6rpx solid #C8A464;
  border-right-color: transparent;
  border-bottom-color: transparent;
  border-radius: 999rpx;
  transform: rotate(-18deg);
}

.piggy-coin {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #2A1D09;
  font-weight: 900;
  background: linear-gradient(145deg, #FFE7A6 0%, #C8A464 100%);
  box-shadow: 0 7rpx 16rpx rgba(0, 0, 0, 0.16);
}

.piggy-coin-front {
  left: 88rpx;
  top: 4rpx;
  width: 38rpx;
  height: 38rpx;
  font-size: 23rpx;
}

.piggy-coin-back {
  left: 126rpx;
  top: 22rpx;
  width: 30rpx;
  height: 30rpx;
  font-size: 18rpx;
  opacity: 0.66;
}

.piggy-ready .piggy-coin-front {
  transform: translateY(-8rpx);
}

.vault-progress {
  position: relative;
  height: 12rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  overflow: hidden;
}

.vault-progress-fill {
  height: 100%;
  min-width: 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #C8A464 0%, #D6E7D2 100%);
}

.vault-stages {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 21rpx;
  color: rgba(255, 247, 239, 0.46);
}

.vault-stages .stage-active {
  color: #D6E7D2;
  font-weight: 700;
}

.vault-claim {
  width: 100%;
  height: 82rpx;
  line-height: normal;
  border: 0;
  border-radius: 18rpx;
  margin: 28rpx 0 0;
  font-size: 29rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.vault-claim::after {
  border: 0;
}

.vault-claim-ready {
  color: #111827;
  background: #C8A464;
  box-shadow: 0 12rpx 28rpx rgba(200, 164, 100, 0.26);
}

.vault-claim-wait,
.vault-claim[disabled] {
  color: rgba(255, 247, 239, 0.58);
  background: rgba(255, 255, 255, 0.12);
  box-shadow: none;
  border: 1rpx solid rgba(255, 247, 239, 0.10);
}

.vault-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.vault-metric {
  min-width: 0;
  padding: 16rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
}

.metric-label {
  display: block;
  font-size: 20rpx;
  line-height: 1.3;
  color: rgba(255, 247, 239, 0.52);
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #D6E7D2;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.metric-value-gold {
  color: #F3D189;
}

.rule-strip {
  margin: 18rpx 24rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(200, 164, 100, 0.20);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.rule-strip-expanded {
  align-items: flex-start;
}

.rule-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rule-strip-expanded .rule-main {
  align-items: flex-start;
}

.rule-label {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
  color: #6F4B1C;
  background: rgba(200, 164, 100, 0.16);
}

.rule-copy-wrap {
  flex: 1;
  min-width: 0;
}

.rule-ticker-window {
  height: 34rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.rule-copy {
  font-size: 23rpx;
  line-height: 1.45;
  color: #64748B;
}

.rule-ticker-copy {
  display: block;
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.rule-slide-a,
.rule-slide-b {
  animation: ruleDropIn 420ms ease both;
}

@keyframes ruleDropIn {
  0% {
    opacity: 0;
    transform: translateY(-22rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.rule-detail-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 1rpx;
}

.rule-detail-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.rule-detail-no {
  flex-shrink: 0;
  width: 32rpx;
  line-height: 1.45;
  text-align: right;
  font-size: 22rpx;
  font-weight: 800;
  color: #A97831;
}

.rule-detail-text {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  line-height: 1.45;
  color: #64748B;
}

.rule-toggle {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #8C7E72;
  line-height: 34rpx;
}

.records-panel {
  margin: 18rpx 24rpx 0;
  padding: 24rpx 0 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(57, 45, 32, 0.05);
  overflow: hidden;
}

.records-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx 18rpx;
}

.records-title {
  display: block;
  font-size: 31rpx;
  font-weight: 800;
  color: #111827;
}

.records-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8C7E72;
}

.filter-bar {
  white-space: nowrap;
  padding: 0 24rpx 18rpx;
  box-sizing: border-box;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 58rpx;
  padding: 0 24rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #84786D;
  background: #F7FAFC;
  border-radius: 999rpx;
  border: 1rpx solid rgba(122, 108, 94, 0.12);
  box-sizing: border-box;
}

.filter-item.active {
  color: #FFF7EF;
  background: #111827;
  border-color: #111827;
  font-weight: 700;
}

.filter-count {
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(132, 120, 109, 0.12);
  color: inherit;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.log-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-top: 1rpx solid rgba(31, 41, 51, 0.06);
  background: #FFFFFF;
}

.log-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: rgba(90, 128, 96, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.log-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.72;
}

.log-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.log-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #1C1917;
}

.log-time,
.log-source,
.log-order {
  font-size: 22rpx;
  color: #8C7E72;
  line-height: 1.45;
}

.log-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 8rpx;
}

.log-amount {
  font-size: 29rpx;
  font-weight: 800;
  color: #5A8060;
}

.log-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.status-pending { background: rgba(160, 108, 70, 0.10); color: #A06C46; }
.status-success { background: rgba(90, 128, 96, 0.10); color: #5A8060; }
.status-fail { background: rgba(183, 100, 71, 0.08); color: #B76447; }
.status-gray { background: rgba(154, 141, 128, 0.10); color: #9A8D80; }

.load-footer {
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 1rpx solid rgba(31, 41, 51, 0.06);
}

.no-more {
  font-size: 22rpx;
  color: #B0A396;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 0 88rpx;
  border-top: 1rpx solid rgba(31, 41, 51, 0.06);
}

.empty-icon {
  width: 68rpx;
  height: 68rpx;
  opacity: 0.24;
  margin-bottom: 18rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #78716C;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #B0A396;
}

.skeleton-wrap {
  padding: 0 24rpx 20rpx;
}

.sk-log {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(31, 41, 51, 0.06);
}

.sk-icon,
.sk-line,
.sk-amount-box {
  background: linear-gradient(90deg, #F3EEE9 25%, #EBE2D8 50%, #F3EEE9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.sk-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.sk-info {
  flex: 1;
}

.sk-line {
  height: 24rpx;
  margin-bottom: 12rpx;
}

.sk-long { width: 55%; }
.sk-short { width: 35%; height: 20rpx; }

.sk-amount-box {
  width: 80rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.bottom-space {
  height: 60rpx;
}
