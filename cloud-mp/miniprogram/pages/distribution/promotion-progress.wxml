<view class="container">
  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="vault-card">
      <view class="vault-head">
        <view>
          <text class="vault-title">我的存款</text>
        </view>
      </view>

      <view class="vault-hero">
        <view class="vault-copy">
          <view class="vault-amount-row">
            <text class="vault-currency">¥</text>
            <text class="vault-amount">{{summary.total_amount_text}}</text>
          </view>
          <text class="vault-hint">{{summary.vault_hint_text}}</text>
        </view>
        <view class="piggy-visual {{summary.claimable_amount > 0 ? 'piggy-ready' : ''}}">
          <view class="piggy-coin piggy-coin-back">¥</view>
          <view class="piggy-coin piggy-coin-front">¥</view>
          <view class="piggy-ear"></view>
          <view class="piggy-body">
            <view class="piggy-slot"></view>
            <view class="piggy-eye"></view>
            <view class="piggy-snout">
              <view class="piggy-nostril piggy-nostril-left"></view>
              <view class="piggy-nostril piggy-nostril-right"></view>
            </view>
          </view>
          <view class="piggy-leg piggy-leg-left"></view>
          <view class="piggy-leg piggy-leg-right"></view>
          <view class="piggy-tail"></view>
        </view>
      </view>

      <view class="vault-progress">
        <view class="vault-progress-fill" style="width: {{summary.progress_percent}}%;"></view>
      </view>
      <view class="vault-stages">
        <text>入罐</text>
        <text class="{{summary.claimable_amount > 0 ? 'stage-active' : ''}}">可提取</text>
        <text class="{{summary.unlocked_amount > 0 ? 'stage-active' : ''}}">已入账</text>
      </view>

      <button
        class="vault-claim {{summary.claimable_amount > 0 && !summary.claim_disabled ? 'vault-claim-ready' : 'vault-claim-wait'}}"
        loading="{{depositSubmitting}}"
        disabled="{{depositSubmitting}}"
        bindtap="onClaimToCommission"
      >{{summary.claim_button_text}}</button>

      <view class="vault-metrics">
        <view class="vault-metric">
          <text class="metric-label">可提取转佣金</text>
          <text class="metric-value metric-value-gold">¥{{summary.claimable_amount_text}}</text>
        </view>
        <view class="vault-metric">
          <text class="metric-label">升级可解锁</text>
          <text class="metric-value">¥{{summary.next_level_unlock_amount_text}}</text>
        </view>
      </view>
    </view>

    <view class="rule-strip {{depositGuideExpanded ? 'rule-strip-expanded' : ''}}" bindtap="onToggleDepositGuide">
      <view class="rule-main">
        <text class="rule-label">存款提取规则</text>
        <view class="rule-copy-wrap" wx:if="{{depositGuideExpanded}}">
          <view class="rule-detail-list">
            <view class="rule-detail-item" wx:for="{{depositRuleDetails}}" wx:key="no">
              <text class="rule-detail-no">{{item.no}}</text>
              <text class="rule-detail-text">{{item.text}}</text>
            </view>
          </view>
        </view>
      </view>
      <text class="rule-toggle">{{depositGuideExpanded ? '收起' : '展开'}}</text>
    </view>

    <view class="records-panel">
      <view class="records-head">
        <view>
          <text class="records-title">存款明细</text>
        </view>
      </view>

      <view class="filter-bar">
        <view
          class="filter-item {{currentStatus === item.status ? 'active' : ''}}"
          wx:for="{{statusTabs}}"
          wx:key="status"
          bindtap="onStatusChange"
          data-status="{{item.status}}"
        >
          <text>{{item.label}}</text>
          <text class="filter-count" wx:if="{{item.count > 0}}">{{item.count}}</text>
        </view>
      </view>

      <view class="skeleton-wrap" wx:if="{{loading && logs.length === 0}}">
        <view class="sk-log" wx:for="{{[1,2,3]}}" wx:key="index">
          <view class="sk-icon"></view>
          <view class="sk-info">
            <view class="sk-line sk-long"></view>
            <view class="sk-line sk-short"></view>
          </view>
          <view class="sk-amount-box"></view>
        </view>
      </view>

      <view class="log-item" wx:for="{{filteredLogs}}" wx:key="id">
        <view class="log-icon-wrap">
          <image src="/assets/icons/dollar-sign.svg" mode="aspectFit" class="log-icon"></image>
        </view>
        <view class="log-info">
          <text class="log-title">{{item.title}}</text>
          <text class="log-source">{{item.sourceText}}</text>
          <text class="log-time">{{item.created_at_text}}</text>
        </view>
        <view class="log-right">
          <text class="log-amount">+¥{{item.amount}}</text>
          <view class="log-status {{item.statusClass}}">{{item.statusText}}</view>
        </view>
      </view>

      <view class="load-footer" wx:if="{{!loading && filteredLogs.length > 0}}">
        <text class="no-more">没有更多了</text>
      </view>

      <view class="empty-state" wx:if="{{!loading && filteredLogs.length === 0}}">
        <image src="/assets/icons/dollar-sign.svg" mode="aspectFit" class="empty-icon"></image>
        <text class="empty-title">暂无存款明细</text>
        <text class="empty-desc">升级奖励产生后，会先放进存钱罐</text>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>
</view>
