<view class="container">
  <view class="overview-card">
    <view class="overview-inner">
      <view class="overview-main">
        <text class="overview-label">已存升级奖励</text>
        <view class="overview-amount-row">
          <text class="overview-currency">¥</text>
          <text class="overview-amount">{{summary.locked_amount_text}}</text>
        </view>
        <text class="overview-sub">{{summary.next_unlock_text}}</text>
      </view>
      <view class="overview-side">
        <view class="side-block">
          <text class="side-label">已入账</text>
          <text class="side-amount">¥{{summary.unlocked_amount_text}}</text>
        </view>
        <view class="side-block">
          <text class="side-label">待入账</text>
          <text class="side-amount">¥{{summary.unlockable_amount_text}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="filter-bar">
    <view
      class="filter-item {{currentStatus === item.status ? 'active' : ''}}"
      wx:for="{{statusTabs}}"
      wx:key="status"
      bindtap="onStatusChange"
      data-status="{{item.status}}"
    >
      <text>{{item.label}}</text>
      <text class="filter-count" wx:if="{{item.count > 0}}">{{item.count}}</text>
    </view>
  </view>

  <scroll-view class="log-scroll" scroll-y>
    <view class="log-list">
      <view class="skeleton-wrap" wx:if="{{loading && logs.length === 0}}">
        <view class="sk-log" wx:for="{{[1,2,3,4,5]}}" wx:key="index">
          <view class="sk-icon"></view>
          <view class="sk-info">
            <view class="sk-line sk-long"></view>
            <view class="sk-line sk-short"></view>
          </view>
          <view class="sk-amount-box"></view>
        </view>
      </view>

      <view class="log-item" wx:for="{{filteredLogs}}" wx:key="id">
        <view class="log-icon-wrap">
          <image src="/assets/icons/dollar-sign.svg" mode="aspectFit" class="log-icon"></image>
        </view>
        <view class="log-info">
          <text class="log-title">{{item.title}}</text>
          <text class="log-time">{{item.created_at_text}}</text>
          <text class="log-source">{{item.sourceText}}</text>
          <text class="log-order" wx:if="{{item.orderNoDisplay}}">订单：{{item.orderNoDisplay}}</text>
        </view>
        <view class="log-right">
          <text class="log-amount">+¥{{item.amount}}</text>
          <view class="log-status {{item.statusClass}}">{{item.statusText}}</view>
        </view>
      </view>

      <view class="load-footer" wx:if="{{!loading && filteredLogs.length > 0}}">
        <text class="no-more">没有更多了</text>
      </view>

      <view class="empty-state" wx:if="{{!loading && filteredLogs.length === 0}}">
        <image src="/assets/icons/dollar-sign.svg" mode="aspectFit" class="empty-icon"></image>
        <text class="empty-title">暂无存款明细</text>
        <text class="empty-desc">产生升级奖励后会在这里显示预计收益</text>
      </view>

      <view class="deposit-guide-card">
        <view class="deposit-guide-head" bindtap="onToggleDepositGuide">
          <view class="deposit-guide-title-wrap">
            <text class="deposit-guide-kicker">说明</text>
            <text class="deposit-guide-title">我的存款怎么玩</text>
          </view>
          <view class="deposit-guide-toggle">
            <text>{{depositGuideExpanded ? '收起' : '展开'}}</text>
            <text class="deposit-guide-arrow {{depositGuideExpanded ? 'expanded' : ''}}">⌄</text>
          </view>
        </view>
        <view class="deposit-guide-body" wx:if="{{depositGuideExpanded}}">
          <view class="deposit-guide-row">
            <text class="deposit-guide-index">01</text>
            <text class="deposit-guide-copy">产生升级奖励后，会先记录为预计收益。</text>
          </view>
          <view class="deposit-guide-row">
            <text class="deposit-guide-index">02</text>
            <text class="deposit-guide-copy">达到对应等级或解锁条件后，预计收益会转为已入账。</text>
          </view>
          <view class="deposit-guide-row">
            <text class="deposit-guide-index">03</text>
            <text class="deposit-guide-copy">订单退款、取消或奖励回滚时，对应记录会显示为已失效或已扣回。</text>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>
</view>
