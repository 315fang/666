<view class="page" wx:if="{{!loading}}">

  <!-- 当前等级 -->
  <view class="current-level" wx:if="{{progress}}">
    <view class="level-badge">{{progress.current_name}}</view>
    <view class="level-stats">
      <view class="stat">
        <text class="stat-val">¥{{progress.stats.total_spent || 0}}</text>
        <text class="stat-lbl">累计消费</text>
      </view>
      <view class="stat">
        <text class="stat-val">{{progress.stats.growth_value || 0}}</text>
        <text class="stat-lbl">成长值</text>
      </view>
      <view class="stat">
        <text class="stat-val">¥{{progress.stats.recharge_total || 0}}</text>
        <text class="stat-lbl">累计充值</text>
      </view>
      <view class="stat">
        <text class="stat-val">{{progress.stats.c1_count || 0}}</text>
        <text class="stat-lbl">C1推荐数</text>
      </view>
      <view class="stat">
        <text class="stat-val">{{progress.stats.b1_count || 0}}</text>
        <text class="stat-lbl">B1推荐数</text>
      </view>
    </view>
  </view>

  <!-- 升级存钱罐 -->
  <view class="piggy-card" wx:if="{{progress && progress.piggy_bank}}">
    <view class="piggy-head">
      <view>
        <text class="piggy-title">升级存钱罐</text>
        <text class="piggy-sub" wx:if="{{progress.next_name}}">升至 {{progress.next_name}} 可解锁</text>
        <text class="piggy-sub" wx:else>已达当前最高目标</text>
      </view>
      <view class="piggy-amount-box">
        <text class="piggy-currency">¥</text>
        <text class="piggy-amount">{{progress.piggy_bank.next_level_unlock_amount_text}}</text>
      </view>
    </view>
    <view class="piggy-summary">
      <view class="piggy-summary-item">
        <text class="piggy-summary-value">¥{{progress.piggy_bank.locked_amount_text}}</text>
        <text class="piggy-summary-label">锁定中</text>
      </view>
      <view class="piggy-summary-item">
        <text class="piggy-summary-value">¥{{progress.piggy_bank.unlocked_amount_text}}</text>
        <text class="piggy-summary-label">已解锁</text>
      </view>
      <view class="piggy-summary-item">
        <text class="piggy-summary-value">¥{{progress.piggy_bank.unlockable_amount_text}}</text>
        <text class="piggy-summary-label">待入账</text>
      </view>
    </view>
    <scroll-view class="piggy-buckets" scroll-x>
      <view class="piggy-bucket-list">
        <view class="piggy-bucket {{item.has_amount ? 'active' : ''}}" wx:for="{{progress.piggy_bank.buckets}}" wx:key="target_level">
          <text class="piggy-bucket-name">{{item.target_name}}</text>
          <text class="piggy-bucket-amount">¥{{item.locked_amount_text}}</text>
          <text class="piggy-bucket-sub">已解 ¥{{item.unlocked_amount_text}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 下一级目标 -->
  <view class="next-target" wx:if="{{progress && progress.next_level != null}}">
    <view class="section-title">距离 {{progress.next_name}}</view>
    <view class="conditions">
      <view class="condition" wx:for="{{progress.conditions}}" wx:key="label">
        <view class="cond-header">
          <text class="cond-label">{{item.label}}</text>
          <text class="cond-status {{item.met ? 'met' : ''}}">{{item.met ? '✓ 已达成' : item.current + ' / ' + item.target}}</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill {{item.met ? 'full' : ''}}" style="width: {{item.met ? 100 : (item.target > 0 ? (item.current / item.target * 100 > 100 ? 100 : item.current / item.target * 100) : 0)}}%"></view>
        </view>
      </view>
    </view>
  </view>
  <view class="max-level" wx:elif="{{progress && progress.next_level == null}}">
    <text>🎉 已达最高等级</text>
  </view>

  <!-- 晋升历史 -->
  <view class="history-section" wx:if="{{logs.length > 0}}">
    <view class="section-title">晋升记录</view>
    <view class="timeline">
      <view class="timeline-item" wx:for="{{logs}}" wx:key="_id">
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <view class="timeline-title">{{item.from_name}} → {{item.to_name}}</view>
          <view class="timeline-desc">
            <text wx:if="{{item.trigger_type === 'recharge'}}">通过充值晋升</text>
            <text wx:elif="{{item.trigger_type === 'growth'}}">通过成长值晋升</text>
            <text wx:else>通过推荐业绩晋升</text>
          </view>
          <view class="timeline-meta">
            <text>消费 ¥{{item.total_spent || 0}}</text>
            <text>成长值 {{item.growth_value || 0}}</text>
            <text>充值 ¥{{item.recharge_total || 0}}</text>
            <text>下级 {{item.direct_member_count || 0}} 人</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="empty" wx:elif="{{!progress}}">
    <text>暂无晋升数据</text>
  </view>
</view>

<view class="loading" wx:else>
  <text>加载中...</text>
</view>
