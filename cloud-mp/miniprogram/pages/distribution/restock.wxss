page {
  background: #f7f1e8;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top left, rgba(164, 117, 62, 0.12), transparent 34%),
    linear-gradient(180deg, #fbf7f0 0%, #f4ece0 100%);
}

.hero-card,
.section-card,
.product-card,
.empty-card {
  border-radius: 28rpx;
  background: rgba(255, 252, 247, 0.96);
  border: 1rpx solid rgba(118, 83, 45, 0.12);
  box-shadow: 0 18rpx 40rpx rgba(84, 52, 26, 0.08);
}

.hero-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(145deg, #fffaf4 0%, #f4e8d9 100%);
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  color: #9a6d3f;
  letter-spacing: 4rpx;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 38rpx;
  line-height: 1.3;
  color: #3e2b1f;
  font-weight: 700;
}

.hero-inline {
  margin-top: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.6);
}

.hero-label {
  font-size: 24rpx;
  color: #8c6b4d;
}

.hero-value {
  font-size: 36rpx;
  color: #412919;
  font-weight: 700;
}

.section-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-head.compact {
  margin-bottom: 22rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #3f2a1d;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8c7158;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  position: relative;
}

.product-card.selected {
  border-color: rgba(109, 69, 35, 0.34);
  box-shadow: 0 18rpx 44rpx rgba(84, 52, 26, 0.11);
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 22rpx;
  background: #efe4d5;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-name {
  font-size: 28rpx;
  color: #362316;
  font-weight: 600;
}

.product-price {
  font-size: 28rpx;
  color: #7b4522;
  font-weight: 700;
}

.product-retail,
.product-stock {
  font-size: 22rpx;
  color: #937760;
}

.select-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #4b2d17;
  color: #fff7ef;
  font-size: 22rpx;
}

.quantity-panel {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.quantity-label {
  font-size: 28rpx;
  color: #5b3d26;
  font-weight: 600;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.qty-btn,
.qty-input {
  height: 64rpx;
  border-radius: 18rpx;
  background: #f5ede2;
  color: #4d3320;
}

.qty-btn {
  width: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
}

.qty-input {
  width: 128rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
}

.quick-row {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.quick-btn {
  min-width: 132rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #f3e7d8;
  color: #79583e;
  text-align: center;
  font-size: 24rpx;
}

.quick-btn.active {
  background: linear-gradient(135deg, #4c2f17 0%, #7b512c 100%);
  color: #fff7ef;
}

.summary-box {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #f6eee4;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.summary-label {
  display: block;
  font-size: 24rpx;
  color: #8c6f56;
}

.summary-note {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #a0846a;
}

.summary-total {
  font-size: 42rpx;
  font-weight: 700;
  color: #7a4220;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 24rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 247, 0.96);
  box-shadow: 0 -12rpx 36rpx rgba(84, 52, 26, 0.08);
}

.action-summary {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.summary-qty {
  font-size: 22rpx;
  color: #8f7660;
}

.summary-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: #432a18;
}

.action-btn {
  min-width: 250rpx;
  text-align: center;
  padding: 24rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4a2c15 0%, #79502d 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-card {
  padding: 64rpx 24rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #412b1c;
  font-weight: 700;
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #907761;
}
