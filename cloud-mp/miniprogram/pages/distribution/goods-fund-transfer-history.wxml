<view class="container">
  <view class="list-section">
    <view class="transfer-item" wx:for="{{list}}" wx:key="application_id">
      <view class="item-header">
        <view>
          <text class="direction">{{item.direction_text}}</text>
          <text class="counterparty">{{item.counterparty_text}}</text>
        </view>
        <text class="status {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <view class="item-main">
        <text class="amount">¥{{item.amount_text}}</text>
        <text class="relation">{{item.relation_source_text || '普通邀请'}}</text>
      </view>
      <view class="item-info">
        <text class="time">申请时间：{{item.created_at_text}}</text>
        <text class="review-time" wx:if="{{item.reviewed_at_text}}">审核时间：{{item.reviewed_at_text}}</text>
      </view>
      <view class="item-info">
        <text>单号：{{item.application_no}}</text>
      </view>
      <view class="reject-reason" wx:if="{{item.review_reason}}">
        审核说明：{{item.review_reason}}
      </view>
    </view>

    <view class="empty-state" wx:if="{{list.length === 0 && !loading}}">
      <image src="/assets/images/placeholder.svg" mode="aspectFit" class="empty-img"></image>
      <text>暂无货款划拨申请记录</text>
    </view>

    <view class="loading-more" wx:if="{{loading}}">加载中...</view>
    <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>
  </view>
</view>
