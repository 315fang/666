<view class="container">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack">
        <image class="back-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"></image>
      </view>
      <text class="nav-title">邀请海报</text>
    </view>
  </view>

  <view class="page-body">
    <view class="poster-section">
      <!-- 与分享链接 ?invite= 一致，为邀请码（非后台「会员码 member_no」） -->
      <view class="invite-code-row" wx:if="{{memberCode}}">
        <text class="invite-code-label">我的邀请码</text>
        <text class="invite-code-value">{{memberCode}}</text>
        <view class="invite-code-copy" bindtap="onCopyCode">复制</view>
      </view>

      <!-- 海报预览（静态整张图不挂载 Canvas） -->
      <view class="poster-preview-wrap">
        <canvas
          wx:if="{{!posterImagePath || posterGenerating}}"
          id="posterCanvas"
          type="2d"
          class="poster-canvas"
        ></canvas>
        <image
          wx:if="{{posterImagePath && !posterGenerating}}"
          class="poster-result-img"
          src="{{posterImagePath}}"
          mode="aspectFit"
          show-menu-by-longpress
        ></image>
        <view class="poster-generating" wx:if="{{posterGenerating && !posterImagePath}}">
          <view class="poster-spin"></view>
          <text class="poster-gen-text">海报生成中...</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="poster-actions">
        <view class="poster-action-btn poster-action-secondary" bindtap="onRegeneratePoster">
          <text class="poster-action-text-secondary">重新生成</text>
        </view>
        <view class="poster-action-btn poster-action-primary {{!posterImagePath ? 'btn-disabled' : ''}}" bindtap="onSavePoster">
          <text class="poster-action-text">保存到相册</text>
        </view>
      </view>

      <view class="poster-tip">长按海报可直接分享或保存</view>
    </view>
    <view class="page-bottom-spacer"></view>
  </view>
</view>
