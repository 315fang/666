<!--pages/distribution/center.wxml - 分销中心（重新设计版）-->
<view class="container">
  
  <!-- 1. 顶部背景 + 核心信息 -->
  <view class="header-bg">
    <view class="header-content">
      <!-- 用户信息行 -->
      <view class="user-row" bindtap="onProfileTap">
        <image class="avatar" src="{{userInfo.avatar || userInfo.avatar_url || '/assets/images/default-avatar.svg'}}" mode="aspectFill"></image>
        <view class="user-info">
          <text class="nickname">{{userInfo.nick_name || userInfo.nickname || '微信用户'}}</text>
          <view class="role-badge">{{userInfo.role_name || '普通用户'}}</view>
        </view>
        <view class="arrow">›</view>
      </view>

      <view class="growth-mini">
        <view class="growth-line">
          <text>积分 {{growthValue || 0}}</text>
          <text wx:if="{{growthLoaded && nextGrowthThreshold}}">下一级 {{nextGrowthThreshold}}</text>
          <text wx:elif="{{growthLoaded}}">已达最高等级</text>
        </view>
        <view class="growth-bar-bg">
          <view class="growth-bar-fill" style="width: {{growthPercent || 0}}%"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 2. 用户与渠道摘要 -->
  <view class="section-card">
    <view class="section-title">
      <view class="title-left">
        <view class="title-dot"></view>
        <text>用户与渠道摘要</text>
      </view>
    </view>

    <view class="stats-bar inline-stats">
      <view class="stat-item" bindtap="onTeamTap">
        <view class="stat-value">{{team.totalCount || 0}}<text class="unit">人</text></view>
        <view class="stat-label">我的团队</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onOrderTap">
        <view class="stat-value">-</view>
        <view class="stat-label">分销订单</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onInviteTap">
        <view class="stat-value">-</view>
        <view class="stat-label">邀请成员</view>
      </view>
    </view>

    <view class="menu-section">
      <view class="menu-item" bindtap="onTeamTap">
        <view class="menu-left">
          <view class="menu-icon team">
            <image class="icon-img" src="/assets/icons/users.svg" mode="aspectFit"/>
          </view>
          <text class="menu-name">我的团队</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="onOrderTap">
        <view class="menu-left">
          <view class="menu-icon order">
            <image class="icon-img" src="/assets/icons/shopping-bag.svg" mode="aspectFit"/>
          </view>
          <text class="menu-name">分销订单</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="onPromotionProgress">
        <view class="menu-left">
          <view class="menu-icon promotion">
            <image class="icon-img" src="/assets/icons/trending-up.svg" mode="aspectFit"/>
          </view>
          <text class="menu-name">升级存钱罐</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="onInviteTap">
        <view class="menu-left">
          <view class="menu-icon share">
            <image class="icon-img" src="/assets/icons/share.svg" mode="aspectFit"/>
          </view>
          <text class="menu-name">团队邀请</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 3. 资金摘要 -->
  <view class="section-card">
    <view class="section-title">
      <view class="title-left">
        <view class="title-dot"></view>
        <text>资金摘要</text>
      </view>
    </view>

    <view class="fund-overview">
      <view class="fund-main">
        <text class="fund-label">可提现佣金</text>
        <text class="fund-value">¥{{balance || '0.00'}}</text>
      </view>
      <view class="fund-actions">
        <button class="fund-btn primary" bindtap="onWithdrawTap">提现</button>
      </view>
    </view>

    <view class="stats-bar inline-stats">
      <view class="stat-item" bindtap="onCommissionLogsTap">
        <view class="stat-value">¥{{stats.totalEarnings || '0.00'}}</view>
        <view class="stat-label">累计收益</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">¥{{stats.frozenAmount || '0.00'}}</view>
        <view class="stat-label">待结算</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" wx:if="{{isAgent}}">
        <view class="stat-value">¥{{goodsFundBalance || '0.00'}}</view>
        <view class="stat-label">货款余额</view>
      </view>
    </view>

    <view class="menu-section">
      <view class="menu-item" bindtap="onCommissionLogsTap">
        <view class="menu-left">
          <view class="menu-icon commission">
            <image class="icon-img" src="/assets/icons/dollar-sign.svg" mode="aspectFit"/>
          </view>
          <text class="menu-name">佣金明细</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="onWithdrawHistoryTap">
        <view class="menu-left">
          <view class="menu-icon commission">
            <image class="icon-img" src="/assets/icons/list.svg" mode="aspectFit"/>
          </view>
          <text class="menu-name">提现记录</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="onFundPoolTap">
        <view class="menu-left">
          <view class="menu-icon promotion">
            <image class="icon-img" src="/assets/icons/dollar-sign.svg" mode="aspectFit"/>
          </view>
          <text class="menu-name">我的基金池</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="onGoodsFundTransferHistoryTap">
        <view class="menu-left">
          <view class="menu-icon share">
            <image class="icon-img" src="/assets/icons/dollar-sign.svg" mode="aspectFit"/>
          </view>
          <text class="menu-name">货款划拨记录</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 4. 代理商专区 (仅代理可见) -->
  <view class="section-card agent-section" wx:if="{{isAgent}}">
    <view class="section-title">
      <view class="title-left">
        <view class="title-dot"></view>
        <text>代理商工作台</text>
      </view>
      <view class="agent-badge">专属</view>
    </view>
    <view class="agent-grid">
      <view class="agent-item highlight" bindtap="goWorkbench">
        <view class="item-icon">
          <image src="/assets/icons/truck.svg" mode="aspectFit"/>
        </view>
        <view class="item-content">
          <text class="item-title">发货管理</text>
          <text class="item-desc">处理订单、发货</text>
        </view>
        <view class="item-badge" wx:if="{{agentPending > 0}}">{{agentPending}}</view>
      </view>
      <view class="agent-item" bindtap="onRechargeGoodsFund">
        <view class="item-icon">
          <image src="/assets/icons/package.svg" mode="aspectFit"/>
        </view>
        <view class="item-content">
          <text class="item-title">货款充值</text>
          <text class="item-desc">补充发货货款</text>
        </view>
      </view>
      <view class="agent-item" bindtap="goGoodsFundLogs">
        <view class="item-icon">
          <image src="/assets/icons/list.svg" mode="aspectFit"/>
        </view>
        <view class="item-content">
          <text class="item-title">货款流水</text>
          <text class="item-desc">查看充值与扣减</text>
        </view>
      </view>
      <view class="agent-item" bindtap="onCommissionToFund">
        <view class="item-icon">
          <image src="/assets/icons/dollar-sign.svg" mode="aspectFit"/>
        </view>
        <view class="item-content">
          <text class="item-title">佣金转货款</text>
          <text class="item-desc">1:1 转入货款余额</text>
        </view>
      </view>
    </view>

    <view class="fund-actions mt-3">
      <button class="fund-btn plain" bindtap="goAgentPortal">复制网页端链接</button>
    </view>
  </view>

  <!-- 分享弹窗 -->
  <view class="share-modal {{showShareModal ? 'show' : ''}}">
    <view class="mask" bindtap="hideShareModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text>分享邀请</text>
        <view class="close" bindtap="hideShareModal">×</view>
      </view>
      <view class="qr-section">
        <text class="qr-tip">点击下方按钮分享给好友</text>
      </view>
      <view class="share-actions">
        <button class="action-btn primary" bindtap="goInvitePosterPage">
          <image class="btn-icon-img" src="/assets/icons/message.svg" mode="aspectFit"/>
          <text>发给微信好友</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 提现弹窗 -->
  <view class="withdraw-popup {{showWithdraw ? 'show' : ''}}">
    <view class="mask" bindtap="hideWithdraw"></view>
    <view class="popup-content">
      <view class="popup-title">申请提现</view>
      <view class="popup-balance">可提现余额：¥{{balance}}</view>
      <view class="popup-fee-hint">
        <text class="fee-text">提现规则：{{withdrawRules.ruleText}}</text>
      </view>
      <input class="popup-input" type="digit" placeholder="请输入提现金额" bindinput="onWithdrawInput" value="{{withdrawAmount}}" maxlength="10" />
      <view class="popup-fee-calc" wx:if="{{withdrawAmount}}">
        <text class="fee-calc-text">手续费约：¥{{withdrawFee}}，实际到账约：¥{{withdrawActual}}</text>
      </view>
      <button class="popup-btn" bindtap="confirmWithdraw">确认提现</button>
    </view>
  </view>
  <!-- 品牌动画（提现成功等） -->
  <brand-animation id="brandAnimation"></brand-animation>
  <portal-password-dialog id="portalPasswordDialog" />
</view>
