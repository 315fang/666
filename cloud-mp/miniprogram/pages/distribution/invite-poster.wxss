.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F3ED 0%, #FAFAF8 30%, #F1EEEA 100%);
  box-sizing: border-box;
}

.nav-bar {
  background: #2E2218;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 200;
}
.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.85;
}
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #FFF8F0;
}

.page-body {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

.page-bottom-spacer {
  height: calc(60rpx + env(safe-area-inset-bottom));
}

.poster-section {
  padding: 24rpx;
}

.invite-code-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 29, 21, 0.05);
}
.invite-code-label {
  font-size: 22rpx;
  color: #9A8D80;
}
.invite-code-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E1710;
  letter-spacing: 3rpx;
  flex: 1;
  min-width: 200rpx;
}
.invite-code-copy {
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
  font-size: 24rpx;
  font-weight: 600;
  color: #FFF8F0;
}

.poster-variant-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.poster-variant-label {
  font-size: 24rpx;
  color: #7F7266;
  flex-shrink: 0;
}

.poster-variant-switch {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 4rpx 16rpx rgba(37, 29, 21, 0.05);
}

.poster-variant-chip {
  min-width: 168rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-variant-chip--active {
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
  box-shadow: 0 8rpx 20rpx rgba(160, 120, 64, 0.22);
}

.poster-variant-chip-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #7F7266;
}

.poster-variant-chip-text--active {
  color: #FFF8F0;
}

.poster-preview-wrap {
  background: #FDF8F2;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  width: 100%;
  aspect-ratio: 600 / 760;
  box-shadow: 0 8rpx 40rpx rgba(180, 120, 40, 0.12), 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.poster-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.poster-result-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.poster-generating {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: rgba(30, 20, 14, 0.6);
}
.poster-spin {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.15);
  border-top-color: #C8A258;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.poster-gen-text {
  font-size: 26rpx;
  color: rgba(255, 248, 240, 0.75);
}

.poster-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
.poster-action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.poster-action-primary {
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
}
.poster-action-secondary {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #DDD5CB;
}
.poster-action-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFF8F0;
}
.poster-action-text-secondary {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E1710;
}
.btn-disabled {
  opacity: 0.4;
}
.btn-muted {
  opacity: 0.55;
}

.poster-tip {
  text-align: center;
  font-size: 22rpx;
  color: #B0A090;
  margin-top: 14rpx;
}
