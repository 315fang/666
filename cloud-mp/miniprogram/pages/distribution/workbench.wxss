page {
  background: #f7f1e8;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top right, rgba(183, 145, 92, 0.14), transparent 32%),
    linear-gradient(180deg, #fbf7f0 0%, #f4ece0 100%);
}

.hero-card,
.section-card,
.order-card {
  border-radius: 28rpx;
  background: rgba(255, 252, 247, 0.96);
  border: 1rpx solid rgba(118, 83, 45, 0.12);
  box-shadow: 0 18rpx 40rpx rgba(84, 52, 26, 0.08);
}

.hero-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(145deg, #fffaf4 0%, #f4e8d9 100%);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  color: #9a6d3f;
  letter-spacing: 4rpx;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.25;
  color: #3e2b1f;
  font-weight: 700;
}

.hero-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(128, 92, 52, 0.08);
  color: #7a5531;
  font-size: 22rpx;
}

.hero-badge-icon {
  width: 26rpx;
  height: 26rpx;
}

.hero-main {
  margin-bottom: 28rpx;
}

.hero-stock {
  display: block;
  font-size: 76rpx;
  line-height: 1;
  font-weight: 700;
  color: #3d2715;
}

.hero-stock-unit {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #876647;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.metric-cell {
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.62);
}

.metric-cell.accent {
  background: linear-gradient(135deg, #4c2f17 0%, #7b512c 100%);
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: #907156;
}

.metric-value {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #362316;
}

.metric-cell.accent .metric-label,
.metric-cell.accent .metric-value {
  color: #fff8ef;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
}

.hero-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.hero-btn-primary {
  background: linear-gradient(135deg, #4a2c15 0%, #79502d 100%);
  color: #fff;
}

.hero-btn-ghost {
  background: rgba(121, 80, 45, 0.08);
  color: #6e4b2c;
  border: 1rpx solid rgba(121, 80, 45, 0.14);
}

.section-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #3f2a1d;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8c7158;
}

.pill-scroll {
  width: 100%;
}

.pill-row {
  display: flex;
  gap: 16rpx;
}

.status-pill {
  position: relative;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #f4eadf;
  color: #715237;
  white-space: nowrap;
  font-size: 24rpx;
}

.status-pill.active {
  background: linear-gradient(135deg, #4b2d17 0%, #7b532e 100%);
  color: #fff7ef;
}

.pill-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #cf4a3c;
  color: #fff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  padding: 28rpx;
}

.order-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.order-no {
  font-size: 24rpx;
  color: #8b715a;
}

.order-state {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #efe3d3;
  color: #7a5532;
  font-size: 22rpx;
}

.order-body {
  display: flex;
  gap: 20rpx;
}

.product-thumb {
  width: 132rpx;
  height: 132rpx;
  border-radius: 22rpx;
  background: #efe4d5;
  flex-shrink: 0;
}

.product-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.product-name {
  font-size: 28rpx;
  line-height: 1.4;
  color: #342217;
  font-weight: 600;
}

.product-extra {
  font-size: 24rpx;
  color: #8e735b;
}

.product-price {
  font-size: 30rpx;
  color: #7a3f20;
  font-weight: 700;
}

.address-box {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f6eee4;
}

.address-name {
  display: block;
  font-size: 24rpx;
  color: #5b3d26;
  font-weight: 600;
}

.address-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #8b6e54;
}

.order-foot {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(110, 76, 46, 0.08);
}

.order-tip {
  font-size: 24rpx;
  color: #7a5e45;
}

.empty-card {
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #40291c;
  font-weight: 700;
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #917661;
}

.loading-block {
  text-align: center;
  padding: 24rpx 0 32rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #8c745f;
}
