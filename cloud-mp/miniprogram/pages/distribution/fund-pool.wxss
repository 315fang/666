.page { padding: 20rpx 30rpx; background: #f5f7fa; min-height: 100vh; }
.loading { display: flex; justify-content: center; align-items: center; min-height: 60vh; color: #999; font-size: 28rpx; }

.summary-card {
  background: linear-gradient(135deg, #B98B58 0%, #8D6A3F 100%);
  border-radius: 20rpx;
  padding: 50rpx 30rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 24rpx;
}
.summary-amount { font-size: 56rpx; font-weight: 700; margin-bottom: 8rpx; }
.summary-label { font-size: 28rpx; opacity: 0.9; margin-bottom: 8rpx; }
.summary-count { font-size: 24rpx; opacity: 0.7; }

.pool-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.section-head { margin-bottom: 20rpx; }
.section-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.section-tip { font-size: 22rpx; color: #909399; line-height: 1.6; }
.pool-badge {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}
.pool-badge.enabled { color: #0f766e; background: rgba(15, 118, 110, 0.12); }
.pool-badge.disabled { color: #6b7280; background: rgba(107, 114, 128, 0.12); }
.overview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.overview-item {
  background: #faf8f5;
  border-radius: 12rpx;
  padding: 22rpx 18rpx;
}
.overview-label { font-size: 22rpx; color: #909399; margin-bottom: 8rpx; }
.overview-value { font-size: 30rpx; font-weight: 600; color: #303133; }

.sub-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.section-title { font-size: 30rpx; font-weight: 600; color: #303133; margin-bottom: 20rpx; }
.sub-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.sub-item {
  background: #faf8f5;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  text-align: center;
}
.sub-amount { font-size: 32rpx; font-weight: 600; color: #B98B58; margin-bottom: 6rpx; }
.sub-label { font-size: 24rpx; color: #909399; }

.entries-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.empty-entries { text-align: center; padding: 60rpx 0; color: #c0c4cc; font-size: 28rpx; }
.entry-list { display: flex; flex-direction: column; gap: 1rpx; }
.entry-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}
.entry-item:last-child { border-bottom: none; }
.entry-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.entry-source { font-size: 28rpx; font-weight: 500; color: #303133; }
.entry-amount { font-size: 30rpx; font-weight: 600; color: #B98B58; }
.entry-sub { margin-bottom: 8rpx; }
.entry-sub-text { font-size: 22rpx; color: #909399; line-height: 1.6; }
.entry-footer { display: flex; align-items: center; }
.entry-date { font-size: 22rpx; color: #c0c4cc; }
