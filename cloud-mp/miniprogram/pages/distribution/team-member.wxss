.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(94, 177, 255, 0.32), transparent 24%),
    linear-gradient(180deg, #0d59bc 0%, #0d6bd8 24%, #eef5ff 24%, #f5f9ff 100%);
  display: flex;
  flex-direction: column;
}

.nav-bar {
  background: transparent;
  flex-shrink: 0;
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  position: relative;
}

.nav-back,
.nav-right {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.95;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.main-scroll {
  flex: 1;
  height: 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.hero-card {
  margin: 18rpx 24rpx 0;
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(155deg, rgba(255, 255, 255, 0.26), rgba(255, 255, 255, 0.12));
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow: 0 24rpx 48rpx rgba(10, 61, 129, 0.22);
}

.hero-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
  border: 4rpx solid rgba(255, 255, 255, 0.18);
  flex-shrink: 0;
}

.hero-meta {
  flex: 1;
  min-width: 0;
}

.hero-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.hero-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.hero-pill {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #0d61ce;
}

.hero-pill.light {
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
}

.hero-relation {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.76);
}

.hero-relation.inviter {
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.9);
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-stat {
  min-height: 124rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(5, 24, 53, 0.18);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.hero-stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.68);
}

.hero-stat-value {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #ffffff;
  word-break: break-all;
}

.hero-stat-value.small {
  font-size: 24rpx;
}

.detail-section,
.action-card {
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(18, 69, 140, 0.08);
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #12366a;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8ea1be;
  line-height: 1.55;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.detail-card {
  min-height: 120rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f9ff;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.detail-label {
  font-size: 20rpx;
  color: #8da3c1;
}

.detail-value {
  font-size: 26rpx;
  line-height: 1.5;
  color: #12366a;
  font-weight: 600;
  word-break: break-all;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: linear-gradient(180deg, #f6f9ff 0%, #edf4ff 100%);
}

.action-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #12366a;
}

.action-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #7f93b2;
}

.action-arrow {
  font-size: 32rpx;
  color: #9cb1cf;
}

.skeleton-wrap {
  padding: 18rpx 24rpx 0;
}

.sk-hero,
.sk-card {
  background: linear-gradient(90deg, rgba(238, 244, 255, 0.95) 25%, rgba(220, 232, 251, 0.95) 50%, rgba(238, 244, 255, 0.95) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

.sk-hero {
  height: 320rpx;
  border-radius: 32rpx;
}

.sk-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.sk-card {
  height: 120rpx;
  border-radius: 22rpx;
}

.empty-state {
  margin: 120rpx 48rpx 0;
  padding: 56rpx 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(18, 69, 140, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
  opacity: 0.32;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #12366a;
}

.empty-desc {
  font-size: 24rpx;
  color: #7f93b2;
  line-height: 1.6;
  text-align: center;
}

.empty-retry-btn {
  min-width: 180rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: #0d61ce;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.bottom-space {
  height: 56rpx;
}
