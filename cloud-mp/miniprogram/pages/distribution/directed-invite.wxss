.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #edf5ff 0%, #f8fbff 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  gap: 16rpx;
}

.state-title {
  font-size: 32rpx;
  color: #12366a;
  font-weight: 700;
}

.state-desc {
  font-size: 24rpx;
  color: #7f94b2;
  line-height: 1.7;
}

.hero-card,
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(16, 73, 146, 0.08);
  margin-bottom: 16rpx;
}

.hero-card {
  background: linear-gradient(135deg, #0f67d2 0%, #0c4fa9 100%);
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: rgba(255,255,255,0.68);
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255,255,255,0.84);
}

.status-pill {
  display: inline-flex;
  margin-top: 20rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.16);
  color: #fff;
  font-size: 22rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #12366a;
  margin-bottom: 12rpx;
}

.card-line {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4d668c;
  line-height: 1.7;
}

.card-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #7f94b2;
  line-height: 1.7;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #0d61ce;
  border: 1rpx solid #d7e4f7;
}

.action-btn.primary {
  background: #0d61ce;
  color: #fff;
  border-color: #0d61ce;
}

.action-btn::after {
  border: none;
}

.footer-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #7f94b2;
  line-height: 1.7;
  text-align: center;
}
