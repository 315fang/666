<!-- pages/slash/list.wxml -->
<view class="container">
  <view class="nav-bar" style="padding-top: {{navTopPadding}}px;">
    <view class="nav-back" bindtap="onBack">
      <image class="nav-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"/>
    </view>
    <text class="nav-title">砍价专区</text>
    <view class="nav-placeholder"/>
  </view>

  <view class="hero-shell">
    <view class="hero-badge-row">
      <view class="hero-badge">
        <image class="hero-badge-icon" src="/assets/icons/tag.svg" mode="aspectFit"></image>
        <text class="hero-badge-text">全员可参与</text>
      </view>
      <view class="hero-badge hero-badge--soft">
        <image class="hero-badge-icon" src="/assets/icons/share.svg" mode="aspectFit"></image>
        <text class="hero-badge-text">{{activities.length || 0}} 个活动</text>
      </view>
    </view>

    <view class="hero-card">
      <view class="hero-copy">
        <text class="hero-title">发起砍价，好友一起帮你省</text>
        <text class="hero-subtitle">发起后分享给好友帮砍，每次都会压低当前价格；随时回到“我的砍价”查看进度和最终成交价。</text>
      </view>

      <view class="hero-stats">
        <view class="stat-card">
          <text class="stat-label">专区活动</text>
          <text class="stat-value">{{activities.length || 0}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">我的砍价</text>
          <text class="stat-value">{{myRecords.length || 0}}</text>
        </view>
        <view class="stat-card stat-card--member">
          <text class="stat-label">参与方式</text>
          <text class="stat-value stat-value--small">分享助力</text>
        </view>
      </view>

      <view class="hero-actions">
        <view class="hero-btn hero-btn-primary" bindtap="onGoMySlash">我的砍价</view>
        <view class="hero-btn" bindtap="onGoActivities">去发起</view>
      </view>
    </view>
  </view>

  <view class="tab-row">
    <view class="tab-item {{activeTab === 'activities' ? 'active' : ''}}" bindtap="switchTab" data-tab="activities">砍价商品</view>
    <view class="tab-item {{activeTab === 'my' ? 'active' : ''}}" bindtap="switchTab" data-tab="my">我的砍价</view>
  </view>

  <scroll-view scroll-y class="scroll-area" wx:if="{{activeTab === 'activities'}}">
    <view class="section-head">
      <view>
        <text class="section-title">可发起活动</text>
        <text class="section-subtitle">重点看原价、可砍到底价和助力规则。</text>
      </view>
    </view>

    <view class="state-loading" wx:if="{{loading && !activities.length}}">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-img"></view>
        <view class="skeleton-body">
          <view class="skeleton-line skeleton-line-title"></view>
          <view class="skeleton-line skeleton-line-price"></view>
          <view class="skeleton-line skeleton-line-meta"></view>
        </view>
      </view>
    </view>

    <view class="empty-wrap" wx:if="{{!activities.length && !loading}}">
      <image src="/assets/icons/package.svg" class="empty-icon" mode="aspectFit"/>
      <text class="empty-text">暂无砍价活动\n活动上线后可从这里发起，已发起记录看“我的砍价”</text>
    </view>

    <view class="product-list">
      <view class="product-card" wx:for="{{activities}}" wx:key="id" bindtap="onStartSlash" data-activity="{{item}}">
        <view class="img-wrap">
          <image class="product-img" src="{{item.product && item.product.images && item.product.images[0] || '/assets/icons/package.svg'}}" mode="aspectFill" binderror="onActivityImageError" data-index="{{index}}"/>
          <view class="corner-badge">砍价</view>
        </view>
        <view class="product-info">
          <text class="product-name line-2">{{item.product && item.product.name || '商品'}}</text>
          <view class="tag-row">
            <text class="tag tag-hot" wx:if="{{item._saveNum > 0}}">省 ¥{{item._saveYuan}}</text>
            <text class="tag">好友帮砍</text>
            <text class="tag tag-muted">{{item.expire_hours}}h有效</text>
          </view>
          <view class="price-row">
            <view class="price-block">
              <text class="price-label">原价</text>
              <text class="price-val strikethrough">¥{{item.original_price}}</text>
            </view>
            <view class="price-arrow">→</view>
            <view class="price-block">
              <text class="price-label">可砍至</text>
              <text class="price-val floor">¥{{item.floor_price}}</text>
            </view>
          </view>
          <view class="meta-line" wx:if="{{item._retailHint}}">
            <text class="meta-muted">零售价参考 ¥{{item._retailHint}}</text>
          </view>
          <view class="stock-row" wx:if="{{item.stock_limit > 0}}">
            <view class="stock-bar">
              <view class="stock-fill" style="width: {{item._soldPct}}%;"/>
            </view>
            <text class="stock-text">已砍成 {{item._soldCount}} 件 · 剩余 {{item._stockRemain}} 件</text>
          </view>
          <text class="one-line-desc" wx:if="{{item._summary}}">{{item._summary}}</text>
          <view class="action-row">
            <text class="helpers-hint">最多{{item.max_helpers === -1 ? '不限' : item.max_helpers}}人帮砍 · 单笔随机砍 ¥{{item.min_slash_per_helper}}~{{item.max_slash_per_helper}}</text>
            <view class="start-btn">发起砍价</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <scroll-view scroll-y class="scroll-area" wx:if="{{activeTab === 'my'}}">
    <view class="section-head">
      <view>
        <text class="section-title">我的砍价</text>
        <text class="section-subtitle">查看当前价格、帮砍进度和最终购买入口。</text>
      </view>
    </view>

    <view class="state-loading" wx:if="{{loading && !myRecords.length}}">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-img"></view>
        <view class="skeleton-body">
          <view class="skeleton-line skeleton-line-title"></view>
          <view class="skeleton-line skeleton-line-price"></view>
          <view class="skeleton-line skeleton-line-meta"></view>
        </view>
      </view>
    </view>

    <view class="empty-wrap" wx:if="{{!myRecords.length && !loading}}">
      <image src="/assets/icons/package.svg" class="empty-icon" mode="aspectFit"/>
      <text class="empty-text">还没有砍价记录\n去砍价商品页发起第一刀吧</text>
      <view class="empty-action" bindtap="onGoActivities">去发起砍价</view>
    </view>

    <view class="record-list">
      <view class="record-card" wx:for="{{myRecords}}" wx:key="id" bindtap="onViewRecord" data-no="{{item.slash_no}}">
        <image class="record-img" src="{{item.product && item.product.images && item.product.images[0] || '/assets/icons/package.svg'}}" mode="aspectFill"/>
        <view class="record-info">
          <text class="record-name">{{item.product && item.product.name || '商品'}}</text>
          <view class="record-price-row">
            <text class="record-current">¥{{item.current_price}}</text>
            <text class="record-floor">底价 ¥{{item.floor_price}}</text>
          </view>
          <view class="record-progress-wrap">
            <view class="record-progress-bar">
              <view class="record-progress-fill" style="width: {{item.original_price > item.floor_price ? (1 - (item.current_price - item.floor_price) / (item.original_price - item.floor_price)) * 100 : 0}}%;"/>
            </view>
            <text class="record-helper-count">{{item.helper_count}}人已帮砍</text>
          </view>
          <view class="record-status-row">
            <view class="slash-status {{item.status}}">
              <text wx:if="{{item.status === 'active'}}">进行中</text>
              <text wx:elif="{{item.status === 'success'}}">已到底价</text>
              <text wx:elif="{{item.status === 'expired'}}">已过期</text>
              <text wx:else>已购买</text>
            </view>
            <text class="share-hint" wx:if="{{item.status === 'active'}}">继续邀请好友</text>
          </view>
          <view class="record-action" catchtap="onViewRecord" data-no="{{item.slash_no}}">查看砍价详情</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
