/** pages/slash/detail.wxss **/
page { padding-bottom: 180rpx; }
.container { min-height: 100vh; background: #F7F7F7; }

/* Nav */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.nav-placeholder { width: 56rpx; }

/* Loading */
.loading-wrap { padding: 0; }
.skeleton-block { background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%); border-radius: 20rpx; animation: shimmer 1.5s infinite; }
@keyframes shimmer { 0%{ background-position: -400rpx 0 } 100%{ background-position: 400rpx 0 } }

/* Product card */
.product-card { margin: 20rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; overflow: hidden; display: flex; gap: 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.product-img { width: 200rpx; height: 200rpx; flex-shrink: 0; }
.product-info { flex: 1; padding: 24rpx 20rpx; display: flex; flex-direction: column; justify-content: space-between; gap: 10rpx; }
.title-row { display: flex; flex-direction: column; gap: 10rpx; }
.corn-tag { align-self: flex-start; font-size: 20rpx; font-weight: 800; color: #FFF; background: linear-gradient(135deg, #E85D4C, #FF8A65); padding: 6rpx 16rpx; border-radius: 8rpx; }
.product-name { font-size: 30rpx; font-weight: 700; color: #1A1A1A; line-height: 1.4; }
.product-name.line-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.sub-price-row { display: flex; align-items: center; gap: 10rpx; }
.sub-muted { font-size: 22rpx; color: #AAA; }
.sub-strike { font-size: 24rpx; color: #BBB; text-decoration: line-through; }
.status-badge { display: inline-flex; padding: 8rpx 18rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 700; align-self: flex-start; margin-top: 12rpx; }
.status-badge.status-active { background: rgba(255,107,53,0.1); color: #FF6B35; }
.status-badge.status-success { background: rgba(16,185,129,0.1); color: #10B981; }
.status-badge.status-expired { background: rgba(0,0,0,0.06); color: #AAA; }
.status-badge.status-purchased { background: rgba(59,130,246,0.1); color: #3B82F6; }

/* Price card */
.price-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; padding: 28rpx 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.price-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.price-col { display: flex; flex-direction: column; gap: 6rpx; }
.price-col-right { margin-left: auto; align-items: flex-end; }
.price-label { font-size: 20rpx; color: #AAA; }
.price-current { font-size: 44rpx; font-weight: 800; color: #FF6B35; }
.price-floor { font-size: 36rpx; font-weight: 800; color: #10B981; }
.price-original { font-size: 28rpx; font-weight: 400; color: #BBB; text-decoration: line-through; }
/* Progress */
.progress-section { margin-bottom: 16rpx; }
.progress-bar { width: 100%; height: 12rpx; background: #F0F0F0; border-radius: 6rpx; overflow: hidden; margin-bottom: 10rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #FF6B35, #FF9A56); border-radius: 6rpx; transition: width 0.5s; }
.progress-meta { display: flex; justify-content: space-between; }
.helper-count { font-size: 22rpx; color: #888; }
.progress-pct { font-size: 22rpx; color: #FF6B35; font-weight: 700; }

/* Countdown */
.countdown-row { display: flex; align-items: center; gap: 8rpx; margin-top: 12rpx; }
.icon-xs { width: 28rpx; height: 28rpx; opacity: 0.5; }
.countdown-text { font-size: 24rpx; color: #FF6B35; font-weight: 600; }
.expired-row { justify-content: center; }
.expired-text { font-size: 24rpx; color: #BBB; }

.save-stats { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 8rpx; }
.save-pill { display: flex; align-items: center; gap: 8rpx; background: #FFF8F5; border: 1rpx solid rgba(255,107,53,0.2); border-radius: 12rpx; padding: 12rpx 18rpx; }
.save-pill-warn { background: #FFFBEB; border-color: rgba(245,158,11,0.35); }
.save-pill-label { font-size: 22rpx; color: #888; }
.save-pill-val { font-size: 26rpx; font-weight: 800; color: #FF6B35; }
.save-pill-warn .save-pill-val { color: #D97706; }

.rule-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.rule-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 16rpx; }
.rule-line { font-size: 24rpx; color: #666; line-height: 1.65; display: block; padding-left: 8rpx; }
.rule-dot { color: #FF6B35; margin-right: 8rpx; }

.stock-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.stock-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.stock-title { font-size: 26rpx; font-weight: 700; color: #1A1A1A; }
.stock-sub { font-size: 22rpx; color: #FF6B35; font-weight: 600; }
.stock-bar { height: 12rpx; background: #F0F0F0; border-radius: 6rpx; overflow: hidden; }
.stock-fill { height: 100%; background: linear-gradient(90deg, #FF6B35, #FF9A56); border-radius: 6rpx; max-width: 100%; }

.desc-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.desc-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 12rpx; }
.desc-body { font-size: 24rpx; color: #666; line-height: 1.6; }

.trust-bar { margin: 16rpx 24rpx 0; padding: 20rpx 24rpx; background: #FAFAFA; border-radius: 16rpx; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 12rpx; }
.trust-item { font-size: 22rpx; color: #999; }
.trust-sep { font-size: 22rpx; color: #E0E0E0; }

/* Helpers card */
.helpers-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 20rpx; }
.helper-list { display: flex; flex-direction: column; gap: 16rpx; }
.helper-item { display: flex; align-items: center; gap: 16rpx; }
.helper-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; flex-shrink: 0; background: #F0F0F0; }
.helper-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.helper-name { font-size: 26rpx; font-weight: 600; color: #1A1A1A; }
.helper-cut { font-size: 22rpx; color: #10B981; font-weight: 600; }
.helper-time { font-size: 20rpx; color: #BBB; }

/* Empty helpers */
.empty-helpers { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0; gap: 12rpx; }
.empty-icon { width: 60rpx; height: 60rpx; opacity: 0.2; }
.empty-text { font-size: 24rpx; color: #BBB; text-align: center; line-height: 1.8; }

/* Bottom bar */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #FFFFFF; border-top: 1rpx solid #F0F0F0; padding: 16rpx 24rpx 40rpx; display: flex; gap: 16rpx; align-items: stretch; z-index: 100; }
.btn-col-share { width: 200rpx; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4rpx; background: rgba(255,107,53,0.1); border-radius: 20rpx; padding: 12rpx 8rpx; }
.share-button-reset { margin: 0; border: 0; line-height: 1.2; box-sizing: border-box; }
.share-button-reset::after { border: 0; }
.btn-col-share .btn-icon { width: 36rpx; height: 36rpx; opacity: 0.75; }
.btn-col-main { font-size: 24rpx; font-weight: 800; color: #FF6B35; }
.btn-col-sub { font-size: 18rpx; color: #E85D4C; }
.btn-buy-wrap { flex: 1; min-width: 0; }
.btn-icon { width: 32rpx; height: 32rpx; opacity: 0.7; }
.btn-icon-sm { width: 28rpx; height: 28rpx; opacity: 0.8; }
.btn-buy { width: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 20rpx; min-height: 96rpx; padding: 14rpx 20rpx; box-sizing: border-box; }
.btn-buy-line1 { font-size: 28rpx; font-weight: 800; color: #FFFFFF; line-height: 1.3; }
.btn-buy-line2 { font-size: 20rpx; color: rgba(255,255,255,0.88); margin-top: 6rpx; line-height: 1.2; }
.btn-buy-ready { background: linear-gradient(135deg, #10B981, #34D399); }
.btn-buy-default { background: linear-gradient(135deg, #FF6B35, #FF9A56); }
.btn-disabled { flex: 1; display: flex; align-items: center; justify-content: center; background: #F0F0F0; color: #BBB; font-size: 26rpx; border-radius: 50rpx; min-height: 96rpx; }

/* 被邀请者：帮砍按钮 */
.btn-help-wrap { flex: 1; min-width: 0; }
.btn-help { width: 100%; display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 12rpx; background: linear-gradient(135deg, #FF6B35, #FF9A56); border-radius: 20rpx; min-height: 96rpx; padding: 14rpx 20rpx; box-sizing: border-box; }
.btn-help-loading { background: #FFB28C; }
.btn-help-text { font-size: 32rpx; font-weight: 800; color: #FFFFFF; }

/* 被邀请者：已帮砍状态 */
.btn-helped-wrap { flex: 1; display: flex; gap: 16rpx; align-items: center; }
.btn-helped { flex: 1; display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 10rpx; background: #F0FDF4; border: 1rpx solid #BBF7D0; border-radius: 20rpx; min-height: 96rpx; padding: 14rpx 16rpx; box-sizing: border-box; }
.btn-helped-text { font-size: 26rpx; font-weight: 700; color: #10B981; }
.btn-invite-helper { flex-shrink: 0; margin: 0; border: 0; line-height: 1.2; box-sizing: border-box; padding: 0 24rpx; background: rgba(255,107,53,0.1); border-radius: 20rpx; min-height: 96rpx; font-size: 24rpx; font-weight: 700; color: #FF6B35; display: flex; align-items: center; justify-content: center; }
.btn-invite-helper::after { border: 0; }
.btn-full-wrap { border-radius: 20rpx; }
.btn-success-wrap { background: #F0FDF4; color: #10B981; font-weight: 600; border-radius: 50rpx; }
