/** pages/slash/list.wxss **/
.container { min-height: 100vh; background: #F8F3ED; }

/* Nav */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.nav-placeholder { width: 56rpx; }

/* Intro card */
.intro-card { margin: 20rpx 24rpx; background: linear-gradient(135deg, #B98B58 0%, #D4B896 100%); border-radius: 24rpx; padding: 28rpx 24rpx; display: flex; align-items: center; justify-content: space-between; }
.intro-left { flex: 1; }
.intro-badge { background: rgba(255,255,255,0.25); color: #FFF; font-size: 18rpx; font-weight: 700; padding: 6rpx 14rpx; border-radius: 20rpx; }
.intro-title { display: block; font-size: 32rpx; font-weight: 800; color: #FFF; margin: 10rpx 0 6rpx; }
.intro-desc { font-size: 22rpx; color: rgba(255,255,255,0.85); line-height: 1.5; }
.intro-actions { display: flex; align-items: center; gap: 12rpx; margin-top: 18rpx; }
.intro-action { padding: 10rpx 18rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 700; color: #FFF; border: 1rpx solid rgba(255,255,255,0.48); background: rgba(255,255,255,0.14); }
.intro-action-primary { color: #8A5D2A; background: #FFF; border-color: #FFF; }
.intro-icon { width: 80rpx; height: 80rpx; opacity: 0.9; filter: invert(1); }

/* Tabs */
.tab-row { display: flex; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #888; cursor: pointer; position: relative; }
.tab-item.active { color: #B98B58; font-weight: 700; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 20%; right: 20%; height: 4rpx; background: #B98B58; border-radius: 2rpx; }

/* Scroll area */
.scroll-area { padding: 16rpx 24rpx 60rpx; }

/* Empty */
.empty-wrap { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 16rpx; }
.empty-icon { width: 80rpx; height: 80rpx; opacity: 0.25; }
.empty-text { font-size: 26rpx; color: #BBB; text-align: center; line-height: 1.8; }
.empty-action { margin-top: 8rpx; padding: 12rpx 24rpx; border-radius: 8rpx; background: linear-gradient(135deg, #B98B58, #D4B896); color: #FFF; font-size: 22rpx; font-weight: 700; }

/* Product list */
.product-list { display: flex; flex-direction: column; gap: 16rpx; }
.product-card { background: #FFFFFF; border-radius: 20rpx; overflow: hidden; display: flex; gap: 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.img-wrap { position: relative; width: 180rpx; height: 180rpx; flex-shrink: 0; }
.product-img { width: 100%; height: 100%; object-fit: cover; }
.corner-badge { position: absolute; left: 0; top: 0; background: linear-gradient(135deg, #E85D4C, #FF8A65); color: #FFF; font-size: 20rpx; font-weight: 800; padding: 6rpx 14rpx; border-radius: 0 0 12rpx 0; }
.product-info { flex: 1; padding: 20rpx 20rpx; display: flex; flex-direction: column; justify-content: space-between; gap: 8rpx; }
.product-name { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.product-name.line-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.35; }
.tag-row { display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag { font-size: 18rpx; color: #B98B58; background: rgba(185,139,88,0.12); padding: 4rpx 12rpx; border-radius: 8rpx; font-weight: 600; }
.tag-hot { color: #B95E46; background: rgba(185,94,70,0.12); }
.tag-muted { color: #888; background: #F5F5F5; }
.meta-line { margin-top: -4rpx; }
.meta-muted { font-size: 20rpx; color: #AAA; }
.stock-row { display: flex; flex-direction: column; gap: 6rpx; }
.stock-bar { height: 8rpx; background: #F0F0F0; border-radius: 4rpx; overflow: hidden; }
.stock-fill { height: 100%; background: linear-gradient(90deg, #E85D4C, #FFAB91); border-radius: 4rpx; max-width: 100%; }
.stock-text { font-size: 20rpx; color: #888; }
.one-line-desc { font-size: 22rpx; color: #999; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.price-row { display: flex; align-items: center; gap: 10rpx; }
.price-from, .price-to { display: flex; flex-direction: column; gap: 2rpx; }
.price-label { font-size: 18rpx; color: #AAA; }
.price-val { font-size: 26rpx; font-weight: 700; }
.price-val.strikethrough { text-decoration: line-through; color: #AAA; font-size: 22rpx; font-weight: 400; }
.price-val.floor { color: #B95E46; }
.price-arrow { font-size: 24rpx; color: #DDD; margin: 0 6rpx; }
.action-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 12rpx; margin-top: 4rpx; }
.helpers-hint { font-size: 18rpx; color: #AAA; flex: 1; line-height: 1.45; }
.start-btn { background: linear-gradient(135deg, #B98B58, #D4B896); color: #FFF; font-size: 22rpx; font-weight: 700; padding: 10rpx 20rpx; border-radius: 50rpx; }

/* My records */
.record-list { display: flex; flex-direction: column; gap: 16rpx; }
.record-card { background: #FFFFFF; border-radius: 20rpx; overflow: hidden; display: flex; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.record-img { width: 160rpx; height: 160rpx; object-fit: cover; flex-shrink: 0; }
.record-info { flex: 1; padding: 20rpx; display: flex; flex-direction: column; gap: 10rpx; }
.record-name { font-size: 26rpx; font-weight: 700; color: #1A1A1A; }
.record-price-row { display: flex; align-items: baseline; gap: 16rpx; }
.record-current { font-size: 36rpx; font-weight: 800; color: #B95E46; }
.record-floor { font-size: 20rpx; color: #AAA; }
.record-progress-wrap { display: flex; align-items: center; gap: 12rpx; }
.record-progress-bar { flex: 1; height: 8rpx; background: #F0F0F0; border-radius: 4rpx; overflow: hidden; }
.record-progress-fill { height: 100%; background: linear-gradient(90deg, #B98B58, #D4B896); border-radius: 4rpx; }
.record-helper-count { font-size: 20rpx; color: #888; white-space: nowrap; }
.record-status-row { display: flex; align-items: center; justify-content: space-between; }
.slash-status { font-size: 20rpx; font-weight: 700; padding: 6rpx 14rpx; border-radius: 20rpx; }
.slash-status.active { background: rgba(185, 139, 88, 0.1); color: #B98B58; }
.slash-status.success { background: rgba(16, 185, 129, 0.1); color: #10B981; }
.slash-status.expired { background: rgba(0,0,0,0.06); color: #AAA; }
.slash-status.purchased { background: rgba(59, 130, 246, 0.1); color: #3B82F6; }
.share-hint { font-size: 20rpx; color: #B98B58; }
.record-action { align-self: flex-start; padding: 10rpx 16rpx; border-radius: 8rpx; background: #2C1A0E; color: #FFF; font-size: 22rpx; font-weight: 700; }
