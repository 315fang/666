<!--pages/slash/detail.wxml-->
<view class="container">
  <view class="nav-bar" style="padding-top: {{navTopPadding}}px;">
    <view class="nav-back" bindtap="onBack">
      <image class="nav-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"/>
    </view>
    <text class="nav-title">砍价详情</text>
    <view class="nav-placeholder"/>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="skeleton-block hero-skeleton"></view>
    <view class="skeleton-block card-skeleton"></view>
    <view class="skeleton-block card-skeleton"></view>
  </view>

  <block wx:if="{{!loading && detail}}">
    <view class="hero-shell">
      <view class="hero-card">
        <image class="hero-product-img" src="{{detail.product && detail.product.images && detail.product.images[0] || '/assets/icons/package.svg'}}" mode="aspectFill"/>
        <view class="hero-copy">
          <view class="hero-badge-row">
            <text class="hero-badge">砍价活动</text>
            <view class="status-badge status-{{detail.status}}">
              <text>{{statusTextMap[detail.status] || detail.status}}</text>
            </view>
          </view>
          <text class="hero-title">{{detail.product && detail.product.name || '商品'}}</text>
          <view class="sub-price-row" wx:if="{{detail.product && detail.product.retail_price}}">
            <text class="sub-muted">零售价参考</text>
            <text class="sub-strike">¥{{detail.product.retail_price}}</text>
          </view>
          <view class="hero-stats">
            <view class="stat-card">
              <text class="stat-label">当前价</text>
              <text class="stat-value">¥{{detail.current_price}}</text>
            </view>
            <view class="stat-card">
              <text class="stat-label">底价目标</text>
              <text class="stat-value">¥{{detail.floor_price}}</text>
            </view>
            <view class="stat-card">
              <text class="stat-label">已帮砍</text>
              <text class="stat-value">{{detail.helper_count || 0}}人</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">价格进度</text>
        <text class="section-side">{{detail._progressPct}}%</text>
      </view>

      <view class="progress-bar">
        <view class="progress-fill" style="width: {{detail._progressPct}}%;"/>
      </view>

      <view class="save-stats">
        <view class="save-pill">
          <text class="save-pill-label">已砍掉</text>
          <text class="save-pill-val">¥{{detail._alreadySaved}}</text>
        </view>
        <view class="save-pill save-pill-warn" wx:if="{{detail.status === 'active'}}">
          <text class="save-pill-label">距底价还差</text>
          <text class="save-pill-val">¥{{detail.amount_to_floor || detail._toFloor}}</text>
        </view>
      </view>

      <view class="notice-row" wx:if="{{detail.status === 'active' && !detail._expired}}">
        <image src="/assets/icons/clock.svg" class="icon-xs" mode="aspectFit"/>
        <text class="notice-text" wx:if="{{detail._remainSecs > 0 || detail._remainHours > 0 || detail._remainMins > 0}}">剩余 {{detail._remainHours}}小时{{detail._remainMins}}分{{detail._remainSecs}}秒</text>
        <text class="notice-text" wx:else>即将结束，请尽快分享</text>
      </view>
      <view class="notice-row" wx:if="{{detail.status === 'expired' || detail._expired}}">
        <image src="/assets/icons/info.svg" class="icon-xs" mode="aspectFit"/>
        <text class="notice-text">活动已结束</text>
      </view>
    </view>

    <view class="section-card" wx:if="{{detail.activity}}">
      <text class="section-title block-title">活动规则</text>
      <view class="rule-line" wx:if="{{detail.activity.expire_hours}}"><text class="rule-dot"></text><text>活动有效期 {{detail.activity.expire_hours}} 小时。</text></view>
      <view class="rule-line"><text class="rule-dot"></text><text>到底价后可按当前价下单，价格以结算页为准。</text></view>
    </view>

    <view class="section-card" wx:if="{{detail.activity && detail.activity.stock_limit > 0}}">
      <view class="section-head">
        <text class="section-title">抢购进度</text>
        <text class="section-side">剩余 {{detail._stockRemain}} 件</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{detail._soldPct}}%;"/>
      </view>
    </view>

    <view class="section-card" wx:if="{{detail._productSummary}}">
      <text class="section-title block-title">商品亮点</text>
      <text class="desc-body">{{detail._productSummary}}</text>
    </view>

    <view class="trust-bar">
      <text class="trust-item">正品保障</text>
      <text class="trust-sep">|</text>
      <text class="trust-item">按规则履约</text>
      <text class="trust-sep">|</text>
      <text class="trust-item">好友助力更划算</text>
    </view>

    <view class="section-card" wx:if="{{detail.helpers && detail.helpers.length > 0}}">
      <text class="section-title block-title">帮砍好友</text>
      <view class="helper-list">
        <view class="helper-item" wx:for="{{detail.helpers}}" wx:key="id">
          <image class="helper-avatar" src="{{item.user && (item.user.avatar || item.user.avatar_url) || '/assets/icons/user.svg'}}" mode="aspectFill"/>
          <view class="helper-info">
            <text class="helper-name">{{item.user && (item.user.nick_name || item.user.nickname) || '好友'}}</text>
            <text class="helper-cut">砍了 ¥{{item.cut_amount}}</text>
          </view>
          <text class="helper-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>

    <view class="section-card" wx:if="{{!detail.helpers || detail.helpers.length === 0}}">
      <text class="section-title block-title">帮砍好友</text>
      <view class="empty-helpers">
        <image src="/assets/icons/users.svg" class="empty-icon" mode="aspectFit"/>
        <text class="empty-text">暂无帮砍记录\n去分享给好友吧</text>
      </view>
    </view>
  </block>

  <view class="bottom-bar" wx:if="{{!loading && detail}}">
    <block wx:if="{{isOwner}}">
      <button class="btn-col-share share-button-reset" wx:if="{{detail.status === 'active'}}" open-type="share">
        <image src="/assets/icons/share.svg" class="btn-icon" mode="aspectFit"/>
        <text class="btn-col-main">邀请好友</text>
        <text class="btn-col-sub">每刀随机减</text>
      </button>
      <view class="btn-buy-wrap" wx:if="{{detail.status === 'success' || detail.status === 'active'}}">
        <view class="btn-buy {{detail.status === 'success' ? 'btn-buy-ready' : 'btn-buy-default'}}" bindtap="onBuy">
          <text class="btn-buy-line1" wx:if="{{detail.status === 'success'}}">已到底价 · 立即下单</text>
          <text class="btn-buy-line1" wx:else>¥{{detail.current_price}} 立即下单</text>
          <text class="btn-buy-line2" wx:if="{{detail.status === 'active'}}">现价可直接购买</text>
          <text class="btn-buy-line2" wx:if="{{detail.status === 'success'}}">库存有限以结算为准</text>
        </view>
      </view>
      <view class="btn-disabled" wx:if="{{detail.status === 'expired' || detail.status === 'purchased'}}">
        <text wx:if="{{detail.status === 'expired'}}">活动已结束</text>
        <text wx:else>已完成购买</text>
      </view>
    </block>

    <block wx:else>
      <block wx:if="{{detail.status === 'active'}}">
        <view class="btn-helped-wrap" wx:if="{{alreadyHelped}}">
          <view class="btn-helped">
            <image src="/assets/icons/check-circle.svg" class="btn-icon-sm" mode="aspectFit"/>
            <text class="btn-helped-text">已帮砍 ¥{{myHelpAmount}}</text>
          </view>
          <button class="btn-invite-helper share-button-reset" open-type="share">
            <text>继续邀请</text>
          </button>
        </view>

        <view class="btn-disabled btn-full-wrap" wx:elif="{{helperFull}}">
          <text>帮砍名额已满</text>
        </view>

        <view class="btn-help-wrap" wx:else>
          <view class="btn-help {{helping ? 'btn-help-loading' : ''}}" bindtap="onHelp">
            <image src="/assets/icons/tag.svg" class="btn-icon" mode="aspectFit" wx:if="{{!helping}}"/>
            <text class="btn-help-text" wx:if="{{!helping}}">帮忙砍一刀</text>
            <text class="btn-help-text" wx:else>帮砍中…</text>
          </view>
        </view>
      </block>

      <view class="btn-disabled btn-success-wrap" wx:elif="{{detail.status === 'success'}}">
        <text>已砍到底价</text>
      </view>

      <view class="btn-disabled" wx:elif="{{detail.status === 'expired' || detail.status === 'purchased'}}">
        <text wx:if="{{detail.status === 'expired'}}">活动已结束</text>
        <text wx:else>好友已完成购买</text>
      </view>
    </block>
  </view>
</view>
