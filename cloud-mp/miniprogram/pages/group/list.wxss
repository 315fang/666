/** pages/group/list.wxss **/
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1e4a6d 0, #1e4a6d 430rpx, #edf5fb 430rpx, #f7fbff 100%);
  padding-bottom: 60rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 28rpx;
}

.nav-back,
.nav-placeholder {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) invert(1);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
}

.hero-shell,
.member-tip,
.tab-row,
.section-head,
.activity-list,
.group-list,
.skeleton-list,
.empty-wrap {
  margin-left: 28rpx;
  margin-right: 28rpx;
}

.hero-shell {
  margin-top: 10rpx;
}

.hero-badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.14);
  border: 1rpx solid rgba(255,255,255,0.16);
}

.hero-badge-icon {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) invert(1);
}

.hero-badge-text {
  font-size: 22rpx;
  color: #f8fbff;
}

.hero-card {
  padding: 34rpx 30rpx 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.06));
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 20rpx 44rpx rgba(9, 31, 50, 0.16);
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  font-size: 48rpx;
  line-height: 1.28;
  color: #f8fafc;
  font-weight: 700;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.65;
  color: rgba(234, 243, 251, 0.78);
}

.member-tip {
  margin-top: 18rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(245,249,253,0.96));
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 10rpx 24rpx rgba(30, 74, 109, 0.06);
}

.tip-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.82;
}

.tip-text {
  font-size: 22rpx;
  color: #5f7690;
  line-height: 1.65;
}

.tab-row {
  margin-top: 18rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  display: flex;
  gap: 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  min-height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #6f8399;
}

.tab-item.active {
  color: #16324d;
  font-weight: 700;
  background: linear-gradient(135deg, #d6e6f5 0%, #7fa7c8 100%);
}

.section-head {
  margin-top: 30rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #16324d;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b8297;
}

.section-filter {
  flex-shrink: 0;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(36, 95, 147, 0.16);
  color: #245f93;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 88rpx 0;
  gap: 18rpx;
}

.empty-icon {
  width: 84rpx;
  height: 84rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 26rpx;
  color: #6f8399;
  text-align: center;
  line-height: 1.8;
}

.empty-action {
  margin-top: 8rpx;
  min-height: 72rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #245f93, #1e4a6d);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.activity-list,
.group-list,
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.activity-card,
.group-record,
.skeleton-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(245,249,253,0.96));
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  box-shadow: 0 12rpx 28rpx rgba(30, 74, 109, 0.06);
}

.img-wrap,
.skeleton-img {
  position: relative;
  width: 190rpx;
  height: 190rpx;
  flex-shrink: 0;
}

.product-img,
.record-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.corner-badge {
  position: absolute;
  left: 0;
  top: 0;
  background: linear-gradient(135deg, #245f93, #7fa7c8);
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  padding: 6rpx 14rpx;
  border-radius: 0 0 14rpx 0;
}

.activity-info,
.record-info,
.skeleton-body {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 10rpx;
  min-width: 0;
}

.product-name,
.record-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #16324d;
}

.line-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 18rpx;
  color: #245f93;
  background: rgba(36, 95, 147, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.tag-hot {
  color: #b77923;
  background: rgba(197, 139, 71, 0.12);
}

.tag-muted {
  color: #6f8399;
  background: #f0f5fa;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.group-price {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.price-label,
.original-price-label {
  font-size: 20rpx;
  color: #7b8fa4;
}

.group-price-val {
  font-size: 38rpx;
  font-weight: 800;
  color: #1e4a6d;
}

.original-price {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  font-size: 22rpx;
  color: #9caec0;
  text-decoration: line-through;
}

.stock-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stock-bar {
  height: 8rpx;
  background: #dfeaf3;
  border-radius: 999rpx;
  overflow: hidden;
}

.stock-fill,
.record-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #245f93, #7fa7c8);
  border-radius: 999rpx;
  max-width: 100%;
}

.stock-text,
.one-line-desc,
.meta-item,
.member-text,
.record-helper-count {
  font-size: 20rpx;
  color: #6f8399;
}

.one-line-desc {
  line-height: 1.5;
}

.meta-row,
.record-action-row,
.member-progress,
.record-status-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-progress--unpaid {
  margin-top: 2rpx;
}

.member-pill {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(36, 95, 147, 0.08);
  border: 1rpx solid rgba(36, 95, 147, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-pill-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #245f93;
  line-height: 1;
}

.meta-copy {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
  min-width: 0;
}

.meta-dot {
  color: #b0c1d1;
}

.start-btn,
.record-action {
  margin-left: auto;
  min-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #245f93, #1e4a6d);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.member-avatars {
  display: flex;
  gap: 4rpx;
}

.avatar-placeholder {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #edf5fb;
  border: 2rpx solid rgba(36, 95, 147, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-letter {
  font-size: 20rpx;
  font-weight: 700;
  color: #245f93;
}

.avatar-more {
  font-size: 20rpx;
  color: #245f93;
  padding: 0 4rpx;
  font-weight: 600;
}

.group-status {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  align-self: flex-start;
}

.group-status.open {
  background: rgba(36, 95, 147, 0.1);
  color: #245f93;
}

.group-status.success {
  background: rgba(15, 118, 110, 0.12);
  color: #0f766e;
}

.group-status.fail,
.group-status.failed,
.group-status.cancelled,
.group-status.expired {
  background: rgba(107, 130, 151, 0.12);
  color: #6f8399;
}

.share-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(36, 95, 147, 0.08);
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
}

.share-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.7;
}

.share-row text {
  font-size: 22rpx;
  color: #245f93;
  font-weight: 600;
}

.record-img-wrap {
  position: relative;
  width: 168rpx;
  height: 168rpx;
  flex-shrink: 0;
}

.record-img {
  width: 168rpx;
  height: 168rpx;
  flex-shrink: 0;
}

.record-overlay-unpaid,
.record-overlay-status {
  position: absolute;
  left: 0;
  top: 0;
  padding: 6rpx 14rpx;
  font-size: 18rpx;
  font-weight: 800;
  border-radius: 0 0 14rpx 0;
  color: #fff;
}

.record-overlay-unpaid {
  background: linear-gradient(135deg, #e67e22, #d35400);
}

.record-overlay-open {
  background: linear-gradient(135deg, #245f93, #7fa7c8);
}

.record-overlay-success {
  background: linear-gradient(135deg, #0f766e, #10b981);
}

.record-overlay-fail,
.record-overlay-failed,
.record-overlay-cancelled {
  background: rgba(107, 130, 151, 0.85);
}

.group-record--unpaid {
  border: 2rpx solid rgba(230, 126, 34, 0.25);
  background: linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(255, 255, 255, 0.96));
}

.group-record--paid {
  border: 1rpx solid rgba(36, 95, 147, 0.08);
}

.record-head-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.record-badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}

.record-badge {
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.record-badge--unpaid {
  background: rgba(230, 126, 34, 0.12);
  color: #d35400;
}

.record-badge--paid {
  background: rgba(16, 185, 129, 0.1);
  color: #0f766e;
}

.record-badge--role {
  background: rgba(36, 95, 147, 0.08);
  color: #245f93;
}

.record-badge--status {
  background: rgba(36, 95, 147, 0.08);
  color: #245f93;
}

.record-badge--success {
  background: rgba(16, 185, 129, 0.1);
  color: #0f766e;
}

.record-badge--fail,
.record-badge--failed,
.record-badge--cancelled {
  background: rgba(107, 130, 151, 0.1);
  color: #6f8399;
}

.unpaid-price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 4rpx;
}

.unpaid-price {
  font-size: 34rpx;
  font-weight: 800;
  color: #d35400;
}

.unpaid-hint {
  font-size: 20rpx;
  color: #6f8399;
}

.record-action--pay {
  background: linear-gradient(135deg, #e67e22, #d35400) !important;
  color: #fff !important;
}

.record-action--cancel {
  background: rgba(107, 130, 151, 0.1) !important;
  color: #6f8399 !important;
}

.record-action--secondary {
  background: rgba(107, 130, 151, 0.12) !important;
  color: #5f7690 !important;
}

.group-record--cancelled {
  border: 1rpx solid rgba(107, 130, 151, 0.15);
  background: linear-gradient(180deg, rgba(245, 245, 245, 0.96), rgba(250, 250, 250, 0.96));
  opacity: 0.85;
}

.record-overlay-cancelled {
  position: absolute;
  left: 0;
  top: 0;
  padding: 6rpx 14rpx;
  font-size: 18rpx;
  font-weight: 800;
  border-radius: 0 0 14rpx 0;
  color: #fff;
  background: rgba(107, 130, 151, 0.85);
}

.record-img--dimmed {
  opacity: 0.6;
}

.record-name--dimmed {
  color: #999;
}

.record-badge--cancelled-tag {
  background: rgba(229, 62, 62, 0.1);
  color: #e53e3e;
}

.cancelled-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 1.5;
}

.skeleton-img {
  background: #dfeaf3;
}

.skeleton-line {
  border-radius: 8rpx;
  background: #dfeaf3;
  position: relative;
  overflow: hidden;
}

.skeleton-line-title { width: 65%; height: 28rpx; }
.skeleton-line-price { width: 40%; height: 36rpx; }
.skeleton-line-meta { width: 80%; height: 22rpx; }

.skeleton-line::after,
.skeleton-img::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  animation: shimmer 1.6s infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}
