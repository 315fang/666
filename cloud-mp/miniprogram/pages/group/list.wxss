/** pages/group/list.wxss **/
.container { min-height: 100vh; background: #F8F3ED; }

/* Nav */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; background: #FFFFFF; border-bottom: 1rpx solid #EDE6DC; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.nav-placeholder { width: 56rpx; }

/* Intro */
.intro-card { margin: 20rpx 24rpx; background: linear-gradient(135deg, #2C1A0E 0%, #4A3222 100%); border-radius: 24rpx; padding: 28rpx 24rpx; display: flex; align-items: center; justify-content: space-between; }
.intro-left { flex: 1; }
.intro-badge { background: rgba(255,255,255,0.2); color: #FFF; font-size: 20rpx; font-weight: 700; padding: 6rpx 16rpx; border-radius: 8rpx; }
.intro-title { display: block; font-size: 32rpx; font-weight: 800; color: #FFF; margin: 10rpx 0 6rpx; }
.intro-desc { font-size: 22rpx; color: rgba(255,255,255,0.8); line-height: 1.5; }
.intro-icon { width: 80rpx; height: 80rpx; opacity: 0.85; filter: invert(1); }

/* Member tip */
.member-tip { margin: 0 24rpx 16rpx; background: rgba(185,139,88,0.08); border: 1rpx solid rgba(185,139,88,0.2); border-radius: 16rpx; padding: 20rpx 24rpx; display: flex; align-items: center; gap: 16rpx; }
.tip-icon { width: 36rpx; height: 36rpx; opacity: 0.7; }
.tip-text { font-size: 22rpx; color: #8D6A3F; line-height: 1.6; }

/* Tab */
.tab-row { display: flex; background: #FFFFFF; border-bottom: 1rpx solid #EDE6DC; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #B0A396; cursor: pointer; position: relative; transition: color 0.25s; }
.tab-item.active { color: #8D6A3F; font-weight: 700; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 25%; right: 25%; height: 5rpx; background: #B98B58; border-radius: 3rpx; }

/* Empty */
.empty-wrap { display: flex; flex-direction: column; align-items: center; padding: 100rpx 0; gap: 20rpx; }
.empty-icon { width: 88rpx; height: 88rpx; opacity: 0.2; }
.empty-text { font-size: 26rpx; color: #B0A396; text-align: center; line-height: 1.8; }

/* Activity list */
.activity-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.activity-card { background: #FFFFFF; border-radius: 24rpx; overflow: hidden; display: flex; box-shadow: 0 4rpx 16rpx rgba(40,32,24,0.06); }
.img-wrap { position: relative; width: 180rpx; height: 180rpx; flex-shrink: 0; }
.product-img { width: 100%; height: 100%; object-fit: cover; }
.corner-badge { position: absolute; left: 0; top: 0; background: linear-gradient(135deg, #B95E46, #E8A074); color: #FFF; font-size: 20rpx; font-weight: 800; padding: 6rpx 14rpx; border-radius: 0 0 12rpx 0; }
.activity-info { flex: 1; padding: 20rpx; display: flex; flex-direction: column; justify-content: space-between; gap: 8rpx; }
.product-name { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.product-name.line-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.35; }
.tag-row { display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag { font-size: 18rpx; color: #8D6A3F; background: rgba(185,139,88,0.12); padding: 4rpx 12rpx; border-radius: 8rpx; font-weight: 600; }
.tag-hot { color: #B95E46; background: rgba(185,94,70,0.12); }
.tag-muted { color: #888; background: #F5F5F5; }
.stock-row { display: flex; flex-direction: column; gap: 6rpx; margin-top: 4rpx; }
.stock-bar { height: 8rpx; background: #EDE6DC; border-radius: 4rpx; overflow: hidden; }
.stock-fill { height: 100%; background: linear-gradient(90deg, #B98B58, #D4B896); border-radius: 4rpx; max-width: 100%; }
.stock-text { font-size: 20rpx; color: #8D755A; }
.one-line-desc { font-size: 22rpx; color: #B0A396; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.price-row { display: flex; align-items: baseline; gap: 16rpx; }
.group-price { display: flex; flex-direction: column; gap: 2rpx; }
.price-label { font-size: 20rpx; color: #B0A396; }
.group-price-val { font-size: 36rpx; font-weight: 800; color: #B95E46; }
.original-price { font-size: 22rpx; color: #B0A396; text-decoration: line-through; }
.meta-row { display: flex; align-items: center; gap: 8rpx; }
.meta-item { font-size: 22rpx; color: #8D755A; }
.meta-dot { color: #D4B896; }
.start-btn { margin-left: auto; background: linear-gradient(135deg, #B98B58, #D4B896); color: #FFF; font-size: 22rpx; font-weight: 700; padding: 12rpx 24rpx; border-radius: 999rpx; white-space: nowrap; }

/* My groups */
.group-list { padding: 16rpx 24rpx 60rpx; display: flex; flex-direction: column; gap: 20rpx; }
.group-record { background: #FFFFFF; border-radius: 24rpx; overflow: hidden; display: flex; box-shadow: 0 4rpx 16rpx rgba(40,32,24,0.06); }
.record-img { width: 160rpx; height: 160rpx; object-fit: cover; flex-shrink: 0; }
.record-info { flex: 1; padding: 20rpx; display: flex; flex-direction: column; gap: 10rpx; }
.record-name { font-size: 26rpx; font-weight: 700; color: #1A1A1A; }
.member-progress { display: flex; align-items: center; gap: 12rpx; }
.member-avatars { display: flex; gap: 4rpx; }
.avatar-placeholder { width: 40rpx; height: 40rpx; border-radius: 50%; background: #F8F3ED; border: 2rpx solid rgba(185,139,88,0.25); display: flex; align-items: center; justify-content: center; }
.avatar-letter { font-size: 20rpx; font-weight: 700; color: #B98B58; }
.avatar-more { font-size: 20rpx; color: #B98B58; padding: 0 4rpx; font-weight: 600; }
.member-text { font-size: 22rpx; color: #8D6A3F; font-weight: 600; }
.group-status { font-size: 20rpx; font-weight: 700; padding: 6rpx 14rpx; border-radius: 8rpx; align-self: flex-start; }
.group-status.open { background: rgba(185,139,88,0.1); color: #B98B58; }
.group-status.success { background: rgba(16,185,129,0.1); color: #10B981; }
.group-status.fail, .group-status.cancelled { background: rgba(0,0,0,0.04); color: #B0A396; }
.share-row { display: flex; align-items: center; gap: 8rpx; background: rgba(185,139,88,0.08); padding: 10rpx 16rpx; border-radius: 999rpx; }
.share-icon { width: 28rpx; height: 28rpx; opacity: 0.7; }
.share-row text { font-size: 22rpx; color: #8D6A3F; font-weight: 600; }

/* Skeleton loading */
.skeleton-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.skeleton-card { background: #FFFFFF; border-radius: 24rpx; overflow: hidden; display: flex; box-shadow: 0 4rpx 16rpx rgba(40,32,24,0.06); }
.skeleton-img { width: 180rpx; height: 180rpx; background: #EDE6DC; flex-shrink: 0; }
.skeleton-body { flex: 1; padding: 20rpx; display: flex; flex-direction: column; gap: 16rpx; }
.skeleton-line { border-radius: 8rpx; background: #EDE6DC; position: relative; overflow: hidden; }
.skeleton-line-title { width: 65%; height: 28rpx; }
.skeleton-line-price { width: 40%; height: 36rpx; }
.skeleton-line-meta { width: 80%; height: 22rpx; }
.skeleton-line::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent); animation: shimmer 1.6s infinite; }
@keyframes shimmer { 0% { left: -100%; } 100% { left: 100%; } }
