/** pages/group/detail.wxss **/
page { padding-bottom: 180rpx; }

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1e4a6d 0, #1e4a6d 430rpx, #edf5fb 430rpx, #f7fbff 100%);
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 28rpx;
}

.nav-back,
.nav-placeholder {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) invert(1);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
}

.hero-shell,
.section-card,
.trust-bar,
.state-banner,
.loading-wrap {
  margin-left: 28rpx;
  margin-right: 28rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.skeleton-block {
  background: #dfeaf3;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.hero-skeleton { height: 260rpx; }
.card-skeleton { height: 180rpx; }

.skeleton-block::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.45), transparent);
  animation: shimmer 1.6s infinite;
}

/* 用户订单状态横幅 */
.my-status-banner {
  margin: 16rpx 28rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.my-status-paid {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.12), rgba(36, 95, 147, 0.08));
  border: 1rpx solid rgba(16, 185, 129, 0.18);
}

.my-status-unpaid {
  background: linear-gradient(135deg, rgba(230, 126, 34, 0.14), rgba(211, 84, 0, 0.08));
  border: 1rpx solid rgba(230, 126, 34, 0.25);
}

.my-status-cancelled {
  background: linear-gradient(135deg, rgba(107, 130, 151, 0.2), rgba(36, 95, 147, 0.08));
  border: 1rpx solid rgba(107, 130, 151, 0.24);
}

.my-status-unknown {
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(36, 95, 147, 0.08);
}

.my-status-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.my-status-role {
  font-size: 26rpx;
  font-weight: 700;
  color: #f8fafc;
}

.my-status-text {
  font-size: 22rpx;
  color: rgba(248, 251, 255, 0.8);
}

.my-status-right {
  flex-shrink: 0;
}

.my-status-btn {
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #e67e22, #d35400);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 999rpx;
}

.my-status-btn-secondary {
  background: linear-gradient(135deg, #245f93, #1e4a6d);
}

.my-status-order-link {
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #f8fafc;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 999rpx;
}

/* 成员"我"标记 */
.member-avatar--me {
  border-color: #c6a16e;
  border-width: 4rpx;
  box-shadow: 0 8rpx 18rpx rgba(198, 161, 110, 0.18);
}

.me-tag {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  background: #c6a16e;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.hero-shell {
  margin-top: 10rpx;
}

.hero-card {
  padding: 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, rgba(250, 253, 255, 0.98), rgba(232, 241, 248, 0.94));
  border: 1rpx solid rgba(36, 95, 147, 0.12);
  display: flex;
  gap: 20rpx;
  box-shadow: 0 20rpx 44rpx rgba(9, 31, 50, 0.16);
}

.hero-product-img {
  width: 184rpx;
  height: 184rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  box-shadow: 0 10rpx 20rpx rgba(30, 74, 109, 0.08);
}

.hero-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-badge-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hero-badge,
.status-badge {
  display: inline-flex;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  align-items: center;
  font-size: 20rpx;
  font-weight: 700;
}

.status-badge {
  background: rgba(36, 95, 147, 0.08);
  border: 1rpx solid rgba(36, 95, 147, 0.12);
  color: #245f93;
}

.hero-badge {
  background: rgba(36, 95, 147, 0.1);
  border: 1rpx solid rgba(36, 95, 147, 0.14);
  color: #245f93;
}

.status-badge.status-open {
  background: rgba(36, 95, 147, 0.1);
  color: #245f93;
}

.status-badge.status-success {
  background: rgba(15, 118, 110, 0.12);
  color: #0f766e;
}

.status-badge.status-fail,
.status-badge.status-cancelled {
  background: rgba(107, 130, 151, 0.12);
  color: #5f7690;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.45;
  color: #16324d;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.d-tag {
  font-size: 18rpx;
  color: #245f93;
  background: rgba(36, 95, 147, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.d-tag-hot {
  color: #b77923;
  background: rgba(198, 161, 110, 0.16);
}

.price-row {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
  margin-top: 4rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(36, 95, 147, 0.08);
}

.price-main,
.price-side {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  justify-content: center;
}

.price-main {
  flex: 1;
}

.price-side {
  min-width: 144rpx;
  padding-left: 22rpx;
  border-left: 1rpx solid rgba(36, 95, 147, 0.12);
  flex-shrink: 0;
}

.price-label {
  font-size: 20rpx;
  color: #6f8399;
}

.group-price {
  font-size: 46rpx;
  font-weight: 800;
  color: #b77923;
  line-height: 1.1;
}

.original-price {
  font-size: 26rpx;
  color: #8fa1b2;
  text-decoration: line-through;
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.stat-card {
  flex: 1;
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(245,249,253,0.96));
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  box-shadow: 0 10rpx 24rpx rgba(30, 74, 109, 0.06);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #6b8297;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #16324d;
}

.section-card {
  margin-top: 18rpx;
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(245,249,253,0.96));
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  box-shadow: 0 12rpx 28rpx rgba(30, 74, 109, 0.06);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16324d;
}

.block-title {
  display: block;
  margin-bottom: 16rpx;
}

.section-side {
  font-size: 24rpx;
  color: #245f93;
  font-weight: 700;
}

.progress-card .section-side {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(36, 95, 147, 0.08);
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #dfeaf3;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #245f93 0%, #5b8fb8 78%, #c6a16e 100%);
  border-radius: 999rpx;
}

.member-list {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 96rpx;
}

.member-item--me {
  padding: 10rpx 8rpx 12rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(36, 95, 147, 0.08), rgba(36, 95, 147, 0.02));
  border: 1rpx solid rgba(36, 95, 147, 0.08);
}

.avatar-wrap {
  position: relative;
}

.member-avatar,
.avatar-empty {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #edf5fb;
}

.member-avatar {
  border: 3rpx solid rgba(36, 95, 147, 0.16);
}

.avatar-empty {
  background: rgba(36, 95, 147, 0.04);
  border: 3rpx dashed rgba(36, 95, 147, 0.2);
}

.owner-tag {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #245f93, #7fa7c8);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.member-name {
  font-size: 22rpx;
  color: #6f8399;
  text-align: center;
  width: 96rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-name {
  color: #a7b8c7;
}

.notice-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(36, 95, 147, 0.06);
}

.icon-xs {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.82;
}

.notice-text,
.rule-line,
.desc-body {
  font-size: 24rpx;
  color: #5f7690;
  line-height: 1.65;
}

.rule-line {
  display: flex;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.rule-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #245f93;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.stock-progress {
  margin-top: 8rpx;
}

.trust-bar {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.82);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.trust-item {
  font-size: 22rpx;
  color: #6f8399;
}

.trust-sep {
  font-size: 22rpx;
  color: #d2dce6;
}

.state-banner {
  margin-top: 16rpx;
  padding: 24rpx 24rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: center;
}

.success-banner {
  background: linear-gradient(135deg, rgba(15,118,110,0.12), rgba(30,74,109,0.12));
}

.fail-banner {
  background: rgba(107, 130, 151, 0.12);
}

.state-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #16324d;
}

.state-desc {
  font-size: 22rpx;
  color: #6f8399;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.94), #ffffff);
  border-top: 1rpx solid rgba(36, 95, 147, 0.08);
  padding: 16rpx 24rpx 40rpx;
  display: flex;
  gap: 16rpx;
  align-items: stretch;
  z-index: 100;
}

.btn-col-share {
  width: 200rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  background: rgba(36, 95, 147, 0.08);
  border-radius: 20rpx;
  padding: 12rpx 8rpx;
}

.share-button-reset {
  margin: 0;
  border: 0;
  line-height: 1.2;
  box-sizing: border-box;
}

.share-button-reset::after { border: 0; }

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.78;
}

.btn-col-main {
  font-size: 24rpx;
  font-weight: 800;
  color: #245f93;
}

.btn-col-sub {
  font-size: 18rpx;
  color: #6f8399;
}

.btn-join-wrap {
  flex: 1;
  min-width: 0;
}

.btn-join-wrap.full-width {
  width: 100%;
}

.btn-join {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #245f93, #1e4a6d);
  color: #fff;
  border-radius: 20rpx;
  min-height: 96rpx;
  padding: 14rpx 20rpx;
  box-sizing: border-box;
}

.btn-pay {
  background: linear-gradient(135deg, #e67e22, #d35400);
}

.btn-line1 {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.3;
}

.btn-line2 {
  font-size: 20rpx;
  color: rgba(255,255,255,0.88);
  margin-top: 6rpx;
  line-height: 1.2;
}

.btn-disabled {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #dfeaf3;
  color: #6f8399;
  font-size: 26rpx;
  border-radius: 999rpx;
  min-height: 96rpx;
}

.btn-status-note {
  background: rgba(36, 95, 147, 0.1);
  color: #245f93;
}

.success-done {
  background: rgba(15, 118, 110, 0.12);
  color: #0f766e;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}
