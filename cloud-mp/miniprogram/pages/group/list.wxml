<!-- pages/group/list.wxml -->
<view class="container">
  <view class="nav-bar" style="padding-top: {{navTopPadding}}px;">
    <view class="nav-back" bindtap="onBack">
      <image class="nav-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"/>
    </view>
    <text class="nav-title">拼团专区</text>
    <view class="nav-placeholder"/>
  </view>

  <view class="hero-shell">
    <view class="hero-badge-row">
      <view class="hero-badge">
        <image class="hero-badge-icon" src="/assets/icons/users.svg" mode="aspectFit"></image>
        <text class="hero-badge-text">会员可发起</text>
      </view>
      <view class="hero-badge hero-badge--soft">
        <image class="hero-badge-icon" src="/assets/icons/gift.svg" mode="aspectFit"></image>
        <text class="hero-badge-text">{{activities.length || 0}} 个活动</text>
      </view>
    </view>

    <view class="hero-card">
      <view class="hero-copy">
        <text class="hero-title">组团下单，价格更直接</text>
        <text class="hero-subtitle">会员开团，好友参团，人数凑齐后立即按拼团价成交；发起后可在“我的拼团”持续查看进度。</text>
      </view>

      <view class="hero-stats">
        <view class="stat-card">
          <text class="stat-label">专区活动</text>
          <text class="stat-value">{{activities.length || 0}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">我的拼团</text>
          <text class="stat-value">{{myGroups.length || 0}}</text>
        </view>
        <view class="stat-card stat-card--member">
          <text class="stat-label">当前身份</text>
          <text class="stat-value stat-value--small">{{isMember ? '会员' : '未开通'}}</text>
        </view>
      </view>

      <view class="hero-actions">
        <view class="hero-btn hero-btn-primary" bindtap="onGoMyGroups">我的拼团</view>
        <view class="hero-btn" bindtap="onGoActivities">去发起</view>
      </view>
    </view>
  </view>

  <view class="member-tip" wx:if="{{showMemberTip}}">
    <image class="tip-icon" src="/assets/icons/star.svg" mode="aspectFit"/>
    <text class="tip-text">完成首单消费即可升级为会员，解锁发起拼团权限。</text>
  </view>

  <view class="tab-row">
    <view class="tab-item {{tab === 'activities' ? 'active' : ''}}" bindtap="switchTab" data-tab="activities">拼团商品</view>
    <view class="tab-item {{tab === 'my' ? 'active' : ''}}" bindtap="switchTab" data-tab="my">我的拼团</view>
  </view>

  <view wx:if="{{tab === 'activities'}}">
    <view class="section-head">
      <view>
        <text class="section-title">可发起活动</text>
        <text class="section-subtitle">先看人数门槛和拼团价，再决定是否开团。</text>
      </view>
    </view>

    <view class="skeleton-list" wx:if="{{loading && !activities.length}}">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-img"></view>
        <view class="skeleton-body">
          <view class="skeleton-line skeleton-line-title"></view>
          <view class="skeleton-line skeleton-line-price"></view>
          <view class="skeleton-line skeleton-line-meta"></view>
        </view>
      </view>
    </view>

    <view class="empty-wrap" wx:if="{{!activities.length && !loading}}">
      <image src="/assets/icons/package.svg" class="empty-icon" mode="aspectFit"/>
      <text class="empty-text">暂无拼团活动\n活动上线后可从这里发起，已参与记录看“我的拼团”</text>
    </view>

    <view class="activity-list">
      <view class="activity-card" wx:for="{{activities}}" wx:key="id" bindtap="onStartGroup" data-activity="{{item}}">
        <view class="img-wrap">
          <image class="product-img" src="{{item.product && item.product.images && item.product.images[0] || '/assets/icons/package.svg'}}" mode="aspectFill" binderror="onActivityImageError" data-index="{{index}}"/>
          <view class="corner-badge">拼团</view>
        </view>
        <view class="activity-info">
          <text class="product-name line-2">{{item.product && item.product.name || '商品'}}</text>
          <view class="tag-row">
            <text class="tag tag-hot" wx:if="{{item._saveNum > 0}}">省 ¥{{item._saveYuan}}</text>
            <text class="tag">{{item.min_members}}人起拼</text>
            <text class="tag tag-muted">最多{{item._maxCap}}人</text>
          </view>
          <view class="price-row">
            <view class="group-price">
              <text class="price-label">拼团价</text>
              <text class="group-price-val">¥{{item.group_price}}</text>
            </view>
            <view class="original-price">
              <text class="original-price-label">单买价</text>
              <text wx:if="{{item._linePrice}}">¥{{item._linePrice}}</text>
              <text wx:else>¥{{item.original_price || (item.product && item.product.retail_price) || '-'}}</text>
            </view>
          </view>
          <view class="stock-row" wx:if="{{item.stock_limit > 0}}">
            <view class="stock-bar">
              <view class="stock-fill" style="width: {{item._soldPct}}%;"/>
            </view>
            <text class="stock-text">已拼 {{item._soldCount}} 件 · 剩余 {{item._stockRemain}} 件</text>
          </view>
          <text class="one-line-desc" wx:if="{{item._summary}}">{{item._summary}}</text>
          <view class="meta-row">
            <view class="meta-copy">
              <text class="meta-item">{{item.min_members}}人成团</text>
              <text class="meta-dot">·</text>
              <text class="meta-item">开团后{{item.expire_hours}}h有效</text>
            </view>
            <view class="start-btn">{{isMember ? '发起拼团' : '需要会员'}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{tab === 'my'}}">
    <view class="section-head">
      <view>
        <text class="section-title">我的拼团</text>
        <text class="section-subtitle">查看开团进度、分享状态和成团结果。</text>
      </view>
    </view>

    <view class="skeleton-list" wx:if="{{loading && !myGroups.length}}">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-img"></view>
        <view class="skeleton-body">
          <view class="skeleton-line skeleton-line-title"></view>
          <view class="skeleton-line skeleton-line-price"></view>
          <view class="skeleton-line skeleton-line-meta"></view>
        </view>
      </view>
    </view>

    <view class="empty-wrap" wx:if="{{!myGroups.length && !loading}}">
      <image src="/assets/icons/package.svg" class="empty-icon" mode="aspectFit"/>
      <text class="empty-text">还没有参与拼团\n快去发起一个吧</text>
      <view class="empty-action" bindtap="onGoActivities">去发起拼团</view>
    </view>

    <view class="group-list">
      <!-- 未支付的拼团订单 -->
      <view class="group-record group-record--unpaid" wx:for="{{myGroups}}" wx:key="id" wx:if="{{item.payment_status === 'unpaid'}}">
        <view class="record-img-wrap">
          <image class="record-img" src="{{item.groupOrder && item.groupOrder.product && item.groupOrder.product.images && item.groupOrder.product.images[0] || '/assets/icons/package.svg'}}" mode="aspectFill"/>
          <view class="record-overlay-unpaid">
            <text>待支付</text>
          </view>
        </view>
        <view class="record-info">
          <view class="record-head-row">
            <text class="record-name">{{item.groupOrder && item.groupOrder.product && item.groupOrder.product.name || '商品'}}</text>
          </view>
          <view class="record-badge-row">
            <view class="record-badge record-badge--role" wx:if="{{item.is_leader}}">我发起的</view>
            <view class="record-badge record-badge--role" wx:else>我参与的</view>
          </view>
          <view class="member-progress member-progress--unpaid">
            <view class="member-pill">
              <text class="member-pill-label">团</text>
            </view>
            <text class="member-text">平台人数 {{item._memberText}}</text>
          </view>
          <view class="unpaid-price-row">
            <text class="unpaid-price">¥{{item.pay_amount || '0.00'}}</text>
            <text class="unpaid-hint">支付后自动加入拼团</text>
          </view>
          <view class="record-action-row">
            <view class="record-action record-action--pay" catchtap="onGoPayOrder" data-order-id="{{item.order_id}}" data-order-no="{{item.order_no}}">
              <text>去支付</text>
            </view>
            <view class="record-action record-action--cancel" catchtap="onCancelUnpaidOrder" data-order-id="{{item.order_id}}">
              <text>取消</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 已取消/已退款的拼团订单 -->
      <view class="group-record group-record--cancelled" wx:for="{{myGroups}}" wx:key="id" wx:if="{{item.payment_status === 'cancelled'}}" bindtap="onViewGroup" data-no="{{item.groupOrder && item.groupOrder.group_no}}">
        <view class="record-img-wrap">
          <image class="record-img record-img--dimmed" src="{{item.groupOrder && item.groupOrder.product && item.groupOrder.product.images && item.groupOrder.product.images[0] || '/assets/icons/package.svg'}}" mode="aspectFill"/>
          <view class="record-overlay-cancelled">
            <text>已取消</text>
          </view>
        </view>
        <view class="record-info">
          <view class="record-head-row">
            <text class="record-name record-name--dimmed">{{item.groupOrder && item.groupOrder.product && item.groupOrder.product.name || '商品'}}</text>
          </view>
          <view class="record-badge-row">
            <view class="record-badge record-badge--cancelled-tag">订单已取消</view>
            <view class="record-badge record-badge--role" wx:if="{{item.is_leader}}">我发起的</view>
            <view class="record-badge record-badge--role" wx:else>我参与的</view>
          </view>
          <view class="cancelled-hint">
            <text>你的订单已取消，拼团可能仍在继续</text>
          </view>
          <view class="record-action-row">
            <view class="record-action record-action--secondary" catchtap="onViewGroup" data-no="{{item.groupOrder && item.groupOrder.group_no}}">
              <text>查看团状态</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 已支付的拼团订单 -->
      <view class="group-record group-record--paid" wx:for="{{myGroups}}" wx:key="id" wx:if="{{item.payment_status === 'paid'}}" bindtap="onViewGroup" data-no="{{item.groupOrder && item.groupOrder.group_no}}">
        <view class="record-img-wrap">
          <image class="record-img" src="{{item.groupOrder && item.groupOrder.product && item.groupOrder.product.images && item.groupOrder.product.images[0] || '/assets/icons/package.svg'}}" mode="aspectFill"/>
          <view class="record-overlay-status record-overlay-{{item.groupOrder.status}}">
            <text wx:if="{{item.groupOrder && item.groupOrder.status === 'open'}}">拼团中</text>
            <text wx:elif="{{item.groupOrder && item.groupOrder.status === 'success'}}">已成团</text>
            <text wx:else>已结束</text>
          </view>
        </view>
        <view class="record-info">
          <view class="record-head-row">
            <text class="record-name">{{item.groupOrder && item.groupOrder.product && item.groupOrder.product.name || '商品'}}</text>
          </view>
          <view class="record-badge-row">
            <view class="record-badge record-badge--paid">已支付</view>
            <view class="record-badge record-badge--role" wx:if="{{item.is_leader}}">我发起的</view>
            <view class="record-badge record-badge--role" wx:else>我参与的</view>
            <view class="record-badge record-badge--status record-badge--{{item.groupOrder.status}}">
              <text wx:if="{{item.groupOrder && item.groupOrder.status === 'open'}}">进行中</text>
              <text wx:elif="{{item.groupOrder && item.groupOrder.status === 'success'}}">已成团</text>
              <text wx:else>已失败</text>
            </view>
          </view>
          <view class="member-progress">
            <view class="member-pill">
              <text class="member-pill-label">团</text>
            </view>
            <text class="member-text">平台人数 {{item._memberText}}</text>
          </view>
          <view class="record-action-row">
            <view class="share-row" wx:if="{{item.groupOrder && item.groupOrder.status === 'open'}}" catchtap="onShare" data-no="{{item.groupOrder.group_no}}">
              <image class="share-icon" src="/assets/icons/share.svg" mode="aspectFit"/>
              <text>分享给好友参团</text>
            </view>
            <view class="record-action" catchtap="onViewGroup" data-no="{{item.groupOrder && item.groupOrder.group_no}}">
              <text>查看进度</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
