.page {
  min-height: 100vh;
  background: #F4F8FA;
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
}

.state-loading,
.state-error {
  padding: 120rpx 40rpx;
  text-align: center;
  color: #64748B;
  font-size: 28rpx;
}

.cover {
  width: 100%;
  display: block;
  vertical-align: top;
}

.body {
  padding: 32rpx 28rpx 80rpx;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -24rpx;
  position: relative;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
  line-height: 1.35;
  margin-bottom: 20rpx;
}

.summary {
  display: block;
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.6;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.rich-wrap {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.75;
}

.empty-rich {
  font-size: 26rpx;
  color: #94A3B8;
}
