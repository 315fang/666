/* 品牌资讯详情 — 2026 青春版 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 28%, #F7F5FF 100%);
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
}

.state-loading,
.state-error {
  padding: 120rpx 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.15);
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #a8a29e;
}

.error-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: #78716c;
}

.cover {
  width: 100%;
  display: block;
  vertical-align: top;
}

.body {
  padding: 36rpx 28rpx 80rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -28rpx;
  position: relative;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #1c1917;
  line-height: 1.35;
  margin-bottom: 20rpx;
}

.summary {
  display: block;
  font-size: 26rpx;
  color: #78716c;
  line-height: 1.6;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.1);
}

.rich-wrap {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.8;
  word-break: break-word;
}

.rich-wrap image {
  max-width: 100%;
  border-radius: 12rpx;
  margin: 16rpx 0;
}

.empty-rich {
  text-align: center;
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #a8a29e;
}
