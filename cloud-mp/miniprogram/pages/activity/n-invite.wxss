.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef5ff 0%, #f8fafc 28%, #f5f5f4 100%);
}

.hero {
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1f3f64, #335d89);
  box-shadow: 0 20rpx 60rpx rgba(31, 63, 100, 0.18);
  text-align: center;
  color: #fff;
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  display: block;
  margin: 28rpx auto 20rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.22);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.4;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.92);
}

.meta-row {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.meta-item {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.14);
}

.meta-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.meta-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.section-title,
.invalid-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.loading-text,
.invalid-desc,
.action-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #57534e;
}

.benefit-item,
.flow-step {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
}

.benefit-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2563eb;
  margin-top: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.benefit-text,
.step-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: #374151;
}

.step-index {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: #eff6ff;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.primary-btn {
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.disabled-btn {
  background: #d6d3d1;
  color: #fff;
}
