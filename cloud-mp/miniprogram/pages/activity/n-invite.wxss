/* 邀请页 — 2026 青春版 */
.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 28%, #F7F5FF 100%);
}

/* Hero */
.hero {
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #a78bfa 100%);
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.25);
  text-align: center;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(8px);
  font-size: 22rpx;
  font-weight: 600;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  display: block;
  margin: 28rpx auto 20rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.22);
  position: relative;
  z-index: 1;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.92);
  position: relative;
  z-index: 1;
}

.meta-row {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
  position: relative;
  z-index: 1;
}

.meta-item {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(8px);
}

.meta-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.meta-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

/* 通用卡片 */
.card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.section-title,
.invalid-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1917;
}

/* 加载中 */
.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.15);
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #a8a29e;
}

/* 无效邀请 */
.invalid-card {
  text-align: center;
  padding: 60rpx 32rpx;
}

.invalid-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  display: block;
}

.invalid-desc,
.action-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #78716c;
}

/* 权益列表 */
.benefit-item {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  gap: 16rpx;
}

.benefit-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.benefit-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: #374151;
}

/* 流程步骤 */
.flow-step {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  gap: 16rpx;
}

.step-index {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.step-line {
  position: absolute;
  left: 45rpx;
  top: 64rpx;
  width: 2rpx;
  height: 40rpx;
  background: rgba(102, 126, 234, 0.2);
}

.step-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: #374151;
  padding-top: 8rpx;
}

/* 操作按钮 */
.primary-btn {
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
  border: none;
}

.primary-btn::after {
  border: none;
}

.disabled-btn {
  background: #d6d3d1;
  box-shadow: none;
}

.safe-bottom {
  height: calc(48rpx + env(safe-area-inset-bottom));
}
