/* 限时专享 — 2026 青春版 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 30%, #F7F5FF 100%);
  display: flex;
  flex-direction: column;
}

.nav-bar {
  flex-shrink: 0;
  background: rgba(15, 15, 35, 0.85);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  position: relative;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.scroll {
  flex: 1;
  height: 0;
  padding: 0 24rpx 24rpx;
}

/* 档期选择 */
.slot-strip {
  margin-top: 24rpx;
  white-space: nowrap;
}

.slot-strip-inner {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 12rpx;
}

.slot-chip {
  min-width: 180rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  transition: all 0.3s;
}

.slot-chip.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.slot-chip-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1c1917;
}

.slot-chip-sub {
  font-size: 20rpx;
  color: #78716c;
}

.slot-chip.active .slot-chip-title,
.slot-chip.active .slot-chip-sub {
  color: #fff;
}

/* Hero 区域 */
.hero {
  margin-top: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #a78bfa 100%);
  color: #fff;
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.25);
  position: relative;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  filter: blur(2rpx);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.hero-countdown {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hero-countdown-label {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.72);
}

.hero-countdown-value {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(8px);
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 2rpx;
  color: #fff;
}

.hero-kicker {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  position: relative;
  z-index: 1;
}

.hero-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
  position: relative;
  z-index: 1;
}

/* 列表头 */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 0 16rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1917;
}

.list-count {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
  padding: 6rpx 16rpx;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 999rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #1c1917;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #a8a29e;
}

/* 商品卡片 */
.goods-card {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 26rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.goods-img-wrap {
  position: relative;
  flex-shrink: 0;
}

.goods-img {
  width: 208rpx;
  height: 208rpx;
  border-radius: 18rpx;
}

.goods-sold-out {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 18rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.goods-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.goods-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.goods-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1917;
  line-height: 1.4;
}

.mode-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.mode-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
  white-space: nowrap;
}

.mode-tag-money {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.mode-tag-points {
  background: rgba(245, 158, 11, 0.1);
  color: #d97706;
}

.goods-desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: #78716c;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 库存进度条 */
.goods-meta {
  margin-top: 4rpx;
}

.goods-remain-bar {
  height: 8rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.goods-remain-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 999rpx;
  transition: width 0.5s ease;
}

.goods-remain-text {
  font-size: 20rpx;
  color: #a8a29e;
}

/* 价格行 */
.price-row {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx;
}

.p-money {
  color: #667eea;
  font-size: 34rpx;
  font-weight: 700;
}

.p-points {
  color: #d97706;
  font-size: 28rpx;
  font-weight: 700;
}

.p-sep {
  color: #d6d3d1;
  font-size: 24rpx;
}

.p-origin {
  margin-left: 6rpx;
  color: #a8a29e;
  font-size: 22rpx;
  text-decoration: line-through;
}

/* 按钮行 */
.btn-row {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.btn {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 18rpx 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: transform 0.15s;
}

.btn:active {
  transform: scale(0.95);
}

.btn-detail {
  background: rgba(102, 126, 234, 0.08);
  color: #667eea;
}

.btn-points {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(245, 158, 11, 0.25);
}

.btn-money {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.25);
}

.btn.disabled {
  opacity: 0.38;
  pointer-events: none;
}

.safe-bottom {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

/* 加载状态 */
.state-loading {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx;
}

.loading-spinner-wrap {
  margin-bottom: 20rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.15);
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #a8a29e;
}

/* 空状态页 */
.empty-state {
  flex: 1;
  padding: 140rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-state .empty-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-state-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1917;
  margin-bottom: 12rpx;
}

.empty-state-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: #a8a29e;
}
