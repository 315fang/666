/* 限时专享 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #EDE8F5 0%, #F4F1FA 40%, #F8F6FF 100%);
  display: flex;
  flex-direction: column;
}

/* 导航栏 — 只在这里保留毛玻璃 */
.nav-bar {
  flex-shrink: 0;
  background: rgba(15, 15, 35, 0.82);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  position: relative;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.scroll {
  flex: 1;
  height: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 0 24rpx 24rpx;
  overflow-x: hidden;
}

/* 档期选择 */
.slot-strip {
  margin-top: 24rpx;
  white-space: nowrap;
}

.slot-strip-inner {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 12rpx;
}

.slot-chip {
  min-width: 160rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 1rpx solid #E8E4F0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.slot-chip.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  box-shadow: 0 6rpx 18rpx rgba(102, 126, 234, 0.28);
}

.slot-chip-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1c1917;
}

.slot-chip-sub {
  font-size: 20rpx;
  color: #78716c;
}

.slot-chip.active .slot-chip-title,
.slot-chip.active .slot-chip-sub {
  color: #fff;
}

/* Hero 区域 — 去掉 glow 装饰，渐变收敛为两色 */
.hero {
  margin-top: 24rpx;
  padding: 28rpx 28rpx 32rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.22);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

/* 防止倒计时把 kicker 文字挤出 */
.hero-kicker {
  flex-shrink: 1;
  min-width: 0;
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 1rpx;
}

.hero-countdown {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.hero-countdown-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

.hero-countdown-value {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 2rpx;
  color: #fff;
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
}

/* 列表头 */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 0 16rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1c1917;
}

.list-count {
  font-size: 22rpx;
  color: #667eea;
  font-weight: 600;
  padding: 4rpx 14rpx;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 6rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 64rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-text {
  font-size: 28rpx;
  color: #1c1917;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #a8a29e;
}

/* 商品卡片 — 纯白背景，去毛玻璃 */
.goods-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  gap: 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.goods-img-wrap {
  position: relative;
  flex-shrink: 0;
}

.goods-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.goods-sold-out {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.48);
  border-radius: 12rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.goods-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.goods-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
}

.goods-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1917;
  line-height: 1.4;
}

/* 标签 — 直角圆角，去胶囊感 */
.mode-tags {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  align-items: flex-end;
}

.mode-tag {
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  font-size: 18rpx;
  font-weight: 600;
  white-space: nowrap;
}

.mode-tag-money {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.mode-tag-points {
  background: rgba(217, 119, 6, 0.1);
  color: #d97706;
}

.goods-desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: #78716c;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 库存进度条 */
.goods-meta {
  margin-top: 2rpx;
}

.goods-remain-bar {
  height: 6rpx;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.goods-remain-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 999rpx;
  transition: width 0.5s ease;
}

.goods-remain-text {
  font-size: 20rpx;
  color: #a8a29e;
}

/* 价格行 — 去 flex-wrap，层级清晰 */
.price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-wrap: nowrap;
  overflow: hidden;
}

.p-money {
  color: #5a6fd6;
  font-size: 36rpx;
  font-weight: 700;
  white-space: nowrap;
}

.p-points {
  color: #d97706;
  font-size: 26rpx;
  font-weight: 700;
  white-space: nowrap;
}

.p-sep {
  color: #d6d3d1;
  font-size: 22rpx;
  flex-shrink: 0;
}

.p-origin {
  color: #a8a29e;
  font-size: 20rpx;
  text-decoration: line-through;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 按钮行 — 固定策略，不换行 */
.btn-row {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
}

.btn {
  text-align: center;
  padding: 16rpx 0;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: transform 0.15s;
  white-space: nowrap;
}

.btn:active {
  transform: scale(0.96);
}

/* 查看详情：固定宽度，不抢空间 */
.btn-detail {
  width: 180rpx;
  flex-shrink: 0;
  background: #F5F3FF;
  color: #667eea;
}

/* 积分兑换 和 立即秒杀 各占剩余一半 */
.btn-points {
  flex: 1;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.2);
}

.btn-money {
  flex: 1;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.22);
}

.btn.disabled {
  opacity: 0.35;
  pointer-events: none;
}

.safe-bottom {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

/* 加载状态 */
.state-loading {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx;
}

.loading-spinner-wrap {
  margin-bottom: 20rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.12);
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #a8a29e;
}

/* 空状态页 */
.empty-state {
  flex: 1;
  padding: 140rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-state-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
  margin-bottom: 12rpx;
}

.empty-state-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: #a8a29e;
}
