.page {
  min-height: 100vh;
  background: #f7f1ea;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  background: #2e2218;
  flex-shrink: 0;
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  position: relative;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.9;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #fff8f0;
}

.scroll {
  flex: 1;
  height: 0;
  padding: 0 24rpx 24rpx;
}

.hero {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #4b3527 0%, #81604a 100%);
  color: #fff8f0;
  box-shadow: 0 16rpx 40rpx rgba(61, 41, 26, 0.18);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-kicker {
  font-size: 22rpx;
  color: rgba(255, 248, 240, 0.82);
  letter-spacing: 2rpx;
}

.hero-deadline {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 240, 0.14);
  font-size: 22rpx;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.hero-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 248, 240, 0.86);
}

.hero-tip {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: rgba(255, 248, 240, 0.76);
}

.list-title {
  margin: 26rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #44403c;
}

.empty {
  text-align: center;
  color: #a8a29e;
  padding: 40rpx;
  font-size: 26rpx;
}

.goods-card {
  background: #fffaf5;
  border-radius: 26rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(45, 32, 23, 0.06);
}

.goods-img {
  width: 208rpx;
  height: 208rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #f5f5f4;
}

.goods-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.goods-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.goods-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1917;
}

.mode-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.mode-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.mode-tag-money {
  background: rgba(185, 40, 39, 0.1);
  color: #b91c1c;
}

.mode-tag-points {
  background: rgba(161, 98, 7, 0.1);
  color: #a16207;
}

.goods-desc {
  font-size: 22rpx;
  line-height: 1.7;
  color: #78716c;
}

.goods-meta {
  font-size: 22rpx;
  color: #a8a29e;
}

.price-row {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx;
}

.p-money {
  color: #dc2626;
  font-size: 32rpx;
  font-weight: 700;
}

.p-points {
  color: #b45309;
  font-size: 28rpx;
  font-weight: 700;
}

.p-sep {
  color: #d6d3d1;
  font-size: 24rpx;
}

.p-origin {
  margin-left: 6rpx;
  color: #a8a29e;
  font-size: 22rpx;
  text-decoration: line-through;
}

.btn-row {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.btn {
  flex: 1;
  min-width: 168rpx;
  text-align: center;
  padding: 18rpx 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.btn-detail {
  background: #f5ede4;
  color: #6b4f38;
}

.btn-points {
  background: linear-gradient(135deg, #fde68a, #f59e0b);
  color: #6b3f00;
}

.btn-money {
  background: linear-gradient(135deg, #d97706, #b45309);
  color: #fff7ed;
}

.btn.disabled {
  opacity: 0.38;
  pointer-events: none;
}

.safe-bottom {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

.state-loading {
  padding: 120rpx;
  text-align: center;
  color: #a8a29e;
}

.empty-state {
  flex: 1;
  padding: 140rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-state-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #44403c;
}

.empty-state-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #a8a29e;
}
