.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f2ea 0%, #f7fafc 200rpx, #f7fafc 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #5b3716 0%, #c77b30 100%);
  box-shadow: 0 12rpx 30rpx rgba(91, 55, 22, 0.18);
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.84);
}

.state-wrap {
  padding: 140rpx 40rpx;
  text-align: center;
  color: #64748b;
}

.state-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.state-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.retry-btn {
  width: 240rpx;
  margin: 32rpx auto 0;
  padding: 20rpx 0;
  border-radius: 999rpx;
  background: #0f172a;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.bundle-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.bundle-card {
  overflow: hidden;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.bundle-cover {
  width: 100%;
  height: 360rpx;
  background: #e2e8f0;
}

.bundle-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #5b3716 0%, #d4a56c 100%);
}

.bundle-cover-placeholder-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.84);
  font-weight: 600;
}

.bundle-info {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 26rpx 24rpx 28rpx;
}

.bundle-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.bundle-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(199, 123, 48, 0.12);
  color: #8b5e34;
  font-size: 20rpx;
  font-weight: 600;
}

.bundle-tag-soft {
  background: rgba(148, 163, 184, 0.12);
  color: #64748b;
}

.bundle-title {
  font-size: 34rpx;
  line-height: 1.4;
  color: #0f172a;
  font-weight: 700;
}

.bundle-subtitle {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.7;
}

.bundle-meta {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.bundle-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #b05a46;
}

.bundle-count {
  font-size: 22rpx;
  color: #94a3b8;
}

.bundle-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f7;
}

.bundle-entry-text {
  font-size: 24rpx;
  color: #5b3716;
  font-weight: 600;
}

.bundle-entry-arrow {
  font-size: 30rpx;
  color: #c77b30;
  font-weight: 600;
}
