/* pages/address/edit.wxss */
.container {
  min-height: 100vh;
  background: #F8FAFC;
  padding: 20rpx 24rpx;
  padding-bottom: 200rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 28rpx;
  color: #334155;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: block;
}

.required-mark {
  color: #DC2626;
  margin-left: 6rpx;
}

.field-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #64748B;
}

.form-input {
  font-size: 28rpx;
  color: #0F172A;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.form-textarea {
  font-size: 28rpx;
  color: #0F172A;
  width: 100%;
  min-height: 80rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #0F172A;
}

picker {
  display: block;
  width: 100%;
}

.form-picker .placeholder {
  color: #94A3B8;
}

.form-picker .arrow {
  font-size: 32rpx;
  color: #94A3B8;
}

.wechat-address-entry {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #3B82F6;
}

.region-panel {
  position: fixed;
  inset: 0;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}

.region-panel.show {
  opacity: 1;
  pointer-events: auto;
}

.region-mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.4);
}

.region-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  overflow: hidden;
}

.region-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.region-title {
  font-size: 28rpx;
  color: #0F172A;
  font-weight: 600;
}

.region-action {
  font-size: 26rpx;
  color: #64748B;
}

.region-action.confirm {
  color: #2563EB;
  font-weight: 600;
}

.region-picker-view {
  width: 100%;
  height: 480rpx;
}

.region-option {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #0F172A;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row-between .form-label {
  margin-bottom: 0;
}

/* 保存 */
.save-section {
  padding: 40rpx 0;
}

.save-btn {
  background: linear-gradient(135deg, #1C1917 0%, #3A3027 100%);
  color: #FFF7F0;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.save-btn.disabled {
  opacity: 0.5;
}
