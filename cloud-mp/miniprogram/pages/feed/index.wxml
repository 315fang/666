<view class="page">
  <view class="hero-card">
    <view class="hero-top">
      <view>
        <text class="hero-kicker">AI 定见</text>
        <text class="hero-title">Hi, {{userName}}</text>
        <text class="hero-sub">当前推荐能力已下线，后续会以新内容形态回归。</text>
      </view>
      <view class="box-entry" bindtap="goToBox">
        <image class="box-icon" src="/assets/icons/box.svg" mode="aspectFit"></image>
        <view class="box-badge" wx:if="{{boxCount > 0}}">{{boxCount}}</view>
      </view>
    </view>
  </view>

  <view class="section-card empty-shell" wx:if="{{currentIndex >= cards.length && !loading}}">
    <view class="empty-mark">AI</view>
    <text class="empty-title">今日 AI 推荐暂停开放</text>
    <text class="empty-sub">定见箱仍然保留，后续恢复推荐后会继续沿用你的偏好积累。</text>
    <view class="empty-actions">
      <view class="ghost-btn" bindtap="refreshFeed">重新检查</view>
      <view class="primary-btn" bindtap="goToBox">查看定见箱</view>
    </view>
  </view>

  <view class="action-hint" wx:if="{{currentIndex < cards.length}}">
    <text>左滑跳过，右滑加入定见箱</text>
  </view>
</view>
