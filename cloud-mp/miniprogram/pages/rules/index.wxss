page { background: #f5ede1; }
.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(205, 161, 92, 0.16), transparent 32%),
    linear-gradient(180deg, #f8f1e5 0%, #f1e4d2 100%);
}

.hero-card,
.card {
  background: rgba(255, 252, 246, 0.94);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid rgba(191, 151, 97, 0.18);
  box-shadow: 0 18rpx 40rpx rgba(117, 81, 33, 0.08);
  margin-bottom: 24rpx;
}

.hero-eyebrow {
  display: block;
  font-size: 22rpx;
  color: #a2783e;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #3b2b1a;
  line-height: 1.4;
}

.summary {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6d5740;
  line-height: 1.7;
}

.item {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(191, 151, 97, 0.12);
}

.item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.index {
  width: 54rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #a2783e;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.text {
  flex: 1;
  font-size: 26rpx;
  color: #4f3b28;
  line-height: 1.7;
}

.empty-card {
  text-align: center;
}

.empty {
  font-size: 28rpx;
  color: #8e7559;
  display: block;
}
