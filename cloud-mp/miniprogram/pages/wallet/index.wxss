/* pages/wallet/index.wxss — 淡紫简洁版 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #E8E0F0 0%, #F0EBF8 30%, #F7F5FF 100%);
  position: relative;
}

.main-scroll { flex: 1; }

/* ── 余额卡 ── */
.balance-card { padding: 24rpx 24rpx 0; }

.balance-card-inner {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 28rpx;
  padding: 40rpx 36rpx 36rpx;
  box-shadow: 0 12rpx 28rpx rgba(102, 126, 234, 0.2);
}

.balance-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
}

.balance-amount-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.balance-symbol { font-size: 36rpx; color: rgba(255, 255, 255, 0.7); font-weight: 600; }

.balance-amount {
  font-size: 80rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.balance-meta-row { margin-bottom: 28rpx; }

.balance-meta-text { font-size: 22rpx; color: rgba(255, 255, 255, 0.6); }

.balance-action-row { display: flex; gap: 16rpx; }

.withdraw-btn {
  min-width: 200rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.withdraw-btn-text { font-size: 28rpx; font-weight: 600; color: #fff; }

.withdraw-history-btn {
  min-width: 168rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.withdraw-history-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
}

/* ── 通用卡片 ── */
.section-card {
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1c1917;
  margin-bottom: 20rpx;
}

.section-title-inline { margin-bottom: 0; }

.section-more {
  font-size: 24rpx;
  color: #667eea;
}

/* ── 佣金概览四格 ── */
.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.overview-item {
  background: rgba(102, 126, 234, 0.04);
  border: 1rpx solid rgba(102, 126, 234, 0.08);
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.overview-val { font-size: 34rpx; font-weight: 700; color: #1c1917; }
.overview-frozen { color: #d97706; }
.overview-estimated { color: #8b5cf6; }
.overview-pending { color: #f59e0b; }
.overview-settled { color: #10b981; }
.overview-key { font-size: 22rpx; color: #78716c; }
.overview-tip { font-size: 18rpx; color: #a8a29e; line-height: 1.5; }

/* ── 待入账展开卡 ── */
.pending-card {
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  overflow: hidden;
}

.pc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pc-header-left { flex: 1; }

.pc-title { display: block; font-size: 28rpx; font-weight: 700; color: #1c1917; }

.pc-subtitle { display: block; font-size: 22rpx; color: #78716c; margin-top: 4rpx; }

.pc-header-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.pc-total { font-size: 36rpx; font-weight: 700; color: #667eea; }

.pc-arrow {
  font-size: 36rpx;
  color: #a8a29e;
  display: inline-block;
  transition: transform 0.25s;
  transform: rotate(0deg);
}

.pc-arrow-up { transform: rotate(90deg); }

.pc-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.pc-detail-open { max-height: 520rpx; }

.pc-divider {
  height: 1rpx;
  background: rgba(102, 126, 234, 0.08);
  margin: 20rpx 0 16rpx;
}

.pc-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 14rpx 0;
}

.pc-row-left {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  flex: 1;
}

.pc-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.pc-dot-estimated { background: #8b5cf6; }
.pc-dot-frozen    { background: #d97706; }
.pc-dot-pending   { background: #f59e0b; }
.pc-dot-settling  { background: #10b981; }

.pc-row-label { display: block; font-size: 26rpx; font-weight: 600; color: #1c1917; }

.pc-row-hint { display: block; font-size: 20rpx; color: #a8a29e; margin-top: 4rpx; }

.pc-row-amount { font-size: 28rpx; font-weight: 700; flex-shrink: 0; padding-top: 2rpx; }
.pc-amount-estimated { color: #8b5cf6; }
.pc-amount-frozen   { color: #d97706; }
.pc-amount-pending  { color: #f59e0b; }
.pc-amount-settling { color: #10b981; }

/* ── 代理商货款入口 ── */
.goods-fund-entry {
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gfe-left { display: flex; align-items: center; gap: 18rpx; flex: 1; }
.gfe-icon { font-size: 44rpx; }
.gfe-info { display: flex; flex-direction: column; }
.gfe-title { font-size: 28rpx; font-weight: 700; color: #1c1917; }
.gfe-sub { font-size: 22rpx; color: #78716c; margin-top: 4rpx; }
.gfe-right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.gfe-balance { font-size: 30rpx; font-weight: 700; color: #667eea; }
.gfe-arrow { font-size: 32rpx; color: #a8a29e; }

/* ── 提现记录 ── */
.withdraw-skeleton { padding-top: 4rpx; }

.withdraw-record {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.06);
}

.withdraw-record:last-child { border-bottom: none; }

.withdraw-record-main {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.withdraw-record-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.withdraw-record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1917;
}

.withdraw-record-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.withdraw-status-pending { color: #d97706; background: rgba(217, 119, 6, 0.08); }
.withdraw-status-approved { color: #667eea; background: rgba(102, 126, 234, 0.08); }
.withdraw-status-processing { color: #8b5cf6; background: rgba(139, 92, 246, 0.08); }
.withdraw-status-success { color: #10b981; background: rgba(16, 185, 129, 0.08); }
.withdraw-status-fail { color: #ef4444; background: rgba(239, 68, 68, 0.08); }
.withdraw-status-muted { color: #a8a29e; background: rgba(168, 162, 158, 0.08); }

.withdraw-record-time {
  display: block;
  font-size: 22rpx;
  color: #a8a29e;
  margin-bottom: 4rpx;
}

.withdraw-record-hint {
  display: block;
  font-size: 22rpx;
  color: #78716c;
  line-height: 1.5;
}

.withdraw-record-reason {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #ef4444;
  line-height: 1.5;
}

.withdraw-record-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  padding-top: 2rpx;
}

.withdraw-record-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
}

.withdraw-record-actual {
  font-size: 20rpx;
  color: #a8a29e;
  margin-top: 6rpx;
}

.withdraw-empty {
  padding: 36rpx 0 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.withdraw-empty-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #78716c;
  margin-bottom: 8rpx;
}

.withdraw-empty-sub {
  font-size: 22rpx;
  color: #a8a29e;
  line-height: 1.5;
}

/* ── 佣金流水 ── */
.log-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.06);
}

.log-item:last-child { border-bottom: none; }

.log-left { flex: 1; margin-right: 16rpx; }

.log-type-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.log-type { font-size: 28rpx; font-weight: 600; color: #1c1917; }

.log-status-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.log-status-frozen          { color: #d97706; background: rgba(217, 119, 6, 0.08); }
.log-status-pending_approval { color: #f59e0b; background: rgba(245, 158, 11, 0.08); }
.log-status-approved        { color: #667eea; background: rgba(102, 126, 234, 0.08); }
.log-status-settled         { color: #10b981; background: rgba(16, 185, 129, 0.08); }
.log-status-cancelled       { color: #a8a29e; background: rgba(168, 162, 158, 0.08); }

.log-time { display: block; font-size: 22rpx; color: #a8a29e; margin-bottom: 4rpx; }

.log-deadline { font-size: 20rpx; color: #78716c; }

.log-right { flex-shrink: 0; padding-top: 2rpx; }

.log-amount { font-size: 32rpx; font-weight: 700; }

.log-positive { color: #10b981; }
.log-negative { color: #667eea; }

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.empty-text { font-size: 28rpx; color: #78716c; font-weight: 600; margin-bottom: 10rpx; }
.empty-sub { font-size: 24rpx; color: #a8a29e; }

/* ── 底部说明 ── */
.footer-note {
  margin: 24rpx 24rpx 0;
  padding: 0 4rpx;
}

.footer-note-text {
  display: block;
  font-size: 22rpx;
  color: #a8a29e;
  line-height: 1.7;
}

/* ── 提现弹窗 ── */
.popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 15, 35, 0.4);
  backdrop-filter: blur(8px);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.popup-panel {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 8rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1917;
}

.popup-close {
  position: absolute;
  right: 0;
  font-size: 44rpx;
  color: #a8a29e;
  line-height: 1;
}

.popup-balance-tip {
  font-size: 24rpx;
  color: #78716c;
  text-align: center;
  margin-bottom: 16rpx;
}

.popup-balance-num { font-weight: 700; color: #1c1917; }

.popup-rule-tip {
  margin-bottom: 24rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #78716c;
  text-align: center;
}

.popup-input-wrap {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(102, 126, 234, 0.1);
  padding: 16rpx 0 20rpx;
  margin-bottom: 20rpx;
}

.popup-input-symbol { font-size: 40rpx; color: #1c1917; font-weight: 600; margin-right: 10rpx; }

.popup-input { flex: 1; font-size: 48rpx; font-weight: 700; color: #1c1917; height: 72rpx; }

.popup-calc-tip {
  margin-bottom: 28rpx;
  font-size: 22rpx;
  color: #78716c;
  text-align: center;
}

.popup-btn-row { display: flex; gap: 16rpx; }

.popup-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(102, 126, 234, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-cancel-text { font-size: 28rpx; font-weight: 600; color: #78716c; }

.popup-confirm {
  flex: 2;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.2);
}

.btn-loading { opacity: 0.6; }

.popup-confirm-text { font-size: 28rpx; font-weight: 600; color: #fff; }

/* ── 骨架屏 ── */
.skeleton-wrap { padding-top: 4rpx; }

.sk-log {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.04);
}

.sk-info { flex: 1; margin-right: 20rpx; }

.sk-amount {
  width: 80rpx;
  height: 32rpx;
  background: linear-gradient(90deg, rgba(102,126,234,0.04) 25%, rgba(102,126,234,0.08) 50%, rgba(102,126,234,0.04) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx;
}

.sk-line {
  height: 24rpx;
  background: linear-gradient(90deg, rgba(102,126,234,0.04) 25%, rgba(102,126,234,0.08) 50%, rgba(102,126,234,0.04) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.sk-long { width: 65%; }
.sk-short { width: 40%; height: 20rpx; }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
