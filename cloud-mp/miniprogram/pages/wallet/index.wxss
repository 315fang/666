/* pages/wallet/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F3ED 0%, #FAFAF8 30%, #F1EEEA 100%);
  position: relative;
}

.main-scroll { flex: 1; }

/* ── 余额卡 ── */
.balance-card { padding: 24rpx 24rpx 0; }

.balance-card-inner {
  background: linear-gradient(140deg, #2B2018 0%, #1A1511 100%);
  border-radius: 28rpx;
  padding: 40rpx 36rpx 36rpx;
  box-shadow: 0 16rpx 40rpx rgba(28, 20, 14, 0.18);
}

.balance-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 240, 220, 0.55);
  margin-bottom: 16rpx;
}

.balance-amount-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.balance-symbol { font-size: 36rpx; color: rgba(255, 240, 220, 0.80); font-weight: 600; }

.balance-amount { font-size: 80rpx; font-weight: 700; color: #FFF7EF; line-height: 1; }

.balance-meta-row { margin-bottom: 28rpx; }

.balance-meta-text { font-size: 22rpx; color: rgba(212, 184, 150, 0.70); }

.balance-action-row { display: flex; }

.withdraw-btn {
  min-width: 200rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: rgba(185, 139, 88, 0.20);
  border: 1rpx solid rgba(185, 139, 88, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.withdraw-btn-text { font-size: 28rpx; font-weight: 600; color: #D4B896; }

/* ── 通用卡片 ── */
.section-card {
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 29, 21, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1C1917;
  margin-bottom: 20rpx;
}

/* ── 佣金概览四格 ── */
.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.overview-item {
  background: #F8F5F1;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.overview-val { font-size: 34rpx; font-weight: 700; color: #1C1917; }
.overview-frozen { color: #B76447; }
.overview-estimated { color: #8E6AC8; }
.overview-pending { color: #A06C46; }
.overview-settled { color: #5A8060; }
.overview-key { font-size: 22rpx; color: #9A8D80; }
.overview-tip { font-size: 18rpx; color: #B0A396; line-height: 1.5; }

/* ── 待入账展开卡 ── */
.pending-card {
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 29, 21, 0.05);
  overflow: hidden;
}

.pc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pc-header-left { flex: 1; }

.pc-title { display: block; font-size: 28rpx; font-weight: 700; color: #1C1917; }

.pc-subtitle { display: block; font-size: 22rpx; color: #9A8D80; margin-top: 4rpx; }

.pc-header-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.pc-total { font-size: 36rpx; font-weight: 700; color: #A06C46; }

.pc-arrow {
  font-size: 36rpx;
  color: #B0A396;
  display: inline-block;
  transition: transform 0.25s;
  transform: rotate(0deg);
}

.pc-arrow-up { transform: rotate(90deg); }

.pc-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.pc-detail-open { max-height: 520rpx; }

.pc-divider {
  height: 1rpx;
  background: rgba(122, 108, 94, 0.10);
  margin: 20rpx 0 16rpx;
}

.pc-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 14rpx 0;
}

.pc-row-left {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  flex: 1;
}

.pc-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.pc-dot-estimated { background: #8E6AC8; }
.pc-dot-frozen    { background: #B76447; }
.pc-dot-pending   { background: #D4965A; }
.pc-dot-settling  { background: #5A8060; }

.pc-row-label { display: block; font-size: 26rpx; font-weight: 600; color: #1C1917; }

.pc-row-hint { display: block; font-size: 20rpx; color: #B0A396; margin-top: 4rpx; }

.pc-row-amount { font-size: 28rpx; font-weight: 700; flex-shrink: 0; padding-top: 2rpx; }
.pc-amount-estimated { color: #8E6AC8; }
.pc-amount-frozen   { color: #B76447; }
.pc-amount-pending  { color: #D4965A; }
.pc-amount-settling { color: #5A8060; }

/* ── 代理商货款入口 ── */
.goods-fund-entry {
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 29, 21, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gfe-left { display: flex; align-items: center; gap: 18rpx; flex: 1; }
.gfe-icon { font-size: 44rpx; }
.gfe-info { display: flex; flex-direction: column; }
.gfe-title { font-size: 28rpx; font-weight: 700; color: #1C1917; }
.gfe-sub { font-size: 22rpx; color: #9A8D80; margin-top: 4rpx; }
.gfe-right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.gfe-balance { font-size: 30rpx; font-weight: 700; color: #A06C46; }
.gfe-arrow { font-size: 32rpx; color: #B0A396; }

/* ── 佣金流水 ── */
.log-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(122, 108, 94, 0.08);
}

.log-item:last-child { border-bottom: none; }

.log-left { flex: 1; margin-right: 16rpx; }

.log-type-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.log-type { font-size: 28rpx; font-weight: 600; color: #1C1917; }

.log-status-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.log-status-frozen          { color: #B76447; background: #FAECE8; }
.log-status-pending_approval { color: #A06C46; background: #F8EEE4; }
.log-status-approved        { color: #6A7E9A; background: #EEF4FB; }
.log-status-settled         { color: #53725B; background: #EDF6EF; }
.log-status-cancelled       { color: #9A8D80; background: #F2EFEC; }

.log-time { display: block; font-size: 22rpx; color: #B0A396; margin-bottom: 4rpx; }

.log-deadline { font-size: 20rpx; color: #C5A884; }

.log-right { flex-shrink: 0; padding-top: 2rpx; }

.log-amount { font-size: 32rpx; font-weight: 700; }

.log-positive { color: #5A8060; }
.log-negative { color: #B76447; }

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.empty-text { font-size: 28rpx; color: #78716C; font-weight: 600; margin-bottom: 10rpx; }
.empty-sub { font-size: 24rpx; color: #B0A396; }

/* ── 底部说明 ── */
.footer-note {
  margin: 24rpx 24rpx 0;
  padding: 0 4rpx;
}

.footer-note-text {
  display: block;
  font-size: 22rpx;
  color: #B0A396;
  line-height: 1.7;
}

/* ── 提现弹窗 ── */
.popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.popup-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 8rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C1917;
}

.popup-close {
  position: absolute;
  right: 0;
  font-size: 44rpx;
  color: #B0A396;
  line-height: 1;
}

.popup-balance-tip {
  font-size: 24rpx;
  color: #9A8D80;
  text-align: center;
  margin-bottom: 32rpx;
}

.popup-balance-num { font-weight: 700; color: #1C1917; }

.popup-input-wrap {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(122, 108, 94, 0.15);
  padding: 16rpx 0 20rpx;
  margin-bottom: 36rpx;
}

.popup-input-symbol { font-size: 40rpx; color: #1C1917; font-weight: 600; margin-right: 10rpx; }

.popup-input { flex: 1; font-size: 48rpx; font-weight: 700; color: #1C1917; height: 72rpx; }

.popup-btn-row { display: flex; gap: 16rpx; }

.popup-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  background: #F2EEE8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-cancel-text { font-size: 28rpx; font-weight: 600; color: #78716C; }

.popup-confirm {
  flex: 2;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2B2018 0%, #1A1511 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-loading { opacity: 0.6; }

.popup-confirm-text { font-size: 28rpx; font-weight: 600; color: #FFF7EF; }

/* ── 骨架屏 ── */
.skeleton-wrap { padding-top: 4rpx; }

.sk-log {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(122, 108, 94, 0.06);
}

.sk-info { flex: 1; margin-right: 20rpx; }

.sk-amount {
  width: 80rpx;
  height: 32rpx;
  background: linear-gradient(90deg, #F3EEE9 25%, #EBE2D8 50%, #F3EEE9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx;
}

.sk-line {
  height: 24rpx;
  background: linear-gradient(90deg, #F3EEE9 25%, #EBE2D8 50%, #F3EEE9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.sk-long { width: 65%; }
.sk-short { width: 40%; height: 20rpx; }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
