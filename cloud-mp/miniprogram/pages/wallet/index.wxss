/* pages/wallet/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f8f7f4;
  position: relative;
}

.main-scroll { flex: 1; }

.balance-card { padding: 24rpx 24rpx 0; }

.balance-card-inner {
  background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
  border-radius: 28rpx;
  padding: 40rpx 36rpx 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.15);
}

.balance-label { display: block; font-size: 22rpx; color: rgba(255,255,255,0.7); margin-bottom: 16rpx; }
.balance-amount-row { display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 12rpx; }
.balance-symbol { font-size: 36rpx; color: rgba(255,255,255,0.7); font-weight: 600; }
.balance-amount { font-size: 80rpx; font-weight: 700; color: #fff; line-height: 1; }
.balance-meta-row { margin-bottom: 28rpx; }
.balance-meta-text { font-size: 22rpx; color: rgba(255,255,255,0.6); }
.balance-action-row { display: flex; gap: 16rpx; }

.withdraw-btn {
  min-width: 200rpx; height: 80rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.2); border: 1rpx solid rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center; padding: 0 40rpx;
}
.withdraw-btn-text { font-size: 28rpx; font-weight: 600; color: #fff; }

.withdraw-history-btn {
  min-width: 168rpx; height: 80rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.1); border: 1rpx solid rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center; padding: 0 32rpx;
}
.withdraw-history-btn-text { font-size: 26rpx; font-weight: 600; color: rgba(255,255,255,0.8); }

.section-card {
  margin: 16rpx 24rpx 0; background: #fff; border-radius: 24rpx;
  padding: 28rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.04);
}
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.section-title { display: block; font-size: 28rpx; font-weight: 700; color: #1f2937; margin-bottom: 20rpx; }
.section-title-inline { margin-bottom: 0; }
.section-more { font-size: 24rpx; color: #2563eb; }

.overview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.overview-item {
  background: #f0f4f8; border: 1rpx solid rgba(0,0,0,0.04);
  border-radius: 16rpx; padding: 20rpx; display: flex; flex-direction: column; gap: 8rpx;
}
.overview-val { font-size: 34rpx; font-weight: 700; color: #1f2937; }
.overview-frozen { color: #d97706; }
.overview-estimated { color: #6366f1; }
.overview-pending { color: #f59e0b; }
.overview-settled { color: #10b981; }
.overview-key { font-size: 22rpx; color: #6b7280; }
.overview-tip { font-size: 18rpx; color: #9ca3af; line-height: 1.5; }

.pending-card {
  margin: 16rpx 24rpx 0; background: #fff; border-radius: 24rpx;
  padding: 24rpx 28rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.04); overflow: hidden;
}
.pc-header { display: flex; align-items: center; justify-content: space-between; }
.pc-header-left { flex: 1; }
.pc-title { display: block; font-size: 28rpx; font-weight: 700; color: #1f2937; }
.pc-subtitle { display: block; font-size: 22rpx; color: #6b7280; margin-top: 4rpx; }
.pc-header-right { display: flex; align-items: center; gap: 10rpx; flex-shrink: 0; }
.pc-total { font-size: 36rpx; font-weight: 700; color: #dc2626; }
.pc-arrow { font-size: 36rpx; color: #9ca3af; display: inline-block; transition: transform 0.25s; transform: rotate(0deg); }
.pc-arrow-up { transform: rotate(90deg); }
.pc-detail { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
.pc-detail-open { max-height: 520rpx; }
.pc-divider { height: 1rpx; background: #f3f4f6; margin: 20rpx 0 16rpx; }
.pc-row { display: flex; align-items: flex-start; justify-content: space-between; padding: 14rpx 0; }
.pc-row-left { display: flex; align-items: flex-start; gap: 14rpx; flex: 1; }
.pc-dot { width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0; margin-top: 8rpx; }
.pc-dot-estimated { background: #6366f1; }
.pc-dot-frozen { background: #d97706; }
.pc-dot-pending { background: #f59e0b; }
.pc-dot-settling { background: #10b981; }
.pc-row-label { display: block; font-size: 26rpx; font-weight: 600; color: #1f2937; }
.pc-row-hint { display: block; font-size: 20rpx; color: #9ca3af; margin-top: 4rpx; }
.pc-row-amount { font-size: 28rpx; font-weight: 700; flex-shrink: 0; padding-top: 2rpx; }
.pc-amount-estimated { color: #6366f1; }
.pc-amount-frozen { color: #d97706; }
.pc-amount-pending { color: #f59e0b; }
.pc-amount-settling { color: #10b981; }

.goods-fund-entry {
  margin: 16rpx 24rpx 0; background: #fff; border-radius: 24rpx;
  padding: 24rpx 28rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.04);
  display: flex; align-items: center; justify-content: space-between;
}
.gfe-left { display: flex; align-items: center; gap: 18rpx; flex: 1; }
.gfe-icon { font-size: 44rpx; }
.gfe-info { display: flex; flex-direction: column; }
.gfe-title { font-size: 28rpx; font-weight: 700; color: #1f2937; }
.gfe-sub { font-size: 22rpx; color: #6b7280; margin-top: 4rpx; }
.gfe-right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.gfe-balance { font-size: 30rpx; font-weight: 700; color: #dc2626; }
.gfe-arrow { font-size: 32rpx; color: #9ca3af; }

.withdraw-skeleton { padding-top: 4rpx; }
.withdraw-record {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 22rpx 0; border-bottom: 1rpx solid #f3f4f6;
}
.withdraw-record:last-child { border-bottom: none; }
.withdraw-record-main { flex: 1; min-width: 0; margin-right: 16rpx; }
.withdraw-record-top { display: flex; align-items: center; gap: 10rpx; margin-bottom: 6rpx; }
.withdraw-record-title { font-size: 28rpx; font-weight: 600; color: #1f2937; }
.withdraw-record-status { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 999rpx; }
.withdraw-status-pending { color: #d97706; background: #fef3c7; }
.withdraw-status-approved { color: #2563eb; background: #dbeafe; }
.withdraw-status-processing { color: #6366f1; background: #e0e7ff; }
.withdraw-status-success { color: #10b981; background: #d1fae5; }
.withdraw-status-fail { color: #dc2626; background: #fee2e2; }
.withdraw-status-muted { color: #9ca3af; background: #f3f4f6; }
.withdraw-record-time { display: block; font-size: 22rpx; color: #9ca3af; margin-bottom: 4rpx; }
.withdraw-record-hint { display: block; font-size: 22rpx; color: #6b7280; line-height: 1.5; }
.withdraw-record-reason { display: block; margin-top: 6rpx; font-size: 22rpx; color: #dc2626; line-height: 1.5; }
.withdraw-record-side { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; padding-top: 2rpx; }
.withdraw-record-amount { font-size: 32rpx; font-weight: 700; color: #dc2626; }
.withdraw-record-actual { font-size: 20rpx; color: #9ca3af; margin-top: 6rpx; }
.withdraw-empty { padding: 36rpx 0 22rpx; display: flex; flex-direction: column; align-items: center; }
.withdraw-empty-title { font-size: 26rpx; font-weight: 600; color: #6b7280; margin-bottom: 8rpx; }
.withdraw-empty-sub { font-size: 22rpx; color: #9ca3af; line-height: 1.5; }

.log-item {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 22rpx 0; border-bottom: 1rpx solid #f3f4f6;
}
.log-item:last-child { border-bottom: none; }
.log-left { flex: 1; margin-right: 16rpx; }
.log-type-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 6rpx; }
.log-type { font-size: 28rpx; font-weight: 600; color: #1f2937; }
.log-status-badge { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 999rpx; }
.log-status-frozen { color: #d97706; background: #fef3c7; }
.log-status-pending_approval { color: #f59e0b; background: #fef9c3; }
.log-status-approved { color: #2563eb; background: #dbeafe; }
.log-status-settled { color: #10b981; background: #d1fae5; }
.log-status-cancelled { color: #9ca3af; background: #f3f4f6; }
.log-time { display: block; font-size: 22rpx; color: #9ca3af; margin-bottom: 4rpx; }
.log-deadline { font-size: 20rpx; color: #6b7280; }
.log-right { flex-shrink: 0; padding-top: 2rpx; }
.log-amount { font-size: 32rpx; font-weight: 700; }
.log-positive { color: #10b981; }
.log-negative { color: #dc2626; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0 40rpx; }
.empty-text { font-size: 28rpx; color: #6b7280; font-weight: 600; margin-bottom: 10rpx; }
.empty-sub { font-size: 24rpx; color: #9ca3af; }

.footer-note { margin: 24rpx 24rpx 0; padding: 0 4rpx; }
.footer-note-text { display: block; font-size: 22rpx; color: #9ca3af; line-height: 1.7; }

.popup-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1000;
  display: flex; align-items: flex-end; justify-content: center;
}
.popup-panel {
  width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx calc(40rpx + env(safe-area-inset-bottom)); box-sizing: border-box;
}
.popup-header { display: flex; align-items: center; justify-content: center; position: relative; margin-bottom: 8rpx; }
.popup-title { font-size: 32rpx; font-weight: 700; color: #1f2937; }
.popup-close { position: absolute; right: 0; font-size: 44rpx; color: #9ca3af; line-height: 1; }
.popup-balance-tip { font-size: 24rpx; color: #6b7280; text-align: center; margin-bottom: 16rpx; }
.popup-balance-num { font-weight: 700; color: #1f2937; }
.popup-rule-tip { margin-bottom: 24rpx; font-size: 22rpx; line-height: 1.6; color: #6b7280; text-align: center; }
.popup-input-wrap { display: flex; align-items: center; border-bottom: 2rpx solid #e5e7eb; padding: 16rpx 0 20rpx; margin-bottom: 20rpx; }
.popup-input-symbol { font-size: 40rpx; color: #1f2937; font-weight: 600; margin-right: 10rpx; }
.popup-input { flex: 1; font-size: 48rpx; font-weight: 700; color: #1f2937; height: 72rpx; }
.popup-calc-tip { margin-bottom: 28rpx; font-size: 22rpx; color: #6b7280; text-align: center; }
.popup-btn-row { display: flex; gap: 16rpx; }
.popup-cancel {
  flex: 1; height: 88rpx; border-radius: 999rpx; background: #f3f4f6;
  display: flex; align-items: center; justify-content: center;
}
.popup-cancel-text { font-size: 28rpx; font-weight: 600; color: #6b7280; }
.popup-confirm {
  flex: 2; height: 88rpx; border-radius: 999rpx; background: #2563eb;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
}
.btn-loading { opacity: 0.6; }
.popup-confirm-text { font-size: 28rpx; font-weight: 600; color: #fff; }

.skeleton-wrap { padding-top: 4rpx; }
.sk-log {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 22rpx 0; border-bottom: 1rpx solid #f3f4f6;
}
.sk-info { flex: 1; margin-right: 20rpx; }
.sk-amount {
  width: 80rpx; height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%; animation: shimmer 1.4s ease-in-out infinite; border-radius: 10rpx;
}
.sk-line {
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%; animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx; margin-bottom: 12rpx;
}
.sk-long { width: 65%; }
.sk-short { width: 40%; height: 20rpx; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
