<!--pages/lottery/lottery.wxml-->
<view class="container">
  <view class="nav-bar" style="padding-top: {{navTopPadding}}px;">
    <view class="nav-back" bindtap="onBack">
      <image class="nav-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"/>
    </view>
    <text class="nav-title">积分抽奖</text>
    <view class="nav-placeholder"/>
  </view>

  <view class="wheel-panel" wx:if="{{mode === 'spin'}}">
    <view class="gacha-stage">
      <view class="gacha-machine {{spinning ? 'is-running' : ''}} {{opening ? 'is-opening' : ''}}">
        <view class="machine-top">
          <text class="machine-brand">POINTS DRAW</text>
          <view class="machine-lights">
            <view class="machine-light" wx:for="{{[1,2,3,4,5]}}" wx:key="index"></view>
          </view>
        </view>
        <view class="machine-window">
          <view class="machine-glass"></view>
          <view class="capsule-cloud">
            <view
              class="capsule-sample capsule-pos-{{index % 6}}"
              wx:for="{{machineCapsules}}"
              wx:key="index"
              style="background: linear-gradient(180deg, {{item.theme_color}} 0%, {{item.accent_color}} 100%);"
            >
              <text class="capsule-sample-emoji">{{item.display_emoji}}</text>
            </view>
          </view>
        </view>
        <view class="machine-base">
          <view class="machine-chute">
            <view class="result-capsule capsule-placeholder" wx:if="{{!lastPrize}}">
              <text class="result-capsule-mark">?</text>
            </view>
            <view
              class="result-capsule {{opening ? 'capsule-drop' : 'capsule-ready'}}"
              wx:if="{{lastPrize}}"
              style="background: linear-gradient(180deg, {{lastPrize.theme_color}} 0%, {{lastPrize.accent_color}} 100%);"
            >
              <view class="capsule-top"></view>
              <view class="capsule-bottom"></view>
              <text class="result-capsule-mark">{{lastPrize.display_emoji}}</text>
            </view>
          </view>
          <view class="machine-controls">
            <view class="machine-dial">
              <view class="machine-dial-core"></view>
            </view>
            <view class="machine-handle">
              <view class="machine-handle-bar"></view>
              <view class="machine-handle-knob"></view>
            </view>
          </view>
        </view>

        <view class="machine-footer">
          <view class="machine-footer-chip">
            <text class="machine-footer-label">投币</text>
            <text class="machine-footer-value">{{costPoints}} 积分</text>
          </view>
          <view class="machine-start-btn {{spinning || !prizes.length ? 'disabled' : ''}}" bindtap="onDraw">
            <text wx:if="{{opening}}">正在开球...</text>
            <text wx:elif="{{spinning}}">机器出货中...</text>
            <text wx:elif="{{!prizes.length}}">奖池加载中</text>
            <text wx:else>开始抽奖</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-head">
    <view>
      <text class="section-title">我的中奖记录</text>
      <text class="section-subtitle">默认展示最近 3 条，展开后可查看完整记录。</text>
    </view>
  </view>
  <view class="records-list">
    <view class="empty-tip" wx:if="{{!records.length}}">
      <image src="/assets/icons/package.svg" class="empty-icon" mode="aspectFit"/>
      <text>{{emptyRecordText}}</text>
    </view>
    <view class="record-item" wx:for="{{records}}" wx:key="id" wx:if="{{recordsExpanded || index < defaultRecordCount}}">
      <view class="record-icon">{{item.display_emoji}}</view>
      <view class="record-left">
        <text class="record-prize">{{item.prize_name}}</text>
        <text class="record-time">{{item.created_at}}</text>
      </view>
      <view class="record-status {{item.status}}">
        <text wx:if="{{item.status === 'pending'}}">待领取</text>
        <text wx:else>已发放</text>
      </view>
    </view>
    <view
      class="records-toggle"
      wx:if="{{records.length > defaultRecordCount}}"
      bindtap="toggleRecords"
      hover-class="records-toggle-hover"
    >
      <text class="records-toggle-text">{{recordsExpanded ? '收起记录' : '展开全部记录'}}</text>
      <text class="records-toggle-arrow">{{recordsExpanded ? '˄' : '˅'}}</text>
    </view>
  </view>

  <view class="section-head">
    <view>
      <text class="section-title">奖池预览</text>
      <text class="section-subtitle">默认收起展示，展开后可查看全部奖项。</text>
    </view>
  </view>
  <view class="prize-grid">
    <view
      class="prize-item"
      wx:for="{{prizes}}"
      wx:key="id"
      wx:if="{{prizesExpanded || index < defaultPrizeCount}}"
      style="border-color: {{item.accent_color}};"
    >
      <view class="prize-item-top">
        <text class="prize-badge">{{item.badge_text}}</text>
        <image wx:if="{{item.image_url}}" class="prize-img" src="{{item.image_url}}" mode="aspectFit"/>
        <view wx:else class="prize-icon-shell" style="background: linear-gradient(135deg, {{item.theme_color}} 0%, {{item.accent_color}} 100%);">
          <text class="prize-emoji">{{item.display_emoji || prizeEmoji[item.type] || '🎁'}}</text>
        </view>
      </view>
      <text class="prize-name">{{item.name}}</text>
      <text class="prize-value">{{item.display_value}}</text>
    </view>
  </view>
  <view
    class="records-toggle prize-toggle"
    wx:if="{{prizes.length > defaultPrizeCount}}"
    bindtap="togglePrizes"
    hover-class="records-toggle-hover"
  >
    <text class="records-toggle-text">{{prizesExpanded ? '收起奖池预览' : '展开奖池预览'}}</text>
    <text class="records-toggle-arrow">{{prizesExpanded ? '˄' : '˅'}}</text>
  </view>

  <view class="result-modal" wx:if="{{showResult && lastPrize}}">
    <view class="result-overlay" bindtap="closeResult"/>
    <view class="result-card">
      <view class="result-icon-ring" style="background: linear-gradient(135deg, {{lastPrize.theme_color}} 0%, {{lastPrize.accent_color}} 100%);">
        <text class="result-emoji">{{lastPrize.display_emoji}}</text>
      </view>
      <text class="result-type {{lastPrize.type === 'miss' ? 'miss' : 'win'}}">
        {{lastPrize.type === 'miss' ? resultMissTitle : resultWinTitle}}
      </text>
      <text class="result-prize-name">{{lastPrize.name}}</text>
      <text class="result-value">{{lastPrize.display_value}}</text>
      <text class="result-badge">{{lastPrize.badge_text}}</text>
      <view class="result-actions">
        <view class="result-btn primary" bindtap="closeResult">我知道了</view>
        <view class="result-btn" bindtap="onDraw" wx:if="{{lastPrize.type === 'miss'}}">再抽一次</view>
      </view>
    </view>
  </view>
</view>
