/** pages/lottery/lottery.wxss **/

.container {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #1e4a6d 0, #1e4a6d 420rpx, #edf5fb 420rpx, #f7fbff 100%);
  padding-bottom: 72rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 28rpx;
}

.nav-back,
.nav-placeholder {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
  filter: invert(1);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.wheel-panel,
.records-list,
.prize-grid,
.section-head {
  margin-left: 28rpx;
  margin-right: 28rpx;
}

.wheel-panel {
  margin-top: 20rpx;
  padding: 12rpx 0 20rpx;
  border-radius: 28rpx;
  background: transparent;
  border: none;
  box-shadow: none;
}

.panel-head,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel-title,
.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #16324d;
}

.panel-subtitle,
.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b8297;
}

.panel-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(36, 95, 147, 0.1);
  color: #245f93;
  font-size: 22rpx;
  font-weight: 600;
}

.gacha-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.gacha-machine {
  width: 100%;
  border-radius: 32rpx;
  padding: 24rpx 24rpx 30rpx;
  background: linear-gradient(180deg, #245f93 0%, #1e4a6d 72%, #16324d 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08), 0 18rpx 36rpx rgba(30, 74, 109, 0.18);
}

.gacha-machine.is-running {
  animation: machinePulse 0.9s ease-in-out infinite;
}

.machine-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.machine-brand {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: #EAF3FB;
  font-weight: 700;
}

.machine-lights {
  display: flex;
  gap: 8rpx;
}

.machine-light {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #F8FAFC;
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.45);
}

.gacha-machine.is-running .machine-light:nth-child(odd) {
  background: #C58B47;
}

.machine-window {
  position: relative;
  height: 360rpx;
  overflow: hidden;
  border-radius: 28rpx 28rpx 18rpx 18rpx;
  background: radial-gradient(circle at top, rgba(196, 223, 247, 0.26), rgba(19, 41, 61, 0.94) 62%);
  border: 6rpx solid rgba(226, 232, 240, 0.22);
}

.machine-glass {
  position: absolute;
  top: 0;
  right: 24rpx;
  bottom: 0;
  width: 90rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.14), rgba(255,255,255,0.02));
}

.capsule-cloud {
  position: relative;
  width: 100%;
  height: 100%;
}

.capsule-sample {
  position: absolute;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 14rpx 24rpx rgba(15, 23, 42, 0.32);
}

.gacha-machine.is-running .capsule-sample {
  animation: floatCapsule 1.3s ease-in-out infinite alternate;
}

.capsule-pos-0 { top: 34rpx; left: 34rpx; }
.capsule-pos-1 { top: 66rpx; left: 132rpx; }
.capsule-pos-2 { top: 24rpx; right: 36rpx; }
.capsule-pos-3 { top: 152rpx; left: 58rpx; }
.capsule-pos-4 { top: 174rpx; left: 174rpx; }
.capsule-pos-5 { top: 138rpx; right: 52rpx; }

.capsule-sample-emoji {
  font-size: 42rpx;
}

.machine-base {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.machine-chute {
  position: relative;
  flex: 1;
  min-height: 120rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(19, 41, 61, 0.92), rgba(30, 74, 109, 0.96));
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.result-capsule {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 20rpx rgba(0, 0, 0, 0.35);
}

.capsule-top,
.capsule-bottom {
  position: absolute;
  left: 0;
  right: 0;
  height: 50%;
}

.capsule-top {
  top: 0;
  border-radius: 54rpx 54rpx 22rpx 22rpx;
  background: rgba(255, 255, 255, 0.16);
}

.capsule-bottom {
  bottom: 0;
  border-radius: 22rpx 22rpx 54rpx 54rpx;
  background: rgba(15, 23, 42, 0.12);
}

.result-capsule-mark {
  position: relative;
  z-index: 2;
  font-size: 44rpx;
}

.capsule-placeholder {
  background: linear-gradient(180deg, #d7e8f6, #5f7690);
  opacity: 0.75;
}

.capsule-ready {
  transform: translateY(0) scale(0.96);
}

.capsule-drop {
  animation: capsuleDrop 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.machine-controls {
  width: 180rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.machine-dial {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d7e8f6, #7da7ca);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.26);
}

.machine-dial-core {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #16324d;
}

.machine-handle {
  position: relative;
  width: 72rpx;
  height: 118rpx;
}

.machine-handle-bar {
  position: absolute;
  right: 20rpx;
  bottom: 12rpx;
  width: 12rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #e5eef7, #7f9db7);
}

.machine-handle-knob {
  position: absolute;
  top: 0;
  right: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c58b47, #efd1a6);
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.26);
}

.gacha-machine.is-running .machine-handle {
  animation: handlePull 0.9s ease-in-out infinite;
}

.machine-footer {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.machine-footer-chip {
  min-width: 148rpx;
  min-height: 84rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
}

.machine-footer-label {
  font-size: 20rpx;
  color: rgba(234, 243, 251, 0.66);
}

.machine-footer-value {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #f7fbff;
}

.machine-start-btn {
  flex: 1;
  min-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d6e6f5 0%, #7fa7c8 100%);
  color: #16324d;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.35), 0 12rpx 24rpx rgba(12, 29, 45, 0.22);
}

.machine-start-btn.disabled {
  opacity: 0.55;
}

.section-head {
  margin-top: 34rpx;
  margin-bottom: 18rpx;
}

.prize-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.prize-item {
  min-height: 220rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(36, 95, 147, 0.12);
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(180deg, #ffffff 0%, #f4f9fd 100%);
  box-shadow: 0 12rpx 24rpx rgba(30, 74, 109, 0.06);
}

.prize-item-top {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.prize-badge {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #245f93;
  background: rgba(36, 95, 147, 0.08);
  font-weight: 600;
}

.prize-img {
  width: 72rpx;
  height: 72rpx;
}

.prize-icon-shell {
  width: 82rpx;
  height: 82rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(30, 74, 109, 0.12);
}

.prize-emoji {
  font-size: 54rpx;
  line-height: 1;
}

.prize-name {
  font-size: 28rpx;
  line-height: 1.4;
  color: #17324d;
  font-weight: 700;
}

.prize-value {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6f8399;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.empty-tip {
  text-align: center;
  color: #6f8399;
  font-size: 24rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-icon {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.5;
  filter: invert(38%) sepia(14%) saturate(938%) hue-rotate(169deg) brightness(89%) contrast(86%);
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(245,249,253,0.96));
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  box-shadow: 0 10rpx 24rpx rgba(30, 74, 109, 0.06);
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(36, 95, 147, 0.16), rgba(125, 167, 202, 0.16));
  font-size: 34rpx;
}

.record-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.record-prize {
  font-size: 26rpx;
  color: #17324d;
  font-weight: 600;
}

.record-time {
  font-size: 20rpx;
  color: #6f8399;
}

.record-substatus {
  font-size: 20rpx;
  color: #b45309;
  line-height: 1.5;
}

.record-status {
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  background: rgba(36, 95, 147, 0.08);
  color: #245f93;
}

.record-status.pending {
  background: rgba(197, 139, 71, 0.14);
  color: #b77923;
}

.record-status.issued,
.record-status.completed {
  background: rgba(15, 118, 110, 0.12);
  color: #0f766e;
}

.record-status.claim_required,
.record-status.claim_submitted,
.record-status.approved,
.record-status.shipped {
  background: rgba(37, 99, 235, 0.12);
  color: #1d4ed8;
}

.record-status.failed,
.record-status.cancelled {
  background: rgba(239, 68, 68, 0.12);
  color: #b91c1c;
}

.record-action {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(36, 95, 147, 0.1);
  color: #245f93;
  font-size: 22rpx;
  font-weight: 600;
}

.records-toggle {
  min-height: 76rpx;
  border-radius: 20rpx;
  background: rgba(36, 95, 147, 0.08);
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.records-toggle-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #245f93;
}

.records-toggle-arrow {
  font-size: 22rpx;
  color: #245f93;
  line-height: 1;
}

.records-toggle-hover {
  background: rgba(36, 95, 147, 0.14);
}

.prize-toggle {
  margin: 14rpx 28rpx 0;
}

.result-modal {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
background: rgba(16, 37, 56, 0.42);
}

.result-card {
  position: relative;
  z-index: 2;
  width: 580rpx;
  padding: 48rpx 40rpx 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6fbff 100%);
  border: 1rpx solid rgba(36, 95, 147, 0.08);
  text-align: center;
  box-shadow: 0 24rpx 60rpx rgba(30, 74, 109, 0.16);
}

.result-icon-ring {
  width: 136rpx;
  height: 136rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.2);
}

.result-emoji {
  font-size: 72rpx;
}

.result-type {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}

.result-type.win {
  color: #b77923;
}

.result-type.miss {
  color: #245f93;
}

.result-prize-name {
  display: block;
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #17324d;
}

.result-value {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6f8399;
}

.result-badge {
  display: inline-block;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #245f93;
  background: rgba(36, 95, 147, 0.08);
}

.result-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
}

.result-btn {
  min-width: 180rpx;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(36, 95, 147, 0.08);
  color: #245f93;
}

.result-btn.primary {
  background: linear-gradient(135deg, #245f93, #1e4a6d);
  color: #f7fbff;
}

@keyframes machinePulse {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

@keyframes floatCapsule {
  0% { transform: translateY(0) rotate(-3deg); }
  100% { transform: translateY(10rpx) rotate(4deg); }
}

@keyframes handlePull {
  0%, 100% { transform: rotate(0deg); }
  35% { transform: rotate(8deg); }
  70% { transform: rotate(-3deg); }
}

@keyframes capsuleDrop {
  0% { transform: translateY(-54rpx) scale(0.82); opacity: 0; }
  50% { transform: translateY(12rpx) scale(1.02); opacity: 1; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}
