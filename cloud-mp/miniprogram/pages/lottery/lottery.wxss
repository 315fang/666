/* 积分抽奖 — 2026 青春版 */
.container {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #667eea 0, #764ba2 420rpx, #E8E0F0 420rpx, #F7F5FF 100%);
  padding-bottom: 72rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 28rpx;
  background: rgba(15, 15, 35, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-back,
.nav-placeholder {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
  filter: invert(1);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.wheel-panel,
.records-list,
.prize-grid,
.section-head {
  margin-left: 28rpx;
  margin-right: 28rpx;
}

.wheel-panel {
  margin-top: 20rpx;
  padding: 12rpx 0 20rpx;
  border-radius: 28rpx;
  background: transparent;
  border: none;
  box-shadow: none;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1917;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #78716c;
}

/* 扭蛋机 */
.gacha-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.gacha-machine {
  width: 100%;
  border-radius: 32rpx;
  padding: 24rpx 24rpx 30rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 72%, #5b3a8a 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.1), 0 18rpx 36rpx rgba(102, 126, 234, 0.25);
}

.gacha-machine.is-running {
  animation: machinePulse 0.9s ease-in-out infinite;
}

.machine-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.machine-brand {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 700;
}

.machine-lights {
  display: flex;
  gap: 8rpx;
}

.machine-light {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.4);
}

.gacha-machine.is-running .machine-light:nth-child(odd) {
  background: #f59e0b;
  box-shadow: 0 0 16rpx rgba(245, 158, 11, 0.6);
}

.machine-window {
  position: relative;
  height: 360rpx;
  overflow: hidden;
  border-radius: 28rpx 28rpx 18rpx 18rpx;
  background: radial-gradient(circle at top, rgba(167, 139, 250, 0.3), rgba(30, 15, 60, 0.94) 62%);
  border: 6rpx solid rgba(255, 255, 255, 0.15);
}

.machine-glass {
  position: absolute;
  top: 0;
  right: 24rpx;
  bottom: 0;
  width: 90rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.14), rgba(255,255,255,0.02));
}

.capsule-cloud {
  position: relative;
  width: 100%;
  height: 100%;
}

.capsule-sample {
  position: absolute;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 14rpx 24rpx rgba(15, 23, 42, 0.35);
}

.gacha-machine.is-running .capsule-sample {
  animation: floatCapsule 1.3s ease-in-out infinite alternate;
}

.capsule-pos-0 { top: 34rpx; left: 34rpx; }
.capsule-pos-1 { top: 66rpx; left: 132rpx; }
.capsule-pos-2 { top: 24rpx; right: 36rpx; }
.capsule-pos-3 { top: 152rpx; left: 58rpx; }
.capsule-pos-4 { top: 174rpx; left: 174rpx; }
.capsule-pos-5 { top: 138rpx; right: 52rpx; }

.capsule-sample-emoji {
  font-size: 42rpx;
}

.machine-base {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.machine-chute {
  position: relative;
  flex: 1;
  min-height: 120rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(30, 15, 60, 0.92), rgba(102, 126, 234, 0.96));
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.result-capsule {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 20rpx rgba(0, 0, 0, 0.35);
}

.capsule-top,
.capsule-bottom {
  position: absolute;
  left: 0;
  right: 0;
  height: 50%;
}

.capsule-top {
  top: 0;
  border-radius: 54rpx 54rpx 22rpx 22rpx;
  background: rgba(255, 255, 255, 0.18);
}

.capsule-bottom {
  bottom: 0;
  border-radius: 22rpx 22rpx 54rpx 54rpx;
  background: rgba(15, 23, 42, 0.12);
}

.result-capsule-mark {
  position: relative;
  z-index: 2;
  font-size: 44rpx;
}

.capsule-placeholder {
  background: linear-gradient(180deg, rgba(255,255,255,0.3), rgba(102,126,234,0.5));
  opacity: 0.75;
}

.capsule-ready {
  transform: translateY(0) scale(0.96);
}

.capsule-drop {
  animation: capsuleDrop 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.machine-controls {
  width: 180rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.machine-dial {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255,255,255,0.3), rgba(167,139,250,0.5));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.26);
}

.machine-dial-core {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #5b3a8a;
}

.machine-handle {
  position: relative;
  width: 72rpx;
  height: 118rpx;
}

.machine-handle-bar {
  position: absolute;
  right: 20rpx;
  bottom: 12rpx;
  width: 12rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.5), rgba(167,139,250,0.6));
}

.machine-handle-knob {
  position: absolute;
  top: 0;
  right: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.26);
}

.gacha-machine.is-running .machine-handle {
  animation: handlePull 0.9s ease-in-out infinite;
}

.machine-footer {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.machine-footer-chip {
  min-width: 148rpx;
  min-height: 84rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
}

.machine-footer-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.machine-footer-value {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.machine-start-btn {
  flex: 1;
  min-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(245, 158, 11, 0.3);
}

.machine-start-btn.disabled {
  opacity: 0.55;
}

/* 奖池网格 */
.prize-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.prize-item {
  min-height: 220rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.06);
}

.prize-item-top {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.prize-badge {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.08);
  font-weight: 600;
}

.prize-img {
  width: 72rpx;
  height: 72rpx;
}

.prize-icon-shell {
  width: 82rpx;
  height: 82rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(102,126,234,0.12), rgba(118,75,162,0.12));
}

.prize-emoji {
  font-size: 54rpx;
  line-height: 1;
}

.prize-name {
  font-size: 28rpx;
  line-height: 1.4;
  color: #1c1917;
  font-weight: 700;
}

.prize-value {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #78716c;
}

/* 记录列表 */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.empty-tip {
  text-align: center;
  color: #78716c;
  font-size: 24rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-emoji {
  font-size: 64rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #78716c;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.05);
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.12), rgba(118, 75, 162, 0.12));
  font-size: 34rpx;
}

.record-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.record-prize {
  font-size: 26rpx;
  color: #1c1917;
  font-weight: 600;
}

.record-time {
  font-size: 20rpx;
  color: #78716c;
}

.record-substatus {
  font-size: 20rpx;
  color: #d97706;
  line-height: 1.5;
}

.record-status {
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  background: rgba(102, 126, 234, 0.08);
  color: #667eea;
}

.record-status.pending {
  background: rgba(245, 158, 11, 0.12);
  color: #d97706;
}

.record-status.issued,
.record-status.completed {
  background: rgba(16, 185, 129, 0.12);
  color: #10b981;
}

.record-status.claim_required,
.record-status.claim_submitted,
.record-status.approved,
.record-status.shipped {
  background: rgba(102, 126, 234, 0.12);
  color: #667eea;
}

.record-status.failed,
.record-status.cancelled {
  background: rgba(239, 68, 68, 0.12);
  color: #ef4444;
}

.record-action {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.records-toggle {
  min-height: 76rpx;
  border-radius: 20rpx;
  background: rgba(102, 126, 234, 0.06);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.records-toggle-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
}

.records-toggle-arrow {
  font-size: 22rpx;
  color: #667eea;
  line-height: 1;
}

.records-toggle-hover {
  background: rgba(102, 126, 234, 0.12);
}

.prize-toggle {
  margin: 14rpx 28rpx 0;
}

/* 结果弹窗 */
.result-modal {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(15, 15, 35, 0.5);
  backdrop-filter: blur(8px);
}

.result-card {
  position: relative;
  z-index: 2;
  width: 580rpx;
  padding: 48rpx 40rpx 40rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  text-align: center;
  box-shadow: 0 24rpx 60rpx rgba(102, 126, 234, 0.2);
}

.result-icon-ring {
  width: 136rpx;
  height: 136rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 18rpx 36rpx rgba(102, 126, 234, 0.3);
}

.result-emoji {
  font-size: 72rpx;
}

.result-type {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}

.result-type.win {
  color: #667eea;
}

.result-type.miss {
  color: #78716c;
}

.result-prize-name {
  display: block;
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #1c1917;
}

.result-value {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #78716c;
}

.result-badge {
  display: inline-block;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.08);
}

.result-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
}

.result-btn {
  min-width: 180rpx;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(102, 126, 234, 0.08);
  color: #667eea;
}

.result-btn.primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.25);
}

/* 动画 */
@keyframes machinePulse {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

@keyframes floatCapsule {
  0% { transform: translateY(0) rotate(-3deg); }
  100% { transform: translateY(10rpx) rotate(4deg); }
}

@keyframes handlePull {
  0%, 100% { transform: rotate(0deg); }
  35% { transform: rotate(8deg); }
  70% { transform: rotate(-3deg); }
}

@keyframes capsuleDrop {
  0% { transform: translateY(-54rpx) scale(0.82); opacity: 0; }
  50% { transform: translateY(12rpx) scale(1.02); opacity: 1; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}
