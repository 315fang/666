/** pages/lottery/lottery.wxss **/

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #111827 0%, #0F172A 42%, #020617 100%);
  padding-bottom: 60rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
}

.nav-back,
.nav-placeholder {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
  filter: invert(1);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.hero-card,
.wheel-panel,
.records-list,
.prize-grid {
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.hero-card {
  margin-top: 16rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(17, 24, 39, 0.92), rgba(30, 41, 59, 0.86));
  border: 1rpx solid rgba(96, 165, 250, 0.18);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.35);
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: rgba(147, 197, 253, 0.9);
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.35;
  color: #F8FAFC;
  font-weight: 700;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(226, 232, 240, 0.7);
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.stat-card {
  flex: 1;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.stat-card.highlight {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.22), rgba(147, 197, 253, 0.14));
  border-color: rgba(147, 197, 253, 0.28);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(226, 232, 240, 0.68);
}

.stat-value {
  display: block;
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.wheel-panel {
  margin-top: 24rpx;
  padding: 30rpx 24rpx 34rpx;
  border-radius: 28rpx;
  background: rgba(15, 23, 42, 0.84);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.panel-head,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel-title,
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.panel-subtitle,
.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(203, 213, 225, 0.68);
}

.panel-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.16);
  color: #93C5FD;
  font-size: 22rpx;
}

.gacha-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-top: 28rpx;
}

.gacha-machine {
  width: 100%;
  border-radius: 32rpx;
  padding: 24rpx 24rpx 30rpx;
  background: linear-gradient(180deg, #172554 0%, #0F172A 70%, #1E293B 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.gacha-machine.is-running {
  animation: machinePulse 0.9s ease-in-out infinite;
}

.machine-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.machine-brand {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: #BFDBFE;
  font-weight: 700;
}

.machine-lights {
  display: flex;
  gap: 8rpx;
}

.machine-light {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #F8FAFC;
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.45);
}

.gacha-machine.is-running .machine-light:nth-child(odd) {
  background: #3B82F6;
}

.machine-window {
  position: relative;
  height: 360rpx;
  overflow: hidden;
  border-radius: 28rpx 28rpx 18rpx 18rpx;
  background: radial-gradient(circle at top, rgba(59, 130, 246, 0.3), rgba(15, 23, 42, 0.95) 62%);
  border: 6rpx solid rgba(226, 232, 240, 0.22);
}

.machine-glass {
  position: absolute;
  top: 0;
  right: 24rpx;
  bottom: 0;
  width: 90rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.14), rgba(255,255,255,0.02));
}

.capsule-cloud {
  position: relative;
  width: 100%;
  height: 100%;
}

.capsule-sample {
  position: absolute;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 14rpx 24rpx rgba(15, 23, 42, 0.45);
}

.gacha-machine.is-running .capsule-sample {
  animation: floatCapsule 1.3s ease-in-out infinite alternate;
}

.capsule-pos-0 { top: 34rpx; left: 34rpx; }
.capsule-pos-1 { top: 66rpx; left: 132rpx; }
.capsule-pos-2 { top: 24rpx; right: 36rpx; }
.capsule-pos-3 { top: 152rpx; left: 58rpx; }
.capsule-pos-4 { top: 174rpx; left: 174rpx; }
.capsule-pos-5 { top: 138rpx; right: 52rpx; }

.capsule-sample-emoji {
  font-size: 42rpx;
}

.machine-base {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.machine-chute {
  position: relative;
  flex: 1;
  min-height: 120rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.95));
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.result-capsule {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 20rpx rgba(0, 0, 0, 0.35);
}

.capsule-top,
.capsule-bottom {
  position: absolute;
  left: 0;
  right: 0;
  height: 50%;
}

.capsule-top {
  top: 0;
  border-radius: 54rpx 54rpx 22rpx 22rpx;
  background: rgba(255, 255, 255, 0.16);
}

.capsule-bottom {
  bottom: 0;
  border-radius: 22rpx 22rpx 54rpx 54rpx;
  background: rgba(15, 23, 42, 0.12);
}

.result-capsule-mark {
  position: relative;
  z-index: 2;
  font-size: 44rpx;
}

.capsule-placeholder {
  background: linear-gradient(180deg, #CBD5E1, #64748B);
  opacity: 0.75;
}

.capsule-ready {
  transform: translateY(0) scale(0.96);
}

.capsule-drop {
  animation: capsuleDrop 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.machine-controls {
  width: 180rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.machine-dial {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #BFDBFE, #3B82F6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.26);
}

.machine-dial-core {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #1E293B;
}

.machine-handle {
  position: relative;
  width: 72rpx;
  height: 118rpx;
}

.machine-handle-bar {
  position: absolute;
  right: 20rpx;
  bottom: 12rpx;
  width: 12rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #CBD5E1, #64748B);
}

.machine-handle-knob {
  position: absolute;
  top: 0;
  right: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3B82F6, #BFDBFE);
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.26);
}

.gacha-machine.is-running .machine-handle {
  animation: handlePull 0.9s ease-in-out infinite;
}

.gacha-tip {
  font-size: 22rpx;
  color: rgba(203, 213, 225, 0.74);
}

.draw-btn {
  min-width: 280rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #BFDBFE 100%);
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  padding: 24rpx 48rpx;
  border-radius: 999rpx;
  text-align: center;
}

.draw-btn.disabled {
  opacity: 0.55;
}

.section-head {
  margin: 34rpx 24rpx 18rpx;
}

.prize-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.prize-item {
  min-height: 220rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.18);
}

.prize-item-top {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.prize-badge {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #FFF;
  background: rgba(255, 255, 255, 0.16);
}

.prize-img {
  width: 72rpx;
  height: 72rpx;
}

.prize-emoji {
  font-size: 54rpx;
  line-height: 1;
}

.prize-name {
  font-size: 28rpx;
  line-height: 1.4;
  color: #FFF;
  font-weight: 700;
}

.prize-value {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.empty-tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.38);
  font-size: 24rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-icon {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.36;
  filter: invert(1);
}

.record-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.06);
  font-size: 34rpx;
}

.record-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-prize {
  font-size: 26rpx;
  color: #FFF;
  font-weight: 600;
}

.record-time {
  font-size: 20rpx;
  color: rgba(203, 213, 225, 0.5);
}

.record-status {
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
}

.record-status.pending {
  background: rgba(59, 130, 246, 0.18);
  color: #BFDBFE;
}

.record-status.claimed {
  background: rgba(16, 185, 129, 0.18);
  color: #6EE7B7;
}

.record-status.expired {
  background: rgba(148, 163, 184, 0.16);
  color: rgba(226, 232, 240, 0.68);
}

.result-modal {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(2, 6, 23, 0.78);
}

.result-card {
  position: relative;
  z-index: 2;
  width: 580rpx;
  padding: 48rpx 40rpx 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #111827 0%, #0F172A 100%);
  border: 1rpx solid rgba(96, 165, 250, 0.2);
  text-align: center;
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.45);
}

.result-icon-ring {
  width: 136rpx;
  height: 136rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.2);
}

.result-emoji {
  font-size: 72rpx;
}

.result-type {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}

.result-type.win {
  color: #BFDBFE;
}

.result-type.miss {
  color: rgba(226, 232, 240, 0.64);
}

.result-prize-name {
  display: block;
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #FFF;
}

.result-value {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(226, 232, 240, 0.75);
}

.result-badge {
  display: inline-block;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #E2E8F0;
  background: rgba(255, 255, 255, 0.08);
}

.result-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
}

.result-btn {
  min-width: 180rpx;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.08);
  color: #E2E8F0;
}

.result-btn.primary {
  background: linear-gradient(135deg, #3B82F6, #BFDBFE);
  color: #111827;
}

@keyframes machinePulse {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

@keyframes floatCapsule {
  0% { transform: translateY(0) rotate(-3deg); }
  100% { transform: translateY(10rpx) rotate(4deg); }
}

@keyframes handlePull {
  0%, 100% { transform: rotate(0deg); }
  35% { transform: rotate(8deg); }
  70% { transform: rotate(-3deg); }
}

@keyframes capsuleDrop {
  0% { transform: translateY(-54rpx) scale(0.82); opacity: 0; }
  50% { transform: translateY(12rpx) scale(1.02); opacity: 1; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}
