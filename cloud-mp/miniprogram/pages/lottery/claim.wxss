.claim-page {
  min-height: 100vh;
  background: #f4f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.loading-wrap {
  min-height: 50vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 28rpx;
}

.claim-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.claim-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #16324d;
}

.claim-status {
  display: inline-block;
  margin-top: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(36, 95, 147, 0.1);
  color: #245f93;
  font-size: 22rpx;
  font-weight: 600;
}

.claim-value {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #0f766e;
  font-weight: 600;
}

.claim-tip,
.address-text,
.empty-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.7;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-action {
  font-size: 24rpx;
  color: #245f93;
}

.address-name,
.form-label {
  display: block;
  font-size: 26rpx;
  color: #111827;
  font-weight: 600;
}

.form-row {
  margin-top: 18rpx;
}

.form-row-column {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-input,
.form-textarea {
  margin-top: 12rpx;
  width: 100%;
  border-radius: 18rpx;
  background: #f8fafc;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #111827;
}

.form-textarea {
  min-height: 160rpx;
}

.submit-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #1e4a6d;
  color: #fff;
  font-size: 28rpx;
}

.submit-btn::after {
  border: none;
}
