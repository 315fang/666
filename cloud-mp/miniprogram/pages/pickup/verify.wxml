<view class="wrap">
  <view class="loading" wx:if="{{scopeLoading}}">加载门店信息中...</view>

  <block wx:elif="{{verifyScope && verifyScope.has_verify_access}}">
    <view class="hero-card">
      <text class="hero-title">自提核销</text>
      <text class="hero-desc">你只能核销所属门店的自提订单，不能跨门店代核销。</text>
    </view>

    <view class="scope-card">
      <text class="scope-label">当前门店归属</text>
      <picker wx:if="{{verifyScope.requires_station_selection}}" mode="selector" range="{{verifyScope.stations}}" range-key="name" bindchange="onStationChange" value="{{selectedStationIndex}}">
        <view class="station-picker">
          <text class="station-picker-text">{{selectedStationId ? verifyScope.stations[selectedStationIndex].name : '请选择当前核销门店'}}</text>
        </view>
      </picker>
      <view class="station-fixed" wx:if="{{verifyScope.requires_station_selection && selectedStationId}}">
        <text class="station-fixed-name">{{verifyScope.stations[selectedStationIndex].name}}</text>
        <text class="station-fixed-sub">{{verifyScope.stations[selectedStationIndex].city}} {{verifyScope.stations[selectedStationIndex].address || ''}}</text>
      </view>
      <view class="station-fixed" wx:elif="{{verifyScope.stations.length === 1}}">
        <text class="station-fixed-name">{{verifyScope.stations[0].name}}</text>
        <text class="station-fixed-sub">{{verifyScope.stations[0].city}} {{verifyScope.stations[0].address || ''}}</text>
      </view>
      <text class="scope-tip">顾客必须前往订单所选门店，由该门店人员完成核销。</text>
      <view class="scope-entry" bindtap="goPendingOrders">
        <text class="scope-entry-text">查看当前门店待核销订单</text>
        <text class="scope-entry-arrow">›</text>
      </view>
    </view>

    <view class="block">
      <text class="label">16 位核销码</text>
      <input class="inp" value="{{code}}" bindinput="onCodeInput" placeholder="请输入顾客出示的核销码" maxlength="16" />
      <button class="btn" loading="{{loading}}" bindtap="onVerifyCode">确认核销</button>
    </view>

    <view class="divider">或</view>

    <view class="block">
      <text class="label">扫码核销</text>
      <button class="btn secondary" bindtap="onScan">扫一扫</button>
      <input class="inp mt" value="{{qrToken}}" bindinput="onTokenInput" placeholder="也可手动粘贴二维码内容" />
      <button class="btn" loading="{{loadingQr}}" bindtap="onVerifyQr">核销二维码</button>
    </view>

    <view class="result-card {{lastResult.success ? 'success' : 'fail'}}" wx:if="{{lastResult}}">
      <text class="result-title">{{lastResult.title}}</text>
      <text class="result-desc">{{lastResult.desc}}</text>
    </view>
  </block>

  <view class="empty-card" wx:else>
    <text class="empty-title">暂无自提核销权限</text>
    <text class="empty-desc">只有加入门店体系且属于对应自提门店的人员，才可执行核销。</text>
  </view>
</view>
