page { background: #f5ede1; }
.container { min-height: 100vh; padding: 0 0 40rpx; background: linear-gradient(180deg, #f8f1e5 0%, #f3e6d4 100%); }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #3b2b1a; }
.nav-placeholder { width: 56rpx; }

.hero-card,
.station-card,
.voucher-card,
.verified-card,
.tip-section {
  margin: 18rpx 24rpx 0;
  border-radius: 28rpx;
  padding: 28rpx;
  background: rgba(255, 251, 245, 0.96);
  border: 1rpx solid rgba(191, 151, 97, 0.18);
  box-shadow: 0 18rpx 40rpx rgba(117, 81, 33, 0.08);
}

.hero-card.pending {
  background: linear-gradient(135deg, #fff8ee 0%, #f7ebd5 100%);
}

.hero-card.verified {
  background: linear-gradient(135deg, #f6f0e5 0%, #efe7d6 100%);
}

.hero-eyebrow,
.section-title {
  display: block;
  font-size: 22rpx;
  color: #a2783e;
  letter-spacing: 4rpx;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #3b2b1a;
}

.hero-desc,
.station-addr,
.station-contact,
.qr-hint,
.verified-time,
.tip-item {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #755d43;
  line-height: 1.7;
}

.station-name {
  display: block;
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #46301a;
}

.qr-wrap {
  width: 440rpx;
  margin: 28rpx auto 0;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fff;
}

.qr-canvas { width: 200px; height: 200px; margin: 0 auto; display: block; }

.divider-row { display: flex; align-items: center; gap: 16rpx; margin: 28rpx 0 20rpx; }
.divider-line { flex: 1; height: 1rpx; background: rgba(162, 120, 62, 0.2); }
.divider-text { font-size: 22rpx; color: #a08565; white-space: nowrap; }

.code-display {
  padding: 22rpx 26rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(191, 122, 52, 0.5);
  background: #fffdf8;
  text-align: center;
}

.code-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #5e3d1d;
  letter-spacing: 4rpx;
  font-family: monospace;
}

.code-copy-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d5a15b 0%, #bb7a34 100%);
  color: #fff7ef;
  font-size: 28rpx;
  font-weight: 700;
}
