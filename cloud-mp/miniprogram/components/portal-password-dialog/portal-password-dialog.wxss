.ppd-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10050;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.52);
}

.ppd-panel {
  width: 100%;
  max-width: 620rpx;
  box-sizing: border-box;
  padding: 38rpx 34rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 28rpx 72rpx rgba(15, 23, 42, 0.22);
}

.ppd-header {
  margin-bottom: 28rpx;
}

.ppd-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #0f172a;
  text-align: center;
}

.ppd-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748b;
  text-align: center;
}

.ppd-input-wrap {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 0 16rpx 0 28rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe6ef;
}

.ppd-input {
  flex: 1;
  min-width: 0;
  height: 96rpx;
  font-size: 36rpx;
  line-height: 96rpx;
  color: #0f172a;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.ppd-placeholder {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 400;
  letter-spacing: 0;
}

.ppd-eye {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 999rpx;
}

.ppd-eye-press {
  background: #e2e8f0;
}

.ppd-eye-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.78;
}

.ppd-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 30rpx;
}

.ppd-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}

.ppd-btn-cancel {
  color: #475569;
  background: #eef2f7;
}

.ppd-btn-confirm {
  color: #ffffff;
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
}
