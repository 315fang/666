<view class="ppd-mask" wx:if="{{visible}}" catchtouchmove="noop">
  <view class="ppd-panel" catchtap="noop">
    <view class="ppd-header">
      <text class="ppd-title">{{title}}</text>
      <text class="ppd-desc">用于确认资金与业务操作，请勿向他人泄露。</text>
    </view>

    <view class="ppd-input-wrap">
      <input
        class="ppd-input"
        type="number"
        maxlength="6"
        password="{{!passwordVisible}}"
        value="{{password}}"
        placeholder="{{placeholderText}}"
        placeholder-class="ppd-placeholder"
        focus="{{inputFocused}}"
        confirm-type="done"
        bindinput="onInput"
        bindconfirm="onConfirm"
      />
      <view class="ppd-eye" bindtap="onToggleVisible" hover-class="ppd-eye-press">
        <image class="ppd-eye-icon" src="{{passwordVisible ? '/assets/icons/eye-off.svg' : '/assets/icons/eye.svg'}}" mode="aspectFit" />
      </view>
    </view>

    <view class="ppd-actions">
      <view class="ppd-btn ppd-btn-cancel" bindtap="onCancel">{{cancelText}}</view>
      <view class="ppd-btn ppd-btn-confirm" bindtap="onConfirm">{{confirmText}}</view>
    </view>
  </view>
</view>
