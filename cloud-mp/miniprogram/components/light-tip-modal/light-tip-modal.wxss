.ltm-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.ltm-panel {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.ltm-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 20rpx;
}

.ltm-scroll {
  max-height: 45vh;
  margin-bottom: 24rpx;
}

.ltm-body {
  font-size: 28rpx;
  line-height: 1.65;
  color: #555;
  white-space: pre-wrap;
}

.ltm-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #b98b58, #d4b896);
  border-radius: 999rpx;
}
