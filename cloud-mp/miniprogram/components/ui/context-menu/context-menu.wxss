/* 长按上下文菜单 */
.ctx-menu-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.3);
}

.ctx-menu {
  position: absolute;
  min-width: 280rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 0;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15), 0 0 0 1rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.ctx-menu-enter {
  animation: ctxMenuIn 0.25s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

.ctx-menu-exit {
  animation: ctxMenuOut 0.2s ease forwards;
}

@keyframes ctxMenuIn {
  0% { opacity: 0; transform: scale(0.85); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes ctxMenuOut {
  0% { opacity: 1; transform: scale(1); }
  100% { opacity: 0; transform: scale(0.85); }
}

.ctx-menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  transition: background 0.15s;
}

.ctx-menu-item--hover {
  background: rgba(102, 126, 234, 0.06);
}

.ctx-menu-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.ctx-menu-text {
  font-size: 28rpx;
  font-weight: 500;
}
