/* 左滑删除组件 */
.swipe-cell {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.swipe-cell-content {
  position: relative;
  z-index: 2;
  background: #fff;
  will-change: transform;
}

.swipe-cell-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1;
  display: flex;
  align-items: stretch;
}

.swipe-cell-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  min-width: 150rpx;
}

.swipe-cell-action--delete {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.swipe-cell-action-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.swipe-cell-action-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}
