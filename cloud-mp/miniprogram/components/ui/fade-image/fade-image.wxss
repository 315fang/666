/* 图片淡入组件 */
.fade-image-wrap {
  position: relative;
  overflow: hidden;
  background: var(--luxury-ivory, #EAF2F8);
}

.fade-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  background: var(--luxury-ivory, #EAF2F8);
}

.fade-placeholder-img {
  width: 60%;
  height: 60%;
  opacity: 0.3;
}

.fade-placeholder-shimmer {
  width: 100%;
  height: 100%;
  background: linear-gradient(
    110deg,
    rgba(102, 126, 234, 0.04) 8%,
    rgba(102, 126, 234, 0.1) 18%,
    rgba(102, 126, 234, 0.04) 33%
  );
  background-size: 200% 100%;
  animation: fadeShimmer 1.5s ease-in-out infinite;
}

@keyframes fadeShimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.fade-image {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0;
}

.fade-error {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--luxury-ivory, #EAF2F8);
  z-index: 2;
}

.fade-error-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
  opacity: 0.4;
}

.fade-error-text {
  font-size: 20rpx;
  color: var(--text-muted, #99AABA);
}
