.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0 8rpx;
  min-height: 100rpx;
  position: relative;
  -webkit-tap-highlight-color: transparent;
}

.tab-bar-item:active {
  opacity: 0.7;
}

.tab-bar-icon-wrap {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-bar-item-active .tab-bar-icon-wrap {
  transform: scale(1.1) translateY(-2rpx);
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-bar-text {
  font-size: 20rpx;
  margin-top: 6rpx;
  line-height: 1.2;
  font-weight: 500;
  transition: color 0.3s ease;
}

.tab-bar-item-active .tab-bar-text {
  font-weight: 700;
}

.tab-bar-indicator {
  position: absolute;
  top: 4rpx;
  width: 36rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #2563eb;
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.3);
  animation: indicatorPop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes indicatorPop {
  0% { transform: scaleX(0.3) translateY(-4rpx); opacity: 0; }
  100% { transform: scaleX(1) translateY(0); opacity: 1; }
}
