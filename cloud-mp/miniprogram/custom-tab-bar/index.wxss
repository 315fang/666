.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(159, 178, 193, 0.28);
  box-shadow: 0 -12rpx 34rpx rgba(16, 42, 67, 0.08);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 7px 0 5px;
  min-height: 48px;
  position: relative;
}

.tab-bar-item-active::before {
  content: '';
  position: absolute;
  top: 4px;
  width: 18px;
  height: 2px;
  border-radius: 999px;
  background: #C6A16E;
  box-shadow: 0 2px 8px rgba(198, 161, 110, 0.36);
}

.tab-bar-icon {
  width: 24px;
  height: 24px;
  margin-top: 2px;
}

.tab-bar-text {
  font-size: 10px;
  margin-top: 3px;
  line-height: 1.2;
  font-weight: 500;
}
