/**
 * ╔══════════════════════════════════════════════╗
 * ║  全局特效样式系统 — 2026 青春版              ║
 * ║  涟漪 / 动画 / 毛玻璃 / 渐变 / 微交互      ║
 * ╚══════════════════════════════════════════════╝
 */

/* ═══════════════ 1. 涟漪点击效果 ═══════════════ */
.ripple {
  position: relative;
  overflow: hidden;
  -webkit-tap-highlight-color: transparent;
}

.ripple::after {
  content: '';
  display: block;
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  pointer-events: none;
  background-image: radial-gradient(circle, rgba(255,255,255,0.35) 10%, transparent 10.01%);
  background-repeat: no-repeat;
  background-position: 50%;
  transform: scale(10, 10);
  opacity: 0;
  transition: transform 0.5s, opacity 1s;
}

.ripple:active::after {
  transform: scale(0, 0);
  opacity: 0.3;
  transition: 0s;
}

/* 暗色涟漪（用于浅色背景） */
.ripple-dark::after {
  background-image: radial-gradient(circle, rgba(102, 126, 234, 0.15) 10%, transparent 10.01%);
}

/* 金色涟漪 */
.ripple-gold::after {
  background-image: radial-gradient(circle, rgba(198, 161, 110, 0.25) 10%, transparent 10.01%);
}

/* ═══════════════ 2. 卡片入场动画 ═══════════════ */
@keyframes slideUpFade {
  0% {
    opacity: 0;
    transform: translateY(40rpx) scale(0.98);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes slideLeftFade {
  0% {
    opacity: 0;
    transform: translateX(40rpx);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes scaleIn {
  0% {
    opacity: 0;
    transform: scale(0.9);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes bounceIn {
  0% { opacity: 0; transform: scale(0.3); }
  50% { opacity: 1; transform: scale(1.05); }
  70% { transform: scale(0.95); }
  100% { transform: scale(1); }
}

.card-enter {
  animation: slideUpFade 0.45s cubic-bezier(0.23, 1, 0.32, 1) both;
}

.card-enter-scale {
  animation: scaleIn 0.4s cubic-bezier(0.23, 1, 0.32, 1) both;
}

.card-enter-bounce {
  animation: bounceIn 0.5s cubic-bezier(0.23, 1, 0.32, 1) both;
}

/* 延迟系列 */
.delay-1 { animation-delay: 50ms; }
.delay-2 { animation-delay: 100ms; }
.delay-3 { animation-delay: 150ms; }
.delay-4 { animation-delay: 200ms; }
.delay-5 { animation-delay: 250ms; }
.delay-6 { animation-delay: 300ms; }
.delay-7 { animation-delay: 350ms; }
.delay-8 { animation-delay: 400ms; }

/* ═══════════════ 3. 毛玻璃效果 ═══════════════ */
.glass {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.glass-dark {
  background: rgba(15, 23, 42, 0.45);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.glass-purple {
  background: rgba(102, 126, 234, 0.15);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(118, 75, 162, 0.2);
}

.glass-card {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px) saturate(160%);
  -webkit-backdrop-filter: blur(16px) saturate(160%);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.08);
}

/* ═══════════════ 4. 现代配色渐变 ═══════════════ */
.gradient-purple {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.gradient-purple-soft {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.12) 0%, rgba(118, 75, 162, 0.08) 100%);
}

.gradient-sunset {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.gradient-ocean {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.gradient-aurora {
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
}

.gradient-neon {
  background: linear-gradient(135deg, #00d2ff 0%, #7b2ff7 100%);
}

.gradient-dark-neon {
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
}

.gradient-mesh {
  background:
    radial-gradient(at 40% 20%, rgba(102, 126, 234, 0.3) 0px, transparent 50%),
    radial-gradient(at 80% 0%, rgba(118, 75, 162, 0.2) 0px, transparent 50%),
    radial-gradient(at 0% 50%, rgba(240, 147, 251, 0.15) 0px, transparent 50%),
    linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
}

/* 流动渐变动画 */
@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.gradient-animated {
  background-size: 200% 200%;
  animation: gradientShift 6s ease infinite;
}

/* ═══════════════ 5. 浮动与呼吸效果 ═══════════════ */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

@keyframes breathe {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.02); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 20rpx rgba(102, 126, 234, 0.2); }
  50% { box-shadow: 0 0 40rpx rgba(102, 126, 234, 0.4); }
}

.float { animation: float 3s ease-in-out infinite; }
.breathe { animation: breathe 3s ease-in-out infinite; }
.pulse-soft { animation: pulse 2s ease-in-out infinite; }
.glow { animation: glow 2s ease-in-out infinite; }

/* ═══════════════ 6. 数字翻滚 ═══════════════ */
@keyframes numberSlideUp {
  0% { opacity: 0; transform: translateY(100%); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes numberSlideDown {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-100%); }
}

@keyframes numberFlash {
  0% { color: inherit; }
  30% { color: #667eea; transform: scale(1.1); }
  100% { color: inherit; transform: scale(1); }
}

.number-enter {
  animation: numberSlideUp 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

.number-flash {
  animation: numberFlash 0.6s ease-out;
}

/* ═══════════════ 7. 按钮微交互 ═══════════════ */
.btn-press {
  transition: transform 0.15s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.15s ease;
}

.btn-press:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.btn-spring {
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.btn-spring:active {
  transform: scale(0.92);
}

/* ═══════════════ 8. Tab指示器 ═══════════════ */
@keyframes indicatorSlide {
  0% { transform: scaleX(0.5); opacity: 0; }
  100% { transform: scaleX(1); opacity: 1; }
}

.tab-indicator-animated {
  animation: indicatorSlide 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  transform-origin: center;
}

/* ═══════════════ 9. 列表动画 ═══════════════ */
@keyframes listSlideIn {
  0% {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

.list-enter {
  animation: listSlideIn 0.35s cubic-bezier(0.23, 1, 0.32, 1) both;
}

/* 删除滑出 */
@keyframes slideOutLeft {
  0% { transform: translateX(0); opacity: 1; max-height: 200rpx; }
  50% { transform: translateX(-100%); opacity: 0; }
  100% { transform: translateX(-100%); opacity: 0; max-height: 0; padding: 0; margin: 0; }
}

.slide-out-left {
  animation: slideOutLeft 0.4s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

/* ═══════════════ 10. 弹窗动画 ═══════════════ */
@keyframes modalFadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes modalSlideUp {
  0% { transform: translateY(100%); }
  100% { transform: translateY(0); }
}

@keyframes modalScaleIn {
  0% { opacity: 0; transform: scale(0.85); }
  100% { opacity: 1; transform: scale(1); }
}

.modal-enter {
  animation: modalFadeIn 0.25s ease;
}

.modal-panel-enter {
  animation: modalSlideUp 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.modal-center-enter {
  animation: modalScaleIn 0.3s cubic-bezier(0.23, 1, 0.32, 1);
}

/* ═══════════════ 11. 霓虹发光效果 ═══════════════ */
.neon-blue {
  color: #00d2ff;
  text-shadow:
    0 0 10rpx rgba(0, 210, 255, 0.5),
    0 0 20rpx rgba(0, 210, 255, 0.3),
    0 0 40rpx rgba(0, 210, 255, 0.15);
}

.neon-purple {
  color: #a78bfa;
  text-shadow:
    0 0 10rpx rgba(167, 139, 250, 0.5),
    0 0 20rpx rgba(167, 139, 250, 0.3);
}

.neon-border {
  border: 1rpx solid rgba(0, 210, 255, 0.3);
  box-shadow:
    0 0 10rpx rgba(0, 210, 255, 0.1),
    inset 0 0 10rpx rgba(0, 210, 255, 0.05);
}

/* ═══════════════ 12. 骨架屏增强 ═══════════════ */
@keyframes shimmerWave {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.shimmer {
  background: linear-gradient(
    90deg,
    rgba(102, 126, 234, 0.06) 25%,
    rgba(102, 126, 234, 0.12) 50%,
    rgba(102, 126, 234, 0.06) 75%
  );
  background-size: 200% 100%;
  animation: shimmerWave 1.5s ease-in-out infinite;
}

/* ═══════════════ 13. 粒子/彩蛋 ═══════════════ */
@keyframes confettiFall {
  0% {
    transform: translateY(-100vh) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(720deg);
    opacity: 0;
  }
}

@keyframes starBurst {
  0% { transform: scale(0) rotate(0deg); opacity: 1; }
  50% { transform: scale(1.2) rotate(180deg); opacity: 0.8; }
  100% { transform: scale(0) rotate(360deg); opacity: 0; }
}

/* ═══════════════ 14. 进度条动画 ═══════════════ */
@keyframes progressPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

@keyframes progressGlow {
  0% { box-shadow: 0 0 4rpx rgba(102, 126, 234, 0.3); }
  50% { box-shadow: 0 0 16rpx rgba(102, 126, 234, 0.6); }
  100% { box-shadow: 0 0 4rpx rgba(102, 126, 234, 0.3); }
}

.progress-animated {
  animation: progressGlow 2s ease-in-out infinite;
}

/* ═══════════════ 15. 下拉刷新自定义 ═══════════════ */
@keyframes pullSpin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes pullBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-8rpx) scale(1.05); }
}

.pull-spinner {
  animation: pullSpin 0.8s linear infinite;
}

.pull-bounce {
  animation: pullBounce 0.6s ease-in-out infinite;
}

/* ═══════════════ 16. 成功/失败反馈 ═══════════════ */
@keyframes successPop {
  0% { transform: scale(0); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

@keyframes errorShake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-8rpx); }
  20%, 40%, 60%, 80% { transform: translateX(8rpx); }
}

.success-pop {
  animation: successPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.error-shake {
  animation: errorShake 0.5s ease-in-out;
}

/* ═══════════════ 17. 工具类 ═══════════════ */
.tap-highlight-none {
  -webkit-tap-highlight-color: transparent;
}

.will-change-transform {
  will-change: transform;
}

.gpu-accelerated {
  transform: translateZ(0);
  backface-visibility: hidden;
}

/* 减少动效偏好（无障碍） */
@media (prefers-reduced-motion: reduce) {
  .card-enter, .card-enter-scale, .card-enter-bounce,
  .list-enter, .float, .breathe, .pulse-soft, .glow,
  .shimmer, .gradient-animated, .pull-spinner, .pull-bounce {
    animation: none !important;
  }
  .ripple::after {
    display: none;
  }
}
