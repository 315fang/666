/**
 * 全局特效样式系统
 * 涟漪 / 动画 / 毛玻璃 / 微交互
 */

/* ═══════════════ 1. 涟漪点击效果 ═══════════════ */
.ripple {
  position: relative;
  overflow: hidden;
  -webkit-tap-highlight-color: transparent;
}

.ripple::after {
  content: '';
  display: block;
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  pointer-events: none;
  background-image: radial-gradient(circle, rgba(255,255,255,0.35) 10%, transparent 10.01%);
  background-repeat: no-repeat;
  background-position: 50%;
  transform: scale(10, 10);
  opacity: 0;
  transition: transform 0.5s, opacity 1s;
}

.ripple:active::after {
  transform: scale(0, 0);
  opacity: 0.3;
  transition: 0s;
}

.ripple-dark::after {
  background-image: radial-gradient(circle, rgba(37, 99, 235, 0.12) 10%, transparent 10.01%);
}

/* ═══════════════ 2. 卡片入场动画 ═══════════════ */
@keyframes slideUpFade {
  0% { opacity: 0; transform: translateY(40rpx) scale(0.98); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes scaleIn {
  0% { opacity: 0; transform: scale(0.9); }
  100% { opacity: 1; transform: scale(1); }
}

.card-enter {
  animation: slideUpFade 0.45s cubic-bezier(0.23, 1, 0.32, 1) both;
}

.card-enter-scale {
  animation: scaleIn 0.4s cubic-bezier(0.23, 1, 0.32, 1) both;
}

.delay-1 { animation-delay: 50ms; }
.delay-2 { animation-delay: 100ms; }
.delay-3 { animation-delay: 150ms; }
.delay-4 { animation-delay: 200ms; }
.delay-5 { animation-delay: 250ms; }
.delay-6 { animation-delay: 300ms; }
.delay-7 { animation-delay: 350ms; }
.delay-8 { animation-delay: 400ms; }

/* ═══════════════ 3. 毛玻璃效果 ═══════════════ */
.glass {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.glass-dark {
  background: rgba(30, 58, 95, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.glass-card {
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* ═══════════════ 4. 按钮微交互 ═══════════════ */
.btn-press {
  transition: transform 0.15s cubic-bezier(0.23, 1, 0.32, 1);
}

.btn-press:active {
  transform: scale(0.96);
}

.btn-spring {
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.btn-spring:active {
  transform: scale(0.92);
}

/* ═══════════════ 5. 弹窗动画 ═══════════════ */
@keyframes modalFadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes modalSlideUp {
  0% { transform: translateY(100%); }
  100% { transform: translateY(0); }
}

@keyframes modalScaleIn {
  0% { opacity: 0; transform: scale(0.85); }
  100% { opacity: 1; transform: scale(1); }
}

.modal-enter { animation: modalFadeIn 0.25s ease; }
.modal-panel-enter { animation: modalSlideUp 0.35s cubic-bezier(0.23, 1, 0.32, 1); }
.modal-center-enter { animation: modalScaleIn 0.3s cubic-bezier(0.23, 1, 0.32, 1); }

/* ═══════════════ 6. 骨架屏 ═══════════════ */
@keyframes shimmerWave {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.shimmer {
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmerWave 1.5s ease-in-out infinite;
}

/* ═══════════════ 7. 工具类 ═══════════════ */
.tap-highlight-none { -webkit-tap-highlight-color: transparent; }
.will-change-transform { will-change: transform; }
