.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -1px 0 rgba(15, 23, 42, 0.06);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6px 0 4px;
  min-height: 48px;
}

.tab-bar-icon {
  width: 24px;
  height: 24px;
}

.tab-bar-text {
  font-size: 10px;
  margin-top: 2px;
  line-height: 1.2;
}
