.page-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.page-loading.fullscreen {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 252, 247, 0.78);
  backdrop-filter: blur(4px);
}

.loading-card {
  min-width: 190rpx;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 10rpx 28rpx rgba(32, 24, 18, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.loading-spinner {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(185, 139, 88, 0.22);
  border-top-color: #B98B58;
  animation: page-loading-spin 0.8s linear infinite;
}

.loading-text {
  font-size: 22rpx;
  color: #6D6258;
}

@keyframes page-loading-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
