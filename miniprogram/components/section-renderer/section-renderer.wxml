<!-- section-renderer 动态渲染引擎 WXML -->
<!-- 根据 section.section_type 渲染对应 UI 组件 -->

<!-- ① 轮播图 / 海报 -->
<block wx:if="{{section.section_type === 'banner'}}">
  <view class="sr-section sr-banner">
    <swiper
      style="height: {{section.config.height || 400}}rpx; border-radius: {{section.config.borderRadius || 0}}rpx;"
      autoplay="{{section.config.autoplay !== false}}"
      circular="{{section.config.images.length > 1}}"
      interval="{{section.config.interval || 4000}}"
      indicator-dots="{{section.config.images.length > 1}}"
      indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#CA8A04">
      <swiper-item wx:for="{{section.config.images}}" wx:key="index">
        <image class="sr-banner-img" src="{{item}}" mode="aspectFill" lazy-load bindtap="onSectionTap" data-url="{{item}}"/>
      </swiper-item>
    </swiper>
  </view>
</block>

<!-- ② 商品宫格 -->
<block wx:if="{{section.section_type === 'product-grid'}}">
  <view class="sr-section sr-product-grid">
    <view class="sr-section-header" wx:if="{{section.title}}">
      <text class="sr-section-title">{{section.title}}</text>
      <text class="sr-section-subtitle" wx:if="{{section.subtitle}}">{{section.subtitle}}</text>
    </view>
    <view class="sr-grid-wrap" style="--cols: {{section.config.columns || 2}}">
      <product-card
        wx:for="{{products}}"
        wx:key="id"
        product="{{item}}"
        bindtap="onSectionTap"
        data-product="{{item}}"
        class="sr-grid-item {{section.config.cardStyle || 'card'}}-style"/>
    </view>
    <view class="sr-empty" wx:if="{{products.length === 0}}">
      <text class="sr-empty-text">暂无商品</text>
    </view>
  </view>
</block>

<!-- ③ 快捷入口 -->
<block wx:if="{{section.section_type === 'quick-entry'}}">
  <view class="sr-section sr-quick-entry">
    <view class="sr-section-header" wx:if="{{section.title}}">
      <text class="sr-section-title">{{section.title}}</text>
    </view>
    <view class="sr-entries-wrap" style="--cols: {{section.config.columns || 4}}">
      <!-- 数据由 pages/index/index.js 的 quickEntries 注入到 section.config.entries -->
      <view
        class="sr-entry-item {{section.config.style || 'icon-text'}}"
        wx:for="{{section.config.entries || []}}"
        wx:key="id"
        bindtap="onSectionTap"
        data-url="{{item.link_value}}"
        data-type="{{item.link_type}}">
        <image class="sr-entry-icon" src="{{item.icon_url}}" mode="aspectFit"/>
        <text class="sr-entry-label">{{item.name}}</text>
      </view>
    </view>
  </view>
</block>

<!-- ④ 公告条 -->
<block wx:if="{{section.section_type === 'notice-bar'}}">
  <view class="sr-section sr-notice-bar"
    style="background: {{section.config.bgColor || '#FEF3C7'}}; color: {{section.config.textColor || '#92400E'}}">
    <text class="sr-notice-icon">{{section.config.icon || '📣'}}</text>
    <scroll-view class="sr-notice-scroll" scroll-x="{{section.config.scrollable !== false}}">
      <text class="sr-notice-text">{{section.config.text}}</text>
    </scroll-view>
  </view>
</block>

<!-- ⑤ 图文区块 -->
<block wx:if="{{section.section_type === 'text-block'}}">
  <view class="sr-section sr-text-block" style="background: {{section.config.bgColor || '#fff'}}">
    <view class="sr-section-header" wx:if="{{section.title || section.config.title}}">
      <text class="sr-section-title-en" wx:if="{{section.config.titleEn}}">{{section.config.titleEn}}</text>
      <text class="sr-section-title">{{section.title || section.config.title}}</text>
    </view>
    <!-- 图文布局 image-top -->
    <image class="sr-text-img sr-img-top"
      wx:if="{{section.config.image && section.config.layout === 'image-top'}}"
      src="{{section.config.image}}" mode="aspectFill"/>
    <view class="sr-text-content {{section.config.layout || 'text-only'}}">
      <!-- 图文布局 image-left / image-right -->
      <image class="sr-text-img"
        wx:if="{{section.config.image && (section.config.layout === 'image-left' || section.config.layout === 'image-right')}}"
        src="{{section.config.image}}" mode="aspectFill"/>
      <text class="sr-text-body">{{section.config.body}}</text>
    </view>
  </view>
</block>

<!-- ⑥ 倒计时活动 -->
<block wx:if="{{section.section_type === 'countdown'}}">
  <view class="sr-section sr-countdown"
    style="background: {{section.config.bgColor || '#1C1917'}}; color: {{section.config.textColor || '#fff'}}">
    <text class="sr-countdown-title">{{section.config.title || '限时秒杀'}}</text>
    <view class="sr-countdown-clock">
      <view class="sr-clock-block"><text class="sr-clock-num">{{countdown.hours}}</text><text class="sr-clock-label">时</text></view>
      <text class="sr-clock-sep">:</text>
      <view class="sr-clock-block"><text class="sr-clock-num">{{countdown.minutes}}</text><text class="sr-clock-label">分</text></view>
      <text class="sr-clock-sep">:</text>
      <view class="sr-clock-block"><text class="sr-clock-num">{{countdown.seconds}}</text><text class="sr-clock-label">秒</text></view>
    </view>
  </view>
</block>

<!-- ⑦ 特色卡片区 -->
<block wx:if="{{section.section_type === 'feature-cards'}}">
  <view class="sr-section sr-feature-cards">
    <view class="sr-section-header" wx:if="{{section.title}}">
      <text class="sr-section-title">{{section.title}}</text>
    </view>
    <view class="sr-features-wrap" style="--cols: {{section.config.columns || 2}}">
      <view class="sr-feat-card"
        wx:for="{{section.config.cards || []}}"
        wx:key="id"
        style="background: {{item.bg_gradient || '#1a1a2e'}}"
        bindtap="onSectionTap"
        data-url="{{item.link_value}}"
        data-type="{{item.link_type}}">
        <image class="sr-feat-icon" src="{{item.icon_url}}" mode="aspectFit" wx:if="{{item.icon_url}}"/>
        <text class="sr-feat-tag">{{item.tag}}</text>
        <text class="sr-feat-name">{{item.name}}</text>
        <text class="sr-feat-desc">{{item.description}}</text>
      </view>
    </view>
  </view>
</block>

<!-- ⑧ 分隔线 / 间距 -->
<block wx:if="{{section.section_type === 'divider'}}">
  <view class="sr-section sr-divider" style="height: {{section.config.height || 32}}rpx">
    <view class="sr-divider-line"
      wx:if="{{section.config.showLine}}"
      style="border-color: {{section.config.color || '#E7E5E4'}}"/>
  </view>
</block>
