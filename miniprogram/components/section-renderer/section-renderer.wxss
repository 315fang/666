/* section-renderer 组件样式 */

/* 通用区块间距 */
.sr-section { margin-bottom: 24rpx; }

/* ========== 标题 ========== */
.sr-section-header {
  padding: 32rpx 32rpx 16rpx;
}
.sr-section-title-en {
  display: block;
  font-size: 20rpx;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  text-transform: uppercase;
  margin-bottom: 4rpx;
}
.sr-section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.sr-section-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* ========== Banner ========== */
.sr-banner-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* ========== 商品宫格 ========== */
.sr-grid-wrap {
  display: grid;
  grid-template-columns: repeat(var(--cols, 2), 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}
.sr-empty { display: flex; justify-content: center; padding: 48rpx; }
.sr-empty-text { color: var(--text-muted); font-size: 26rpx; }

/* ========== 快捷入口 ========== */
.sr-entries-wrap {
  display: grid;
  grid-template-columns: repeat(var(--cols, 4), 1fr);
  gap: 8rpx;
  padding: 16rpx 24rpx;
}
.sr-entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
}
.sr-entry-icon { width: 80rpx; height: 80rpx; }
.sr-entry-label { font-size: 22rpx; color: var(--text-secondary); text-align: center; }

/* ========== 公告条 ========== */
.sr-notice-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  min-height: 72rpx;
}
.sr-notice-icon { font-size: 32rpx; flex-shrink: 0; }
.sr-notice-scroll { flex: 1; }
.sr-notice-text { font-size: 26rpx; white-space: nowrap; }

/* ========== 图文区块 ========== */
.sr-text-block { padding: 0 0 24rpx; }
.sr-text-img { width: 100%; height: 300rpx; display: block; }
.sr-img-top { margin-bottom: 16rpx; }
.sr-text-content {
  padding: 0 32rpx;
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}
.sr-text-content.text-only { flex-direction: column; }
.sr-text-content.image-left, .sr-text-content.image-right { flex-direction: row; }
.sr-text-content .sr-text-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.sr-text-body { font-size: 28rpx; color: var(--text-secondary); line-height: 1.7; flex: 1; }

/* ========== 倒计时 ========== */
.sr-countdown {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  gap: 24rpx;
  border-radius: 20rpx;
  margin: 0 24rpx;
}
.sr-countdown-title { font-size: 32rpx; font-weight: 700; }
.sr-countdown-clock {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.sr-clock-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 8rpx 24rpx;
}
.sr-clock-num { font-size: 56rpx; font-weight: 800; line-height: 1; }
.sr-clock-label { font-size: 20rpx; opacity: 0.7; }
.sr-clock-sep { font-size: 48rpx; font-weight: 700; opacity: 0.6; }

/* ========== 特色卡片 ========== */
.sr-features-wrap {
  display: grid;
  grid-template-columns: repeat(var(--cols, 2), 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}
.sr-feat-card {
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-height: 200rpx;
}
.sr-feat-icon { width: 48rpx; height: 48rpx; margin-bottom: 8rpx; }
.sr-feat-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.15);
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  align-self: flex-start;
}
.sr-feat-name { font-size: 30rpx; font-weight: 700; color: #fff; }
.sr-feat-desc { font-size: 22rpx; color: rgba(255,255,255,0.7); line-height: 1.5; }

/* ========== 分隔线 ========== */
.sr-divider { display: flex; align-items: center; padding: 0 32rpx; }
.sr-divider-line { flex: 1; border-top: 1rpx solid; }
