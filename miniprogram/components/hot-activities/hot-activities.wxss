.hot-activities-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.ha-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.ha-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ha-title-group {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.ha-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.ha-subtitle {
  font-size: 18rpx;
  color: #CA8A04;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.ha-icon-box {
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #D4A84B 0%, #CA8A04 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ha-icon {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

.ha-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.ha-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #888;
}

.ha-arrow {
  width: 20rpx;
  height: 20rpx;
  opacity: 0.6;
}

.ha-body {
  display: flex;
  gap: 20rpx;
}

.ha-item {
  flex: 1;
  height: 160rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
  padding: 20rpx;
}

.group-buy {
  background: linear-gradient(135deg, #2C2520 0%, #1C1917 100%);
}

.slash-price {
  background: linear-gradient(135deg, #D4A84B 0%, #CA8A04 100%);
}

.ha-item-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ha-item-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.group-buy .ha-item-title {
  color: #F0C96A;
}

.slash-price .ha-item-title {
  color: #1C1917;
}

.ha-item-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}

.slash-price .ha-item-desc {
  color: rgba(28, 25, 23, 0.65);
}

.ha-item-bg {
  position: absolute;
  right: -10rpx;
  bottom: -10rpx;
  width: 100rpx;
  height: 100rpx;
  opacity: 0.2;
}
