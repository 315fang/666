.new-arrivals-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.na-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.na-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.na-title-group {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.na-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.na-subtitle {
  font-size: 18rpx;
  color: #CA8A04;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.na-icon-box {
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #D4A84B 0%, #CA8A04 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.na-icon {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

.na-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.na-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #888;
}

.na-arrow {
  width: 20rpx;
  height: 20rpx;
  opacity: 0.6;
}

.na-scroll {
  width: 100%;
  white-space: nowrap;
}

.na-list {
  display: inline-flex;
  gap: 20rpx;
}

.na-item {
  width: 260rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.na-img-wrap {
  width: 260rpx;
  height: 260rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F5F5F5;
  position: relative;
}

.na-img {
  width: 100%;
  height: 100%;
}

.na-member-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(212, 168, 75, 0.9);
  color: #FFF;
  font-size: 18rpx;
  text-align: center;
  padding: 4rpx 0;
  font-weight: 500;
}

.na-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.na-name {
  font-size: 24rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.na-price-row {
  display: flex;
  align-items: baseline;
  color: #CA8A04;
  font-weight: 700;
}

.na-currency {
  font-size: 20rpx;
}

.na-price {
  font-size: 28rpx;
}
