/* pages/wallet/index.wxss - 佣金账户 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F3ED 0%, #FAFAF8 30%, #F1EEEA 100%);
}

.main-scroll { flex: 1; }

/* ═══ 余额卡 ═══ */
.balance-card { padding: 20rpx 24rpx 0; }

.balance-card-inner {
  background: linear-gradient(140deg, #2B2018 0%, #1A1511 100%);
  border-radius: 28rpx;
  padding: 36rpx 36rpx 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(28, 20, 14, 0.20);
}

.wallet-type-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  color: #2B2018;
  background: #C8A258;
  border-radius: 6rpx;
  padding: 4rpx 14rpx;
  margin-bottom: 18rpx;
  letter-spacing: 0.5rpx;
}

.balance-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 240, 220, 0.55);
  margin-bottom: 12rpx;
}

.balance-amount-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.balance-symbol {
  font-size: 36rpx;
  color: rgba(255, 240, 220, 0.80);
  font-weight: 600;
}

.balance-amount {
  font-size: 80rpx;
  font-weight: 700;
  color: #FFF7EF;
  line-height: 1;
}

.balance-meta-row {
  margin-bottom: 28rpx;
}

.balance-meta-text {
  font-size: 22rpx;
  color: rgba(255, 240, 220, 0.45);
}

.balance-action-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.withdraw-btn {
  min-width: 200rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(200, 162, 88, 0.2);
  border: 1rpx solid rgba(200, 162, 88, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.withdraw-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #D4B070;
}

.log-btn {
  height: 76rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
}

.log-btn-text {
  font-size: 26rpx;
  color: rgba(255, 240, 220, 0.45);
}

/* ═══ 佣金流转生命周期（4块） ═══ */
.lifecycle-section {
  margin: 20rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(37, 29, 21, 0.05);
}

.lifecycle-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1C1917;
  margin-bottom: 8rpx;
}

.lifecycle-hint {
  font-size: 20rpx;
  color: #B0A090;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.lifecycle-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.lc-item {
  background: #F8F5F0;
  border-radius: 16rpx;
  padding: 18rpx 16rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.lc-item-highlight {
  background: linear-gradient(135deg, #FDF6EB 0%, #F8EDD6 100%);
  border: 1rpx solid rgba(200, 162, 88, 0.3);
}

.lc-badge {
  display: inline-block;
  font-size: 19rpx;
  font-weight: 600;
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  align-self: flex-start;
  margin-bottom: 4rpx;
}

.lc-frozen   { color: #B76447; background: #FAECE8; }
.lc-pending  { color: #A06C28; background: #F8EEE0; }
.lc-settling { color: #4A6E8A; background: #EEF4FB; }
.lc-available { color: #2E6A44; background: #E8F6EE; }

.lc-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1C1917;
}

.lc-value-highlight {
  color: #8A6020;
}

.lc-desc {
  font-size: 20rpx;
  color: #9A8D80;
}

/* ═══ 代理商货款账户入口 ═══ */
.goods-fund-entry {
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 24rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(37, 29, 21, 0.05);
  border-left: 4rpx solid #C8A258;
}

.gfe-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.gfe-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #F4EDE0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.gfe-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.7;
}

.gfe-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.gfe-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1C1917;
}

.gfe-sub {
  font-size: 21rpx;
  color: #9A8D80;
  line-height: 1.4;
}

.gfe-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.gfe-balance {
  font-size: 30rpx;
  font-weight: 700;
  color: #3A2E24;
}

.gfe-arrow {
  font-size: 32rpx;
  color: #B0A090;
}

/* ═══ 佣金明细 ═══ */
.section-card {
  margin: 16rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(37, 29, 21, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1C1917;
}

.section-link {}
.section-link-text {
  font-size: 24rpx;
  color: #9A8D80;
}

/* 骨架屏 */
.skeleton-wrap { padding-top: 12rpx; }
.sk-log {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(122, 108, 94, 0.06);
}
.sk-info { flex: 1; }
.sk-line {
  height: 22rpx;
  border-radius: 6rpx;
  background: #EDEAE6;
  margin-bottom: 10rpx;
}
.sk-long { width: 60%; }
.sk-short { width: 35%; }
.sk-amount {
  width: 100rpx;
  height: 34rpx;
  border-radius: 8rpx;
  background: #EDEAE6;
}

/* 流水列表 */
.log-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(122, 108, 94, 0.08);
}
.log-item:last-child { border-bottom: none; }

.log-left { flex: 1; margin-right: 16rpx; }

.log-type-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.log-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1917;
}

.log-badge {
  font-size: 19rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
}
.badge-frozen   { color: #B76447; background: #FAECE8; }
.badge-pending  { color: #A06C28; background: #F8EEE0; }
.badge-settling { color: #4A6E8A; background: #EEF4FB; }
.badge-settled  { color: #2E6A44; background: #E8F6EE; }
.badge-cancel   { color: #9A8D80; background: #F2EFEC; }

.log-time {
  display: block;
  font-size: 22rpx;
  color: #B0A396;
  margin-bottom: 4rpx;
}

.log-deadline {
  font-size: 20rpx;
  color: #C5A884;
}

.log-right { flex-shrink: 0; padding-top: 2rpx; }

.log-amount {
  font-size: 32rpx;
  font-weight: 700;
}
.log-positive { color: #2E6A44; }
.log-negative { color: #B76447; }

.view-all-row {
  padding: 20rpx 0 4rpx;
  display: flex;
  justify-content: center;
}

.view-all-text {
  font-size: 24rpx;
  color: #9A8D80;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 0 36rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #78716C;
  font-weight: 600;
  margin-bottom: 10rpx;
}
.empty-sub { font-size: 24rpx; color: #B0A396; }

/* ═══ 底部说明 ═══ */
.footer-note {
  margin: 20rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
}
.footer-note-text {
  display: block;
  font-size: 21rpx;
  color: #9A8D80;
  line-height: 1.7;
}

/* ═══ 提现弹窗 ═══ */
.popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.popup-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C1917;
}

.popup-close {
  font-size: 40rpx;
  color: #9A8D80;
  line-height: 1;
  padding: 0 8rpx;
}

.popup-balance-tip {
  font-size: 26rpx;
  color: #78716C;
  margin-bottom: 12rpx;
}

.popup-balance-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #2E6A44;
}

.popup-note {
  font-size: 22rpx;
  color: #B76447;
  background: #FAECE8;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.popup-input-wrap {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid rgba(122, 108, 94, 0.15);
  padding: 16rpx 0 20rpx;
  margin-bottom: 32rpx;
}

.popup-input-symbol {
  font-size: 40rpx;
  font-weight: 700;
  color: #1C1917;
  margin-right: 12rpx;
}

.popup-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: 700;
  color: #1C1917;
  height: 72rpx;
}

.popup-btn-row {
  display: flex;
  gap: 16rpx;
}

.popup-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  background: #F2EFEC;
  display: flex;
  align-items: center;
  justify-content: center;
}
.popup-cancel-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #78716C;
}

.popup-confirm {
  flex: 2;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #C8A258 0%, #9C6E32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.popup-confirm.btn-loading { opacity: 0.7; }
.popup-confirm-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFF7EF;
}
