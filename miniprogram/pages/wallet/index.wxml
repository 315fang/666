<!-- pages/wallet/index.wxml - 佣金账户（分销佣金，与货款账户完全独立） -->
<view class="container">
  <scroll-view class="main-scroll" scroll-y enable-back-to-top>

    <!-- ═══ 顶部余额卡 ═══ -->
    <view class="balance-card">
      <view class="balance-card-inner">
        <!-- 标识 -->
        <view class="wallet-type-tag">佣金账户</view>
        <text class="balance-label">可提现佣金（元）</text>
        <view class="balance-amount-row">
          <text class="balance-symbol">¥</text>
          <text class="balance-amount">{{commissionAvailable}}</text>
        </view>
        <view class="balance-meta-row">
          <text class="balance-meta-text">累计佣金 ¥{{commissionTotal}}</text>
        </view>
        <view class="balance-action-row">
          <view class="withdraw-btn" bindtap="onWithdrawTap">
            <text class="withdraw-btn-text">申请提现</text>
          </view>
          <view class="log-btn" bindtap="onGoCommissionLogs">
            <text class="log-btn-text">明细 ›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ═══ 佣金四阶段概览（生命周期） ═══ -->
    <view class="lifecycle-section">
      <view class="lifecycle-title">佣金流转状态</view>
      <view class="lifecycle-hint">新订单佣金 → 冻结期(T+15) → 审核中 → 待结算 → 可提现</view>
      <view class="lifecycle-grid">
        <!-- 冻结中 -->
        <view class="lc-item">
          <view class="lc-badge lc-frozen">冻结中</view>
          <text class="lc-value">¥{{commissionFrozen}}</text>
          <text class="lc-desc">T+15 自动解冻</text>
        </view>
        <!-- 审核中 -->
        <view class="lc-item">
          <view class="lc-badge lc-pending">审核中</view>
          <text class="lc-value">¥{{commissionPending}}</text>
          <text class="lc-desc">提现申请审核</text>
        </view>
        <!-- 待结算 -->
        <view class="lc-item">
          <view class="lc-badge lc-settling">待结算</view>
          <text class="lc-value">¥{{commissionSettling}}</text>
          <text class="lc-desc">审核通过等打款</text>
        </view>
        <!-- 可提现 -->
        <view class="lc-item lc-item-highlight" bindtap="onWithdrawTap">
          <view class="lc-badge lc-available">可提现</view>
          <text class="lc-value lc-value-highlight">¥{{commissionAvailable}}</text>
          <text class="lc-desc">点击立即提现</text>
        </view>
      </view>
    </view>

    <!-- ═══ 代理商货款账户入口（仅代理可见） ═══ -->
    <view class="goods-fund-entry" wx:if="{{isAgent}}" bindtap="onGoGoodsFund">
      <view class="gfe-left">
        <view class="gfe-icon-wrap">
          <image src="/assets/icons/package.svg" mode="aspectFit" class="gfe-icon"></image>
        </view>
        <view class="gfe-info">
          <text class="gfe-title">货款账户</text>
          <text class="gfe-sub">代理商进货资金，与佣金独立核算</text>
        </view>
      </view>
      <view class="gfe-right">
        <text class="gfe-balance">¥{{goodsFundBalance}}</text>
        <text class="gfe-arrow">›</text>
      </view>
    </view>

    <!-- ═══ 佣金明细 ═══ -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">佣金明细</text>
        <view class="section-link" bindtap="onGoCommissionLogs">
          <text class="section-link-text">查看全部 ›</text>
        </view>
      </view>

      <!-- 骨架屏 -->
      <view class="skeleton-wrap" wx:if="{{logsLoading && logs.length === 0}}">
        <view class="sk-log" wx:for="{{[1,2,3,4]}}" wx:key="index">
          <view class="sk-info">
            <view class="sk-line sk-long"></view>
            <view class="sk-line sk-short"></view>
          </view>
          <view class="sk-amount"></view>
        </view>
      </view>

      <!-- 流水列表 -->
      <view wx:if="{{logs.length > 0}}">
        <view class="log-item" wx:for="{{logs}}" wx:key="id">
          <view class="log-left">
            <view class="log-type-row">
              <text class="log-type">{{item.typeName}}</text>
              <view class="log-badge {{item.statusClass}}">{{item.statusText}}</view>
            </view>
            <text class="log-time">{{item.created_at}}</text>
            <text class="log-deadline" wx:if="{{item.refund_deadline}}">冻结至 {{item.refund_deadline}}</text>
          </view>
          <view class="log-right">
            <text class="log-amount {{item.isWithdraw ? 'log-negative' : 'log-positive'}}">
              {{item.isWithdraw ? '-' : '+'}}¥{{item.amount}}
            </text>
          </view>
        </view>
        <view class="view-all-row" bindtap="onGoCommissionLogs">
          <text class="view-all-text">查看全部佣金记录 ›</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!logsLoading && logs.length === 0}}">
        <text class="empty-text">暂无佣金记录</text>
        <text class="empty-sub">分享商品或发展团队，即可获得佣金</text>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="footer-note">
      <text class="footer-note-text">佣金账户仅记录分销佣金收益，与货款账户独立核算。</text>
      <text class="footer-note-text">佣金冻结期 15 天，解冻后可申请提现，审核通过后打款至银行卡。</text>
    </view>

    <view style="height: 80rpx;"></view>
  </scroll-view>

  <!-- ═══ 提现弹窗 ═══ -->
  <view class="popup-mask" wx:if="{{showWithdraw}}" bindtap="hideWithdraw">
    <view class="popup-panel" catchtap="">
      <view class="popup-header">
        <text class="popup-title">申请提现</text>
        <view class="popup-close" bindtap="hideWithdraw">×</view>
      </view>
      <view class="popup-balance-tip">
        <text>可提现佣金：</text>
        <text class="popup-balance-num">¥{{commissionAvailable}}</text>
      </view>
      <view class="popup-note">⚠️ 提现仅限佣金余额，货款余额请在货款账户操作</view>
      <view class="popup-input-wrap">
        <text class="popup-input-symbol">¥</text>
        <input
          class="popup-input"
          type="digit"
          placeholder="输入提现金额"
          value="{{withdrawAmount}}"
          bindinput="onWithdrawInput"
          focus="{{showWithdraw}}"
        ></input>
      </view>
      <view class="popup-btn-row">
        <view class="popup-cancel" bindtap="hideWithdraw">
          <text class="popup-cancel-text">取消</text>
        </view>
        <view class="popup-confirm {{withdrawing ? 'btn-loading' : ''}}" bindtap="confirmWithdraw">
          <text class="popup-confirm-text">{{withdrawing ? '提交中...' : '确认提现'}}</text>
        </view>
      </view>
    </view>
  </view>

  <brand-animation id="brandAnimation"></brand-animation>
</view>
