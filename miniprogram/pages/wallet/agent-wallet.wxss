.container {
  min-height: 100vh;
  background: #F2EDE8;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  background: #2E2218;
  flex-shrink: 0;
}
.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  position: relative;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.85;
}
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #FFF8F0;
}

/* 滚动区 */
.main-scroll {
  flex: 1;
  height: 0;
}

/* ═══════════════ 余额英雄区（升级版） ═══════════════ */
.balance-hero {
  background: linear-gradient(165deg, #1A1410 0%, #3A2820 45%, #5A4030 100%);
  padding: 44rpx 36rpx 52rpx;
  position: relative;
  overflow: hidden;
}

/* 装饰性背景纹理 */
.balance-hero::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(200,162,88,0.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.balance-hero::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.balance-label {
  display: block;
  font-size: 23rpx;
  color: rgba(255, 248, 240, 0.45);
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
}
.balance-amount-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 38rpx;
  position: relative;
  z-index: 1;
}
.balance-sym {
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(255, 248, 240, 0.8);
}
.balance-num {
  font-size: 76rpx;
  font-weight: 700;
  color: #FFF8F0;
  line-height: 1;
  letter-spacing: -1rpx;
}
.balance-sub-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  padding: 20rpx 0;
}
.balance-sub-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.balance-sub-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFF8F0;
}
.balance-sub-label {
  font-size: 20rpx;
  color: rgba(255, 248, 240, 0.48);
}
.balance-sub-sep {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.12);
}

/* ═══════════════ 流水区（升级版） ═══════════════ */
.logs-section {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -28rpx;
  padding: 32rpx 0 0;
  position: relative;
  z-index: 2;
  box-shadow: 0 -4rpx 24rpx rgba(30, 20, 10, 0.06);
}
.logs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 28rpx 24rpx;
  border-bottom: 1rpx solid #F0EBE4;
}
.logs-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E1710;
}
.filter-tabs {
  display: flex;
  background: #F5F0EA;
  border-radius: 999rpx;
  padding: 4rpx;
  gap: 2rpx;
}
.filter-tab {
  font-size: 22rpx;
  color: #8A7A6E;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  transition: all 0.2s;
}
.filter-tab.active {
  background: #fff;
  color: #3A2C1E;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(37, 29, 21, 0.10);
}

/* ═══════════════ 流水列表（升级版） ═══════════════ */

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 60rpx;
  gap: 16rpx;
}
.error-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(220, 80, 60, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}
.error-icon-img {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.6;
}
.error-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E1710;
}
.error-msg {
  font-size: 24rpx;
  color: #B0A090;
  text-align: center;
  line-height: 1.5;
  max-width: 480rpx;
}
.error-retry-btn {
  margin-top: 12rpx;
  height: 68rpx;
  padding: 0 48rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.error-retry-text {
  font-size: 27rpx;
  font-weight: 500;
  color: #FFF8F0;
}

/* 日期分组标签 */
.date-group-label {
  padding: 24rpx 36rpx 10rpx;
  background: transparent;
}
.date-label-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #9A8A7A;
  letter-spacing: 0.5rpx;
}

/* 流水项 */
.log-item {
  display: flex;
  align-items: flex-start;
  padding: 26rpx 28rpx;
  gap: 18rpx;
  border-bottom: 1rpx solid #FAF8F5;
  transition: background-color 0.15s;
}
.log-item:active {
  background: #FBFAF8;
}

/* 图标区域 - 圆形带阴影 */
.log-icon-wrap {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}
.log-icon-wrap.icon-in {
  background: linear-gradient(135deg, rgba(74, 158, 95, 0.10) 0%, rgba(56, 142, 75, 0.08) 100%);
  box-shadow: 0 2rpx 12rpx rgba(74, 158, 95, 0.08);
}
.log-icon-wrap.icon-out {
  background: linear-gradient(135deg, rgba(210, 110, 65, 0.10) 0%, rgba(190, 90, 50, 0.08) 100%);
  box-shadow: 0 2rpx 12rpx rgba(210, 110, 65, 0.08);
}
.log-icon-svg {
  width: 34rpx;
  height: 34rpx;
}
.log-icon-wrap.icon-in .log-icon-svg { opacity: 0.85; }
.log-icon-wrap.icon-out .log-icon-svg { opacity: 0.85; }

/* 信息区 */
.log-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* 类型行 + 状态标签 */
.log-type-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.log-type {
  font-size: 28rpx;
  color: #1E1710;
  font-weight: 600;
}

/* 状态标签 */
.log-status-tag {
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-size: 19rpx;
  flex-shrink: 0;
}
.log-status-tag.status-pending {
  background: rgba(250, 180, 50, 0.12);
}
.log-status-tag.status-pending .log-status-text { color: #B8860B; font-weight: 500; }
.log-status-tag.status-failed {
  background: rgba(220, 70, 50, 0.08);
}
.log-status-tag.status-failed .log-status-text { color: #C04030; font-weight: 500; }

/* 时间 */
.log-time {
  font-size: 22rpx;
  color: #B5A89A;
}

/* 单号行 */
.log-ref-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 2rpx;
}
.log-ref-label {
  font-size: 20rpx;
  color: #C0B4A8;
  flex-shrink: 0;
}
.log-ref-value {
  font-size: 20rpx;
  color: #A09585;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 备注文字 */
.log-remark {
  font-size: 22rpx;
  color: #B0A494;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 2rpx;
}

/* 金额区 */
.log-amount-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
  padding-top: 2rpx;
}
.log-amount {
  font-size: 31rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}
.log-amount.amount-in { color: #2D8A4E; }
.log-amount.amount-out { color: #D4633A; }

/* 余额详情 */
.log-balance-row {
  display: flex;
  align-items: center;
}
.log-balance-detail {
  font-size: 20rpx;
  color: #B5A89A;
  font-variant-numeric: tabular-nums;
}

/* 骨架屏 */
.sk-list { padding: 0 28rpx; }
.sk-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F8F4F0;
}
.sk-left { display: flex; flex-direction: column; gap: 10rpx; }
.sk-line {
  height: 22rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #F0EAE4 25%, #E8E0D8 50%, #F0EAE4 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}
.sk-long { width: 200rpx; }
.sk-short { width: 130rpx; }
.sk-right { width: 100rpx; height: 30rpx; border-radius: 6rpx; background: linear-gradient(90deg, #F0EAE4 25%, #E8E0D8 50%, #F0EAE4 75%); background-size: 200% 100%; animation: shimmer 1.4s infinite; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

/* 加载更多 */
.load-more {
  padding: 36rpx 0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.load-more-text { font-size: 23rpx; color: #C5BDB2; }

/* 加载动画点 */
.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #C8A258;
  animation: dot-bounce 1.2s infinite ease-in-out;
}
.dot:nth-child(2) { animation-delay: 0.15s; }
.dot:nth-child(3) { animation-delay: 0.3s; }
@keyframes dot-bounce {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

/* 空状态（升级版） */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 72rpx;
  gap: 16rpx;
}
.empty-illustration {
  width: 160rpx;
  height: 140rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-img {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.25;
}
.empty-title { font-size: 30rpx; color: #5A4E44; font-weight: 600; }
.empty-sub { font-size: 24rpx; color: #B5A89A; text-align: center; line-height: 1.6; max-width: 420rpx; }

/* 空状态操作按钮 */
.empty-action {
  margin-top: 20rpx;
  height: 68rpx;
  padding: 0 40rpx;
  border-radius: 34rpx;
  border: 1rpx solid #D8CFC4;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-action-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #7A6A5E;
}

/* 充值按钮（余额区内） */
.recharge-btn {
  margin-top: 28rpx;
  min-height: 104rpx;
  padding: 24rpx 32rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.24);
}
.recharge-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFF8F0;
  letter-spacing: 2rpx;
}

/* 充值按钮灰色（非代理商） */
.recharge-btn-disabled {
  background: rgba(255,255,255,0.14) !important;
  box-shadow: none !important;
  border: 1rpx solid rgba(255,255,255,0.2);
}
.recharge-btn-disabled .recharge-btn-text {
  color: rgba(255,248,240,0.38);
  letter-spacing: 0;
  font-size: 28rpx;
}

/* 非代理商提示页 */
.no-access-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  gap: 16rpx;
}
.no-access-icon { font-size: 80rpx; margin-bottom: 8rpx; }
.no-access-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E1710;
}
.no-access-sub {
  font-size: 26rpx;
  color: #9A8A7A;
  text-align: center;
  line-height: 1.7;
}
.no-access-btn {
  margin-top: 24rpx;
  height: 80rpx;
  padding: 0 60rpx;
  border-radius: 40rpx;
  background: #2E2218;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFF8F0;
}

/* ══ 充值面板 ══ */
.panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.48);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.recharge-panel {
  width: 100%;
  background: #FAFAF8;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx env(safe-area-inset-bottom, 32rpx);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0 20rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E1710;
}

.panel-close {
  width: 56rpx;
  height: 56rpx;
  font-size: 44rpx;
  color: #B0A090;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.panel-tip {
  font-size: 24rpx;
  color: #9A8A7A;
  margin-bottom: 28rpx;
}

/* 预设金额格子 */
.amount-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.amount-item {
  height: 88rpx;
  border-radius: 18rpx;
  background: #F0EBE5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.amount-item.amount-selected {
  background: rgba(200, 162, 88, 0.12);
  border-color: #C8A258;
}

.amount-item-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E1710;
}

.amount-item.amount-selected .amount-item-value {
  color: #9A6A20;
}

/* 自定义金额 */
.custom-amount-wrap {
  display: flex;
  align-items: center;
  height: 88rpx;
  border-radius: 18rpx;
  border: 2rpx solid #E8E0D8;
  background: #fff;
  padding: 0 24rpx;
  gap: 8rpx;
  margin-bottom: 16rpx;
  transition: border-color 0.15s;
}

.custom-amount-wrap.custom-active {
  border-color: #C8A258;
}

.custom-prefix {
  font-size: 28rpx;
  color: #6A5A4E;
  font-weight: 600;
  flex-shrink: 0;
}

.custom-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #1E1710;
  background: transparent;
}

.custom-placeholder {
  color: #C0B4A8;
}

.panel-fee-tip {
  font-size: 22rpx;
  color: #B0A090;
  margin-bottom: 28rpx;
  text-align: center;
}

/* 确认按钮 */
.confirm-btn {
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(160, 120, 60, 0.30);
  margin-bottom: 20rpx;
}

.confirm-btn.confirm-loading {
  opacity: 0.65;
}

.confirm-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFF8F0;
  letter-spacing: 1rpx;
}

.bonus-hint {
  margin: 16rpx 0 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FEF3C7 100%);
  border-radius: 12rpx;
  border: 1rpx solid #F59E0B;
}

.bonus-hint-text {
  font-size: 24rpx;
  color: #B45309;
  font-weight: 500;
}
