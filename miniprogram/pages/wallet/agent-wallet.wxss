.container {
  min-height: 100vh;
  background: #F2EDE8;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  background: #2E2218;
  flex-shrink: 0;
}
.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  position: relative;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.85;
}
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #FFF8F0;
}

/* 滚动区 */
.main-scroll {
  flex: 1;
  height: 0;
}

/* 余额英雄区 */
.balance-hero {
  background: linear-gradient(160deg, #2E2218 0%, #4A3527 100%);
  padding: 40rpx 36rpx 48rpx;
}
.balance-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 248, 240, 0.5);
  margin-bottom: 14rpx;
}
.balance-amount-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 36rpx;
}
.balance-sym {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 248, 240, 0.85);
}
.balance-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFF8F0;
  line-height: 1;
}
.balance-sub-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  padding: 20rpx 0;
}
.balance-sub-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.balance-sub-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFF8F0;
}
.balance-sub-label {
  font-size: 20rpx;
  color: rgba(255, 248, 240, 0.48);
}
.balance-sub-sep {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.12);
}

/* 流水区 */
.logs-section {
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -24rpx;
  padding: 28rpx 0 0;
}
.logs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 28rpx 20rpx;
  border-bottom: 1rpx solid #F5F0EA;
}
.logs-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E1710;
}
.filter-tabs {
  display: flex;
  background: #F5F0EA;
  border-radius: 999rpx;
  padding: 4rpx;
  gap: 2rpx;
}
.filter-tab {
  font-size: 22rpx;
  color: #8A7A6E;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  transition: all 0.2s;
}
.filter-tab.active {
  background: #fff;
  color: #3A2C1E;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(37, 29, 21, 0.10);
}

/* 流水列表 */
.log-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  gap: 18rpx;
  border-bottom: 1rpx solid #F8F4F0;
}
.log-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.log-icon-wrap.icon-in { background: rgba(80, 160, 100, 0.10); }
.log-icon-wrap.icon-out { background: rgba(200, 100, 60, 0.10); }
.log-icon-text {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}
.log-icon-wrap.icon-in .log-icon-text { color: #3A8A58; }
.log-icon-wrap.icon-out .log-icon-text { color: #C05A30; }
.log-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}
.log-type {
  font-size: 28rpx;
  color: #1E1710;
  font-weight: 500;
}
.log-time {
  font-size: 21rpx;
  color: #B0A090;
}
.log-remark {
  font-size: 21rpx;
  color: #9A8A7A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.log-amount-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 5rpx;
  flex-shrink: 0;
}
.log-amount {
  font-size: 30rpx;
  font-weight: 700;
}
.log-amount.amount-in { color: #3A8A58; }
.log-amount.amount-out { color: #C05A30; }
.log-balance {
  font-size: 20rpx;
  color: #B0A090;
}

/* 骨架屏 */
.sk-list { padding: 0 28rpx; }
.sk-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F8F4F0;
}
.sk-left { display: flex; flex-direction: column; gap: 10rpx; }
.sk-line {
  height: 22rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #F0EAE4 25%, #E8E0D8 50%, #F0EAE4 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}
.sk-long { width: 200rpx; }
.sk-short { width: 130rpx; }
.sk-right { width: 100rpx; height: 30rpx; border-radius: 6rpx; background: linear-gradient(90deg, #F0EAE4 25%, #E8E0D8 50%, #F0EAE4 75%); background-size: 200% 100%; animation: shimmer 1.4s infinite; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

/* 加载更多 */
.load-more {
  padding: 32rpx 0;
  text-align: center;
}
.load-more-text { font-size: 24rpx; color: #C0B4A8; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-icon { font-size: 72rpx; }
.empty-title { font-size: 28rpx; color: #5A4E44; font-weight: 500; }
.empty-sub { font-size: 24rpx; color: #B0A090; }

/* 充值按钮（余额区内） */
.recharge-btn {
  margin-top: 28rpx;
  min-height: 104rpx;
  padding: 24rpx 32rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.24);
}
.recharge-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFF8F0;
  letter-spacing: 2rpx;
}

/* 充值按钮灰色（非代理商） */
.recharge-btn-disabled {
  background: rgba(255,255,255,0.14) !important;
  box-shadow: none !important;
  border: 1rpx solid rgba(255,255,255,0.2);
}
.recharge-btn-disabled .recharge-btn-text {
  color: rgba(255,248,240,0.38);
  letter-spacing: 0;
  font-size: 28rpx;
}

/* 非代理商提示页 */
.no-access-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  gap: 16rpx;
}
.no-access-icon { font-size: 80rpx; margin-bottom: 8rpx; }
.no-access-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E1710;
}
.no-access-sub {
  font-size: 26rpx;
  color: #9A8A7A;
  text-align: center;
  line-height: 1.7;
}
.no-access-btn {
  margin-top: 24rpx;
  height: 80rpx;
  padding: 0 60rpx;
  border-radius: 40rpx;
  background: #2E2218;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFF8F0;
}

/* ══ 充值面板 ══ */
.panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.48);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.recharge-panel {
  width: 100%;
  background: #FAFAF8;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx env(safe-area-inset-bottom, 32rpx);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0 20rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E1710;
}

.panel-close {
  width: 56rpx;
  height: 56rpx;
  font-size: 44rpx;
  color: #B0A090;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.panel-tip {
  font-size: 24rpx;
  color: #9A8A7A;
  margin-bottom: 28rpx;
}

/* 预设金额格子 */
.amount-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.amount-item {
  height: 88rpx;
  border-radius: 18rpx;
  background: #F0EBE5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.amount-item.amount-selected {
  background: rgba(200, 162, 88, 0.12);
  border-color: #C8A258;
}

.amount-item-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E1710;
}

.amount-item.amount-selected .amount-item-value {
  color: #9A6A20;
}

/* 自定义金额 */
.custom-amount-wrap {
  display: flex;
  align-items: center;
  height: 88rpx;
  border-radius: 18rpx;
  border: 2rpx solid #E8E0D8;
  background: #fff;
  padding: 0 24rpx;
  gap: 8rpx;
  margin-bottom: 16rpx;
  transition: border-color 0.15s;
}

.custom-amount-wrap.custom-active {
  border-color: #C8A258;
}

.custom-prefix {
  font-size: 28rpx;
  color: #6A5A4E;
  font-weight: 600;
  flex-shrink: 0;
}

.custom-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #1E1710;
  background: transparent;
}

.custom-placeholder {
  color: #C0B4A8;
}

.panel-fee-tip {
  font-size: 22rpx;
  color: #B0A090;
  margin-bottom: 28rpx;
  text-align: center;
}

/* 确认按钮 */
.confirm-btn {
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(160, 120, 60, 0.30);
  margin-bottom: 20rpx;
}

.confirm-btn.confirm-loading {
  opacity: 0.65;
}

.confirm-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFF8F0;
  letter-spacing: 1rpx;
}

.bonus-hint {
  margin: 16rpx 0 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FEF3C7 100%);
  border-radius: 12rpx;
  border: 1rpx solid #F59E0B;
}

.bonus-hint-text {
  font-size: 24rpx;
  color: #B45309;
  font-weight: 500;
}
