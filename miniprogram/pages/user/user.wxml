<view class="container">

  <!-- ══ 头图 Hero + 资产大卡 ══ -->
  <view class="hero-zone">
    <view class="hero-bg"></view>
    <view class="hero-inner">
      <view style="height: {{statusBarHeight}}px;"></view>

      <!-- 顶栏：右侧工具 -->
      <view class="hero-toolbar">
        <view class="hero-toolbar-left"></view>
        <view class="hero-toolbar-right">
          <view class="hero-top-btn" bindtap="goAddress" hover-class="hero-top-btn-hover">
            <image class="hero-top-icon" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
            <text class="hero-top-text">地址</text>
          </view>
          <view class="hero-top-btn" bindtap="goCustomerService" hover-class="hero-top-btn-hover">
            <image class="hero-top-icon" src="/assets/icons/headphones.svg" mode="aspectFit"></image>
            <text class="hero-top-text">客服</text>
          </view>
          <view class="hero-top-btn" bindtap="onSettingsTap" hover-class="hero-top-btn-hover">
            <image class="hero-top-icon" src="/assets/icons/settings.svg" mode="aspectFit"></image>
            <text class="hero-top-text">设置</text>
          </view>
        </view>
      </view>

      <!-- 个人信息 -->
      <view class="hero-profile-wrap">
        <view class="hero-avatar-wrap">
          <image class="hero-avatar" src="{{userInfo.avatar_url || '/assets/images/default-avatar.svg'}}" mode="aspectFill"></image>
        </view>
        <view class="hero-info">
          <view class="hero-name-row">
            <text class="hero-nickname">{{userInfo.nickname || '微信用户'}}</text>
            <view class="hero-profile-edit" catchtap="onTapEditProfile">
              <text class="hero-profile-edit-text">品</text>
            </view>
          </view>
          <view class="hero-tags-row" wx:if="{{isLoggedIn && userInfo}}">
            <text class="hero-tag-level" wx:if="{{isMember}}">{{userInfo.role_name || '会员'}}</text>
            <text class="hero-tag-vip" wx:if="{{isAgent}}">{{userInfo.role_name || '代理商'}}</text>
          </view>
        </view>
        <!-- 未登录提示（如需） -->
        <view class="hero-login-hint" wx:if="{{!isLoggedIn}}" bindtap="onLoginBtnTap">点击登录</view>
      </view>

      <!-- 核心资产卡 -->
      <view class="vip-card">
        <!-- 卡片头部: 省钱与宣传位 -->
        <view class="vip-card-header">
          <view class="vip-card-saved" bindtap="onGrowthPrivilegesTap">
            <text class="saved-label">累计成长值</text><text class="saved-val">{{growthDisplay ? growthDisplay.value : 0}}</text><text class="saved-arrow">›</text>
          </view>
          <view class="vip-card-promo">
            <view class="promo-block" bindtap="onGrowthPrivilegesTap">
              <text class="promo-title">会员中心</text>
              <view class="promo-subtitle">查看特权 <text class="promo-arrow">›</text></view>
            </view>
            <view class="promo-divider"></view>
            <view class="promo-block" bindtap="goPoints">
              <text class="promo-title">积分中心</text>
              <view class="promo-subtitle">每日签到 <text class="promo-arrow">›</text></view>
            </view>
          </view>
        </view>

        <!-- 中央: 资产数据 -->
        <view class="vip-assets-panel">
          <view class="vip-assets-matrix">
            <view class="vip-asset-item" bindtap="onAssetCouponsTap">
              <text class="vip-asset-title">优惠券</text>
              <view class="vip-asset-value">{{isLoggedIn ? unusedCouponCount : '--'}}<text class="vip-asset-sym">张</text></view>
            </view>
            <view class="vip-asset-item" bindtap="onAssetPointsTap">
              <text class="vip-asset-title">我的积分</text>
              <view class="vip-asset-value">{{isLoggedIn ? pointsBalanceDisplay : '--'}}</view>
            </view>
            <view class="vip-asset-item" bindtap="onAssetBalanceTap">
              <text class="vip-asset-title">账户余额</text>
              <view class="vip-asset-value"><text class="vip-asset-sym">¥</text>{{isLoggedIn ? (userInfo.balance || '0.00') : '--'}}</view>
            </view>
            <view class="vip-asset-item" bindtap="onGrowthPrivilegesTap">
              <text class="vip-asset-title">会员等级</text>
              <view class="vip-asset-value">{{growthDisplay.currentTierName || '普通会员'}}</view>
            </view>
          </view>
          <view class="vip-asset-all">
            <text class="all-text">全部\n权益</text>
            <text class="all-arrow">›</text>
          </view>
        </view>

        <!-- 底部: 动作横幅 -->
        <view class="vip-card-banner">
          <view class="banner-left">
            <view class="banner-icon-wrap"><text class="banner-icon-text">¥</text></view>
            <text class="banner-desc">1元优惠券待使用，限指定商品可用</text>
          </view>
          <view class="banner-btn">去使用</view>
        </view>
      </view>
    </view>
  </view>

  <!-- ══ 我的订单 ══ -->
  <view class="section-card section-card--orders">
    <view class="section-row-header" bindtap="onOrderTap" data-type="all">
      <text class="section-row-title">我的订单</text>
      <view class="section-row-more"><text>查看全部</text><text class="arrow-icon">›</text></view>
    </view>
    <view class="order-tabs">
      <view class="order-tab" bindtap="onOrderTap" data-type="pending">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/credit-card.svg" mode="aspectFit"></image>
          <view class="order-tab-badge" wx:if="{{orderStats.pending > 0}}">{{orderStats.pending > 99 ? '99+' : orderStats.pending}}</view>
        </view>
        <text class="order-tab-text">待付款</text>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-type="paid">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/package.svg" mode="aspectFit"></image>
          <view class="order-tab-badge" wx:if="{{orderStats.paid > 0}}">{{orderStats.paid > 99 ? '99+' : orderStats.paid}}</view>
        </view>
        <text class="order-tab-text">待发货</text>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-type="shipped">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/truck.svg" mode="aspectFit"></image>
          <view class="order-tab-badge" wx:if="{{orderStats.shipped > 0}}">{{orderStats.shipped > 99 ? '99+' : orderStats.shipped}}</view>
        </view>
        <text class="order-tab-text">待收货</text>
      </view>
      <view class="order-tab" bindtap="onOrderTap" data-type="pending_review">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/message.svg" mode="aspectFit"></image>
          <view class="order-tab-badge" wx:if="{{orderStats.pendingReview > 0}}">{{orderStats.pendingReview > 99 ? '99+' : orderStats.pendingReview}}</view>
        </view>
        <text class="order-tab-text">待评价</text>
      </view>
      <view class="order-tab" bindtap="onRefundTap">
        <view class="order-tab-icon-wrap">
          <image class="order-tab-icon" src="/assets/icons/refresh-cw.svg" mode="aspectFit"></image>
          <view class="order-tab-badge" wx:if="{{orderStats.refund > 0}}">{{orderStats.refund > 99 ? '99+' : orderStats.refund}}</view>
        </view>
        <text class="order-tab-text">退款/售后</text>
      </view>
    </view>
    <view class="order-aftersale-bar" bindtap="goCustomerService" hover-class="row-press">
      <image class="order-aftersale-icon" src="/assets/icons/headphones.svg" mode="aspectFit"></image>
      <text class="order-aftersale-text">联系客服</text>
      <text class="order-aftersale-hint">售后与订单问题</text>
      <text class="order-aftersale-arrow">›</text>
    </view>
  </view>

  <!-- ══ 四宫格摘要 ══ -->
  <view class="section-card quad-card">
    <view class="quad-grid">
      <view class="quad-cell" bindtap="onQuadExpressTap" hover-class="quad-cell-hover">
        <view class="quad-cell-main">
          <view class="quad-texts">
            <text class="quad-title">快递</text>
            <text class="quad-sub">{{quadExpress.sub}}</text>
          </view>
          <image class="quad-thumb" src="{{quadExpress.image}}" mode="aspectFill"></image>
        </view>
        <text class="quad-action">去查看</text>
      </view>
      <view class="quad-cell" bindtap="onQuadFavoriteTap" hover-class="quad-cell-hover">
        <view class="quad-cell-main">
          <view class="quad-texts">
            <text class="quad-title">收藏</text>
            <text class="quad-sub">{{quadFavorite.sub}}</text>
          </view>
          <image class="quad-thumb" src="{{quadFavorite.image}}" mode="aspectFill"></image>
        </view>
        <text class="quad-action">去查看</text>
      </view>
      <view class="quad-cell" bindtap="onQuadFootprintTap" hover-class="quad-cell-hover">
        <view class="quad-cell-main">
          <view class="quad-texts">
            <text class="quad-title">足迹</text>
            <text class="quad-sub">{{quadFootprint.sub}}</text>
          </view>
          <image class="quad-thumb" src="{{quadFootprint.image}}" mode="aspectFill"></image>
        </view>
        <text class="quad-action">去查看</text>
      </view>
      <view class="quad-cell" bindtap="onQuadRecentTap" hover-class="quad-cell-hover">
        <view class="quad-cell-main">
          <view class="quad-texts">
            <text class="quad-title">{{quadRecent.title}}</text>
            <text class="quad-sub">{{quadRecent.sub}}</text>
          </view>
          <image class="quad-thumb" src="{{quadRecent.image}}" mode="aspectFill"></image>
        </view>
        <text class="quad-action">去查看</text>
      </view>
    </view>
  </view>

  <!-- ══ 我的功能 ══ -->
  <view class="section-card func-card">
    <view class="func-row" bindtap="goAddress" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
      <text class="func-label">地址管理</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider"></view>
    <view class="func-row" bindtap="goFavoritesFootprints" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/star.svg" mode="aspectFit"></image>
      <text class="func-label">足迹收藏</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider"></view>
    <view class="func-row" bindtap="goCoupons" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/tag.svg" mode="aspectFit"></image>
      <text class="func-label">优惠券</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider"></view>
    <view class="func-row" bindtap="goPoints" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/gift.svg" mode="aspectFit"></image>
      <text class="func-label">积分中心</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider" wx:if="{{showBusinessCenter}}"></view>
    <view class="func-row" wx:if="{{showBusinessCenter}}" bindtap="goBusinessCenter" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/shopping-bag.svg" mode="aspectFit"></image>
      <text class="func-label">商务中心</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider" wx:if="{{isLoggedIn}}"></view>
    <view class="func-row" wx:if="{{isLoggedIn}}" bindtap="goPortalPassword" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/settings.svg" mode="aspectFit"></image>
      <text class="func-label">代理商服务</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider" wx:if="{{isLoggedIn}}"></view>
    <view class="func-row" wx:if="{{isLoggedIn}}" bindtap="goStationsMap" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/map-pin.svg" mode="aspectFit"></image>
      <text class="func-label">服务站点地图</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider" wx:if="{{showPickupVerify}}"></view>
    <view class="func-row" wx:if="{{showPickupVerify}}" bindtap="goPickupVerify" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/package.svg" mode="aspectFit"></image>
      <text class="func-label">自提核销（店员）</text>
      <text class="func-arrow">›</text>
    </view>
    <view class="func-divider" wx:if="{{isLoggedIn}}"></view>
    <view class="func-row" wx:if="{{isLoggedIn}}" bindtap="goInvitePoster" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/share.svg" mode="aspectFit"></image>
      <text class="func-label">邀请海报</text>
      <text class="func-arrow">›</text>
    </view>
  </view>

  <view class="section-card func-card">
    <view class="func-row" bindtap="goPrivacy" hover-class="row-press">
      <image class="func-icon" src="/assets/icons/shield.svg" mode="aspectFit"></image>
      <text class="func-label">隐私协议</text>
      <text class="func-arrow">›</text>
    </view>
  </view>

  <view class="safe-area-bottom"></view>

  <view class="avatar-pick-mask" wx:if="{{showAvatarPickSheet}}" catchtap="onCancelAvatarPick">
    <view class="avatar-pick-panel" catchtap="stopP">
      <text class="avatar-pick-title">更换头像</text>
      <text class="avatar-pick-tip">点击下方按钮，从相册或微信头像中选择</text>
      <button class="avatar-pick-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">选择头像</button>
      <view class="avatar-pick-cancel" bindtap="onCancelAvatarPick">取消</view>
    </view>
  </view>

  <view class="nick-modal-mask" wx:if="{{showNicknameModal}}" catchtap="onCancelNickname">
    <view class="nick-modal" catchtap="stopP">
      <text class="nick-modal-title">修改昵称</text>
      <input
        class="nick-modal-input"
        type="nickname"
        placeholder="输入昵称或使用微信昵称"
        maxlength="32"
        value="{{newNickname}}"
        bindinput="onNicknameInput"
      />
      <view class="nick-modal-actions">
        <view class="nick-modal-btn nick-modal-btn-cancel" bindtap="onCancelNickname">取消</view>
        <view class="nick-modal-btn nick-modal-btn-ok" bindtap="onConfirmNickname">保存</view>
      </view>
    </view>
  </view>

  <light-tip-modal
    show="{{lightTipShow}}"
    title="{{lightTipTitle}}"
    content="{{lightTipContent}}"
    bind:close="onLightTipClose"
  />
</view>
