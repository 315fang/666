.wrap {
  padding: 24rpx;
  min-height: 100vh;
  background: #fafaf9;
  box-sizing: border-box;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.tip {
  font-size: 26rpx;
  color: #57534e;
  line-height: 1.6;
  display: block;
  margin-bottom: 28rpx;
}
.btn {
  background: #1c1917;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.btn.secondary {
  background: #e7e5e4;
  color: #1c1917;
  margin-top: 20rpx;
}
.result {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
}
.row {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}
.k {
  font-size: 24rpx;
  color: #78716c;
  margin-bottom: 8rpx;
}
.v {
  font-size: 30rpx;
  color: #1c1917;
  word-break: break-all;
}
.mono {
  font-family: ui-monospace, monospace;
}
.hint {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #a8a29e;
}
