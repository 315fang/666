/* ══ 整体背景 ══ */
.container {
  min-height: 100vh;
  background: #f2f3f5;
  padding-bottom: env(safe-area-inset-bottom, 32rpx);
}

/* ══ 顶部 Hero（头图 + 蒙层） ══ */
.hero-zone {
  position: relative;
  padding: 0 0 20rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  left: 0; right: 0; top: 0; bottom: 0;
  /* 现代高级质感：深蓝色背景渐变 */
  background:
    radial-gradient(100% 120% at 80% 0%, rgba(96, 165, 250, 0.4) 0%, transparent 60%),
    linear-gradient(135deg, #2563EB 0%, #0F172A 100%);
}

.hero-inner {
  position: relative;
  z-index: 1;
  padding: 0 28rpx 0;
}

/* 顶栏控制 */
.hero-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
}

.hero-toolbar-left {
  flex: 1;
}

.hero-toolbar-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-top-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  position: relative;
}

.hero-top-btn-hover {
  opacity: 0.8;
}

.hero-top-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.95;
  filter: brightness(0) invert(1); /* 图标反相为白色以对比深色背景 */
}

/* 顶部工具栏图标 */

.hero-top-text {
  font-size: 20rpx;
  color: #F8FAFC; /* 改为白色 */
  font-weight: 500;
}

/* 个人信息 */
.hero-profile-wrap {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding-bottom: 30rpx;
}

.hero-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  flex-shrink: 0;
}

.hero-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.hero-nickname {
  font-size: 38rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.hero-profile-edit {
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

.hero-tags-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.hero-tag-vip {
  background: linear-gradient(to right, #614633, #382920);
  color: #FFE6CD;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx 0 0 6rpx;
  font-weight: 600;
}

.hero-tag-level {
  background: #EEDEC1;
  color: #382920;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 6rpx 6rpx 0;
  font-weight: 500;
  margin-left: -8rpx;
}

.hero-tag-sub {
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #E2E8F0;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

/* 未登录提示 */
.hero-login-hint {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
  background: rgba(255,255,255,0.25);
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  align-self: center;
}

/* 核心资产卡 VIP Card */
.vip-card {
  background: #4b3c31; /* 深褐色 */
  border-radius: 24rpx;
  padding: 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  margin-bottom: 0rpx;
}

.vip-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 0 24rpx;
  position: relative;
}

.vip-card-saved {
  display: flex;
  align-items: baseline;
  color: #F8F3EC;
}

.saved-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.saved-val {
  font-size: 32rpx;
  font-weight: 600;
  margin: 0 4rpx;
}

.saved-arrow {
  font-size: 24rpx;
  opacity: 0.6;
  margin-left: 4rpx;
}

/* 右上悬浮促销区 */
.vip-card-promo {
  display: flex;
  align-items: center;
  background: #FAFAFA;
  border-radius: 12rpx 0 0 12rpx;
  padding: 12rpx 16rpx;
  gap: 16rpx;
}

.promo-block {
  display: flex;
  flex-direction: column;
}

.promo-title {
  font-size: 24rpx;
  color: #4C4B47;
  font-weight: 600;
}

.promo-subtitle {
  font-size: 20rpx;
  color: #8D8B88;
  margin-top: 4rpx;
}

.promo-highlight {
  color: #E25631;
}

.promo-arrow {
  color: #C0C0C0;
  font-size: 20rpx;
}

.promo-divider {
  width: 1rpx;
  height: 40rpx;
  background: #E8E8E8;
}

.promo-btn-red {
  background: #E53920;
  color: #fff;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: baseline;
  position: relative;
}

.promo-currency {
  font-size: 20rpx;
}

.promo-amount {
  font-size: 32rpx;
  font-weight: 600;
  margin-left: 2rpx;
}

.promo-dot {
  width: 6rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
}

/* 资产数据横排矩阵 */
.vip-assets-panel {
  display: flex;
  align-items: stretch;
  padding: 24rpx 0 16rpx 24rpx;
}

.vip-assets-matrix {
  flex: 1;
  display: flex;
  justify-content: space-between;
  padding-right: 20rpx;
}

.vip-asset-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.vip-asset-title {
  font-size: 22rpx;
  color: #AA9F95;
}

.vip-asset-value {
  font-size: 34rpx;
  color: #F8F3EC;
  font-weight: 600;
  display: flex;
  align-items: baseline;
}

.vip-asset-sym {
  font-size: 20rpx;
  margin-right: 4rpx;
  font-weight: normal;
}

.vip-asset-item:nth-child(2) .vip-asset-sym {
  margin-right: 0;
  margin-left: 2rpx;
}

.vip-asset-all {
  width: 44rpx;
  padding: 0 20rpx 0 16rpx;
  border-left: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #AA9F95;
  font-size: 20rpx;
  position: relative;
}

.all-text {
  text-align: center;
  line-height: 1.2;
}

.all-arrow {
  position: absolute;
  right: 4rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
}

/* 底部功能横幅 */
.vip-card-banner {
  background: #42352B; /* 稍微深一点的底色 */
  border-radius: 0 0 24rpx 24rpx;
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px dotted rgba(255, 255, 255, 0.1);
}

.banner-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.banner-icon-wrap {
  background: #E1C19C;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-icon-text {
  color: #614633;
  font-size: 22rpx;
  font-weight: bold;
}

.banner-desc {
  color: #F8F3EC;
  font-size: 22rpx;
}

.banner-btn {
  background: #F4E2C7;
  color: #53402E;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

/* ══ 通用 section-card ══ */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(30, 74, 109, 0.06);
}

.section-card--orders {
  margin-top: 20rpx;
}

/* ══ 四宫格 ══ */
.quad-card {
  padding: 8rpx 0 16rpx;
}

.quad-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 12rpx 4rpx;
}

.quad-cell {
  width: 50%;
  box-sizing: border-box;
  padding: 14rpx 12rpx 18rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.quad-cell:nth-child(odd) {
  border-right: 1rpx solid #f1f5f9;
}

.quad-cell:nth-last-child(-n + 2) {
  border-bottom: none;
}

.quad-cell-hover {
  background: #f8fafc;
}

.quad-cell-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-height: 100rpx;
}

.quad-texts {
  flex: 1;
  min-width: 0;
}

.quad-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.quad-sub {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quad-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
  flex-shrink: 0;
}

.quad-action {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #c6a16e;
  font-weight: 500;
}

/* ══ 订单区 ══ */
.section-row-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 28rpx 20rpx;
}

.section-row-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
}

.section-row-more {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #64748B;
  gap: 2rpx;
}

.arrow-icon {
  font-size: 24rpx;
  color: #94A3B8;
}

.order-tabs {
  display: flex;
  padding: 0 12rpx 12rpx;
}

/* 订单卡片内：售后相关 · 联系客服 */
.order-aftersale-bar {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  padding: 20rpx 22rpx;
  background: linear-gradient(135deg, #F0F7FB 0%, #E8F4F0 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(30, 74, 109, 0.08);
}

.order-aftersale-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  opacity: 0.75;
}

.order-aftersale-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.order-aftersale-hint {
  flex: 1;
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #64748B;
}

.order-aftersale-arrow {
  font-size: 28rpx;
  color: #94A3B8;
}

.order-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.order-tab-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E8F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.order-tab-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.7;
}

.order-tab-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  padding: 0 6rpx;
  background: #e11d48;
  color: #fff;
  font-size: 18rpx;
  border-radius: 999rpx;
  text-align: center;
}

.order-tab-text {
  font-size: 22rpx;
  color: #475569;
}

/* ══ 功能行列式 ══ */
.func-card {
  margin-bottom: 16rpx;
}

.func-row {
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 20rpx;
  background: transparent;
}

.func-row.row-press {
  background: #E8F2F7;
}

.func-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.65;
  flex-shrink: 0;
}

.func-label {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
}

.func-arrow {
  font-size: 32rpx;
  color: #94A3B8;
}

.func-divider {
  height: 1rpx;
  background: #E2E8F0;
  margin: 0 28rpx;
}

/* ══ 规则卡片 ══ */
.rule-card {
  margin-bottom: 16rpx;
}

.rule-summary {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: #64748B;
  padding: 0 28rpx 24rpx;
}

/* ══ 底部安全区 ══ */
.safe-area-bottom {
  height: env(safe-area-inset-bottom, 40rpx);
  min-height: 40rpx;
}

/* ══ 选择头像弹层 ══ */
.avatar-pick-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  box-sizing: border-box;
}

.avatar-pick-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx 40rpx calc(28rpx + env(safe-area-inset-bottom, 0));
  box-shadow: 0 -8rpx 40rpx rgba(30, 74, 109, 0.12);
}

.avatar-pick-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  text-align: center;
  margin-bottom: 12rpx;
}

.avatar-pick-tip {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

.avatar-pick-btn {
  width: 100% !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  padding: 0 !important;
  margin: 0 0 20rpx 0 !important;
  background: linear-gradient(135deg, #c6a16e 0%, #9a7348 100%) !important;
  color: #fffdf8 !important;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 999rpx !important;
  border: none !important;
}

.avatar-pick-btn::after {
  border: none !important;
}

.avatar-pick-cancel {
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  padding: 16rpx 0;
}

/* ══ 修改昵称弹层 ══ */
.nick-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.nick-modal {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  box-shadow: 0 24rpx 64rpx rgba(30, 74, 109, 0.15);
}

.nick-modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 28rpx;
}

.nick-modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #0f172a;
  background: #e8f2f7;
  border-radius: 16rpx;
  margin-bottom: 36rpx;
}

.nick-modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.nick-modal-btn {
  min-width: 160rpx;
  text-align: center;
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.nick-modal-btn-cancel {
  color: #475569;
  background: #e2e8f0;
}

.nick-modal-btn-ok {
  color: #fffdf8;
  background: linear-gradient(135deg, #c6a16e 0%, #9a7348 100%);
}
