<!--pages/user/member-levels.wxml - 会员等级晋升路线-->
<view class="page">
  <view class="state-wrap" wx:if="{{loading}}">
    <text class="state-text">加载中…</text>
  </view>
  <view class="state-wrap" wx:elif="{{loadError}}">
    <text class="state-text">加载失败</text>
    <view class="retry-btn" bindtap="onRetry">重试</view>
  </view>

  <scroll-view scroll-y class="scroll" wx:else>

    <!-- 顶部进度卡 -->
    <view class="hero-card">
      <view class="hero-top">
        <view class="hero-title-row">
          <text class="hero-tier-name">{{currentTierName || '普通会员'}}</text>
          <text class="hero-growth-label">成长值</text>
          <text class="hero-growth-val">{{growthValue}}</text>
        </view>
      </view>
      <view class="progress-wrap">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{barPercent}}%"></view>
        </view>
        <view class="progress-labels">
          <text class="progress-min">{{currentTierMin}}</text>
          <text class="progress-next-val" wx:if="{{nextTierMin != null}}">{{nextTierMin}}</text>
        </view>
      </view>
      <text class="hero-sub" wx:if="{{subLine}}">{{subLine}}</text>
      <text class="hero-sub hero-sub-max" wx:else>已达到最高等级</text>
    </view>

    <!-- 等级阶梯列表 -->
    <view class="section-title-wrap">
      <text class="section-title">晋升路线</text>
    </view>

    <view class="tier-list">
      <view
        wx:for="{{growthTiers}}"
        wx:key="min"
        class="tier-row {{item.active ? 'tier-row-active' : ''}} {{item.passed ? 'tier-row-passed' : ''}}"
      >
        <view class="tier-left">
          <view class="tier-dot {{item.active ? 'dot-active' : ''}} {{item.passed ? 'dot-passed' : ''}}">
            <text class="dot-check" wx:if="{{item.passed}}">✓</text>
          </view>
          <view class="tier-line" wx:if="{{!item.isLast}}"></view>
        </view>
        <view class="tier-body">
          <view class="tier-head-row">
            <text class="tier-name">{{item.name || '档位'}}</text>
            <view class="tier-tag-current" wx:if="{{item.active}}">当前</view>
            <view class="tier-tag-done" wx:if="{{item.passed && !item.active}}">已达成</view>
          </view>
          <text class="tier-threshold">成长值 ≥ {{item.min}}</text>
          <text class="tier-discount">购物折扣 {{item.discountText}}</text>
          <text class="tier-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="footer-tip">
      <text>成长值由消费累积，折扣实时按当前成长值档位计算</text>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>
</view>
