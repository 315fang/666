.page {
  min-height: 100vh;
  background: #fafaf9;
  padding-bottom: env(safe-area-inset-bottom);
}

.head-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 28rpx 8rpx;
}

.clear-all {
  font-size: 24rpx;
  color: #b98b58;
  flex-shrink: 0;
  padding: 4rpx 8rpx;
}

.list-scroll {
  height: calc(100vh - 120rpx);
  padding: 0 24rpx 32rpx;
  box-sizing: border-box;
}

.row {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(28, 25, 23, 0.06);
}

.thumb {
  width: 144rpx;
  height: 144rpx;
  border-radius: 12rpx;
  background: #f2eeea;
  flex-shrink: 0;
}

.row-main {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1917;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.row-meta {
  font-size: 26rpx;
  color: #b98b58;
  font-weight: 600;
}

.row-time {
  font-size: 22rpx;
  color: #9a8b7c;
}

.row-del {
  padding: 16rpx;
  flex-shrink: 0;
}

.del-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.45;
}

.empty {
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #6a5f55;
}
