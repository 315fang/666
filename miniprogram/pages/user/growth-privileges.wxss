.page {
  min-height: 100vh;
  background: #f5f2ee;
}

.scroll {
  height: 100vh;
}

.state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.state-text {
  font-size: 28rpx;
  color: #78716c;
}

.retry-btn {
  margin-top: 24rpx;
  font-size: 26rpx;
}

.hero {
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(140deg, #2b2018 0%, #1a1511 100%);
  color: rgba(255, 240, 220, 0.92);
}

.hero-label {
  font-size: 24rpx;
  opacity: 0.75;
  display: block;
}

.hero-value {
  font-size: 56rpx;
  font-weight: 700;
  display: block;
  margin-top: 12rpx;
}

.hero-hint {
  font-size: 22rpx;
  opacity: 0.6;
  line-height: 1.5;
  display: block;
  margin-top: 20rpx;
}

.section {
  margin: 0 24rpx 32rpx;
}

.section-muted {
  opacity: 0.95;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
  display: block;
}

.section-desc {
  font-size: 24rpx;
  color: #78716c;
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  line-height: 1.45;
  display: block;
}

.tier-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(122, 108, 94, 0.12);
}

.tier-active {
  border-color: #c6a16e;
  box-shadow: 0 8rpx 24rpx rgba(198, 161, 110, 0.15);
}

.tier-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.tier-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1917;
}

.tier-tag {
  font-size: 20rpx;
  color: #b45309;
  background: rgba(180, 83, 9, 0.12);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.tier-meta {
  font-size: 24rpx;
  color: #57534e;
  margin-top: 12rpx;
  display: block;
}

.tier-desc {
  font-size: 24rpx;
  color: #78716c;
  margin-top: 10rpx;
  display: block;
}

.perks {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.perk {
  font-size: 22rpx;
  color: #57534e;
  background: rgba(122, 108, 94, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.member-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.member-lv {
  font-size: 24rpx;
  color: #a8a29e;
  width: 100rpx;
}

.member-name {
  font-size: 26rpx;
  color: #44403c;
}

.bottom-space {
  height: 48rpx;
}
