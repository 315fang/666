<view class="page">
  <view class="head-row" wx:if="{{items.length > 0}}">
    <text class="clear-all" bindtap="onClearTap">清空</text>
  </view>

  <view class="empty" wx:if="{{items.length === 0}}">
    <text class="empty-text">暂无浏览记录</text>
  </view>

  <scroll-view wx:else scroll-y class="list-scroll" enhanced show-scrollbar="{{false}}">
    <view
      class="row"
      wx:for="{{items}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onOpenDetail"
    >
      <image class="thumb" src="{{item.image || '/assets/images/default-avatar.svg'}}" mode="aspectFill" />
      <view class="row-main">
        <text class="row-title">{{item.name || '商品'}}</text>
        <text class="row-meta" wx:if="{{item.price}}">¥{{item.price}}</text>
        <text class="row-time">{{item.timeText}}</text>
      </view>
      <view class="row-del" catchtap="onRemove" data-id="{{item.id}}">
        <image class="del-icon" src="/assets/icons/trash.svg" mode="aspectFit" />
      </view>
    </view>
  </scroll-view>
</view>
