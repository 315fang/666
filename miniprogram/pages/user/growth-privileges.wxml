<view class="page">
  <view class="state" wx:if="{{loading}}">
    <text class="state-text">加载中…</text>
  </view>
  <view class="state" wx:elif="{{loadError}}">
    <text class="state-text">加载失败</text>
    <button class="retry-btn" bindtap="onRetry">重试</button>
  </view>
  <scroll-view scroll-y class="scroll" wx:else>
    <view class="hero">
      <text class="hero-label">当前成长值</text>
      <text class="hero-value">{{growthValue}}</text>
      <text class="hero-hint">购物折扣档位与积分中心展示档位，均与后台配置的成长值门槛挂钩</text>
    </view>

    <view class="section">
      <text class="section-title">消费成长值 → 购物折扣（复购价）</text>
      <text class="section-desc">以下数据来自后台「会员与成长值 → 成长规则」中的成长值折扣阶梯</text>
      <view
        wx:for="{{growthTiers}}"
        wx:for-index="gi"
        wx:key="gi"
        class="tier-card {{item.active ? 'tier-active' : ''}}"
      >
        <view class="tier-head">
          <text class="tier-name">{{item.name || '档位'}}</text>
          <text wx:if="{{item.active}}" class="tier-tag">当前区间</text>
        </view>
        <text class="tier-meta">成长值 ≥ {{item.min}} · 折扣系数 {{item.discount}}</text>
        <text class="tier-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
      </view>
    </view>

    <view class="section" wx:if="{{pointLevels.length}}">
      <text class="section-title">成长值档位 → 会员礼遇名称（积分中心展示）</text>
      <text class="section-desc">特权文案在后台「会员与成长值 → 成长值等级」中维护</text>
      <view
        wx:for="{{pointLevels}}"
        wx:key="level"
        class="tier-card {{item.level === currentPointLevel ? 'tier-active' : ''}}"
      >
        <view class="tier-head">
          <text class="tier-name">{{item.name}}（Lv.{{item.level}}）</text>
          <text wx:if="{{item.level === currentPointLevel}}" class="tier-tag">当前展示档</text>
        </view>
        <text class="tier-meta">成长值 ≥ {{item.min}}{{item.max != null && item.max !== '' ? ' ，上限 ' + item.max : ' 起'}}</text>
        <view class="perks" wx:if="{{item.perks && item.perks.length}}">
          <text class="perk" wx:for="{{item.perks}}" wx:key="*this" wx:for-item="p">{{p}}</text>
        </view>
      </view>
    </view>

    <view class="section section-muted" wx:if="{{memberLevels.length}}">
      <text class="section-title">代理 / 会员等级（分销体系）</text>
      <text class="section-desc">与成长值相互独立，详见各等级说明</text>
      <view wx:for="{{memberLevels}}" wx:key="level" class="member-row">
        <text class="member-lv">Lv.{{item.level}}</text>
        <text class="member-name">{{item.name}}</text>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>
</view>
