@import "./footprints.wxss";

.page-combo {
  min-height: 100vh;
  background: #fafaf9;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-top {
  display: flex;
  flex-direction: row;
  margin: 0 24rpx;
  padding: 8rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 20rpx rgba(28, 25, 23, 0.06);
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #78716c;
  padding: 20rpx 12rpx;
  border-radius: 999rpx;
  transition: color 0.2s, background 0.2s;
}

.tab-active {
  color: #1c1917;
  font-weight: 600;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(198, 161, 110, 0.2);
}

.panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.panel .list-scroll {
  height: calc(100vh - 200rpx);
  padding: 0 24rpx 32rpx;
  box-sizing: border-box;
}

.panel .head-row {
  flex-shrink: 0;
}
