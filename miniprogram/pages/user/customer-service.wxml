<view class="service-page">
  <view class="hero-panel">
    <view class="hero-bg-orb hero-bg-orb-left"></view>
    <view class="hero-bg-orb hero-bg-orb-right"></view>

    <view class="hero-topbar">
      <view class="hero-topbar-left">
        <text class="hero-title">专属客服</text>
        <text class="hero-subtitle">{{brandName}} 专属客服顾问为您服务</text>
      </view>
      <view class="hero-hours-pill">
        <text>服务时段 {{customerServiceHours}}</text>
      </view>
    </view>

    <view class="hero-main-card">
      <view class="hero-avatar">
        <image class="hero-avatar-icon" src="/assets/icons/headphones.svg" mode="aspectFit"></image>
      </view>

      <view class="hero-main-copy">
        <view class="hero-badge-row">
          <text class="hero-name">专属服务顾问</text>
          <text class="hero-badge">在线响应</text>
        </view>
        <text class="hero-desc">可处理产品咨询、售后问题与服务引导。页面只保留一个主联系区，不再拆多模块。</text>

        <view class="hero-contact-line" wx:if="{{primaryContactText}}">
          <text class="hero-contact-label">{{primaryContactLabel}}</text>
          <text class="hero-contact-value">{{primaryContactText}}</text>
        </view>

        <view class="hero-action-row">
          <view class="hero-primary-btn" bindtap="onPrimaryContactTap">{{primaryActionText}}</view>
          <view class="hero-secondary-btn" bindtap="onSecondaryContactTap" wx:if="{{secondaryActionText}}">{{secondaryActionText}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="faq-panel">
    <view class="faq-head">
      <text class="faq-title">常见问题</text>
      <text class="faq-subtitle">先看处理建议，需要时再联系人工</text>
    </view>

    <view class="faq-list">
      <view class="faq-item" wx:for="{{faqList}}" wx:key="question" bindtap="onFaqTap" data-index="{{index}}">
        <view class="faq-copy">
          <text class="faq-question">{{item.question}}</text>
          <text class="faq-preview">{{item.preview}}</text>
        </view>
        <text class="faq-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="empty-panel" wx:if="{{loaded && !hasAny}}">
    <text class="empty-title">暂未配置客服通道</text>
    <text class="empty-desc">请在后台「系统设置 → 小程序配置 → 客服通道」补充电话、微信号或二维码。</text>
  </view>
</view>
