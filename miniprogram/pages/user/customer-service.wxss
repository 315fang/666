.wrap {
  padding: 24rpx;
  min-height: 100vh;
  background: #fafaf9;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.tip {
  font-size: 26rpx;
  color: #57534e;
  line-height: 1.6;
}

.phone-card {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx 16rpx;
}

.phone-card-hover {
  opacity: 0.92;
}

.label {
  width: 100%;
  font-size: 24rpx;
  color: #78716c;
}

.value {
  flex: 1;
  font-size: 32rpx;
  color: #1c1917;
  font-weight: 500;
}

.action {
  font-size: 26rpx;
  color: #2E6B94;
}

.qr-card .label {
  display: block;
  margin-bottom: 12rpx;
}

.qr-hint {
  display: block;
  font-size: 24rpx;
  color: #a8a29e;
  margin-bottom: 20rpx;
}

.qr-img {
  width: 100%;
  max-width: 480rpx;
  display: block;
  border-radius: 12rpx;
}
