/** pages/category/category.wxss - 问兰镜像分类页重构 **/

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #FFFFFF;
  overflow: hidden;
}

/* 1. 顶部 Logo + 搜索栏 (复用首页风格) */
.page-header {
  background: #FFFFFF;
  padding: 0 32rpx 10rpx; /* 减少底部内边距 */
  border-bottom: 1rpx solid #F5F5F5;
}

.header-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-logo {
  width: 44rpx;
  height: 44rpx;
}

.nav-divider {
  width: 2rpx;
  height: 32rpx;
  background: #E5E5E5;
}

.nav-search-bar {
  flex: 1;
  height: 64rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 12rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

/* 2. 主体分类内容 */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧侧边栏 */
.left-sidebar {
  width: 180rpx;
  background: #F8F8F8;
  height: 100%;
}

.sidebar-item {
  padding: 32rpx 20rpx; /* 稍微减小间距 */
  text-align: center;
  transition: all 0.3s ease;
}

.sidebar-item.active {
  background: #FFFFFF;
  position: relative;
}

.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #D44E4E; /* 品牌红 */
}

.sidebar-text {
  font-size: 26rpx;
  color: #999999;
  transition: color 0.3s;
}

.sidebar-item.active .sidebar-text {
  color: #333333;
  font-weight: 600;
}

/* 右侧产品列表 */
.right-content {
  flex: 1;
  height: 100%;
  background: #FFFFFF;
  padding: 0 30rpx;
}

.cat-section {
  padding-bottom: 40rpx;
}

.cat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0 20rpx; /* 减小间距 */
  position: sticky;
  top: 0;
  background: #FFFFFF;
  z-index: 10;
}

.cat-title-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.cat-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.3;
}

/* 产品卡片样式 */
.product-card-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.product-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #FAFAFA;
}

.card-img {
  width: 200rpx;
  height: 200rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-name {
  font-size: 34rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.card-btn-wrap {
  display: flex;
}

.card-btn {
  background: #D44E4E; /* 品牌红 */
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-weight: 500;
}

/* 底部状态 */
.loading-footer {
  padding: 40rpx 0;
  text-align: center;
}

.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #F3F3F3;
  border-top: 3rpx solid #D44E4E;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.empty-state {
  padding: 100rpx 0;
  text-align: center;
  color: #CCCCCC;
  font-size: 26rpx;
}

.bottom-spacer {
  height: 180rpx;
}

/* 3. 底部购物车栏 */
.quick-cart-bar {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  height: 100rpx;
  background: #FFFFFF;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  padding: 0 10rpx 0 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.cart-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cart-icon-wrap {
  position: relative;
}

.cart-icon {
  width: 50rpx;
  height: 50rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #D44E4E;
  color: #FFFFFF;
  font-size: 18rpx;
  min-width: 30rpx;
  height: 30rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FFFFFF;
}

.cart-price {
  display: flex;
  align-items: baseline;
  color: #333333;
}

.currency {
  font-size: 24rpx;
  font-weight: 600;
}

.amount {
  font-size: 36rpx;
  font-weight: 700;
}

.checkout-btn {
  background: #E0E0E0;
  color: #FFFFFF;
  padding: 0 50rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.checkout-btn.active {
  background: #1A1A1A;
}
