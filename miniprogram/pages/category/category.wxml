<!--pages/category/category.wxml - 问兰镜像分类页重构 -->
<view class="container">
  
  <!-- 1. 顶部 Logo + 搜索栏 (复用首页风格) -->
  <view class="page-header" style="padding-top: {{statusBarHeight}}px">
    <view class="header-inner">
      <image class="nav-logo" src="/assets/icons/home.svg" mode="aspectFit"></image>
      <view class="nav-divider"></view>
      <view class="nav-search-bar" bindtap="onSearchTap">
        <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
        <text class="search-placeholder">素颜三部曲</text>
      </view>
    </view>
  </view>

  <!-- 2. 主体分类内容 -->
  <view class="main-content">
    <!-- 左侧侧边栏 -->
    <scroll-view 
      class="left-sidebar" 
      scroll-y 
      show-scrollbar="{{false}}" 
      scroll-into-view="{{leftToView}}" 
      scroll-with-animation
    >
      <view 
        class="sidebar-item {{currentCategory === item.id ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id" 
        id="left-{{item.id}}"
        bindtap="onCategoryTap" 
        data-id="{{item.id}}"
      >
        <text class="sidebar-text">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧产品列表 -->
    <scroll-view 
      class="right-content" 
      scroll-y 
      scroll-into-view="{{toView}}" 
      scroll-with-animation
      bindscroll="onRightScroll"
    >
      <view 
        class="cat-section" 
        wx:for="{{categories}}" 
        wx:key="id" 
        id="cat-{{item.id}}"
      >
        <!-- 当前分类标题 -->
        <view class="cat-header">
          <text class="cat-title-text">{{item.name}}</text>
          <image class="cat-arrow" src="/assets/icons/arrow-right.svg" mode="aspectFit"></image>
        </view>
        
        <!-- 产品卡片列表 -->
        <view class="product-card-list">
          <view class="product-card" wx:for="{{item.products}}" wx:for-item="product" wx:key="id" bindtap="onProductTap" data-item="{{product}}">
            <image class="card-img" src="{{product.image}}" mode="aspectFit" lazy-load></image>
            <view class="card-info">
              <text class="card-name">{{product.name}}</text>
              <text class="card-desc">{{product.description || '尽享素颜之美'}}</text>
              <view class="card-btn-wrap">
                <view class="card-btn">了解更多 ></view>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 加载状态 -->
      <view class="loading-footer" wx:if="{{loading}}">
        <view class="spinner"></view>
      </view>
      
      <!-- 底部留白适配购物车栏 -->
      <view class="bottom-spacer"></view>
    </scroll-view>
  </view>

  <!-- 3. 底部快捷购物车栏 (保留功能，优化样式) -->
  <view class="quick-cart-bar">
    <view class="cart-left" bindtap="onToggleCartPopup">
      <view class="cart-icon-wrap">
        <image class="cart-icon" src="/assets/icons/shopping-bag.svg" mode="aspectFit"></image>
        <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
      </view>
      <view class="cart-price">
        <text class="currency">¥</text>
        <text class="amount">{{cartTotal}}</text>
      </view>
    </view>
    <view class="checkout-btn {{cartCount > 0 ? 'active' : ''}}" bindtap="onCheckout">
      <text>去结算</text>
    </view>
  </view>

  <!-- 4. 品牌动画组件 -->
  <brand-animation id="brandAnimation" fly-image="{{flyImage}}"></brand-animation>

</view>
