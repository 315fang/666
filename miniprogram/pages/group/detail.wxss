/** pages/group/detail.wxss **/
page { padding-bottom: 180rpx; }
.container { min-height: 100vh; background: #F8F3ED; }

/* Nav */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; background: #FFFFFF; border-bottom: 1rpx solid #EDE6DC; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.nav-placeholder { width: 56rpx; }

/* Loading */
.loading-wrap { padding: 0; }
.skeleton-block { background: #EDE6DC; border-radius: 24rpx; position: relative; overflow: hidden; }
.skeleton-block::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.45), transparent); animation: shimmer 1.6s infinite; }
@keyframes shimmer { 0% { left: -100%; } 100% { left: 100%; } }

/* Product card */
.product-card { margin: 20rpx 24rpx 0; background: #FFFFFF; border-radius: 24rpx; overflow: hidden; display: flex; box-shadow: 0 4rpx 16rpx rgba(40,32,24,0.06); }
.product-img { width: 200rpx; height: 200rpx; flex-shrink: 0; }
.product-info { flex: 1; padding: 24rpx 20rpx; display: flex; flex-direction: column; justify-content: space-between; gap: 12rpx; }
.title-row { display: flex; flex-direction: column; gap: 10rpx; }
.corn-tag { align-self: flex-start; font-size: 20rpx; font-weight: 800; color: #FFF; background: linear-gradient(135deg, #B95E46, #E8A074); padding: 6rpx 16rpx; border-radius: 8rpx; }
.product-name { font-size: 30rpx; font-weight: 700; color: #1A1A1A; line-height: 1.4; }
.product-name.line-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.detail-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.d-tag { font-size: 20rpx; color: #8D6A3F; background: rgba(185,139,88,0.12); padding: 4rpx 12rpx; border-radius: 8rpx; font-weight: 600; }
.d-tag-hot { color: #B95E46; background: rgba(185,94,70,0.12); font-weight: 700; }
.price-row { display: flex; gap: 32rpx; }
.group-price-wrap, .original-price-wrap { display: flex; flex-direction: column; gap: 4rpx; }
.price-label { font-size: 20rpx; color: #B0A396; }
.group-price { font-size: 40rpx; font-weight: 800; color: #B95E46; }
.original-price { font-size: 26rpx; font-weight: 400; color: #B0A396; text-decoration: line-through; }
.status-badge { display: inline-flex; padding: 8rpx 18rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 700; align-self: flex-start; }
.status-badge.status-open { background: rgba(185,139,88,0.1); color: #B98B58; }
.status-badge.status-success { background: rgba(16,185,129,0.1); color: #10B981; }
.status-badge.status-fail, .status-badge.status-cancelled { background: rgba(0,0,0,0.04); color: #B0A396; }

/* Progress card */
.progress-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 24rpx; padding: 28rpx 24rpx; box-shadow: 0 4rpx 16rpx rgba(40,32,24,0.06); }
.progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.progress-fraction { font-size: 28rpx; font-weight: 800; color: #B98B58; }
.progress-bar { width: 100%; height: 12rpx; background: #EDE6DC; border-radius: 6rpx; overflow: hidden; margin-bottom: 24rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #B98B58, #D4B896); border-radius: 6rpx; transition: width 0.5s; }

/* Member list */
.member-list { display: flex; gap: 24rpx; flex-wrap: wrap; margin-bottom: 20rpx; }
.member-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; width: 80rpx; }
.avatar-wrap { position: relative; }
.member-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #F8F3ED; border: 3rpx solid rgba(185,139,88,0.25); }
.owner-tag { position: absolute; top: -10rpx; right: -10rpx; font-size: 18rpx; font-weight: 700; color: #FFF; background: linear-gradient(135deg, #B98B58, #D4B896); padding: 2rpx 8rpx; border-radius: 8rpx; line-height: 1.4; }
.avatar-empty { width: 80rpx; height: 80rpx; border-radius: 50%; background: #F8F3ED; border: 3rpx dashed #D4B896; }
.member-name { font-size: 22rpx; color: #8D755A; text-align: center; width: 80rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.empty-name { color: #D4B896; }

/* Countdown */
.countdown-row { display: flex; align-items: center; gap: 8rpx; }
.icon-xs { width: 28rpx; height: 28rpx; opacity: 0.5; }
.countdown-text { font-size: 24rpx; color: #B98B58; font-weight: 600; }
.need-more-row { margin-top: 12rpx; }
.need-more-text { font-size: 24rpx; color: #B95E46; font-weight: 600; }

.rule-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 24rpx; padding: 28rpx 24rpx; box-shadow: 0 4rpx 16rpx rgba(40,32,24,0.06); }
.rule-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 16rpx; }
.rule-line { font-size: 24rpx; color: #666; line-height: 1.65; display: block; padding-left: 8rpx; }
.rule-dot { color: #B98B58; margin-right: 8rpx; }

.stock-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 24rpx; padding: 28rpx 24rpx; box-shadow: 0 4rpx 16rpx rgba(40,32,24,0.06); }
.stock-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.stock-title { font-size: 26rpx; font-weight: 700; color: #1A1A1A; }
.stock-sub { font-size: 22rpx; color: #B95E46; font-weight: 600; }
.stock-bar { width: 100%; height: 12rpx; background: #EDE6DC; border-radius: 6rpx; overflow: hidden; }
.stock-fill { height: 100%; background: linear-gradient(90deg, #B98B58, #D4B896); border-radius: 6rpx; max-width: 100%; }

.desc-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 24rpx; padding: 28rpx 24rpx; box-shadow: 0 4rpx 16rpx rgba(40,32,24,0.06); }
.desc-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 12rpx; }
.desc-body { font-size: 24rpx; color: #666; line-height: 1.6; }

.trust-bar { margin: 16rpx 24rpx 0; padding: 20rpx 24rpx; background: #FAFAFA; border-radius: 16rpx; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 12rpx; }
.trust-item { font-size: 22rpx; color: #999; }
.trust-sep { font-size: 22rpx; color: #E0E0E0; }

/* Success banner */
.success-banner { margin: 16rpx 24rpx 0; background: linear-gradient(135deg, #10B981, #34D399); border-radius: 24rpx; padding: 28rpx 24rpx; display: flex; align-items: center; gap: 20rpx; }
.success-icon { font-size: 48rpx; }
.success-text-wrap { display: flex; flex-direction: column; gap: 6rpx; }
.success-title { font-size: 32rpx; font-weight: 800; color: #FFF; }
.success-desc { font-size: 22rpx; color: rgba(255,255,255,0.85); }

/* Fail banner */
.fail-banner { margin: 16rpx 24rpx 0; background: rgba(0,0,0,0.03); border-radius: 24rpx; padding: 28rpx 24rpx; display: flex; flex-direction: column; gap: 8rpx; align-items: center; }
.fail-title { font-size: 28rpx; font-weight: 700; color: #B0A396; }
.fail-desc { font-size: 22rpx; color: #C5B8A8; }

/* Bottom bar */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: linear-gradient(180deg, rgba(255,255,255,0.95), #FFFFFF); border-top: 1rpx solid #EDE6DC; padding: 16rpx 24rpx 40rpx; display: flex; gap: 16rpx; align-items: stretch; z-index: 100; }
.btn-col-share { width: 200rpx; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4rpx; background: rgba(185,139,88,0.12); border-radius: 20rpx; padding: 12rpx 8rpx; }
.btn-col-share .btn-icon { width: 36rpx; height: 36rpx; opacity: 0.75; }
.btn-col-main { font-size: 24rpx; font-weight: 800; color: #8D6A3F; }
.btn-col-sub { font-size: 18rpx; color: #B98B58; }
.btn-join-wrap { flex: 1; min-width: 0; }
.btn-icon { width: 32rpx; height: 32rpx; opacity: 0.7; }
.btn-join { width: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, #B98B58, #D4B896); color: #FFFFFF; border-radius: 20rpx; min-height: 96rpx; padding: 14rpx 20rpx; box-sizing: border-box; }
.btn-line1 { font-size: 28rpx; font-weight: 800; line-height: 1.3; }
.btn-line2 { font-size: 20rpx; color: rgba(255,255,255,0.9); margin-top: 6rpx; line-height: 1.2; }
.btn-disabled { flex: 1; display: flex; align-items: center; justify-content: center; background: #EDE6DC; color: #B0A396; font-size: 26rpx; border-radius: 999rpx; min-height: 96rpx; }
.success-done { background: rgba(16,185,129,0.1); color: #10B981; }
