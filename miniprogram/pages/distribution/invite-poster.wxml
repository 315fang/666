<view class="container">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack">
        <image class="back-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"></image>
      </view>
      <text class="nav-title">邀请海报</text>
    </view>
  </view>

  <!-- 勿用 scroll-y：同层内 canvas 为原生组件，在 scroll-view 里常不随滚动，造成「海报钉住、说明在动」 -->
  <view class="page-body">
    <view class="poster-section">
      <view class="invite-code-row" wx:if="{{inviteCode}}">
        <text class="invite-code-label">我的邀请码</text>
        <text class="invite-code-value">{{inviteCode}}</text>
        <view class="invite-code-copy" bindtap="onCopyCode">复制</view>
      </view>

      <view class="poster-variant-bar">
        <view
          class="poster-variant-item {{posterVariant === item.id ? 'active' : ''}}"
          wx:for="{{posterVariantList}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onPosterVariantTap"
        >
          <text class="poster-variant-text">{{item.name}}</text>
        </view>
      </view>
      <view class="poster-variant-hint" wx:if="{{posterVariant === 'invite'}}">含头像、品牌、邀请小程序码与数字邀请码。</view>
      <view class="poster-variant-hint" wx:if="{{posterVariant === 'wxacode'}}">小程序码海报，扫码即可进入（文案对好友尽量简短）。</view>
      <view class="poster-variant-hint" wx:if="{{posterVariant === 'creative'}}">票根风格，适合朋友圈分享。</view>

      <view class="poster-preview-wrap">
        <!-- 生成完成后卸掉 canvas，避免原生层与 image 叠成「两张海报」 -->
        <canvas
          wx:if="{{!posterImagePath || posterGenerating}}"
          id="posterCanvas"
          type="2d"
          class="poster-canvas"
        ></canvas>
        <image
          wx:if="{{posterImagePath}}"
          class="poster-result-img"
          src="{{posterImagePath}}"
          mode="aspectFit"
          show-menu-by-longpress
        ></image>
        <view class="poster-generating" wx:if="{{posterGenerating && !posterImagePath}}">
          <view class="poster-spin"></view>
          <text class="poster-gen-text">海报生成中...</text>
        </view>
      </view>

      <view class="poster-actions">
        <view class="poster-action-btn poster-action-primary" bindtap="onGeneratePoster">
          <text class="poster-action-text">{{posterImagePath ? '重新生成' : '生成海报'}}</text>
        </view>
        <view class="poster-action-btn poster-action-secondary {{!posterImagePath ? 'btn-disabled' : ''}}" bindtap="onSavePoster">
          <text class="poster-action-text">保存到相册</text>
        </view>
      </view>

      <view class="poster-tip">长按海报可直接分享或保存</view>

      <view class="poster-tips-card">
        <block wx:if="{{posterVariant === 'invite'}}">
          <view class="ptip-item">
            <text class="ptip-dot">·</text>
            <text class="ptip-text">好友注册时可填写你的邀请码（绑定规则以平台为准）。</text>
          </view>
        </block>
        <block wx:if="{{posterVariant === 'wxacode'}}">
          <view class="ptip-item">
            <text class="ptip-dot">·</text>
            <text class="ptip-text">（仅您可见）海报对外仅展示简短欢迎语；邀请关系由扫码参数在后台处理。</text>
          </view>
          <view class="ptip-item">
            <text class="ptip-dot">·</text>
            <text class="ptip-text">开发版若扫码失败，请检查后端小程序码配置与体验版环境。</text>
          </view>
        </block>
        <block wx:if="{{posterVariant === 'creative'}}">
          <view class="ptip-item">
            <text class="ptip-dot">·</text>
            <text class="ptip-text">可与「邀请语」「官方码」版搭配使用。</text>
          </view>
        </block>
        <view class="ptip-item">
          <text class="ptip-dot">·</text>
          <text class="ptip-text">佣金与邀请规则以平台配置为准。</text>
        </view>
      </view>
    </view>
    <view class="page-bottom-spacer"></view>
  </view>
</view>
