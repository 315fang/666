<view class="page">
  <view class="hero-card">
    <text class="hero-kicker">货款补仓</text>
    <text class="hero-title">按商品成本口径快速入仓</text>
    <view class="hero-inline">
      <text class="hero-label">当前云仓库存</text>
      <text class="hero-value">{{currentStock}} 件</text>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <text class="section-title">选择进货商品</text>
      <text class="section-sub">优先选择当前有平台库存的商品</text>
    </view>

    <view class="product-list">
      <view class="product-card {{selectedProduct && selectedProduct.id === item.id ? 'selected' : ''}}" wx:for="{{products}}" wx:key="id" data-product="{{item}}" bindtap="onSelectProduct">
        <image class="product-img" src="{{item.image || '/assets/images/placeholder.svg'}}" mode="aspectFill"></image>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-price">代理商价 ¥{{item.agent_price}}</text>
          <text class="product-retail">零售价 ¥{{item.retail_price}}</text>
          <text class="product-stock">平台库存 {{item.stock}} 件</text>
        </view>
        <view class="select-chip" wx:if="{{selectedProduct && selectedProduct.id === item.id}}">已选</view>
      </view>

      <view class="empty-card" wx:if="{{products.length === 0}}">
        <text class="empty-title">暂无可进货的商品</text>
        <text class="empty-sub">等待平台补货后再来看看</text>
      </view>
    </view>
  </view>

  <view class="section-card" wx:if="{{selectedProduct}}">
    <view class="section-head compact">
      <text class="section-title">{{selectedProduct.name}}</text>
      <text class="section-sub">代理商价 ¥{{selectedProduct.agent_price}} / 件</text>
    </view>

    <view class="quantity-panel">
        <text class="quantity-label">进货数量</text>
        <view class="quantity-control">
          <view class="qty-btn" bindtap="onMinus">−</view>
        <input class="qty-input" type="number" value="{{qty || quantity}}" bindinput="onQuantityInput" />
        <view class="qty-btn" bindtap="onPlus">+</view>
      </view>
    </view>

    <view class="quick-row">
      <view class="quick-btn {{(qty || quantity) === 10 ? 'active' : ''}}" data-qty="10" bindtap="onQuickQty">10件</view>
      <view class="quick-btn {{(qty || quantity) === 50 ? 'active' : ''}}" data-qty="50" bindtap="onQuickQty">50件</view>
      <view class="quick-btn {{(qty || quantity) === 100 ? 'active' : ''}}" data-qty="100" bindtap="onQuickQty">100件</view>
      <view class="quick-btn {{(qty || quantity) === 200 ? 'active' : ''}}" data-qty="200" bindtap="onQuickQty">200件</view>
    </view>

    <view class="summary-box">
      <view>
        <text class="summary-label">进货总额</text>
        <text class="summary-note">确认后将直接计入当前库存</text>
      </view>
      <text class="summary-total">¥{{totalAmount}}</text>
    </view>
  </view>

  <view class="action-bar safe-bottom" wx:if="{{selectedProduct}}">
    <view class="action-summary">
      <text class="summary-qty">共 {{qty || quantity}} 件</text>
      <text class="summary-amount">¥{{totalAmount}}</text>
    </view>
    <view class="action-btn" bindtap="onConfirmRestock">确认采购</view>
  </view>
</view>
