page {
    background: #f6efe2;
}

.invite-page {
    min-height: 100vh;
    padding: 32rpx 24rpx 48rpx;
    background:
        radial-gradient(circle at top, rgba(205, 161, 92, 0.18), transparent 34%),
        linear-gradient(180deg, #f8f1e5 0%, #f5ede1 48%, #f1e5d4 100%);
    box-sizing: border-box;
}

.content-wrap,
.state-wrap,
.loading-wrap {
    display: flex;
    flex-direction: column;
    gap: 24rpx;
}

.hero-card,
.stats-card,
.info-card,
.loading-card {
    background: rgba(255, 252, 246, 0.94);
    border: 1rpx solid rgba(191, 151, 97, 0.18);
    border-radius: 28rpx;
    padding: 34rpx 30rpx;
    box-shadow: 0 18rpx 44rpx rgba(116, 83, 33, 0.08);
}

.hero-card.muted {
    margin-top: 160rpx;
}

.hero-eyebrow,
.card-tip {
    display: block;
    font-size: 22rpx;
    letter-spacing: 4rpx;
    color: #a2783e;
}

.hero-title,
.card-title,
.loading-title {
    display: block;
    font-size: 38rpx;
    line-height: 1.35;
    font-weight: 700;
    color: #3b2b1a;
    margin-top: 12rpx;
}

.hero-desc,
.loading-desc {
    display: block;
    font-size: 26rpx;
    line-height: 1.7;
    color: #7f6344;
    margin-top: 16rpx;
}

.card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20rpx;
    margin-bottom: 24rpx;
}

.stats-grid {
    display: flex;
    gap: 16rpx;
}

.stat-item {
    flex: 1;
    min-width: 0;
    padding: 24rpx 16rpx;
    border-radius: 22rpx;
    background: linear-gradient(180deg, #fff9f0 0%, #f8ecd8 100%);
    text-align: center;
}

.stat-value {
    display: block;
    font-size: 44rpx;
    font-weight: 700;
    color: #7f4a16;
}

.stat-label {
    display: block;
    margin-top: 10rpx;
    font-size: 22rpx;
    line-height: 1.5;
    color: #8e7559;
}

.bullet-list,
.steps {
    display: flex;
    flex-direction: column;
    gap: 18rpx;
}

.bullet-item,
.step-row {
    display: flex;
    gap: 18rpx;
    align-items: flex-start;
}

.bullet-dot {
    width: 14rpx;
    height: 14rpx;
    border-radius: 50%;
    background: #c48a43;
    margin-top: 14rpx;
    flex-shrink: 0;
}

.bullet-text,
.step-desc {
    flex: 1;
    font-size: 26rpx;
    line-height: 1.7;
    color: #6d5740;
}

.step-no {
    width: 72rpx;
    font-size: 26rpx;
    font-weight: 700;
    color: #a2783e;
    letter-spacing: 2rpx;
    flex-shrink: 0;
}

.step-body {
    flex: 1;
}

.step-title {
    display: block;
    font-size: 28rpx;
    font-weight: 700;
    color: #49301c;
    margin-bottom: 8rpx;
}

.action-area {
    display: flex;
    flex-direction: column;
    gap: 18rpx;
}

.primary-btn,
.secondary-btn,
.ghost-btn {
    width: 100%;
    height: 88rpx;
    line-height: 88rpx;
    border-radius: 999rpx;
    font-size: 28rpx;
    font-weight: 700;
    border: none;
}

.primary-btn,
.secondary-btn {
    background: linear-gradient(135deg, #d5a15b 0%, #bb7a34 100%);
    color: #fff7ef;
    box-shadow: 0 12rpx 24rpx rgba(167, 108, 40, 0.2);
}

.ghost-btn {
    background: rgba(255, 252, 246, 0.86);
    color: #8f6738;
    border: 1rpx solid rgba(191, 151, 97, 0.28);
}

.spinner {
    width: 60rpx;
    height: 60rpx;
    border-radius: 50%;
    border: 4rpx solid rgba(196, 138, 67, 0.16);
    border-top-color: #c48a43;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}
