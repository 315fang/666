.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #F4EFE8 0%, #FAF8F5 40%, #EEE9E2 100%);
  box-sizing: border-box;
}

/* ═══ 导航栏 ═══ */
.nav-bar {
  background: #2A1E14;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 200;
}
.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.8;
}
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #FFF8F0;
}
.nav-share {
  margin-left: auto;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.75;
}

/* ═══ 页面主体 ═══ */
.page-body {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}
.page-bottom-spacer {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
.poster-section {
  padding: 24rpx 24rpx 0;
}

/* ═══ 会员码栏 ═══ */
.member-code-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(37, 29, 21, 0.06);
}
.member-code-label {
  font-size: 22rpx;
  color: #9A8D80;
  white-space: nowrap;
}
.member-code-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E1710;
  letter-spacing: 4rpx;
  flex: 1;
}
.member-code-copy {
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #C8A258 0%, #9C6E32 100%);
  font-size: 24rpx;
  font-weight: 600;
  color: #FFF8F0;
  white-space: nowrap;
}

/* ═══ 变体标签栏 ═══ */
.poster-variant-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}
.poster-variant-item {
  flex: 1;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.88);
  border: 1.5rpx solid rgba(55, 48, 40, 0.08);
  transition: all 0.15s ease;
}
.poster-variant-item.active {
  background: #1C1510;
  border-color: #1C1510;
  box-shadow: 0 4rpx 12rpx rgba(28, 21, 16, 0.25);
}
.poster-variant-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #6B5D52;
}
.poster-variant-item.active .poster-variant-text {
  color: #FFF7EF;
}
.poster-variant-hint {
  font-size: 22rpx;
  color: #8A7A6E;
  line-height: 1.55;
  margin-bottom: 18rpx;
  padding: 0 4rpx;
}

/* ═══ 海报预览区（宽高比 5:8） ═══ */
.poster-preview-wrap {
  background: linear-gradient(160deg, #2A1E14 0%, #3D2C1C 100%);
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  width: 100%;
  padding-top: 160%;
  box-shadow: 0 16rpx 48rpx rgba(37, 29, 21, 0.22), 0 4rpx 16rpx rgba(37, 29, 21, 0.12);
}

.poster-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 生成中遮罩（覆盖在 canvas 上） */
.poster-generating-mask {
  position: absolute;
  inset: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: rgba(20, 13, 8, 0.72);
  backdrop-filter: blur(4px);
}
.poster-spin-ring {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.12);
  border-top-color: #C8A258;
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
.poster-gen-text {
  font-size: 26rpx;
  color: rgba(255, 248, 240, 0.75);
  letter-spacing: 1rpx;
}

.poster-result-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* ═══ 操作按钮 ═══ */
.poster-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}
.poster-action-btn {
  flex: 1;
  height: 82rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.poster-action-primary {
  background: linear-gradient(135deg, #C8A258 0%, #9C6E32 100%);
  box-shadow: 0 6rpx 20rpx rgba(158, 106, 42, 0.35);
}
.poster-action-outline {
  background: rgba(255, 255, 255, 0.92);
  border: 1.5rpx solid #DDD5CB;
}
.poster-action-outline .poster-action-text {
  color: #3A2E24;
}
.btn-disabled {
  opacity: 0.38;
  pointer-events: none;
}
.btn-loading {
  opacity: 0.7;
}
.poster-action-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFF8F0;
  letter-spacing: 0.5rpx;
}

/* ═══ 提示文字 ═══ */
.poster-tip {
  text-align: center;
  font-size: 22rpx;
  color: #B0A090;
  margin-top: 16rpx;
  margin-bottom: 22rpx;
}

/* ═══ 使用说明卡片 ═══ */
.poster-tips-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(37, 29, 21, 0.04);
}
.ptip-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 16rpx;
}
.ptip-item:last-child {
  margin-bottom: 0;
}
.ptip-dot {
  font-size: 28rpx;
  color: #C8A258;
  flex-shrink: 0;
  line-height: 1.55;
}
.ptip-text {
  font-size: 24rpx;
  color: #8A7A6E;
  line-height: 1.7;
}
