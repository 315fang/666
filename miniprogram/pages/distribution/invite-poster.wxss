.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F3ED 0%, #FAFAF8 30%, #F1EEEA 100%);
  box-sizing: border-box;
}

.nav-bar {
  background: #2E2218;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 200;
}
.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.85;
}
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #FFF8F0;
}

.page-body {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

.page-bottom-spacer {
  height: calc(60rpx + env(safe-area-inset-bottom));
}

.poster-section {
  padding: 24rpx;
}

.invite-code-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 29, 21, 0.05);
}
.invite-code-label {
  font-size: 22rpx;
  color: #9A8D80;
}
.invite-code-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E1710;
  letter-spacing: 3rpx;
  flex: 1;
  min-width: 200rpx;
}
.invite-code-copy {
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
  font-size: 24rpx;
  font-weight: 600;
  color: #FFF8F0;
}

.poster-variant-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.poster-variant-item {
  flex: 1;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(55, 48, 40, 0.08);
}
.poster-variant-item.active {
  background: #1C1917;
  border-color: #1C1917;
}
.poster-variant-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #6B5D52;
}
.poster-variant-item.active .poster-variant-text {
  color: #FFF7EF;
}

.poster-variant-hint {
  font-size: 22rpx;
  color: #8A7A6E;
  line-height: 1.55;
  margin-bottom: 18rpx;
  padding: 0 4rpx;
}

.poster-preview-wrap {
  background: linear-gradient(160deg, #2E2218 0%, #4A3527 100%);
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  width: 100%;
  padding-top: 150%;
  box-shadow: 0 16rpx 48rpx rgba(37, 29, 21, 0.18);
}

.poster-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.poster-result-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.poster-generating {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: rgba(30, 20, 14, 0.6);
}
.poster-spin {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.15);
  border-top-color: #C8A258;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
.poster-gen-text {
  font-size: 26rpx;
  color: rgba(255, 248, 240, 0.75);
}

.poster-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
.poster-action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.poster-action-primary {
  background: linear-gradient(135deg, #C8A258 0%, #A07840 100%);
}
.poster-action-secondary {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #DDD5CB;
}
.poster-action-secondary .poster-action-text {
  color: #1E1710;
}
.btn-disabled {
  opacity: 0.4;
}
.poster-action-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFF8F0;
}

.poster-tip {
  text-align: center;
  font-size: 22rpx;
  color: #B0A090;
  margin-top: 14rpx;
  margin-bottom: 20rpx;
}

.poster-tips-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
}
.ptip-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 14rpx;
}
.ptip-item:last-child {
  margin-bottom: 0;
}
.ptip-dot {
  font-size: 26rpx;
  color: #C8A258;
  flex-shrink: 0;
  line-height: 1.6;
}
.ptip-text {
  font-size: 24rpx;
  color: #8A7A6E;
  line-height: 1.7;
}
