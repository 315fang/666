/* pages/distribution/commission-logs.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #F8F3ED 0%, #FAFAF8 30%, #F1EEEA 100%);
  overflow: hidden;
}

/* 概览卡 */
.overview-card {
  padding: 24rpx 24rpx 0;
  flex-shrink: 0;
}

.overview-inner {
  background: linear-gradient(140deg, #2B2018 0%, #1A1511 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 12rpx 32rpx rgba(28, 20, 14, 0.15);
}

.overview-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.overview-label {
  font-size: 22rpx;
  color: rgba(255, 240, 220, 0.5);
}

.overview-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFF7EF;
  line-height: 1;
}

.overview-amount.sub {
  font-size: 36rpx;
  color: #D4B896;
}

.overview-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.10);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  flex-shrink: 0;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #9A8D80;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 999rpx;
  border: 1rpx solid rgba(122, 108, 94, 0.10);
  flex-shrink: 0;
}

.filter-item.active {
  color: #FFF7EF;
  background: #1C1917;
  border-color: transparent;
  font-weight: 600;
}

/* 列表滚动区 */
.log-scroll {
  flex: 1;
  overflow: hidden;
}

.log-list {
  padding: 0 24rpx;
}

/* 列表项 */
.log-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 29, 21, 0.04);
}

.log-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.log-icon-Direct { background: rgba(185, 139, 88, 0.12); }
.log-icon-Indirect { background: rgba(90, 128, 96, 0.12); }
.log-icon-Stock_Diff { background: rgba(183, 100, 71, 0.12); }
.log-icon-agent_fulfillment { background: rgba(106, 126, 154, 0.12); }

.log-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.7;
}

.log-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.log-type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1917;
}

.log-time {
  font-size: 22rpx;
  color: #B0A396;
}

.log-remark {
  font-size: 22rpx;
  color: #9A8D80;
  line-height: 1.5;
  margin-top: 4rpx;
}

.log-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 8rpx;
}

.log-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #5A8060;
}

.log-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.status-frozen { background: rgba(183, 100, 71, 0.10); color: #B76447; }
.status-pending { background: rgba(160, 108, 70, 0.10); color: #A06C46; }
.status-success { background: rgba(90, 128, 96, 0.10); color: #5A8060; }
.status-gray { background: rgba(154, 141, 128, 0.10); color: #9A8D80; }
.status-fail { background: rgba(183, 100, 71, 0.08); color: #B76447; }

/* 底部加载 */
.load-footer {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #F2EDE8;
  border-top-color: #B98B58;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text,
.no-more {
  font-size: 22rpx;
  color: #B0A396;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.empty-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.25;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #78716C;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #B0A396;
}

/* 骨架屏 */
.skeleton-wrap {
  padding-top: 4rpx;
}

.sk-log {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.sk-icon,
.sk-line,
.sk-amount-box {
  background: linear-gradient(90deg, #F3EEE9 25%, #EBE2D8 50%, #F3EEE9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.sk-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.sk-info {
  flex: 1;
}

.sk-line { height: 24rpx; margin-bottom: 12rpx; }
.sk-long { width: 55%; }
.sk-short { width: 35%; height: 20rpx; }

.sk-amount-box {
  width: 80rpx;
  height: 32rpx;
  flex-shrink: 0;
}
