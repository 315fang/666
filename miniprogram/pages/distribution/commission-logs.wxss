/* pages/distribution/commission-logs.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #F8F3ED 0%, #FAFAF8 30%, #F1EEEA 100%);
  overflow: hidden;
}

/* 概览卡 */
.overview-card {
  padding: 24rpx 24rpx 0;
  flex-shrink: 0;
}

.overview-inner {
  background: linear-gradient(140deg, #2B2018 0%, #1A1511 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 12rpx 32rpx rgba(28, 20, 14, 0.15);
}

.overview-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.overview-label {
  font-size: 22rpx;
  color: rgba(255, 240, 220, 0.5);
}

.overview-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFF7EF;
  line-height: 1;
}

.overview-amount.sub {
  font-size: 36rpx;
  color: #D4B896;
}

.overview-amount.hi {
  font-size: 36rpx;
  color: #A8D4A0;
}

.overview-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.10);
}

/* ═══ 积分入口 ═══ */
.points-entry {
  margin: 12rpx 24rpx 0;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(37, 29, 21, 0.04);
  border-left: 4rpx solid #C8A258;
}

.pe-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.pe-icon { font-size: 36rpx; }

.pe-info { display: flex; flex-direction: column; gap: 4rpx; }

.pe-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1C1917;
}

.pe-sub { font-size: 21rpx; color: #9A8D80; }

.pe-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.pe-balance {
  font-size: 28rpx;
  font-weight: 700;
  color: #8A6020;
}

.pe-arrow { font-size: 28rpx; color: #B0A090; }

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  flex-shrink: 0;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #9A8D80;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 999rpx;
  border: 1rpx solid rgba(122, 108, 94, 0.10);
  flex-shrink: 0;
}

.filter-item.active {
  color: #FFF7EF;
  background: #1C1917;
  border-color: transparent;
  font-weight: 600;
}

/* 列表滚动区 */
.log-scroll {
  flex: 1;
  overflow: hidden;
}

.log-list {
  padding: 0 24rpx;
}

/* ═══ 列表项 ═══ */
.log-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 20rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 14rpx rgba(37, 29, 21, 0.04);
}

.log-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.log-icon {
  width: 36rpx;
  height: 36rpx;
}

.log-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.log-row1 {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.log-type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1917;
}

.log-time {
  font-size: 21rpx;
  color: #B0A396;
}

/* 明细行（来源用户/商品/订单号） */
.log-detail-row {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  margin-top: 2rpx;
}

.log-detail-icon { font-size: 22rpx; line-height: 1.4; flex-shrink: 0; }

.log-detail-text {
  font-size: 22rpx;
  color: #9A8D80;
  line-height: 1.5;
}

.log-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 8rpx;
}

.log-amount {
  font-size: 32rpx;
  font-weight: 700;
}

.log-freeze-tip {
  font-size: 19rpx;
  color: #B0A090;
}

.log-status {
  font-size: 19rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
}

.status-frozen { background: rgba(183, 100, 71, 0.10); color: #B76447; }
.status-pending { background: rgba(160, 108, 70, 0.10); color: #A06C46; }
.status-success { background: rgba(90, 128, 96, 0.10); color: #5A8060; }
.status-gray { background: rgba(154, 141, 128, 0.10); color: #9A8D80; }
.status-fail { background: rgba(183, 100, 71, 0.08); color: #B76447; }

/* 底部加载 */
.load-footer {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #F2EDE8;
  border-top-color: #B98B58;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text,
.no-more {
  font-size: 22rpx;
  color: #B0A396;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.empty-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.25;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #78716C;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #B0A396;
}

/* 骨架屏 */
.skeleton-wrap {
  padding-top: 4rpx;
}

.sk-log {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.sk-icon,
.sk-line,
.sk-amount-box {
  background: linear-gradient(90deg, #F3EEE9 25%, #EBE2D8 50%, #F3EEE9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 10rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.sk-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.sk-info {
  flex: 1;
}

.sk-line { height: 22rpx; margin-bottom: 10rpx; }
.sk-long { width: 55%; }
.sk-med  { width: 45%; height: 19rpx; }
.sk-short { width: 30%; height: 19rpx; }

.sk-amount-box {
  width: 80rpx;
  height: 32rpx;
  flex-shrink: 0;
}
