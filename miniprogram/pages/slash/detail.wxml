<!--pages/slash/detail.wxml - 砍价详情-->
<view class="container">
  <!-- 导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="onBack">
      <image class="nav-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"/>
    </view>
    <text class="nav-title">砍价详情</text>
    <view class="nav-placeholder"/>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="skeleton-block" style="height:300rpx; margin:24rpx;"/>
    <view class="skeleton-block" style="height:200rpx; margin:0 24rpx;"/>
  </view>

  <block wx:if="{{!loading && detail}}">
    <!-- 商品信息卡 -->
    <view class="product-card">
      <image class="product-img" src="{{detail.product && detail.product.images && detail.product.images[0] || '/assets/icons/package.svg'}}" mode="aspectFill"/>
      <view class="product-info">
        <text class="product-name">{{detail.product && detail.product.name || '商品'}}</text>
        <view class="status-badge status-{{detail.status}}">
          <text>{{statusTextMap[detail.status] || detail.status}}</text>
        </view>
      </view>
    </view>

    <!-- 价格进度卡 -->
    <view class="price-card">
      <view class="price-row">
        <view class="price-col">
          <text class="price-label">当前价格</text>
          <text class="price-current">¥{{detail.current_price}}</text>
        </view>
        <view class="price-arrow-wrap">
          <image src="/assets/icons/arrow-right.svg" class="price-arrow-icon" mode="aspectFit"/>
        </view>
        <view class="price-col">
          <text class="price-label">目标底价</text>
          <text class="price-floor">¥{{detail.floor_price}}</text>
        </view>
        <view class="price-col price-col-right">
          <text class="price-label">原价</text>
          <text class="price-original">¥{{detail.original_price}}</text>
        </view>
      </view>

      <!-- 进度条 -->
      <view class="progress-section">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{detail._progressPct}}%;"/>
        </view>
        <view class="progress-meta">
          <text class="helper-count">{{detail.helper_count || 0}}人已帮砍</text>
          <text class="progress-pct">{{detail._progressPct}}%</text>
        </view>
      </view>

      <!-- 倒计时 -->
      <view class="countdown-row" wx:if="{{detail.status === 'active' && !detail._expired}}">
        <image src="/assets/icons/clock.svg" class="icon-xs" mode="aspectFit"/>
        <text class="countdown-text">剩余 {{detail._remainHours}}小时{{detail._remainMins}}分钟</text>
      </view>
      <view class="countdown-row expired-row" wx:if="{{detail.status === 'expired' || detail._expired}}">
        <text class="expired-text">活动已结束</text>
      </view>
    </view>

    <!-- 帮砍记录 -->
    <view class="helpers-card" wx:if="{{detail.helpers && detail.helpers.length > 0}}">
      <text class="card-title">帮砍好友</text>
      <view class="helper-list">
        <view class="helper-item" wx:for="{{detail.helpers}}" wx:key="id">
          <image class="helper-avatar" src="{{item.user && item.user.avatar_url || '/assets/icons/user.svg'}}" mode="aspectFill"/>
          <view class="helper-info">
            <text class="helper-name">{{item.user && item.user.nickname || '好友'}}</text>
            <text class="helper-cut">砍了 ¥{{item.cut_amount}}</text>
          </view>
          <text class="helper-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>
    <view class="helpers-card" wx:if="{{!detail.helpers || detail.helpers.length === 0}}">
      <text class="card-title">帮砍好友</text>
      <view class="empty-helpers">
        <image src="/assets/icons/users.svg" class="empty-icon" mode="aspectFit"/>
        <text class="empty-text">还没有好友帮砍\n快去分享给朋友吧</text>
      </view>
    </view>
  </block>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{!loading && detail}}">
    <view class="btn-share" bindtap="onShare" wx:if="{{detail.status === 'active'}}">
      <image src="/assets/icons/users.svg" class="btn-icon" mode="aspectFit"/>
      <text>邀好友帮砍</text>
    </view>
    <view class="btn-buy {{detail.status === 'success' ? 'btn-buy-ready' : 'btn-buy-default'}}"
          bindtap="onBuy"
          wx:if="{{detail.status === 'success' || detail.status === 'active'}}">
      <text wx:if="{{detail.status === 'success'}}">已到底价，立即购买</text>
      <text wx:else>¥{{detail.current_price}} 立即购买</text>
    </view>
    <view class="btn-disabled" wx:if="{{detail.status === 'expired' || detail.status === 'purchased'}}">
      <text wx:if="{{detail.status === 'expired'}}">活动已过期</text>
      <text wx:else>已完成购买</text>
    </view>
  </view>
</view>
