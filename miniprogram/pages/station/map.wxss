page { background: #f5ede1; }
.container { min-height: 100vh; background: linear-gradient(180deg, #f8f1e5 0%, #f1e5d4 100%); }
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #3b2b1a; }
.nav-placeholder { width: 56rpx; }

.hero-card,
.stats-row,
.map-card,
.station-card,
.claim-card {
  margin: 18rpx 24rpx 0;
  border-radius: 28rpx;
  background: rgba(255, 251, 245, 0.96);
  border: 1rpx solid rgba(191, 151, 97, 0.18);
  box-shadow: 0 18rpx 40rpx rgba(117, 81, 33, 0.08);
}

.hero-card { padding: 30rpx 28rpx; }
.hero-eyebrow { display: block; font-size: 22rpx; letter-spacing: 4rpx; color: #a2783e; }
.hero-title { display: block; margin-top: 12rpx; font-size: 38rpx; font-weight: 700; color: #3b2b1a; line-height: 1.4; }
.hero-desc { display: block; margin-top: 14rpx; font-size: 26rpx; color: #755d43; line-height: 1.7; }

.stats-row { display: flex; padding: 26rpx 0; }
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.stat-num { font-size: 42rpx; font-weight: 800; color: #7f4a16; }
.stat-label { font-size: 22rpx; color: #8e7559; }

.map-card { position: relative; height: 500rpx; overflow: hidden; }
.map-canvas { width: 100%; height: 100%; }
.map-tip { position: absolute; right: 16rpx; bottom: 16rpx; font-size: 20rpx; color: #7a6246; background: rgba(255,252,246,0.92); padding: 8rpx 14rpx; border-radius: 999rpx; }

.section-title { padding: 26rpx 28rpx 10rpx; font-size: 28rpx; font-weight: 700; color: #4b341d; }
.station-list { padding: 0 0 60rpx; display: flex; flex-direction: column; gap: 16rpx; }
.station-card { padding: 24rpx; }
.station-header { display: flex; align-items: center; gap: 10rpx; }
.station-status-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.station-status-dot.active { background: #ae7530; }
.station-status-dot.pending { background: #d79a47; }
.station-status-dot.inactive { background: #cabaa8; }
.station-name { font-size: 30rpx; font-weight: 700; color: #3f2c19; flex: 1; }
.pickup-badge { font-size: 18rpx; font-weight: 700; color: #8e5a1f; background: rgba(191,122,52,0.12); padding: 4rpx 12rpx; border-radius: 20rpx; }
.station-location,
.station-addr,
.claimant-name,
.no-claimant { display: block; font-size: 22rpx; color: #83684a; margin-top: 10rpx; }
.station-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 14rpx; }
.claimant-info { display: flex; align-items: center; gap: 10rpx; }
.claimant-avatar { width: 36rpx; height: 36rpx; border-radius: 50%; }
.claim-btn { font-size: 22rpx; font-weight: 700; color: #8e5a1f; background: rgba(191,122,52,0.1); padding: 10rpx 20rpx; border-radius: 50rpx; }
.station-data { border-top: 1rpx solid rgba(191,151,97,0.12); padding-top: 10rpx; margin-top: 12rpx; }
.data-item { font-size: 20rpx; color: #9a7f61; }

.claim-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999; display: flex; align-items: center; justify-content: center; }
.claim-overlay { position: absolute; inset: 0; background: rgba(53, 33, 16, 0.42); }
.claim-card { position: relative; z-index: 2; padding: 36rpx 30rpx; width: 84%; }
.claim-title { font-size: 32rpx; font-weight: 700; color: #3b2b1a; display: block; text-align: center; margin-bottom: 30rpx; }
.form-group { display: flex; flex-direction: column; gap: 10rpx; margin-bottom: 20rpx; }
.form-label { font-size: 24rpx; color: #8e7559; }
.form-input,
.form-textarea { background: #fffdf8; border-radius: 16rpx; padding: 16rpx 20rpx; font-size: 26rpx; color: #3b2b1a; border: 1rpx solid rgba(191,151,97,0.18); box-sizing: border-box; width: 100%; }
.form-textarea { height: 120rpx; }
.form-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.form-btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 999rpx; font-size: 26rpx; font-weight: 700; }
.form-btn.cancel { background: #f3ebdf; color: #8e7559; }
.form-btn.submit { background: linear-gradient(135deg, #d5a15b 0%, #bb7a34 100%); color: #fff7ef; }
