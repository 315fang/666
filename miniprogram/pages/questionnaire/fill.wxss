page {
    background: #f5ede1;
}

.questionnaire-page {
    min-height: 100vh;
    padding: 28rpx 24rpx 48rpx;
    box-sizing: border-box;
    background:
        radial-gradient(circle at top, rgba(205, 161, 92, 0.16), transparent 34%),
        linear-gradient(180deg, #f8f1e5 0%, #f3e8d8 100%);
}

.loading-container,
.success-container,
.empty-container {
    padding-top: 120rpx;
}

.hero-card,
.form-container,
.footer-card,
.success-card,
.empty-card,
.loading-card {
    background: rgba(255, 252, 246, 0.96);
    border-radius: 28rpx;
    padding: 30rpx 28rpx;
    border: 1rpx solid rgba(191, 151, 97, 0.18);
    box-shadow: 0 18rpx 40rpx rgba(117, 81, 33, 0.08);
}

.form-shell {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.hero-eyebrow,
.success-eyebrow {
    display: block;
    font-size: 22rpx;
    letter-spacing: 4rpx;
    color: #a2783e;
}

.hero-title,
.success-title,
.loading-title {
    display: block;
    margin-top: 12rpx;
    font-size: 38rpx;
    line-height: 1.4;
    font-weight: 700;
    color: #3b2b1a;
}

.hero-desc,
.success-desc,
.loading-desc,
.empty-desc,
.form-tip {
    display: block;
    margin-top: 14rpx;
    font-size: 26rpx;
    color: #755d43;
    line-height: 1.7;
}

.field-group {
    padding: 24rpx 0;
    border-bottom: 1rpx solid rgba(191, 151, 97, 0.12);
}

.field-group:last-child {
    border-bottom: none;
}

.field-label {
    display: flex;
    align-items: center;
    gap: 8rpx;
    margin-bottom: 14rpx;
}

.label-text {
    font-size: 28rpx;
    color: #4b341d;
    font-weight: 700;
}

.label-required {
    color: #bd5c3f;
    font-size: 28rpx;
}

.field-input,
.field-textarea,
.field-picker {
    width: 100%;
    border-radius: 18rpx;
    border: 1rpx solid rgba(191, 151, 97, 0.18);
    background: #fffdf8;
    box-sizing: border-box;
    font-size: 28rpx;
    color: #3b2b1a;
}

.field-input,
.field-picker {
    min-height: 88rpx;
    padding: 24rpx;
}

.field-picker {
    line-height: 1.4;
}

.field-textarea {
    min-height: 160rpx;
    padding: 22rpx 24rpx;
    line-height: 1.7;
}

.field-picker.placeholder {
    color: #ab9983;
}

.radio-group,
.checkbox-group {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.radio-label,
.checkbox-label {
    display: flex;
    align-items: center;
    gap: 12rpx;
    padding: 20rpx 22rpx;
    border-radius: 18rpx;
    background: #fffdf8;
    border: 1rpx solid rgba(191, 151, 97, 0.18);
}

.radio-text,
.checkbox-text {
    font-size: 26rpx;
    color: #5f472f;
}

.privacy-row {
    display: flex;
    align-items: flex-start;
    gap: 14rpx;
}

.privacy-checkbox {
    width: 34rpx;
    height: 34rpx;
    border-radius: 10rpx;
    border: 2rpx solid rgba(191, 151, 97, 0.35);
    flex-shrink: 0;
    margin-top: 6rpx;
    background: #fffdf8;
}

.privacy-checkbox.checked {
    background: #bb7a34;
    border-color: #bb7a34;
    position: relative;
}

.privacy-checkbox.checked::after {
    content: '';
    position: absolute;
    left: 10rpx;
    top: 4rpx;
    width: 10rpx;
    height: 18rpx;
    border-right: 4rpx solid #fff;
    border-bottom: 4rpx solid #fff;
    transform: rotate(40deg);
}

.privacy-text {
    flex: 1;
    font-size: 24rpx;
    line-height: 1.7;
    color: #7f6344;
}

.submit-btn,
.btn-primary,
.btn-secondary {
    width: 100%;
    height: 88rpx;
    line-height: 88rpx;
    border-radius: 999rpx;
    font-size: 28rpx;
    font-weight: 700;
    margin-top: 24rpx;
}

.submit-btn,
.btn-primary {
    background: linear-gradient(135deg, #d5a15b 0%, #bb7a34 100%);
    color: #fff7ef;
}

.submit-btn.disabled {
    opacity: 0.55;
}

.btn-secondary {
    background: #f6efe2;
    color: #8e5a1f;
    border: 1rpx solid rgba(191, 151, 97, 0.24);
}

.success-actions {
    margin-top: 24rpx;
}

.empty-title {
    display: block;
    font-size: 34rpx;
    font-weight: 700;
    color: #3b2b1a;
}

.loading-spinner {
    width: 60rpx;
    height: 60rpx;
    border-radius: 50%;
    border: 4rpx solid rgba(196, 138, 67, 0.16);
    border-top-color: #c48a43;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}
