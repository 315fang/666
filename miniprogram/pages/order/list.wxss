.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #E3EDF4 0%, #F4F8FA 30%, #EDF5F2 100%);
}

.tabs-wrapper {
  background: rgba(255,255,255,0.88);
  border-bottom: 1rpx solid rgba(100, 116, 139, 0.12);
  padding: 8rpx 0;
}

.tabs-scroll {
  white-space: nowrap;
  display: flex;
  align-items: center;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 28rpx;
  font-size: 26rpx;
  color: #64748B;
  position: relative;
  flex-shrink: 0;
}

.tab-item:first-child { margin-left: 16rpx; }
.tab-item:last-child { margin-right: 16rpx; }

.tab-item::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 6rpx;
  background: linear-gradient(135deg, #2E6B94 0%, #C6A16E 100%);
  border-radius: 999rpx;
  opacity: 0;
  transition: all 0.25s ease;
}

.tab-item.active {
  color: #0F172A;
  font-weight: 600;
}

.tab-item.active::after {
  width: 36rpx;
  opacity: 1;
}

.order-list {
  flex: 1;
  overflow: hidden;
}

.order-list-container {
  padding: 24rpx;
}

.order-card,
.skeleton-card {
  background: rgba(255,255,255,0.94);
  border-radius: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(30, 74, 109, 0.08);
  overflow: hidden;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 26rpx 18rpx;
}

.order-no {
  font-size: 22rpx;
  color: #96897D;
}

.order-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.order-status.pending { color: #9A7348; background: #FCF4E8; }
.order-status.paid { color: #1E4A6D; background: #E3EDF4; }
.order-status.shipped { color: #0F766E; background: #ECFDF8; }
.order-status.completed { color: #047857; background: #D1FAE5; }
.order-status.cancelled { color: #64748B; background: #F1F5F9; }
.order-status.refunding,
.order-status.refund_pending,
.order-status.refund_approved,
.order-status.refund_processing { color: #B45309; background: #FFFBEB; }

.order-products {
  padding: 0 26rpx;
}

.order-product {
  display: flex;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(117,105,95,0.08);
}

.product-image,
.product-image-placeholder {
  width: 132rpx;
  height: 132rpx;
  border-radius: 20rpx;
  background: #F1ECE6;
  flex-shrink: 0;
}

.product-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.35;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 26rpx;
  line-height: 1.5;
  color: #241D18;
  font-weight: 600;
}

.product-spec {
  font-size: 22rpx;
  color: #9C8E81;
  margin-top: 6rpx;
}

.product-price-qty,
.order-footer,
.order-total,
.order-actions,
.total-row {
  display: flex;
  align-items: center;
}

.product-price-qty,
.order-footer {
  justify-content: space-between;
}

.product-price,
.total-amount {
  font-size: 30rpx;
  color: #221B16;
  font-weight: 700;
}

.product-qty,
.total-label,
.load-more,
.loading,
.empty-text {
  font-size: 22rpx;
  color: #96897D;
}

.order-footer {
  padding: 20rpx 26rpx 24rpx;
  background: rgba(255,255,255,0.5);
}

.fulfillment-tag {
  font-size: 18rpx;
  background: #F6EFE7;
  color: #8B7158;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-left: 10rpx;
}

.order-actions {
  gap: 12rpx;
}

.btn {
  border-radius: 999rpx;
  font-size: 22rpx;
}

.btn-sm {
  padding: 12rpx 22rpx;
}

.btn-primary { background: #241D18; color: #FFF7F0; }
.btn-secondary { background: #8A6A4E; color: #FFF7F0; }
.btn-ghost { background: #FFF; color: #6D6258; border: 1rpx solid #E7DDD2; }

.load-more,
.loading {
  text-align: center;
  padding: 32rpx 0;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 180rpx;
}

.empty .btn {
  margin-top: 26rpx;
  min-width: 220rpx;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 42rpx;
  height: 42rpx;
  border: 4rpx solid #EFE6DC;
  border-top-color: #B88C62;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 16rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.skeleton-wrapper {
  padding: 8rpx 0;
}

.skeleton-card {
  padding: 24rpx;
}

.skeleton-header,
.skeleton-body,
.skeleton-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.skeleton-header,
.skeleton-footer {
  margin-bottom: 20rpx;
}

.skeleton-body {
  margin-bottom: 20rpx;
}

.skeleton-img,
.skeleton-line,
.skeleton-btn {
  background: linear-gradient(90deg, #f3eee9 25%, #ebe2d8 50%, #f3eee9 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

.skeleton-img {
  width: 132rpx;
  height: 132rpx;
  border-radius: 20rpx;
}

.skeleton-info { flex: 1; margin-left: 18rpx; }

.skeleton-line { height: 28rpx; border-radius: 10rpx; margin-bottom: 14rpx; }
.skeleton-line.short { width: 60%; }
.skeleton-line.tiny { width: 100rpx; height: 24rpx; }
.skeleton-btn { width: 120rpx; height: 52rpx; border-radius: 999rpx; }

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.card-fade-in {
  animation: cardFadeIn 0.45s ease forwards;
  opacity: 0;
}

@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}
