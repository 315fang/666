.container {
    min-height: 100vh;
    background: linear-gradient(180deg, #E3EDF4 0%, #F4F8FA 28%, #EDF5F2 100%);
    padding: 28rpx 0 160rpx;
}

.checkout-hero {
    padding: 8rpx 28rpx 12rpx;
}

.checkout-title {
    display: block;
    font-size: 46rpx;
    color: #0F172A;
    font-weight: 700;
    margin-bottom: 10rpx;
}

.checkout-subtitle {
    display: block;
    font-size: 24rpx;
    line-height: 1.7;
    color: #64748B;
}

.checkout-assurance-card {
    margin: 0 24rpx 20rpx;
    padding: 24rpx 26rpx;
    border-radius: 28rpx;
    background: rgba(255,255,255,0.86);
    box-shadow: 0 10rpx 24rpx rgba(37, 29, 21, 0.05);
    display: flex;
    justify-content: space-between;
    gap: 12rpx;
}

.assurance-item {
    display: flex;
    align-items: center;
    gap: 10rpx;
}

.assurance-icon {
    width: 28rpx;
    height: 28rpx;
}

.assurance-text {
    font-size: 22rpx;
    color: #63584E;
}

.section {
    background: rgba(255,255,255,0.92);
    margin: 20rpx 24rpx;
    border-radius: 28rpx;
    padding: 28rpx 24rpx;
    box-shadow: 0 8rpx 20rpx rgba(35, 27, 20, 0.04);
}

.section-head-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18rpx;
}

.section-title-text {
    font-size: 28rpx;
    font-weight: 600;
    color: #211A15;
}

.section-link-text,
.section-meta-text {
    font-size: 22rpx;
    color: #9A8B7C;
}

.section-link-row {
    display: flex;
    align-items: center;
    gap: 4rpx;
}

.address-info {
    flex: 1;
}

.address-top {
    display: flex;
    align-items: center;
    gap: 16rpx;
    margin-bottom: 10rpx;
}

.address-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #0F172A;
}

.address-phone,
.address-detail {
    font-size: 26rpx;
    color: #64594F;
}

.address-tag {
    font-size: 20rpx;
    color: #8D755A;
    border: 1rpx solid rgba(141,117,90,0.4);
    border-radius: 999rpx;
    padding: 2rpx 12rpx;
}

.address-empty {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.empty-icon-img {
    width: 36rpx;
    height: 36rpx;
}

.empty-text {
    flex: 1;
    font-size: 28rpx;
    color: #73675C;
}

.arrow {
    font-size: 36rpx;
    color: #B1A598;
    margin-left: 12rpx;
}

.goods-item {
    display: flex;
    gap: 20rpx;
    padding: 20rpx 0;
    border-bottom: 1rpx solid rgba(117, 105, 95, 0.08);
}

.goods-item:last-child {
    border-bottom: none;
}

.goods-image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 20rpx;
    background: #F1ECE6;
    flex-shrink: 0;
}

.goods-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.goods-name {
    font-size: 28rpx;
    color: #1F1915;
    font-weight: 600;
    line-height: 1.5;
}

.goods-spec {
    font-size: 22rpx;
    color: #9A8B7C;
    margin-top: 8rpx;
}

.goods-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10rpx;
}

.goods-price {
    font-size: 30rpx;
    color: #221B16;
    font-weight: 700;
}

.goods-quantity {
    font-size: 24rpx;
    color: #938677;
}

.remark-section,
.coupon-section,
.points-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20rpx;
}

.coupon-section {
    flex-direction: column;
    align-items: stretch;
    gap: 12rpx;
}

.coupon-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16rpx;
    width: 100%;
}

.coupon-label-row {
    display: flex;
    align-items: center;
    gap: 12rpx;
    flex-shrink: 0;
}

.coupon-help-chip {
    font-size: 22rpx;
    font-weight: 600;
    color: #8d6a3f;
    padding: 4rpx 14rpx;
    border-radius: 999rpx;
    border: 1rpx solid rgba(185, 139, 88, 0.4);
}

.remark-label,
.coupon-label,
.points-label {
    font-size: 28rpx;
    color: #312821;
    flex-shrink: 0;
}

.points-right {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.points-balance {
    font-size: 24rpx;
    color: #9A8D80;
}

.points-detail {
    padding-top: 0 !important;
    padding-bottom: 16rpx !important;
}

.points-deduct-text {
    font-size: 24rpx;
    color: #B98B58;
    font-weight: 500;
}

.points-deduct-tip {
    font-size: 20rpx;
    color: #B0A396;
    margin-left: 8rpx;
}

.remark-input {
    flex: 1;
    font-size: 26rpx;
    text-align: right;
    color: #62584E;
}

.coupon-right {
    display: flex;
    align-items: center;
    gap: 8rpx;
}

.coupon-selected {
    font-size: 24rpx;
    color: #B05A46;
}

.coupon-none {
    font-size: 24rpx;
    color: #9A8D80;
}

.coupon-tip {
    font-size: 22rpx;
    line-height: 1.5;
    color: #B78B58;
}

.coupon-tip-active {
    color: #C45E3D;
}

.coupon-picker {
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    z-index: 10100;
}

.coupon-picker.show {
    display: block;
}

.coupon-picker-mask {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
}

.coupon-picker-panel {
    position: absolute;
    left: 0;
    right: 0;
    /* 抬离系统导航/手势区，避免 Android 上整片被挡在屏幕外 */
    bottom: 0;
    /* 额外留出一段距离：部分 Android 三键导航 safe-area 为 0，仍会被系统条遮挡 */
    padding-bottom: calc(56rpx + constant(safe-area-inset-bottom));
    padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
    background: #fff;
    border-radius: 32rpx 32rpx 0 0;
    padding-top: 32rpx;
    padding-left: 24rpx;
    padding-right: 24rpx;
    max-height: calc(85vh - constant(safe-area-inset-bottom));
    max-height: calc(85vh - env(safe-area-inset-bottom));
    min-height: 360rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
}

.coupon-picker-scroll {
    flex: 1;
    min-height: 240rpx;
    max-height: 58vh;
}

.coupon-picker-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #201A15;
    text-align: center;
    margin-bottom: 28rpx;
}

.coupon-list {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.coupon-picker-empty {
    text-align: center;
    color: #9A8D80;
    font-size: 24rpx;
    padding: 56rpx 0;
}

.coupon-card {
    display: flex;
    align-items: center;
    border: 2rpx solid #EEE7DF;
    border-radius: 20rpx;
    overflow: hidden;
    position: relative;
}

.coupon-card.active {
    border-color: #B99265;
    background: #FBF6EE;
}

.coupon-card-left {
    width: 180rpx;
    background: #FBF2E8;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24rpx 16rpx;
    flex-shrink: 0;
}

.coupon-value {
    font-size: 36rpx;
    font-weight: 700;
    color: #B76447;
}

.coupon-min {
    font-size: 20rpx;
    color: #A09080;
    margin-top: 6rpx;
}

.coupon-card-right {
    flex: 1;
    padding: 20rpx;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
}

.coupon-name-text {
    font-size: 28rpx;
    font-weight: 500;
    color: #201A15;
}

.coupon-expire {
    font-size: 22rpx;
    color: #9E9286;
}

.coupon-check {
    position: absolute;
    right: 20rpx;
    top: 50%;
    transform: translateY(-50%);
    width: 44rpx;
    height: 44rpx;
    background: #8D755A;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.coupon-no-use {
    text-align: center;
    font-size: 26rpx;
    color: #9A8D80;
    padding: 20rpx 0;
}

.bottom-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255,255,255,0.96);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18rpx 24rpx;
    padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
    box-shadow: 0 -8rpx 24rpx rgba(31, 25, 20, 0.06);
    z-index: 100;
}

.total-lines {
    display: flex;
    flex-direction: column;
    gap: 4rpx;
}

.total-row {
    display: flex;
    align-items: baseline;
}

.discount-label,
.total-label {
    font-size: 24rpx;
    color: #9A8D80;
}

.discount-amount {
    font-size: 26rpx;
    color: #B76447;
    font-weight: 500;
}

.shipping-amount {
    font-size: 26rpx;
    color: #55725F;
    font-weight: 500;
}

.shipping-row { opacity: 0.8; }

.total-price {
    font-size: 40rpx;
    font-weight: 700;
    color: #201A15;
    margin-left: 8rpx;
}

.submit-btn {
    min-width: 220rpx;
    height: 84rpx;
    padding: 0 32rpx;
    border-radius: 999rpx;
    background: linear-gradient(135deg, #1F1B17 0%, #3A3027 100%);
    color: #fff;
    font-size: 28rpx;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
}

.submit-btn.disabled {
    opacity: 0.5;
}

.success-popup {
  position: fixed;
  inset: 0;
  z-index: 999;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.success-popup.show {
  visibility: visible;
  opacity: 1;
}

.success-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
}

.success-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-popup.show .success-content {
  transform: translate(-50%, -50%) scale(1);
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: #F2E9DE;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.success-icon-img {
  width: 58rpx;
  height: 58rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #201A15;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #72675D;
  margin-bottom: 60rpx;
  text-align: center;
}

.success-btns {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary,
.btn-outline {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: #1F1B17;
  color: #fff;
}

.btn-outline {
  background: #fff;
  border: 2rpx solid #E5DED6;
  color: #6A5F55;
}

/* 自提 / 配送方式 */
.delivery-seg {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.delivery-seg-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #6A5F55;
  background: #F3EDE6;
  border: 2rpx solid transparent;
}

.delivery-seg-item.active {
  color: #1F1B17;
  font-weight: 600;
  background: #FFF9F0;
  border-color: #3B82F6;
}

.delivery-seg-item-disabled {
  opacity: 0.45;
}

.delivery-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9A8B7C;
  line-height: 1.5;
}

.delivery-hint-muted {
  color: #B0A090;
}

.pickup-map-link {
  margin-top: 20rpx;
  padding: 12rpx 0;
}

.pickup-map-link-text {
  font-size: 26rpx;
  color: #8B6914;
  text-decoration: underline;
}

.address-optional .empty-text {
  color: #9A8B7C;
}

.pickup-loc-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.pickup-loc-btn {
  margin: 0;
  background: #1F1B17 !important;
  color: #fff !important;
  border-radius: 12rpx !important;
  font-size: 24rpx !important;
}

.pickup-loc-btn.ghost {
  background: #fff !important;
  color: #6A5F55 !important;
  border: 2rpx solid #E5DED6 !important;
}

.ref-loc-name {
    display: block;
    font-size: 22rpx;
    color: #74695F;
    margin-bottom: 16rpx;
}

.pickup-hint-muted {
    display: block;
    font-size: 22rpx;
    color: #9A8B7C;
    line-height: 1.45;
    margin-bottom: 16rpx;
}

.pickup-row {
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  background: #FAF7F3;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
}

.pickup-row-active {
  border-color: #3B82F6;
  background: #FFF9F0;
}

.pickup-row-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.pickup-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #211A15;
}

.pickup-dist {
  font-size: 22rpx;
  color: #B98B58;
}

.pickup-addr {
  font-size: 22rpx;
  color: #74695F;
  line-height: 1.4;
}

.pickup-rule {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #2563EB;
}

.pickup-empty {
  font-size: 24rpx;
  color: #9A8B7C;
}

.pickup-notice-card {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #EFF6FF;
  border: 1rpx solid #BFDBFE;
}

.pickup-notice-title {
  display: block;
  font-size: 22rpx;
  color: #8EA1BE;
}

.pickup-notice-name {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1D4ED8;
}

.pickup-notice-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #54739E;
}

/* ── 货款支付区块 ── */
.goods-fund-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-fund-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.goods-fund-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.goods-fund-balance {
  font-size: 24rpx;
  color: #4CAF50;
}

.goods-fund-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.goods-fund-tip {
  font-size: 22rpx;
  color: #F56C6C;
}

.goods-fund-detail {
  padding-top: 0 !important;
}

.goods-fund-detail-text {
  font-size: 24rpx;
  color: #4CAF50;
}
