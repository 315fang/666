.wrap {
  padding: 24rpx;
  min-height: 100vh;
  background: #fafaf9;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}
.status {
  font-size: 28rpx;
  color: #15803d;
  font-weight: 600;
  display: block;
}
.status.warn {
  color: #b45309;
}
.no {
  font-size: 24rpx;
  color: #78716c;
  margin-top: 12rpx;
  display: block;
}
.title {
  font-size: 26rpx;
  color: #57534e;
  display: block;
  margin-bottom: 12rpx;
}
.txt {
  font-size: 28rpx;
  color: #1c1917;
  display: block;
}
.txt.sub {
  font-size: 24rpx;
  color: #78716c;
  margin-top: 8rpx;
}
.code {
  font-size: 36rpx;
  font-family: ui-monospace, monospace;
  letter-spacing: 4rpx;
  color: #1c1917;
  display: block;
  margin: 16rpx 0;
}
.btn.ghost {
  margin-top: 12rpx;
  background: #e7e5e4;
  color: #1c1917;
  font-size: 26rpx;
}
.qr {
  width: 480rpx;
  max-width: 100%;
  margin-top: 16rpx;
}
.empty {
  padding: 80rpx;
  text-align: center;
  color: #a8a29e;
}
