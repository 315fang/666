.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fafaf9;
}
.map-banner {
  padding: 16rpx 24rpx;
  background: linear-gradient(180deg, #e8f1f7 0%, #f4f8fa 100%);
  border-bottom: 1rpx solid rgba(30, 74, 109, 0.12);
}
.map-banner-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #334155;
  display: block;
}
.map-wrap {
  position: relative;
  width: 100%;
}
.map {
  width: 100%;
  height: 380rpx;
}
.map-choose-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 16rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(30, 74, 109, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(28, 25, 23, 0.18);
}
.list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx;
}
.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(28, 25, 23, 0.04);
  border: 2rpx solid transparent;
  box-sizing: border-box;
}
.item-active {
  border-color: rgba(202, 138, 4, 0.85);
  box-shadow: 0 4rpx 24rpx rgba(202, 138, 4, 0.18);
  background: #fffdf8;
}
.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
  display: block;
}
.sub {
  font-size: 24rpx;
  color: #78716c;
  margin-top: 8rpx;
  display: block;
  line-height: 1.45;
}
.empty {
  text-align: center;
  color: #a8a29e;
  padding: 40rpx;
}
.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}
.sheet {
  width: 100%;
  max-height: 72vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 32rpx 48rpx;
  box-sizing: border-box;
}
.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e7e5e4;
  margin: 8rpx auto 24rpx;
}
.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1c1917;
  display: block;
  margin-bottom: 16rpx;
}
.sheet-line {
  font-size: 26rpx;
  color: #57534e;
  line-height: 1.5;
  display: block;
  margin-bottom: 32rpx;
}
.sheet-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1c1917;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}
