<view class="container" style="padding-top: {{statusBarHeight}}px">
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <image class="nav-icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"/>
    </view>
    <text class="nav-title">自提凭证</text>
    <view class="nav-placeholder"/>
  </view>

  <view class="hero-card {{info.verified_at ? 'verified' : 'pending'}}">
    <text class="hero-eyebrow">{{info.verified_at ? '已完成核销' : '待核销'}}</text>
    <text class="hero-title">{{info.pickupStation.name || '门店自提订单'}}</text>
    <text class="hero-desc">订单号 {{info.order_no || '--'}}，请向工作人员出示下方二维码或核销码。</text>
  </view>

  <view class="station-card" wx:if="{{info.pickupStation}}">
    <text class="section-title">提货站点</text>
    <text class="station-name">{{info.pickupStation.name}}</text>
    <text class="station-addr">{{info.pickupStation.address}}</text>
    <text class="station-contact" wx:if="{{info.pickupStation.pickup_contact}}">联系人：{{info.pickupStation.pickup_contact}}</text>
  </view>

  <view class="voucher-card" wx:if="{{!info.verified_at}}">
    <text class="section-title">扫码核销</text>
    <view class="qr-wrap">
      <canvas canvas-id="qrCanvas" class="qr-canvas" id="qrCanvas"/>
    </view>
    <text class="qr-hint">到店后让工作人员扫描二维码</text>
    <view class="divider-row">
      <view class="divider-line"/>
      <text class="divider-text">或使用数字核销码</text>
      <view class="divider-line"/>
    </view>
    <view class="code-display">
      <text class="code-text">{{codeFormatted}}</text>
    </view>
    <button class="code-copy-btn" bindtap="copyCode">复制核销码</button>
  </view>

  <view class="verified-card" wx:if="{{info.verified_at}}">
    <text class="section-title">核销记录</text>
    <text class="verified-time">核销时间 {{info.verified_at}}</text>
  </view>

  <view class="tip-section">
    <text class="section-title">使用说明</text>
    <text class="tip-item">1. 到达服务站后，向工作人员展示当前页面。</text>
    <text class="tip-item">2. 支持扫描二维码，或直接报出 16 位核销码。</text>
    <text class="tip-item">3. 核销完成后，本页状态会同步更新为已完成。</text>
  </view>
</view>
