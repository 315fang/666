.wrap {
  padding: 28rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #e9f2ff 0%, #f7fbff 100%);
}

.loading,
.empty-card {
  padding: 120rpx 36rpx;
  text-align: center;
  color: #7c8ea8;
}

.hero-card,
.scope-card,
.block,
.result-card,
.empty-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(20, 56, 110, 0.06);
}

.hero-title,
.label,
.result-title,
.empty-title {
  display: block;
  font-size: 30rpx;
  color: #14386e;
  font-weight: 700;
}

.hero-desc,
.scope-tip,
.result-desc,
.empty-desc,
.station-fixed-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6f87aa;
  line-height: 1.6;
}

.scope-entry {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e7eef9;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.scope-entry-text,
.scope-entry-arrow {
  font-size: 24rpx;
  color: #1d4ed8;
}

.scope-label {
  display: block;
  font-size: 24rpx;
  color: #8ea1be;
  margin-bottom: 14rpx;
}

.station-picker,
.station-fixed {
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f4f8ff;
}

.station-picker-text,
.station-fixed-name {
  font-size: 28rpx;
  color: #14386e;
  font-weight: 600;
}

.inp {
  border: 1px solid #d7e4f7;
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin: 18rpx 0 20rpx;
  background: #f9fbff;
}

.inp.mt {
  margin-top: 16rpx;
}

.btn {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.btn.secondary {
  background: #eff6ff;
  color: #2563eb;
  border: 1rpx solid #bfdbfe;
}

.divider {
  text-align: center;
  color: #9ab0ce;
  font-size: 24rpx;
  margin: 16rpx 0;
}

.result-card.success {
  background: #effaf5;
}

.result-card.fail {
  background: #fff7f5;
}
