<!-- pages/splash/splash.wxml -->
<view
  class="splash-root"
  style="background: {{bgColor}};"
  bindtouchstart="onTouchStart"
  bindtouchmove="onTouchMove"
  bindtouchend="onTouchEnd"
>
  <!-- flood阶段：深紫从底部涌入 -->
  <block wx:if="{{phase === 'flood'}}">
    <view class="flood-overlay" style="height: {{floodP * 100}}%; border-radius: {{floodP < 0.96 ? '50% 50% 0 0 / 16px 16px 0 0' : '0'}};">
      <view class="flood-highlight"></view>
    </view>
  </block>

  <!-- interact阶段：下一层颜色从底部涌出 -->
  <block wx:if="{{phase === 'interact' && inLp > 0.008}}">
    <view
      class="next-layer-overlay"
      style="height: {{Math.min(inLp, 1) * 100}}%; background: {{nextLayerColor}}; border-radius: {{inLp < 0.9 ? '52% 48% 0 0 / 18px 14px 0 0' : '0'}};"
    >
      <view class="overlay-highlight"></view>
    </view>
  </block>

  <!-- 中央内容 -->
  <view class="content-wrap">
    <!-- 顶部小标 -->
    <view wx:if="{{phase === 'interact' && !isReveal}}" class="top-label">
      HEMEIMEI · 盒美美
    </view>

    <!-- 层内容 -->
    <view
      wx:if="{{phase === 'interact' && currentLayer}}"
      class="layer-content {{wordAnim}}"
      style="margin-top: {{isReveal ? '0' : '32rpx'}};"
    >
      <!-- Single 层 -->
      <block wx:if="{{currentLayer.type === 'single'}}">
        <view class="layer-en" style="color: {{globalP < 0.45 ? 'rgba(255,255,255,0.25)' : 'rgba(180,140,220,0.35)'}};">
          {{currentLayer.en}}
        </view>
        <view class="layer-tag" style="border-color: {{globalP < 0.45 ? 'rgba(255,255,255,0.2)' : 'rgba(150,100,200,0.3)'}}; color: {{globalP < 0.45 ? 'rgba(255,255,255,0.45)' : 'rgba(130,80,180,0.55)'}};">
          {{currentLayer.tag}}
        </view>
        <view class="layer-title" style="color: {{titleColor}};">{{currentLayer.title}}</view>
        <view class="layer-divider" style="background: {{globalP < 0.45 ? 'rgba(255,255,255,0.25)' : 'rgba(150,100,200,0.3)'}};"></view>
        <view wx:for="{{currentLayer.lines}}" wx:key="index" class="layer-line" style="color: {{subColor}};">{{item}}</view>
      </block>

      <!-- Reveal 层 -->
      <block wx:if="{{currentLayer.type === 'reveal'}}">
        <view class="reveal-en">{{splashConfig.en_title}}</view>
        <view class="reveal-title">{{splashConfig.title}}</view>
        <view class="reveal-credit">{{splashConfig.credit}}</view>
        <view class="reveal-divider"></view>
        <view class="reveal-sub">{{splashConfig.subtitle}}</view>
      </block>
    </view>

    <!-- 进度点 -->
    <view wx:if="{{phase === 'interact' && !isReveal}}" class="progress-dots">
      <view
        wx:for="{{progressDots}}"
        wx:key="index"
        class="dot"
        style="width: {{item.active ? '40rpx' : '10rpx'}}; background: {{item.active ? (globalP < 0.45 ? 'rgba(255,255,255,0.55)' : 'rgba(140,90,200,0.6)') : (globalP < 0.45 ? 'rgba(255,255,255,0.15)' : 'rgba(140,90,200,0.15)')}};"
      ></view>
    </view>
  </view>

  <!-- 箭头提示 -->
  <view
    wx:if="{{phase === 'interact' && !isReveal}}"
    class="arrow-wrap"
    style="opacity: {{arrowOpacity}};"
  >
    <text class="arrow-label" style="color: {{arrowColor}};">下滑</text>
    <view class="arrow-line" style="background: {{arrowColor}};"></view>
    <view class="arrow-line" style="background: {{arrowColor}};"></view>
    <view class="arrow-line" style="background: {{arrowColor}};"></view>
    <view class="arrow-chevron" style="border-color: transparent transparent transparent transparent;">
      <!-- 用 border 模拟 chevron down -->
    </view>
    <text class="arrow-icon" style="color: {{arrowColor}};">∨</text>
  </view>

  <!-- 跳过按钮 -->
  <view
    wx:if="{{phase === 'interact' && showSkip && skipText}}"
    class="skip-btn"
    bindtap="handleSkip"
  >{{skipText}}</view>

  <!-- 倒计时跳过 -->
  <view
    wx:if="{{phase === 'interact' && countdown > 0}}"
    class="countdown-btn"
    bindtap="handleSkip"
  >{{skipText}} {{countdown}}s</view>
</view>
