/* pages/splash/splash.wxss */

.splash-root {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  user-select: none;
  transition: background 0.05s;
}

/* ── Flood 阶段 ── */
.flood-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, #26064F, #3B1060);
  transition: border-radius 0.6s ease;
}

.flood-highlight {
  position: absolute;
  top: 0; left: 25%; right: 25%;
  height: 1px;
  background: rgba(180, 130, 255, 0.25);
}

/* ── 下一层涌出 ── */
.next-layer-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  pointer-events: none;
  transition: border-radius 0.1s;
}

.overlay-highlight {
  position: absolute;
  top: 0; left: 15%; right: 15%;
  height: 1px;
  background: rgba(255, 255, 255, 0.12);
}

/* ── 中央内容 ── */
.content-wrap {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.top-label {
  position: absolute;
  top: 14%;
  font-size: 18rpx;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.25);
  text-align: center;
  transition: color 0.5s;
}

/* ── 层内容 ── */
.layer-content {
  text-align: center;
  padding: 0 80rpx;
  width: 100%;
  box-sizing: border-box;
}

.layer-content.idle {
  opacity: 0;
  transform: translateY(56rpx) scale(1.08);
  filter: blur(12px);
  transition: none;
}

.layer-content.in {
  opacity: 1;
  transform: translateY(0) scale(1);
  filter: blur(0);
  transition: opacity 0.52s cubic-bezier(0.16, 1, 0.3, 1),
              transform 0.52s cubic-bezier(0.16, 1, 0.3, 1),
              filter 0.48s ease;
}

.layer-content.hold {
  opacity: 1;
  transform: translateY(0) scale(1);
  filter: blur(0);
}

.layer-content.out {
  opacity: 0;
  transform: translateY(-48rpx) scale(0.93);
  filter: blur(8px);
  transition: opacity 0.28s ease,
              transform 0.28s ease,
              filter 0.28s ease;
}

.layer-en {
  font-size: 18rpx;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-bottom: 40rpx;
  transition: color 0.4s;
}

.layer-tag {
  display: inline-block;
  border: 1px solid;
  border-radius: 100rpx;
  padding: 8rpx 28rpx;
  font-size: 20rpx;
  letter-spacing: 0.12em;
  margin-bottom: 32rpx;
  transition: all 0.4s;
}

.layer-title {
  font-size: 68rpx;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 40rpx;
  letter-spacing: 0.04em;
  transition: color 0.3s;
}

.layer-divider {
  width: 48rpx;
  height: 2rpx;
  margin: 0 auto 36rpx;
  transition: background 0.4s;
}

.layer-line {
  font-size: 26rpx;
  line-height: 1.9;
  letter-spacing: 0.08em;
  transition: color 0.3s;
}

/* ── Reveal 层 ── */
.reveal-en {
  font-size: 18rpx;
  letter-spacing: 0.32em;
  color: rgba(80, 40, 120, 0.38);
  text-transform: uppercase;
  margin-bottom: 44rpx;
}

.reveal-title {
  font-size: 120rpx;
  font-weight: 900;
  color: #2D1A4A;
  letter-spacing: 0.05em;
  line-height: 1;
  margin-bottom: 24rpx;
}

.reveal-credit {
  font-size: 20rpx;
  color: rgba(80, 40, 120, 0.36);
  letter-spacing: 0.2em;
  margin-bottom: 40rpx;
}

.reveal-divider {
  width: 52rpx;
  height: 2rpx;
  background: rgba(120, 80, 160, 0.2);
  margin: 0 auto 36rpx;
}

.reveal-sub {
  font-size: 32rpx;
  font-weight: 500;
  color: rgba(45, 26, 74, 0.7);
  line-height: 1.8;
  letter-spacing: 0.06em;
}

/* ── 进度点 ── */
.progress-dots {
  position: absolute;
  bottom: 216rpx;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.dot {
  height: 4rpx;
  border-radius: 4rpx;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

/* ── 箭头 ── */
.arrow-wrap {
  position: absolute;
  bottom: 96rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  pointer-events: none;
  transition: opacity 0.3s;
}

.arrow-label {
  font-size: 18rpx;
  letter-spacing: 0.25em;
  font-family: 'PingFang SC', sans-serif;
  margin-bottom: 8rpx;
}

.arrow-line {
  width: 3rpx;
  height: 14rpx;
  border-radius: 2rpx;
}

.arrow-icon {
  font-size: 24rpx;
  line-height: 1;
  margin-top: 4rpx;
}

/* ── 跳过按钮 ── */
.skip-btn {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
  padding: 8rpx 28rpx;
  pointer-events: auto;
}

.countdown-btn {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
  padding: 8rpx 28rpx;
  pointer-events: auto;
}
