.page {
  min-height: 100vh;
  background: #f5f0ea;
  display: flex;
  flex-direction: column;
}
.nav-bar { background: #2e2218; flex-shrink: 0; }
.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  position: relative;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon { width: 36rpx; height: 36rpx; opacity: 0.9; }
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: #fff8f0;
}
.scroll { flex: 1; height: 0; padding: 0 24rpx 24rpx; }
.hero {
  padding: 28rpx 8rpx 20rpx;
}
.hero-title { font-size: 36rpx; font-weight: 700; color: #1c1917; display: block; }
.hero-sub { font-size: 24rpx; color: #78716c; margin-top: 8rpx; display: block; }

.addr-bar {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(28, 25, 23, 0.06);
}
.addr-label { font-size: 24rpx; color: #a8a29e; flex-shrink: 0; }
.addr-val { flex: 1; font-size: 26rpx; color: #1c1917; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.addr-arrow { color: #c8bcaf; font-size: 32rpx; }

.list-title { font-size: 28rpx; font-weight: 600; color: #44403c; margin-bottom: 16rpx; }
.empty { text-align: center; color: #a8a29e; padding: 40rpx; font-size: 26rpx; }

.goods-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(28, 25, 23, 0.05);
}
.goods-img { width: 200rpx; height: 200rpx; border-radius: 16rpx; flex-shrink: 0; background: #f5f5f4; }
.goods-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 10rpx; }
.goods-name { font-size: 28rpx; font-weight: 600; color: #1c1917; }
.goods-meta { font-size: 22rpx; color: #a8a29e; }
.price-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8rpx; font-size: 24rpx; }
.p-points { color: #b45309; font-weight: 600; }
.p-sep { color: #d6d3d1; }
.p-money { color: #dc2626; font-weight: 700; }
.btn-row { display: flex; gap: 12rpx; margin-top: 8rpx; flex-wrap: wrap; }
.btn {
  flex: 1;
  min-width: 200rpx;
  text-align: center;
  padding: 18rpx 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.btn-points { background: linear-gradient(135deg, #fde68a, #f59e0b); color: #422006; }
.btn-money { background: linear-gradient(135deg, #c8a258, #a07840); color: #fff8f0; }
.btn.disabled { opacity: 0.38; pointer-events: none; }

.safe-bottom { height: calc(24rpx + env(safe-area-inset-bottom)); }
.state-loading { padding: 120rpx; text-align: center; color: #a8a29e; }
