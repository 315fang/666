# 环境配置示例文件
# 注意：当前小程序运行时不会自动读取 .env 文件
# 实际生效配置请修改 miniprogram/666-main/config/env.js 中对应环境的配置项

# 环境类型: development | staging | production
NODE_ENV=development

# API 配置
API_BASE_URL=https://dev-api.jxalk.cn/api
API_TIMEOUT=15000

# CDN 配置
CDN_BASE_URL=https://dev-cdn.jxalk.cn

# 功能开关
ENABLE_DEBUG=true
ENABLE_LOG=true
ENABLE_MOCK=false
ENABLE_CACHE=true

# 图片质量 (1-100)
IMAGE_QUALITY=80

# 版本号
VERSION=2.0.0-dev

# 微信小程序配置
WX_APP_ID=your_app_id_here
WX_APP_SECRET=your_app_secret_here
