# Backend .env template (production-oriented, minimal)
# Copy to .env and fill real values.

# App
NODE_ENV=development
PORT=3001
# 反代在 Node 前的层数（单层 Nginx 一般为 1）；不设则生产环境默认 1，避免 express-rate-limit 与 X-Forwarded-For 冲突
# TRUST_PROXY_HOPS=1

# 管理端静态资源目录（默认 ../admin-ui/dist，相对 backend）。整份 dist 须与 index.html 同一次构建
# ADMIN_UI_DIST=/opt/zz/admin-ui/dist

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=s2b2c_db
DB_USER=root
DB_PASSWORD=your_password

# Auth (must be strong in production)
JWT_SECRET=change_to_a_strong_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=change_to_a_strong_admin_secret_at_least_32_chars
ADMIN_JWT_EXPIRES_IN=8h

# CORS (comma-separated in production, e.g. https://a.com,https://b.com)
CORS_ORIGINS=*

# 腾讯位置服务 WebServiceAPI Key（管理端地址解析；小程序站点地图「模糊定位→逆地理市/区」由后端调用，不写在前端）
TENCENT_MAP_KEY=
# 管理台前端地图选点：在 admin-ui 目录使用 VITE_TENCENT_MAP_KEY（见 admin-ui/.env.example），建议与上者同 Key 并开启 JS API + 域名白名单

# WeChat mini program
WECHAT_APPID=wx1234567890abcdef
WECHAT_SECRET=your_wechat_secret
# 「小程序购物订单」跳转订单详情 path，须包含字面量 ${商品订单号}（微信替换为商户订单号=支付 out_trade_no）
# 默认与仓库小程序分包一致：pages/order/detail?id=${商品订单号}&channel=1
# WECHAT_MP_ORDER_DETAIL_PATH=pages/order/detail?id=${商品订单号}&channel=1

# 支付成功后是否调用微信「上传购物详情」接口（需公众平台开通购物订单能力并签协议）。设为 false 可关闭。
# WECHAT_SHOPPING_ORDER_UPLOAD=true
# 发货后是否向微信「上传物流/发货信息」（与上条配套；仅微信支付订单且买家有 openid 时会上传。设为 false 可关闭）。
# WECHAT_SHIPPING_INFO_UPLOAD=true
# 自提订单在微信侧的快递公司编码（文档要求必填项时的占位，默认 OTHER，若报错可改为微信平台支持的编码）
# WECHAT_SHIPPING_PICKUP_EXPRESS_CODE=OTHER
# 快递单未能识别物流公司代码时的兜底编码
# WECHAT_SHIPPING_DEFAULT_EXPRESS_CODE=OTHER
# 商品图为相对路径且无 CDN 域名时，可填一张 https 占位图以满足接口必填图（可选）
# WECHAT_SHOPPING_PLACEHOLDER_IMAGE=https://你的域名/static/placeholder-product.png

# WeChat Pay V3
WECHAT_MCH_ID=1234567890
WECHAT_PAY_SERIAL_NO=your_merchant_cert_serial_number
WECHAT_PAY_API_V3_KEY=your_api_v3_key_32chars_exactly_
WECHAT_PAY_PRIVATE_KEY_PATH=certs/apiclient_key.pem
WECHAT_PAY_CERT_PATH=certs/apiclient_cert.pem
# 平台证书 PEM 输出路径（启动时会自动下载并写入该文件）
WECHAT_PAY_PLATFORM_CERT_PATH=certs/wechatpay_platform_cert.pem
# 须与对外 API 域名一致（与小程序 request 合法域名同源），并在微信商户平台配置相同回调 URL
WECHAT_PAY_NOTIFY_URL=https://api.wenlan.store/api/wechat/pay/notify
# 自动持久化平台证书到 PEM 文件（建议 true）
WECHAT_PAY_CERT_AUTO_PERSIST=true
# 平台证书自动刷新间隔（小时，默认 24）
WECHAT_PAY_CERT_REFRESH_INTERVAL_HOURS=24

# Agent portal
PORTAL_INIT_PASSWORD=change_this_portal_password_in_production

# Storage + CDN (recommended: Aliyun OSS + Tencent CDN)
# Valid providers: local | aliyun | tencent | qiniu | minio
STORAGE_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_OSS_BUCKET=your-aliyun-oss-bucket
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_ENDPOINT=
# Tencent CDN domain (accelerating Aliyun OSS origin)
ALIYUN_OSS_CUSTOM_DOMAIN=https://cdn.your-domain.com

# Local fallback (dev only)
LOCAL_UPLOAD_DIR=uploads
LOCAL_BASE_URL=/uploads

# Orders
ORDER_AUTO_CANCEL_MINUTES=30
ORDER_AUTO_CONFIRM_DAYS=15
AGENT_ORDER_TIMEOUT_HOURS=24

# Users（亦可后台「运营参数 → 用户与账号」覆盖 app_configs SYSTEM）
# 无头像时使用；小程序可填包内路径如 /assets/images/default-avatar.svg
#USER_DEFAULT_AVATAR_URL=/assets/images/default-avatar.svg
# 纯游客闲置超过该天数且无订单/券/团队等则定时清理；0=关闭
#USER_IDLE_GUEST_PURGE_DAYS=7

# Commission
COMMISSION_FREEZE_DAYS=15
COMMISSION_SETTLE_INTERVAL=86400000
# 设为 0/false 时忽略商品表 commission_amount_*（固定元），只按比例与代理体系配置
# COMMISSION_ALLOW_PRODUCT_FIXED=0
# Legacy compatibility (hours)
# COMMISSION_SETTLEMENT_INTERVAL_HOURS=24

# Withdraw
MIN_WITHDRAWAL_AMOUNT=10
MAX_WITHDRAWAL_AMOUNT=50000
MAX_DAILY_WITHDRAWAL=3
WITHDRAWAL_FEE_RATE=0
# 单笔提现手续费封顶（元），0 表示不封顶；若与后台「运营参数」冲突以数据库为准
WITHDRAWAL_FEE_CAP_MAX=0

# Refund
REFUND_MAX_DAYS=15

# Security
API_RATE_LIMIT=100
LOGIN_RATE_LIMIT=5
BODY_SIZE_LIMIT=10mb

# Logistics (Aliyun Market APPCODE)
# If empty, service falls back to mock tracking data.
LOGISTICS_API_KEY=

# Agent Portal
AGENT_PORTAL_URL=https://your-agent-portal.com

# WeChat template message
WX_TEMPLATE_ID=

# Platform top agent (virtual user id for platform-level commission)
PLATFORM_TOP_AGENT_USER_ID=

# Admin init (scripts only)
ADMIN_INIT_PASSWORD=change_this

# Swagger
SWAGGER_ENABLED=false
API_BASE_URL=http://localhost:3001

# Redis (optional, falls back to memory cache)
USE_REDIS=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Multi-instance / horizontal scaling (optional)
# TASK_LOCK_BACKEND=mysql          # 定时任务互斥跨实例（MySQL GET_LOCK）；默认 memory
# ADMIN_TOKEN_BLACKLIST_STORE=redis   # 注销黑名单走 Redis（需 USE_REDIS 且安装 redis 包）
# ADMIN_TOKEN_BLACKLIST_STORE=mysql   # 注销黑名单走表 admin_token_blacklist，先跑 migrations/phase9_admin_token_blacklist.js

# Tencent COS (alternative storage)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_CUSTOM_DOMAIN=

# Qiniu (alternative storage, install sdk: npm i qiniu)
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# MinIO (alternative storage, install sdk: npm i minio)
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=false

# Debug (must stay false in production)
ENABLE_DEBUG_ROUTES=false
ENABLE_TEST_ROUTES=false
ALLOW_OPENID_AUTH=false
