# 集成测试专用环境变量（Docker 本地 MySQL）
NODE_ENV=test
PORT=0

# 数据库 — Docker 容器 s2b2c-test-mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=s2b2c_db_test
DB_USER=root
DB_PASSWORD=test123456

# JWT
JWT_SECRET=integration-test-jwt-secret-at-least-32-characters-long
JWT_EXPIRES_IN=1h
ADMIN_JWT_SECRET=integration-test-admin-jwt-secret-at-least-32-chars
ADMIN_JWT_EXPIRES_IN=1h

# 系统通知收件用户（users.id，避免 notifications 外键指向不存在的用户）
ADMIN_USER_ID=1

# 开放手动支付路由（绕过微信支付）
ENABLE_TEST_ROUTES=true
ENABLE_DEBUG_ROUTES=false
ALLOW_OPENID_AUTH=false

# 佣金/售后 — 测试时缩短
COMMISSION_FREEZE_DAYS=0
REFUND_MAX_DAYS=15

# 提现
WITHDRAWAL_MIN_AMOUNT=10
WITHDRAWAL_FEE_RATE=0

# 安全
API_RATE_LIMIT=9999
LOGIN_RATE_LIMIT=9999

# 存储
STORAGE_PROVIDER=local
