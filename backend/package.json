{
    "name": "s2b2c-backend",
    "version": "1.0.0",
    "description": "S2B2C Digital Franchise System Backend API",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest --forceExit --detectOpenHandles",
        "test:unit": "jest __tests__/utils/ __tests__/services/",
        "test:integration": "jest __tests__/controllers/",
        "test:coverage": "jest --coverage",
        "test:watch": "jest --watch",
        "test:db": "node -e \"require('./config/database').testConnection()\"",
        "migrate:boards": "node scripts/migrate-content-boards.js",
        "migrate:product-marketing-columns": "node migrations/fix_p1_product_marketing_columns.js",
        "migrate:phase9": "node migrations/phase9_admin_token_blacklist.js",
        "migrate:visible-in-mall": "node migrations/apply_visible_in_mall_column.js",
        "wechat:order-path": "node scripts/sync-wechat-order-detail-path.js",
        "wechat:order-path:query": "node scripts/sync-wechat-order-detail-path.js --query",
        "invite:backfill": "node scripts/backfill-invite-codes.js",
        "asset-url:audit": "node scripts/audit-expiring-asset-urls.js",
        "asset-url:repair": "node scripts/audit-expiring-asset-urls.js --apply",
        "member-code:audit": "node scripts/audit-member-codes.js --dry-run",
        "member-code:repair": "node scripts/audit-member-codes.js",
        "db:portal-init-column": "node scripts/add-portal-last-init-issue-at.js"
    },
    "keywords": [
        "s2b2c",
        "wechat",
        "miniprogram",
        "franchise"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "ali-oss": "^6.23.0",
        "axios": "^1.13.5",
        "body-parser": "^1.20.2",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "cos-nodejs-sdk-v5": "^2.15.4",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^6.10.0",
        "helmet": "^8.1.0",
        "hpp": "^0.2.3",
        "jsonwebtoken": "^9.0.3",
        "lru-cache": "^11.2.6",
        "multer": "^2.0.2",
        "mysql2": "^3.6.5",
        "qrcode": "^1.5.4",
        "sequelize": "^6.35.2",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "xss-clean": "^0.1.4"
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "nodemon": "^3.0.2",
        "supertest": "^7.2.2"
    }
}
