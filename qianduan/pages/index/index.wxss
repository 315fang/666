/** pages/index/index.wxss - 问兰镜像首页 **/

.container {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 100rpx;
}

/* ===== 自定义导航栏：毛玻璃效果 ===== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  transition: all 0.3s ease;
}

.nav-transparent {
  background: transparent;
}

.nav-scrolled {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  position: relative;
}

/* 导航栏状态容器 */
.nav-welcome-box, .nav-search-box {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: absolute;
  left: 32rpx;
  right: 32rpx;
}

.nav-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.nav-hidden {
  opacity: 0;
  transform: translateY(20rpx);
  pointer-events: none;
}

.nav-logo {
  width: 44rpx;
  height: 44rpx;
}

.welcome-text {
  font-size: 28rpx;
  color: #333;
  letter-spacing: 2rpx;
  font-weight: 300;
}

.nav-divider {
  width: 2rpx;
  height: 32rpx;
  background: #E5E5E5;
}

.nav-search-bar {
  flex: 1;
  height: 64rpx;
  background: rgba(245, 245, 245, 0.6);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 12rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

/* ===== 全屏海报 Swiper ===== */
.poster-swiper {
  width: 100%;
  height: 100vh; /* 全屏展示 */
}

.poster-item {
  width: 100%;
  height: 100%;
  position: relative;
}

.poster-img {
  width: 100%;
  height: 100%;
}

.poster-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding-right: 60rpx;
  background: linear-gradient(to left, rgba(0,0,0,0.1), transparent);
}

.poster-text-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.poster-en {
  font-size: 32rpx;
  color: #333;
  letter-spacing: 12rpx;
  font-family: 'Times New Roman', serif;
}

.poster-line {
  width: 2rpx;
  height: 60rpx;
  background: #333;
  margin: 20rpx 0;
}

.poster-title {
  font-size: 28rpx;
  color: #666;
  letter-spacing: 4rpx;
  writing-mode: vertical-rl;
}

.poster-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-top: 20rpx;
  letter-spacing: 2rpx;
  writing-mode: vertical-rl;
}

/* ===== 通用 Section 容器 ===== */
.section-container {
  padding: 80rpx 32rpx 0;
}

.section-title-box {
  text-align: center;
  margin-bottom: 60rpx;
}

.en-title-serif {
  display: block;
  font-size: 40rpx; /* 增大字号 */
  color: #1A1A1A;
  letter-spacing: 16rpx; /* 加宽字间距 */
  font-family: 'Times New Roman', serif;
  margin-bottom: 12rpx;
  text-transform: uppercase;
}

.cn-title-bold {
  display: block;
  font-size: 52rpx; /* 增大字号 */
  font-weight: 800; /* 加重字重 */
  color: #1A1A1A;
  letter-spacing: 6rpx;
  margin-bottom: 40rpx;
}

/* ===== 会员臻享模块 (多轮播样式) ===== */
.member-banner-wrap {
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.member-swiper {
  height: 480rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.member-banner-card {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-bg {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.banner-text-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.b-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.b-price-row {
  display: flex;
  align-items: baseline;
  color: #333;
  margin-bottom: 30rpx;
}

.b-unit {
  font-size: 32rpx;
}

.b-value {
  font-size: 88rpx;
  font-weight: 700;
  margin: 0 10rpx;
}

.b-capsule-btn {
  background: #1A1A1A;
  color: #FFFFFF;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.2);
}

/* 美肤方案海报样式 */
.scheme-poster-wrap {
  padding: 0 20rpx;
  margin-bottom: 60rpx;
}

.scheme-full-card {
  background: linear-gradient(135deg, #E8D5B5 0%, #F5E6CC 100%);
  border-radius: 20rpx;
  height: 480rpx;
  display: flex;
  padding: 40rpx;
  overflow: hidden;
}

.scheme-left-content {
  flex: 1.2;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.s-en-small {
  font-size: 20rpx;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.s-cn-large {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
  margin-bottom: 30rpx;
  white-space: pre-wrap;
}

.s-capsule-btn-black {
  background: #1A1A1A;
  color: #FFFFFF;
  padding: 12rpx 30rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: fit-content;
}

.scheme-right-img {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.img-inner-box {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 20rpx;
  width: 240rpx;
  height: 240rpx;
}

.img-inner-box image {
  width: 100%;
  height: 100%;
}

/* ===== 星品挚选 (全屏大型海报样式) ===== */
.star-sections-container {
  background: #FAF9F6;
  padding-bottom: 40rpx;
}

.star-section-item {
  margin-bottom: 80rpx;
}

.star-full-poster {
  background: #fff;
  border-radius: 32rpx;
  margin: 0 20rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.03);
}

.poster-tabs {
  display: flex;
  background: #F5F5F5; /* 大的灰色为底的父容器 */
  border-radius: 60rpx;
  padding: 10rpx;
  margin-bottom: 40rpx;
  position: relative;
  gap: 10rpx;
}

.p-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #999999; /* 未选中时的文字颜色 */
  background: transparent; /* 未选中时透明，显示父容器灰色 */
  border-radius: 50rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.p-tab.active {
  background: #FFFFFF; /* 选中时：白色椭圆容器 */
  color: #000000; 
  font-weight: 900; 
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08); /* 选中时的轻微投影 */
}

.poster-main-body {
  display: flex;
  align-items: center;
  min-height: 500rpx;
  position: relative;
}

.poster-left-info {
  flex: 1;
  position: relative;
  z-index: 2;
}

.p-slogan {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.p-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.p-awards-box {
  margin-bottom: 30rpx;
}

.award-circle {
  width: 140rpx;
  height: 140rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.award-text {
  font-size: 18rpx;
  color: #999;
  line-height: 1.2;
}

.p-sales-badge {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 100rpx;
}

.sales-label {
  font-size: 18rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.sales-val {
  font-size: 24rpx;
  font-weight: 700;
  color: #B8965D;
}

.p-product-img {
  width: 400rpx;
  height: 400rpx;
  flex-shrink: 0;
}

.poster-footer-bar {
  margin-top: 40rpx;
  background: linear-gradient(90deg, #F5E6CC 0%, #E8D5B5 100%);
  border-radius: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 10rpx 0 40rpx;
}

.p-price-tag {
  display: flex;
  align-items: baseline;
  color: #1A1A1A;
}

.p-currency {
  font-size: 28rpx;
  font-weight: 600;
}

.p-amount {
  font-size: 48rpx;
  font-weight: 700;
  margin-left: 4rpx;
}

.p-buy-btn-black {
  background: #1A1A1A;
  color: #FFFFFF;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-arrow {
  font-size: 20rpx;
  margin-left: 8rpx;
}

/* ===== 底部惊喜彩蛋样式 ===== */
.bottom-surprise-section {
  padding: 100rpx 0 160rpx;
  text-align: center;
  background: #FFFFFF;
}

.surprise-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.surprise-icon {
  font-size: 40rpx;
  animation: float 3s infinite ease-in-out;
}

.surprise-text {
  font-size: 24rpx;
  color: #CCCCCC;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.surprise-hidden-content {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  margin-top: 20rpx;
}

.surprise-hidden-content.show {
  max-height: 400rpx;
  opacity: 1;
}

.mirror-seal {
  width: 160rpx;
  height: 160rpx;
  border: 4rpx solid #B8965D;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  background: rgba(184, 150, 93, 0.05);
}

.seal-text {
  font-size: 24rpx;
  color: #B8965D;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: 2rpx;
}

.surprise-msg {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 300;
  line-height: 1.6;
  font-style: italic;
  letter-spacing: 4rpx;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* ===== 底部指引 ===== */
.footer-guide {
  padding: 100rpx 0;
  text-align: center;
}

.guide-en {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #E5E5E5;
  letter-spacing: 12rpx;
  margin-bottom: 12rpx;
}

.guide-cn {
  display: block;
  font-size: 20rpx;
  color: #CCCCCC;
  letter-spacing: 4rpx;
}
