<!--pages/search/search.wxml - 问兰镜像搜索页 -->
<view class="container">
  <!-- 1. 顶部搜索栏 (极简设计) -->
  <view class="search-header">
    <view class="search-input-box">
      <image class="icon-search" src="/assets/icons/search.svg" mode="aspectFit"></image>
      <input class="input-main" 
             placeholder="搜索您心仪的商品" 
             value="{{keyword}}" 
             bindinput="onInput" 
             bindconfirm="onSearch"
             focus="{{true}}"
             confirm-type="search" 
             placeholder-class="input-placeholder"/>
      <view class="clear-wrap" wx:if="{{keyword}}" bindtap="onClear">
        <image class="icon-clear" src="/assets/icons/x.svg" mode="aspectFit"></image>
      </view>
    </view>
    <view class="btn-cancel" bindtap="onCancel">取消</view>
  </view>

  <scroll-view class="search-content" scroll-y>
    
    <!-- 2. 搜索发现 / 热门搜索 (大气卡片式) -->
    <view class="section-box" wx:if="{{!hasSearched && hotKeywords.length > 0}}">
      <view class="section-head">
        <text class="section-title-serif">热门推荐</text>
      </view>
      <view class="hot-grid">
        <view class="hot-item" 
              wx:for="{{hotKeywords}}" 
              wx:key="*this" 
              bindtap="onHistoryTap" 
              data-keyword="{{item}}">
          <text class="hot-num {{index < 3 ? 'top-three' : ''}}">{{index + 1}}</text>
          <text class="hot-text">{{item}}</text>
          <image class="icon-trend" src="/assets/icons/trending-up.svg" mode="aspectFit" wx:if="{{index < 2}}"></image>
        </view>
      </view>
    </view>

    <!-- 3. 搜索历史 (极简列表) -->
    <view class="section-box" wx:if="{{!hasSearched && history.length > 0}}">
      <view class="section-head">
        <text class="section-title-serif">搜索历史</text>
        <image class="icon-delete" src="/assets/icons/trash.svg" mode="aspectFit" bindtap="onClearHistory"></image>
      </view>
      <view class="history-list">
        <view class="history-item" 
              wx:for="{{history}}" 
              wx:key="*this" 
              bindtap="onHistoryTap" 
              data-keyword="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 4. 搜索结果展示 -->
    <view class="result-area" wx:if="{{hasSearched}}">
      <view class="result-summary" wx:if="{{products.length > 0}}">
        <text>为您找到 {{products.length}} 件商品</text>
      </view>

      <view class="product-list-vertical">
        <view class="prod-card" 
              wx:for="{{products}}" 
              wx:key="id"
              bindtap="onProductTap" 
              data-item="{{item}}">
          <image class="prod-img" src="{{item.image || item.images[0]}}" mode="aspectFill"></image>
          <view class="prod-info">
            <text class="prod-name">{{item.name}}</text>
            <view class="prod-price-row">
              <text class="price-unit">¥</text>
              <text class="price-val">{{item.retail_price}}</text>
              <text class="sales-val" wx:if="{{item.sales_count > 0}}">月销{{item.sales_count}}+</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 无结果兜底 -->
      <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
        <view class="empty-icon-wrap">
          <image class="empty-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
        </view>
        <text class="empty-title">未发现匹配商品</text>
        <text class="empty-desc">换个词试试，也许会有惊喜</text>
      </view>
    </view>

  </scroll-view>

  <!-- 全屏加载遮罩 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-ring"></view>
  </view>
</view>
