/** pages/slash/detail.wxss **/
page { padding-bottom: 140rpx; }
.container { min-height: 100vh; background: #F7F7F7; }

/* Nav */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.nav-placeholder { width: 56rpx; }

/* Loading */
.loading-wrap { padding: 0; }
.skeleton-block { background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%); border-radius: 20rpx; animation: shimmer 1.5s infinite; }
@keyframes shimmer { 0%{ background-position: -400rpx 0 } 100%{ background-position: 400rpx 0 } }

/* Product card */
.product-card { margin: 20rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; overflow: hidden; display: flex; gap: 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.product-img { width: 200rpx; height: 200rpx; flex-shrink: 0; }
.product-info { flex: 1; padding: 24rpx 20rpx; display: flex; flex-direction: column; justify-content: space-between; }
.product-name { font-size: 30rpx; font-weight: 700; color: #1A1A1A; line-height: 1.4; }
.status-badge { display: inline-flex; padding: 8rpx 18rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 700; align-self: flex-start; margin-top: 12rpx; }
.status-badge.status-active { background: rgba(255,107,53,0.1); color: #FF6B35; }
.status-badge.status-success { background: rgba(16,185,129,0.1); color: #10B981; }
.status-badge.status-expired { background: rgba(0,0,0,0.06); color: #AAA; }
.status-badge.status-purchased { background: rgba(59,130,246,0.1); color: #3B82F6; }

/* Price card */
.price-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; padding: 28rpx 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.price-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 24rpx; }
.price-col { display: flex; flex-direction: column; gap: 6rpx; }
.price-col-right { margin-left: auto; align-items: flex-end; }
.price-label { font-size: 20rpx; color: #AAA; }
.price-current { font-size: 44rpx; font-weight: 800; color: #FF6B35; }
.price-floor { font-size: 36rpx; font-weight: 800; color: #10B981; }
.price-original { font-size: 28rpx; font-weight: 400; color: #BBB; text-decoration: line-through; }
.price-arrow-wrap { padding: 0 8rpx; }
.price-arrow-icon { width: 28rpx; height: 28rpx; opacity: 0.3; }

/* Progress */
.progress-section { margin-bottom: 16rpx; }
.progress-bar { width: 100%; height: 12rpx; background: #F0F0F0; border-radius: 6rpx; overflow: hidden; margin-bottom: 10rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #FF6B35, #FF9A56); border-radius: 6rpx; transition: width 0.5s; }
.progress-meta { display: flex; justify-content: space-between; }
.helper-count { font-size: 22rpx; color: #888; }
.progress-pct { font-size: 22rpx; color: #FF6B35; font-weight: 700; }

/* Countdown */
.countdown-row { display: flex; align-items: center; gap: 8rpx; margin-top: 12rpx; }
.icon-xs { width: 28rpx; height: 28rpx; opacity: 0.5; }
.countdown-text { font-size: 24rpx; color: #FF6B35; font-weight: 600; }
.expired-row { justify-content: center; }
.expired-text { font-size: 24rpx; color: #BBB; }

/* Helpers card */
.helpers-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 20rpx; }
.helper-list { display: flex; flex-direction: column; gap: 16rpx; }
.helper-item { display: flex; align-items: center; gap: 16rpx; }
.helper-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; flex-shrink: 0; background: #F0F0F0; }
.helper-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.helper-name { font-size: 26rpx; font-weight: 600; color: #1A1A1A; }
.helper-cut { font-size: 22rpx; color: #10B981; font-weight: 600; }
.helper-time { font-size: 20rpx; color: #BBB; }

/* Empty helpers */
.empty-helpers { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0; gap: 12rpx; }
.empty-icon { width: 60rpx; height: 60rpx; opacity: 0.2; }
.empty-text { font-size: 24rpx; color: #BBB; text-align: center; line-height: 1.8; }

/* Bottom bar */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #FFFFFF; border-top: 1rpx solid #F0F0F0; padding: 20rpx 24rpx 40rpx; display: flex; gap: 16rpx; z-index: 100; }
.btn-share { display: flex; align-items: center; justify-content: center; gap: 8rpx; background: rgba(255,107,53,0.1); color: #FF6B35; font-size: 26rpx; font-weight: 700; border-radius: 50rpx; padding: 0 32rpx; height: 80rpx; flex-shrink: 0; }
.btn-icon { width: 32rpx; height: 32rpx; opacity: 0.7; }
.btn-buy { flex: 1; display: flex; align-items: center; justify-content: center; border-radius: 50rpx; height: 80rpx; font-size: 28rpx; font-weight: 700; color: #FFFFFF; }
.btn-buy-ready { background: linear-gradient(135deg, #10B981, #34D399); }
.btn-buy-default { background: linear-gradient(135deg, #FF6B35, #FF9A56); }
.btn-disabled { flex: 1; display: flex; align-items: center; justify-content: center; background: #F0F0F0; color: #BBB; font-size: 26rpx; border-radius: 50rpx; height: 80rpx; }
