/** pages/group/detail.wxss **/
page { padding-bottom: 140rpx; }
.container { min-height: 100vh; background: #F7F7F7; }

/* Nav */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 24rpx; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; }
.nav-back { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.nav-icon { width: 32rpx; height: 32rpx; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.nav-placeholder { width: 56rpx; }

/* Loading */
.loading-wrap { padding: 0; }
.skeleton-block { background: #F0F0F0; border-radius: 20rpx; }

/* Product card */
.product-card { margin: 20rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; overflow: hidden; display: flex; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.product-img { width: 200rpx; height: 200rpx; flex-shrink: 0; }
.product-info { flex: 1; padding: 24rpx 20rpx; display: flex; flex-direction: column; justify-content: space-between; gap: 12rpx; }
.product-name { font-size: 30rpx; font-weight: 700; color: #1A1A1A; line-height: 1.4; }
.price-row { display: flex; gap: 32rpx; }
.group-price-wrap, .original-price-wrap { display: flex; flex-direction: column; gap: 4rpx; }
.price-label { font-size: 20rpx; color: #AAA; }
.group-price { font-size: 40rpx; font-weight: 800; color: #6366F1; }
.original-price { font-size: 26rpx; font-weight: 400; color: #BBB; text-decoration: line-through; }
.status-badge { display: inline-flex; padding: 8rpx 18rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 700; align-self: flex-start; }
.status-badge.status-open { background: rgba(99,102,241,0.1); color: #6366F1; }
.status-badge.status-success { background: rgba(16,185,129,0.1); color: #10B981; }
.status-badge.status-fail, .status-badge.status-cancelled { background: rgba(0,0,0,0.06); color: #AAA; }

/* Progress card */
.progress-card { margin: 16rpx 24rpx 0; background: #FFFFFF; border-radius: 20rpx; padding: 28rpx 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.progress-fraction { font-size: 28rpx; font-weight: 800; color: #6366F1; }
.progress-bar { width: 100%; height: 12rpx; background: #F0F0F0; border-radius: 6rpx; overflow: hidden; margin-bottom: 24rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #6366F1, #8B5CF6); border-radius: 6rpx; transition: width 0.5s; }

/* Member list */
.member-list { display: flex; gap: 24rpx; flex-wrap: wrap; margin-bottom: 20rpx; }
.member-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; width: 80rpx; }
.avatar-wrap { position: relative; }
.member-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #F0F0F0; border: 3rpx solid rgba(99,102,241,0.3); }
.owner-crown { position: absolute; top: -12rpx; right: -6rpx; font-size: 22rpx; }
.avatar-empty { width: 80rpx; height: 80rpx; border-radius: 50%; background: #F7F7F7; border: 3rpx dashed #DDD; }
.member-name { font-size: 18rpx; color: #888; text-align: center; width: 80rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.empty-name { color: #DDD; }

/* Countdown */
.countdown-row { display: flex; align-items: center; gap: 8rpx; }
.icon-xs { width: 28rpx; height: 28rpx; opacity: 0.5; }
.countdown-text { font-size: 24rpx; color: #6366F1; font-weight: 600; }
.need-more-row { margin-top: 12rpx; }
.need-more-text { font-size: 24rpx; color: #FF6B35; font-weight: 600; }

/* Success banner */
.success-banner { margin: 16rpx 24rpx 0; background: linear-gradient(135deg, #10B981, #34D399); border-radius: 20rpx; padding: 28rpx 24rpx; display: flex; align-items: center; gap: 20rpx; }
.success-icon { font-size: 48rpx; }
.success-text-wrap { display: flex; flex-direction: column; gap: 6rpx; }
.success-title { font-size: 32rpx; font-weight: 800; color: #FFF; }
.success-desc { font-size: 22rpx; color: rgba(255,255,255,0.85); }

/* Fail banner */
.fail-banner { margin: 16rpx 24rpx 0; background: rgba(0,0,0,0.04); border-radius: 20rpx; padding: 28rpx 24rpx; display: flex; flex-direction: column; gap: 8rpx; align-items: center; }
.fail-title { font-size: 28rpx; font-weight: 700; color: #AAA; }
.fail-desc { font-size: 22rpx; color: #BBB; }

/* Bottom bar */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #FFFFFF; border-top: 1rpx solid #F0F0F0; padding: 20rpx 24rpx 40rpx; display: flex; gap: 16rpx; z-index: 100; }
.btn-share { display: flex; align-items: center; justify-content: center; gap: 8rpx; background: rgba(99,102,241,0.1); color: #6366F1; font-size: 26rpx; font-weight: 700; border-radius: 50rpx; padding: 0 32rpx; height: 80rpx; flex-shrink: 0; }
.btn-icon { width: 32rpx; height: 32rpx; opacity: 0.7; }
.btn-join { flex: 1; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #6366F1, #8B5CF6); color: #FFFFFF; font-size: 28rpx; font-weight: 700; border-radius: 50rpx; height: 80rpx; }
.btn-disabled { flex: 1; display: flex; align-items: center; justify-content: center; background: #F0F0F0; color: #BBB; font-size: 26rpx; border-radius: 50rpx; height: 80rpx; }
.success-done { background: rgba(16,185,129,0.1); color: #10B981; }
